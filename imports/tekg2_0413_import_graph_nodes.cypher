  {name: "evolutionary adaptation", description: "Retrotransposons enable survival through evolution."},
  {name: "evolutionary amplification", description: "Evolutionary amplification is a mechanism for increasing genomic copy number."},
  {name: "evolutionary arms race", description: "The ongoing conflict between LINE-1 retrotransposons and host cell defense mechanisms."},
  {name: "evolutionary breakpoint", description: "Evolutionary breakpoint is a region where chromosomal rearrangements occur during evolution."},
  {name: "evolutionary conflict", description: "Evolutionary conflict between retrotransposons and their repressors."},
  {name: "Evolutionary conservation", description: "Evolutionary conservation indicates functional constraint."},
  {name: "evolutionary divergence", description: "Evolutionary divergence is the process by which species accumulate differences."},
  {name: "evolutionary fine-tuning of transcriptome", description: "The hypothesis that LINE-1 can serve as an evolutionary fine-tuner of the human transcriptome."},
  {name: "Evolutionary history", description: "Evolutionary history refers to the genetic lineage and divergence of populations."},
  {name: "Evolutionary pressure", description: "Selective pressure on retroelements, inferred from mutation signatures."},
  {name: "Evolutionary processe", description: "Biological processes contributing to evolution."},
  {name: "Evolutionary rearrangement", description: "Chromosomal rearrangements that have occurred during evolution, potentially facilitated by Alu sequences."},
  {name: "ex vivo expansion", description: "Ex vivo expansion is the process of growing cells outside the body."},
  {name: "ex vivo gene therapy", description: "An alternative nonviral gene therapy approach involving modification of cells outside the body."},
