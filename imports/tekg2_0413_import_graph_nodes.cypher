  {name: "Retrotransposon insertion", description: "Retrotransposon insertions are genomic insertions of retrotransposons like Alu and SVA, linked to epigenetic changes and genome instability."},
  {name: "Retrotransposon insertion polymorphism", description: "RIP refers to polymorphic retrotransposon insertions transmitted in the germline."},
  {name: "retrotransposon insertion polymorphism (RIP)", description: "RIPs are structural variants caused by retrotransposon insertions."},
  {name: "Retrotransposon integration", description: "The process by which retrotransposons insert into host genomes."},
