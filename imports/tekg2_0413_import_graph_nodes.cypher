  {name: "generation of extrachromosomal structure", description: "Generation of extrachromosomal structures involves creating DNA or RNA molecules outside of chromosomes."},
  {name: "Generation of genomic diversity/polymorphism", description: "Generation of genomic diversity/polymorphism creates variation in the human genome."},
  {name: "Generation of human diversity", description: "Generation of human diversity refers to processes that create genetic variation in human populations."},
  {name: "generation of human embryonic stem cell LINE", description: "Generation of human embryonic stem cell line is a process to create stable cell lines for research, such as WAe001-A-67 and WAe001-A-68."},
  {name: "generation of induced pluripotent stem cell", description: "Generation of induced pluripotent stem cells is a process for creating pluripotent stem cells from somatic cells."},
  {name: "Generation of inducible cell line", description: "Generation of inducible cell line is a process for creating cell lines with controlled gene expression."},
  {name: "Generation of neurons' plasticity", description: "Generation of neurons' plasticity is a biological process involved in normal brain function."},
