  {name: "Retrotransposon propagation", description: "The process of retrotransposon replication and insertion into new genomic locations."},
  {name: "Retrotransposon recombination-mediated inversion (RRMI)", description: "A mechanism causing chromosomal inversions without altering genomic material amount."},
  {name: "Retrotransposon regulation", description: "Retrotransposon regulation involves controlling the activity of retrotransposable elements."},
  {name: "Retrotransposon repression", description: "Retrotransposon repression is the silencing of retrotransposon activity."},
  {name: "Retrotransposon repression evasion", description: "Mutations in retrotransposons to escape host restriction."},
  {name: "retrotransposon RNP sequestration in cytoplasmic body", description: "Retrotransposon RNP sequestration in cytoplasmic bodies is a regulatory process that confines retrotransposon ribonucleoprotein complexes to prevent their activity."},
  {name: "retrotransposon silencing", description: "A mechanism to restrict the mobility of retrotransposons."},
  {name: "Retrotransposon transcript degradation", description: "Retrotransposon transcript degradation is a miRNA-independent cell survival function."},
  {name: "Retrotransposon transcription", description: "The process of transcribing retrotransposon DNA into RNA."},
