  {name: "Failure to inhibit tissue factor-induced thrombin generation", description: "Failure to inhibit tissue factor-induced thrombin generation is a functional defect in anticoagulant mechanisms."},
  {name: "Fanconi anemia DNA crosslink repair pathway", description: "Fanconi anemia DNA crosslink repair pathway is a DNA repair mechanism that prevents retrotransposition by cleaving nucleic acid intermediates."},
