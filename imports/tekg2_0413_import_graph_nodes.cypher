  {name: "recombination increase", description: "Elevated frequency of genetic recombination."},
  {name: "Recombination-mediated integration", description: "SVA-mediated integration of a circular intermediate leading to lcr16a expansion."},
  {name: "Recombinational editing", description: "A proposed mechanism for the nonrandom genomic distribution of mammalian transposons."},
  {name: "recombinational hotspot", description: "A genomic region with a high frequency of recombination events."},
  {name: "Recombinational mutagenesis", description: "Genome instability caused by recombination involving transposons."},
  {name: "recruitment and amplification of SVMPs into venom gland", description: "Process of incorporating and increasing SVMP genes in snake venom glands."},
  {name: "Recruitment of novel 5'UTR", description: "Frequent acquisition of unrelated regulatory regions during LINE-1 evolution."},
  {name: "recurrent inversion formation", description: "Recurrent inversion formation is a process generating inversion polymorphisms."},
  {name: "redirection of evolutionary trajectory", description: "Redirection of evolutionary trajectory involves altering the course of evolution."},
  {name: "reduced interferon signaling", description: "Reduced interferon signaling is a diminished cellular response to interferon signaling pathways."},
  {name: "reduced suppression of retrotransposition", description: "Reduced suppression of retrotransposition is a hypothesized mechanism where decreased cellular control over LINE-1 activity leads to increased genomic instability."},
  {name: "Reduced TAF1 expression", description: "Reduced TAF1 expression is a diminished level of TAF1 gene expression, particularly in neurons."},
  {name: "reduction of endothelial cell migration", description: "Reduction of endothelial cell migration is a decrease in the movement of endothelial cells, which can affect processes like angiogenesis."},
  {name: "reduction of endothelial cell proliferation", description: "Reduction of endothelial cell proliferation is a decrease in the growth and division of endothelial cells, leading to inhibited cell cycle progression."},
  {name: "regenerative medicine", description: "Regenerative medicine is a field focused on repairing or replacing damaged tissues and organs."},
  {name: "Regenerative therapy", description: "Approaches to treat kidney injury by regenerating tissue."},
  {name: "Regenerative treatment", description: "Regenerative treatment involves using cells to repair or replace damaged tissues."},
  {name: "region-specific methylation", description: "A mechanism to regulate LINE-1 transcription through methylation of specific CpG sites."},
  {name: "regional mutation hypothesis", description: "The hypothesis that a repetitive sequence is subject to the same mutation pressure as its surrounding genomic regions."},
  {name: "regulated transcriptional expression", description: "Regulated transcriptional expression refers to the controlled transcription of genetic elements."},
  {name: "regulating gene expression", description: "Regulating gene expression is the control of the amount and timing of gene product appearance."},
  {name: "Regulation", description: "Regulation of gene expression, potentially involving conserved indels cooperating with transcription factor binding sites."},
  {name: "Regulation of aberrant gene expression", description: "Transposable elements can act as regulators of abnormal gene expression in cancer."},
  {name: "Regulation of Apoptosis", description: "Biological process involved in programmed cell death."},
  {name: "regulation of cell growth", description: "Regulation of cell growth involves controlling the proliferation and division of cells."},
  {name: "Regulation of cell interaction", description: "Control of communication and adhesion between cells."},
  {name: "regulation of cellular gene expression", description: "Regulation of cellular gene expression is a process where HERV sequences may contribute by acting as regulatory elements."},
  {name: "Regulation of chromatin landscape", description: "Regulation of chromatin landscapes involves controlling the structure and accessibility of chromatin, thereby influencing gene expression."},
  {name: "Regulation of gene expression", description: "Regulation of gene expression involves controlling the amount and timing of gene products."},
  {name: "regulation of host gene expression", description: "Mutated and fragmented transposable elements can contribute to regulation of host gene expression."},
  {name: "regulation of human gene", description: "Impact of ERV/LR inserts on gene regulation."},
  {name: "regulation of LINE-1 activity", description: "Control of LINE-1 expression and mobility at transcriptional, post-transcriptional, and integration stages."},
  {name: "Regulation of mRNA template activity", description: "Regulation of mRNA template activity modulates the efficiency of mRNA translation."},
  {name: "Regulation of neuropeptide gene expression", description: "Evolutionary changes in the regulation of neuropeptide and brain-related genes."},
  {name: "regulation of programmed cell death", description: "Regulation of programmed cell death is the control of apoptosis."},
  {name: "Regulation of splicing", description: "Regulation of splicing controls the processing of pre-mRNA into mature mRNA isoforms."},
  {name: "regulation of transcription", description: "A biological process controlling gene expression."},
  {name: "Regulation of transcription initiation", description: "Regulation of transcription initiation is a biological process controlling gene expression."},
  {name: "Regulation of transposable element", description: "The activity of transposable elements is tightly regulated during the life cycle."},
  {name: "regulation of transposable element number", description: "Nonautonomous elements regulate stochastic fluctuations and copy numbers of autonomous elements."},
  {name: "Regulatory activity", description: "Regulatory activity refers to the ability of sequences to control gene expression."},
  {name: "regulatory divergence", description: "Regulatory divergence refers to differences in gene regulation between species."},
  {name: "Regulatory element evolution", description: "Regulatory element evolution is the process by which DNA sequences that control gene expression change over time."},
  {name: "Regulatory element function", description: "Transposable elements can act as regulatory elements controlling gene expression."},
  {name: "Regulatory evolution", description: "Regulatory evolution involves changes in gene expression regulation over evolutionary time."},
  {name: "regulatory function", description: "A role in controlling gene expression, such as acting as an enhancer."},
  {name: "regulatory innovation", description: "Regulatory innovation refers to the evolution of new gene expression control mechanisms."},
  {name: "regulatory network rewiring", description: "Substantial changes in the gene regulatory network."},
  {name: "Regulatory noncoding RNA generation", description: "Generation of regulatory noncoding RNAs that influence gene expression."},
  {name: "Regulatory rewiring", description: "Regulatory rewiring is the alteration of gene regulatory networks."},
  {name: "Regulatory role", description: "Transposable elements have regulatory roles within the genome."},
  {name: "regulatory variation", description: "Genetic variation affecting the regulation of gene expression."},
  {name: "reinfection", description: "Copying mechanism involving reinfection by replication-competent elements."},
  {name: "Reinitiation event", description: "Translation reinitiation event following termination of upstream translation."},
  {name: "remobilization", description: "Remobilization is the subsequent movement of an integrated transposon, which can damage the host genome."},
  {name: "remodeling of the hominid genome", description: "Remodeling of the hominid genome refers to structural and functional changes in the genome during hominid evolution, potentially involving HERV elements."},
  {name: "repair of chromosomal break", description: "Repair of double-strand breaks in DNA."},
  {name: "repair of oxidized DNA lesions", description: "Repair of oxidized DNA lesions is a DNA damage repair process."},
  {name: "Repeat contraction", description: "Decrease in the number of repeat units."},
  {name: "repeat element dysregulation", description: "Abnormal expression or regulation of repeat elements."},
