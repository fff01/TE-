  {name: "retrovirus restriction", description: "Inhibition of retrovirus infectivity."},
  {name: "Reverse cholesterol transport", description: "Reverse cholesterol transport is the process of moving cholesterol from peripheral tissues to the liver."},
  {name: "reverse genetic", description: "Targeted genome editing allows for reverse genetics experiments."},
