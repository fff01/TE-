  {name: "Fibrinolytic activity", description: "Fibrinolytic activity is the process of breaking down blood clots."},
  {name: "Fibrinolytic capacity", description: "Fibrinolytic capacity is the ability of the blood to break down clots."},
  {name: "Fibrosis", description: "Fibrosis is the formation of excess fibrous connective tissue."},
