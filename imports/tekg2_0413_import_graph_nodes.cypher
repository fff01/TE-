  {name: "AluY insertion in BTK", description: "AluY insertion in BTK is a retrotransposon insertion mutation at a specific site in the BTK gene coding region."},
  {name: "AluY insertion in RP1", description: "AluY insertion in RP1 is a mobile element insertion mutation in exon 4 of the RP1 gene associated with macular dystrophy."},
  {name: "AluY insertion in SMARCB1", description: "AluY insertion in SMARCB1 is a transposable element insertion causing a frameshift truncation in exon 2 of the SMARCB1 gene."},
  {name: "AluYa5 insertion in IFN-γR1", description: "AluYa5 insertion in IFN-γR1 is a LINE-1-mediated retrotransposition event causing autosomal recessive IFN-γR1 deficiency."},
  {name: "AluYa5 insertion in NKX2-1", description: "AluYa5 insertion in NKX2-1 is a de novo exonic mobile element insertion causing NKX2-1-related disorder."},
  {name: "AluYb8 insertion in BRCA1", description: "AluYb8 insertion in BRCA1 is a pathogenic variant in the BRCA1 gene that disrupts splicing and leads to a truncated protein."},
  {name: "AluYb9 insertion in PKLR", description: "AluYb9 insertion in PKLR is a homozygous insertion of an Alu retrotransposon within exon 6 of the PKLR gene, causing decreased RNA levels and pyruvate kinase deficiency."},
  {name: "AluYb9 insertion in SPAST", description: "AluYb9 insertion in SPAST is a retrotransposition event causing splicing alteration and hereditary spastic paraplegia."},
  {name: "Amino acid substitutions in ORF2", description: "Amino acid substitutions in ORF2 are mutations at positions 363, 1220, and 1259 that affect LINE-1 retrotransposition frequency and insertion length."},
  {name: "AML oncogenic mutation", description: "AML oncogenic mutations are genetic changes that drive the development of acute myeloid leukemia."},
  {name: "APOBEC3B deletion", description: "APOBEC3B deletion is a deletion polymorphism in the APOBEC3B gene associated with loss of function."},
  {name: "APOBEC3B knockdown", description: "APOBEC3B knockdown is a reduction in APOBEC3B expression achieved via shRNA, leading to increased LINE-1 retrotransposition."},
  {name: "APOBEC3D polymorphism", description: "APOBEC3D polymorphism is a genetic variant that decreases antiviral activity against HIV-1 and Alu retrotransposons."},
  {name: "APOE rs7412/rs429358", description: "APOE rs7412/rs429358 are single nucleotide polymorphisms in the APOE gene with associations in principal component analysis for pregnancy loss."},
  {name: "ATM deficiency", description: "ATM deficiency refers to the reduced or absent function of the ATM protein, often due to mutations, leading to impaired DNA damage response."},
  {name: "ATM mutation", description: "ATM mutation is a germline mutation in the ATM gene linked to hereditary breast cancer risk."},
  {name: "ATRX knockout", description: "ATRX knockout is a genetic modification where the ATRX gene is inactivated, used in iPSC-derived neurons to study its effects."},
  {name: "ATRX mutation", description: "ATRX mutation is a genetic alteration in the ATRX gene that correlates with LINE-1 retrotransposition activity in cancer."},
  {name: "BMI variation", description: "BMI variations refer to changes in Body Mass Index that may be associated with genetic factors and metabolic disease risk."},
  {name: "BRCA1 mutation", description: "BRCA1 mutation is a germline mutation in the BRCA1 gene that contributes to hereditary breast cancer susceptibility."},
  {name: "BRCA2 mutation", description: "BRCA2 mutation is a germline or somatic mutation in the BRCA2 gene implicated in hereditary and sporadic breast cancers."},
  {name: "Btk mutation", description: "Btk mutation refers to genomic alterations in the Btk gene that cause X-linked agammaglobulinemia."},
  {name: "C > T mutation", description: "C > T mutation is a point mutation that optimizes the 5' splice site, leading to aberrant splice-site activation."},
  {name: "c.-108A>G variant", description: "c.-108A>G variant is a nucleotide substitution affecting a highly conserved promoter position in the CHM gene."},
  {name: "c.-90C>G variant", description: "c.-90C>G variant is a nucleotide substitution affecting a highly conserved promoter position in the CHM gene."},
  {name: "C9orf72 mutation", description: "C9orf72 mutation is a genetic alteration in the C9orf72 gene associated with amyotrophic lateral sclerosis and differential repeat element expression."},
  {name: "CAG repeat expansion in HTT", description: "CAG repeat expansion in HTT is a genetic mutation causing Huntington disease."},
  {name: "CAG repeat expansion in PPP2R2B", description: "CAG repeat expansion in PPP2R2B is a genetic mutation associated with spinocerebellar ataxia type 12."},
  {name: "Cancer somatic CNV", description: "Cancer somatic CNVs are copy number variations that occur in somatic cells and are associated with cancer."},
  {name: "CDKN2A mutation", description: "CDKN2A mutation is a genetic alteration in the CDKN2A gene, such as the P16-p.G101W/P14-p.R115L variant."},
  {name: "centSIRT6", description: "centSIRT6 is a rare human centenarian variant of the SIRT6 gene containing two linked substitutions (N308K/A313S)."},
  {name: "CFH rs1061170", description: "CFH rs1061170 is a single nucleotide polymorphism in the CFH gene identified in principal component analysis for pregnancy loss."},
  {name: "cGAS mutation", description: "cGAS mutations are cancer-associated genetic alterations that disrupt the CHK2-cGAS-TRIM41-ORF2p regulatory axis and abolish suppression of L1 retrotransposition."},
  {name: "Chromosome 8 alteration", description: "Chromosome 8 alterations are genetic changes on chromosome 8, commonly observed in advanced prostate carcinoma."},
  {name: "Co-depletion of ADAR and DHX9", description: "Co-depletion of ADAR and DHX9 is a combined reduction of both enzymes, which augments double-stranded RNA accumulation and circular RNA production."},
  {name: "Conserved indel", description: "Conserved indels are insertions or deletions in genomic sequences that are evolutionarily conserved."},
  {name: "Copy number alteration (CNA)", description: "Copy number alteration (CNA) is a genomic mutation involving changes in DNA segment copy numbers, correlated with LINE-1 expression in cancers."},
  {name: "CRISPR-Cas9-induced mutation in Nav3", description: "CRISPR-Cas9-induced mutation in Nav3 is a genetic alteration that demonstrates heightened EGFRvIII-glioma cell proliferation."},
  {name: "CRISPR-Cas9-induced mutation in Spred1", description: "CRISPR-Cas9-induced mutation in Spred1 is a genetic alteration that demonstrates heightened EGFRvIII-glioma cell proliferation."},
  {name: "CRISPR-Cas9-induced mutation in Tead2", description: "CRISPR-Cas9-induced mutation in Tead2 is a genetic alteration that demonstrates heightened EGFRvIII-glioma cell proliferation."},
  {name: "CRISPR/Cas9 site", description: "CRISPR/Cas9 sites are genomic locations targeted for DNA modifications by CRISPR/Cas9 genome editing."},
  {name: "CRP rs2808635/rs876538", description: "CRP rs2808635/rs876538 are single nucleotide polymorphisms in the CRP gene linked to pregnancy loss risk."},
  {name: "CSB mutation", description: "CSB mutation is a genetic alteration in the CSB gene that causes Cockayne syndrome."},
  {name: "CXCR4 P191A mutant", description: "CXCR4 P191A mutant is a genetic variant of the CXCR4 gene that inhibits HIV-1 infection without impairing hematopoietic stem cell differentiation."},
  {name: "CYP11B1-LINE-1.2 deletion", description: "CYP11B1-LINE-1.2 deletion is a genetic alteration that increases CYP11B1 promoter activity and restores Alu enhancer effects."},
  {name: "D125N", description: "D125N is a somatic, damaging single nucleotide variant in the PTPRQ protein."},
  {name: "De novo somatic retrotransposition in KCNIP4", description: "De novo somatic retrotransposition in KCNIP4 is a somatic retrotransposon insertion mutation occurring after neural crest formation in a patient with temporal lobe epilepsy."},
  {name: "defect in ATM", description: "Defect in ATM is a mutation in the ATM gene impairing double-strand break response and fertility."},
  {name: "defect in BLM", description: "Defect in BLM is a mutation in the BLM gene impairing double-strand break response and fertility."},
  {name: "defect in Ku70", description: "Defect in Ku70 is a mutation in the Ku70 gene impairing double-strand break response and fertility."},
  {name: "defect in LIG4", description: "Defect in LIG4 is a mutation in the LIG4 gene impairing double-strand break response and fertility."},
  {name: "defect in MRE11", description: "Defect in MRE11 is a mutation in the MRE11 gene impairing double-strand break response and fertility."},
  {name: "defect in WRN", description: "Defect in WRN is a mutation in the WRN gene impairing double-strand break response and fertility."},
  {name: "deleterious effect", description: "Deleterious effect refers to the harmful impact of L1 retrotransposons, primarily through ectopic recombination."},
  {name: "Deleting the SVA in CDK5RAP2", description: "Deleting the SVA in CDK5RAP2 is a genetic deletion of a SINE-VNTR-Alu retrotransposon in the CDK5RAP2 gene."},
  {name: "Deleting the SVA in SCN8A", description: "Deleting the SVA in SCN8A is a genetic deletion of a SINE-VNTR-Alu retrotransposon in the SCN8A gene."},
  {name: "Deletion", description: "Deletions are loss of nucleotide sequences within L1 insertions during retrotransposition."},
  {name: "deletions of target genomic DNA", description: "Deletions of target genomic DNA are loss of DNA sequences at the site of L1 retrotransposition."},
  {name: "DICER1 deficit", description: "DICER1 deficit is a decreased level of DICER1 that leads to Alu RNA toxicity and age-related macular degeneration."},
  {name: "DICER1 knockdown", description: "DICER1 knockdown is a reduction in DICER1 expression that induces accumulation of Alu RNA and RPE degeneration."},
  {name: "disease-promoting genomic deletion", description: "Disease-promoting genomic deletions are structural mutations that can contribute to disease development, potentially sourced from L1 activity."},
  {name: "DNA methylation in SVA", description: "DNA methylation in SVA is an epigenetic modification of the retrotransposon sequence affecting gene expression."},
  {name: "DNMT1 loss", description: "DNMT1 loss refers to the deletion or functional impairment of the DNMT1 gene, leading to reduced DNA methylation."},
  {name: "duplication in HPRT1 gene", description: "Duplication in HPRT1 gene is a genetic mutation causing Lesch-Nyhan syndrome."},
  {name: "DUX4 misexpression", description: "DUX4 misexpression is an aberrant expression event linked to facioscapulohumeral muscular dystrophy."},
  {name: "dystrophin mutation", description: "Dystrophin mutation is a genetic alteration in the dystrophin gene associated with muscular dystrophy."},
  {name: "DYT3 locu", description: "DYT3 locus is a genetic region associated with X-linked dystonia-parkinsonism."},
  {name: "EGFR mutation", description: "EGFR mutation is an activating mutation common in IDH1 wild-type gliomas."},
  {name: "EGFR T790M mutation", description: "EGFR T790M mutation is a specific mutation in the EGFR gene linked to non-small cell lung cancer."},
  {name: "EPB41L3 hypermethylation", description: "EPB41L3 hypermethylation is increased DNA methylation at the EPB41L3 promoter, detected in 79% of prostate carcinoma samples."},
  {name: "ERCC1 deficiency", description: "ERCC1 deficiency is a genetic condition characterized by impaired ERCC1 protein activity, resulting in enhanced retrotransposition in cells."},
  {name: "ERCC2 deficiency", description: "ERCC2 deficiency is a genetic condition due to mutations in the ERCC2 gene, affecting DNA repair and increasing retrotransposition."},
  {name: "exonic Alu insertion", description: "Exonic Alu insertions are mutations where Alu retrotransposons insert into exonic regions, which are generally deleterious and subject to natural selection."},
  {name: "Exonic deletion of CHD7", description: "Exonic deletion of CHD7 is a deletion mutation encompassing exons 8-12 of the CHD7 gene identified in a patient with CHARGE syndrome."},
  {name: "extra nucleotides at 5' end", description: "Extra nucleotides at the 5' end are additional bases added during L1 integration, possibly from template-jumping."},
  {name: "F13A1 rs5985", description: "F13A1 rs5985 is a single nucleotide polymorphism in the F13A1 gene associated with early pregnancy loss risk."},
  {name: "F460K mutation", description: "F460K mutation is a dimerization mutant of the Metnase transposase domain that impairs DNA cleavage, DNA-binding, and nonhomologous end joining activities."},
  {name: "F8 mutation", description: "F8 mutation is a genetic alteration in the F8 gene that causes hemophilia A."},
  {name: "F9 poly(A) site mutation", description: "F9 poly(A) site mutation is a disease-causing mutation in the Factor 9 gene that affects polyadenylation and is associated with hemophilia B."},
  {name: "FANCD2 deficiency", description: "FANCD2 deficiency is a genetic condition related to Fanconi Anemia that leads to upregulated LINE-1 retrotransposition."},
  {name: "FGB rs1800790", description: "FGB rs1800790 is a single nucleotide polymorphism in the FGB gene associated with increased early pregnancy loss risk."},
  {name: "footprint-free LRRK2-G2019S knock-in", description: "Footprint-free LRRK2-G2019S knock-in is a genetically engineered mutation in the LRRK2 gene without residual DNA sequences."},
  {name: "FV-A2086D mutation", description: "FV-A2086D mutation is a genetic variant in the factor V gene linked to deep vein thrombosis."},
  {name: "FV-W1920R mutation", description: "FV-W1920R mutation is a genetic variant in the factor V gene associated with thrombophilia."},
  {name: "G2A mutation", description: "G2A mutation is a mutation that abolishes myristoylation of the Nef protein."},
  {name: "G3BP1 depletion", description: "G3BP1 depletion is a reduction in G3BP1 protein levels that abrogates stress granule formation."},
  {name: "G3BP1 knockdown", description: "G3BP1 knockdown is a reduction in G3BP1 protein expression that abolishes MxB inhibition of LINE-1 retrotransposition."},
  {name: "Gene deletion of JMJD6", description: "Gene deletion of JMJD6 is a genetic alteration that removes the JMJD6 gene, enhancing IFN-I production and reducing viral susceptibility."},
  {name: "genetic damage", description: "Genetic damage refers to harmful alterations in DNA caused by processes like retrotransposition and ectopic recombination."},
  {name: "Genetic variation in DNMT1, DNMT3B, TET2, TDG", description: "Genetic variation in DNMT1, DNMT3B, TET2, TDG refers to single nucleotide polymorphisms in genes involved in DNA methylation reprogramming."},
  {name: "Genome instability", description: "Genome instability is a condition of increased genetic alterations that can contribute to cancer development."},
  {name: "Genome-wide hypomethylation", description: "Genome-wide hypomethylation is a systemic epigenetic alteration involving reduced DNA methylation across the genome."},
  {name: "Genomic deletion in PDHX", description: "Genomic deletion in PDHX is a pathological approximately 46-kb deletion in the PDHX gene linked to pyruvate dehydrogenase complex deficiency."},
  {name: "Genomic rearrangement", description: "Genomic rearrangements are structural changes in the genome that can result from recombination events."},
  {name: "genomic variation", description: "Genomic variation refers to alterations in the genome, including those induced by L1 retrotransposition and associated DNA damage."},
  {name: "Glu342Lys mutation", description: "Glu342Lys mutation is a point mutation in the α(1)-antitrypsin gene responsible for α(1)-antitrypsin deficiency."},
  {name: "Gross deletion in Artemi", description: "Gross deletion in Artemis is a large-scale genetic disruption common in immunodeficiency gene defects."},
  {name: "Gross deletion in BTK", description: "Gross deletion in BTK is a large-scale genetic disruption observed in primary immunodeficiency genes."},
  {name: "Gross deletion in IGHM", description: "Gross deletion in IGHM is a large-scale genetic disruption frequently found in immunodeficiency patients."},
  {name: "GTSF1 deletion", description: "GTSF1 deletion is a loss-of-function mutation in the GTSF1 gene that causes male-specific sterility."},
  {name: "H19 hypomethylation", description: "H19 hypomethylation is an epigenetic alteration involving reduced methylation of the H19 imprinted gene."},
  {name: "H3K27ac", description: "H3K27ac is a histone modification that undergoes extensive reprogramming during early embryo development and marks active transposons."},
  {name: "H3K4me3 modification", description: "H3K4me3 modifications are epigenetic histone modifications associated with active gene expression."},
  {name: "H3K56ac", description: "H3K56ac is an acetylation modification at lysine 56 of histone H3, detectable throughout preimplantation stages in human embryos."},
  {name: "H3K9me3 deposition", description: "H3K9me3 deposition is an epigenetic modification involving trimethylation of histone H3 at lysine 9."},
  {name: "Harmful mutagenesis", description: "Harmful mutagenesis refers to deleterious genetic alterations that increase the risk of disease."},
  {name: "HBB IVS2-654 (C > T) mutation", description: "HBB IVS2-654 (C > T) mutation is a point mutation in intron 2 of the HBB gene causing β-thalassemia."},
  {name: "HBB mutation", description: "HBB mutation is a genetic alteration in the HBB gene that causes β-thalassemia."},
  {name: "HENMT1 nonsense variant (c.555G>A, p.Trp185*)", description: "This is a homozygous nonsense mutation in the HENMT1 gene identified in a patient with non-obstructive azoospermia."},
  {name: "HERV-K hypomethylation", description: "HERV-K hypomethylation is a reduced methylation state of the HERV-K retroelement associated with adverse prognosis in melanoma."},
  {name: "HERVK9 haploidy", description: "HERVK9 haploidy is a copy number variation involving loss of one copy of the HERVK9 retrotransposon on chromosome 7p11.2."},
  {name: "HESX1 mutation", description: "HESX1 mutations are genetic alterations associated with combined pituitary hormone deficiency and optic nerve anomalies."},
  {name: "high LINE-1 burden", description: "High LINE-1 burden refers to a high number of de novo L1 retrotransposition insertion events in a tumor genome."},
  {name: "High nuclear ORF1p expression", description: "High nuclear ORF1p expression is a molecular alteration linked to lymph node metastasis and worse survival in breast cancer."},
  {name: "High nuclear ORF2p expression", description: "High nuclear ORF2p expression is a molecular alteration associated with adverse clinical outcomes in breast cancer."},
  {name: "High TE content", description: "High TE content is a genomic feature associated with an increased frequency of gross deletions in disease genes."},
  {name: "Histone H1X depletion", description: "Histone H1X depletion is a reduction in H1X levels that leads to transposable element derepression."},
  {name: "histone H3 methylation", description: "Histone H3 methylation is a post-translational modification associated with transcriptional silencing."},
  {name: "Histone H3.3 K27M mutation", description: "Histone H3.3 K27M mutation is a lysine-to-methionine substitution that impairs H3K27me3/me2 deposition and redistributes antagonistic chromatin marks."},
  {name: "Histone H3.3 K36M mutation", description: "Histone H3.3 K36M mutation is a lysine-to-methionine substitution that impairs H3K36me3/me2 deposition and redistributes antagonistic chromatin marks."},
  {name: "HIV-1Δvif", description: "HIV-1Δvif is a mutant strain of HIV-1 lacking the vif gene, used to study viral infection and restriction."},
  {name: "HLA-A deletion", description: "HLA-A deletion is a 14 kb deletion that includes the entire HLA-A gene in Japanese families with leukemia."},
  {name: "HpaII site mutation", description: "HpaII site mutation is a specific alteration in a DNA methylation site that reduces promoter activity in the L1.2B retrotransposon."},
  {name: "HPV 6a DNA integration", description: "HPV 6a DNA integration is a genomic alteration where human papillomavirus type 6a DNA inserts into the host genome, potentially disrupting cellular genes."},
  {name: "HTT CAG repeat instability", description: "HTT CAG repeat instability is a somatic mutation in the HTT gene associated with Huntington's disease."},
  {name: "human-specific sperm hypomethylated domain", description: "Human-specific sperm hypomethylated domains are large genomic regions with reduced methylation in human sperm, frequently occurring in copy number variation regions."},
  {name: "Hypomethylation of AluY promoter", description: "Hypomethylation of AluY promoter is a DNA methylation change associated with placenta-specific gene expression."},
  {name: "IFNAR1 deficiency", description: "IFNAR1 deficiency is a genetic condition resulting in loss of IFNAR1 function."},
  {name: "IFNAR1 knockdown", description: "IFNAR1 knockdown is a genetic manipulation that reduces expression of the IFNAR1 gene."},
  {name: "increased mutation rate", description: "Increased mutation rates refer to elevated frequencies of de novo mutations associated with strong nucleosomes."},
  {name: "indel", description: "Indels are insertion or deletion mutations that can arise from DNA repair deficiencies."},
  {name: "Insertion of snaR-G element", description: "Insertion of snaR-G element is a genetic insertion event that generated new hormone genes in African Great Apes."},
  {name: "insertion/deletion mutation", description: "Insertion/deletion mutation is a type of mutation involving the addition or loss of nucleotides in a DNA sequence."},
  {name: "Insertional mutagenesis in MGA", description: "Insertional mutagenesis in MGA is a somatic mutation where a pseudogene integrates into the promoter and first exon of the MGA gene, abrogating its expression."},
  {name: "Insertional mutation", description: "Insertional mutation is a type of mutation caused by the insertion of genetic elements like LINEs into host chromosomes."},
  {name: "Insertional mutation at p15", description: "Insertional mutation at p15 is a mutation caused by foreign DNA integration leading to altered gene expression at the p15 locus."},
  {name: "inter-chromosomal translocation", description: "Inter-chromosomal translocations are chromosomal rearrangements involving exchanges between non-homologous chromosomes."},
  {name: "intragenic deletion in COL4A5", description: "Intragenic deletion in COL4A5 is an in-frame deletion encompassing exons 38 through 41, associated with Alport syndrome."},
  {name: "Intron removal", description: "Intron removal is a genetic modification involving the deletion of intronic sequences from a gene."},
  {name: "Intronic mutation in CHM", description: "Intronic mutation in CHM is a mutation in the intronic region of the CHM gene that creates a strong acceptor splice site and leads to inclusion of a cryptic exon."},
  {name: "inversion", description: "Inversions are structural rearrangements where segments of L1 insertions are reversed in orientation."},
  {name: "Ionising irradiation", description: "Ionising irradiation is an agent that induces genomic alterations and mutations via retrotransposon activation."},
  {name: "KAP1 depletion", description: "KAP1 depletion is a loss of KAP1 protein function leading to activation of interferon-stimulated genes."},
  {name: "KRAS Q61H mutation", description: "KRAS Q61H mutation is a specific mutation in the KRAS gene associated with non-small cell lung cancer."},
  {name: "KRASG12D", description: "KRASG12D is a specific mutation in the KRAS gene where glycine is replaced by aspartate at position 12."},
  {name: "L1Hs hypomethylation", description: "L1Hs hypomethylation is a reduction in DNA methylation of the L1Hs retrotransposon promoter region, associated with neural tube defects."},
  {name: "large genomic deletion", description: "Large genomic deletions are structural mutations resulting from misrepaired DNA breaks induced by L1 expression."},
  {name: "large indel", description: "Large indels are insertions or deletions of nucleotide sequences that contribute to sequence divergence between species."},
  {name: "LINE-1 element in 3'UTR", description: "LINE-1 element in 3'UTR is a long interspersed nuclear element located in the 3' untranslated region of a gene."},
  {name: "LINE-1 hypomethylation", description: "LINE-1 hypomethylation is a DNA methylation alteration associated with hepatocellular carcinomas."},
  {name: "LINE-1 insertion in APC", description: "LINE-1 insertion in APC is a somatic retrotransposon insertion mutation disrupting the APC gene in colon cancer."},
  {name: "LINE-1 insertion in AR", description: "LINE-1 insertion in AR is a retrotransposon insertion mutation in the 5'UTR of the androgen receptor gene causing reduced expression and partial androgen insensitivity syndrome."},
  {name: "LINE-1 insertion in ATRN", description: "LINE-1 insertion in ATRN is a genomic event involving a retrotransposon insertion that regulates alternative splicing of the attractin gene."},
  {name: "LINE-1 insertion in BAALC", description: "LINE-1 insertion in BAALC is an L1 transposable element insertion mutation disrupting expression of the BAALC gene in head and neck squamous cell carcinoma."},
  {name: "LINE-1 insertion in c-myc", description: "LINE-1 insertion in c-myc is a somatic mutation caused by a LINE-1 sequence insertion into the c-myc gene."},
  {name: "LINE-1 insertion in CADPS2", description: "LINE-1 insertion in CADPS2 is an intronic retrotransposon insertion that disrupts CADPS2 gene expression in human induced pluripotent stem cells."},
  {name: "LINE-1 insertion in CC2D2A", description: "LINE-1 insertion in CC2D2A is an exonic transposon insertion mutation predicted to cause aberrant splicing in the CC2D2A gene."},
  {name: "LINE-1 insertion in CHM", description: "LINE-1 insertion in CHM is a mutation caused by insertion of a full-length L1 retrotransposon into the coding region of the CHM gene."},
  {name: "LINE-1 insertion in CNNM2", description: "LINE-1 insertion in CNNM2 is a somatic retrotransposition event within the CNNM2 gene intron associated with reduced gene expression."},
  {name: "LINE-1 insertion in CYBB", description: "LINE-1 insertion in CYBB is a retrotransposition event causing a mutation in the CYBB gene."},
  {name: "LINE-1 insertion in DMD", description: "LINE-1 insertion in DMD is a de novo transposable element insertion mutation in the DMD gene associated with X-linked dilated cardiomyopathy."},
  {name: "LINE-1 insertion in Dystrophin", description: "LINE-1 insertion in Dystrophin is a retrotransposon insertion mutation in the dystrophin gene associated with muscular dystrophy."},
  {name: "LINE-1 insertion in ERI3", description: "LINE-1 insertion in ERI3 is a retrotransposon insertion mutation found in the ERI3 gene associated with schizophrenia."},
  {name: "LINE-1 insertion in F8", description: "LINE-1 insertion in F8 is a nondeleterious L1 retrotransposon insertion in intron 10 of the factor VIII gene."},
  {name: "LINE-1 insertion in F9", description: "LINE-1 insertion in F9 is a retrotransposition mutation involving a LINE1 element insertion in the factor IX gene."},
  {name: "LINE-1 insertion in Factor VIII gene", description: "LINE-1 insertion in Factor VIII gene is a de novo insertion of L1 sequences causing haemophilia A."},
  {name: "LINE-1 insertion in FRMD4A", description: "LINE-1 insertion in FRMD4A is a somatic retrotransposition event within the FRMD4A gene intron associated with reduced gene expression."},
  {name: "LINE-1 insertion in IL23R", description: "LINE-1 insertion in IL23R is a retrotransposon insertion variant in the IL-23 receptor gene causing early termination."},
  {name: "LINE-1 insertion in MCC", description: "LINE-1 insertion in MCC is a germline retrotransposition event in the tumor suppressor gene MCC that ablates its expression."},
  {name: "LINE-1 insertion in PDHX", description: "LINE-1 insertion in PDHX is a retrotranspositional insertion of a full-length LINE-1 element causing a genomic deletion in the PDHX gene."},
  {name: "LINE-1 insertion in RB1", description: "LINE-1 insertion in RB1 is a constitutional mutation causing aberrant splicing and familial retinoblastoma."},
  {name: "LINE-1 insertion in RP1", description: "LINE-1 insertion in RP1 is a retrotransposon insertion mutation in the RP1 gene associated with retinitis pigmentosa."},
  {name: "LINE-1 insertion in RP2", description: "LINE-1 insertion in RP2 is a retrotransposition event detected in an intron of the RP2 gene in an X-linked retinitis pigmentosa patient."},
  {name: "LINE-1 insertion in SLCO1B3", description: "LINE-1 insertion in SLCO1B3 is a population-specific polymorphic intronic retrotransposon insertion causing deleterious splicing in the SLCO1B3 gene."},
  {name: "LINE-1 insertion in ST18", description: "LINE-1 insertion in ST18 is a tumor-specific retrotransposition event that activates the ST18 gene by interrupting a negative feedback loop."},
  {name: "LINE-1 insertion in STC1", description: "LINE-1 insertion in STC1 is a de novo intronic retrotransposon insertion that acts as a cis-enhancer for the STC1 gene."},
  {name: "LINE-1 insertion into NACC2", description: "LINE-1 insertion into NACC2 is a retrotransposon insertion mutation that disrupts the NACC2 locus and activates oncogenic signaling."},
  {name: "LINE-1 methylation", description: "LINE-1 methylation is an epigenetic modification that regulates the activity of long interspersed nuclear elements."},
  {name: "LINE-1 methylation in blood", description: "LINE-1 methylation in blood is a measure of global DNA methylation levels in blood samples."},
  {name: "LINE-1 methylation in tissue", description: "LINE-1 methylation in tissue is a measure of global DNA methylation levels in tissue samples."},
  {name: "LINE-1 methylation statu", description: "LINE-1 methylation status is a parameter reflecting DNA methylation levels of LINE-1 elements, used as a clinical biomarker in cancer."},
  {name: "LINE-1 mosaicism", description: "LINE-1 mosaicism is a pattern of somatic retrotransposition events causing genetic variation among cells."},
  {name: "LINE-1 polymorphism", description: "LINE-1 polymorphisms are genetic variations in the LINE-1 retrotransposon associated with inter-individual differences in disease susceptibility."},
  {name: "LINE-1 promoter hypomethylation", description: "LINE-1 promoter hypomethylation is a reduction in DNA methylation at the promoter region of LINE-1 retrotransposons, leading to transcriptional activation."},
  {name: "LINE-1 retrotransposition", description: "LINE-1 retrotransposition is a somatic mutation event involving the mobilization of LINE-1 elements in neurons."},
  {name: "LINE-1(CHM) insertion in CHM", description: "LINE-1(CHM) insertion in CHM is a retrotransposon insertion mutation in the CHM gene causing choroideremia."},
  {name: "LINE-1-mediated somatic mosaicism", description: "LINE-1-mediated somatic mosaicism is a genetic condition resulting from retrotransposon-induced somatic mutations in neuronal cells."},
  {name: "LINE-1.2 insertion in F8", description: "LINE-1.2 insertion in F8 is a retrotransposition event causing a mutation in the factor VIII gene associated with hemophilia A."},
  {name: "LINE-1/Alu singleton", description: "LINE-1/Alu singletons are rare, recently acquired transposable element insertions observed in only one person, used as proxies for variation in insertion numbers."},
  {name: "Loss of DHX9", description: "Loss of DHX9 is a genetic alteration resulting in reduced DHX9 function, leading to increased circular RNA production and transcriptional rewiring."},
  {name: "Loss of DNA methylation", description: "Loss of DNA methylation is an epigenetic alteration characterized by reduced methylation levels on DNA."},
  {name: "Loss of FGGY", description: "Loss of FGGY is a genetic alteration involving the FGGY gene."},
  {name: "Loss of MECP2 function", description: "Loss of MECP2 function is a genetic alteration that impairs the protein's activity and causes Rett syndrome."},
  {name: "Loss-of-function mutations in ADAR p150", description: "Loss-of-function mutations in ADAR p150 are genetic alterations that cause Aicardi-Goutières Syndrome."},
  {name: "LRRK2-G2019S mutation", description: "LRRK2-G2019S mutation is a genetic mutation in the LRRK2 gene associated with Parkinson's disease."},
  {name: "LTR70:r.879A>G", description: "LTR70:r.879A>G is an expressed single nucleotide variation on the LTR70 repeat element linked to patient survival in pancreatic cancer."},
  {name: "MAEL promoter hypermethylation", description: "MAEL promoter hypermethylation is an epigenetic alteration associated with decreased MAEL expression and LINE-1 de-repression in hypospermatogenesis."},
  {name: "MAP2K4 translocation", description: "MAP2K4 translocation is a structural variant interrupting the MAP2K4 gene, potentially acting as a driver mutation in breast cancer."},
  {name: "MCC ablation", description: "MCC ablation is the loss of MCC expression due to a LINE-1 retrotransposition event, enabling oncogenic β-catenin/Wnt signaling."},
  {name: "MECP2 mutation", description: "MECP2 mutation is a genetic alteration in the MECP2 gene associated with Rett syndrome."},
  {name: "Methylation of AluY promoter", description: "Methylation of AluY promoter is a DNA methylation state that silences gene expression in embryonic tissues."},
  {name: "Methylation state of LINE-1 5' end", description: "Methylation state of LINE-1 5' end is an epigenetic condition that influences the transcriptional activity of LINE-1 sequences."},
  {name: "methyltransferase-like 3 deficiency", description: "Methyltransferase-like 3 deficiency is a condition resulting from loss or reduction of METTL3 enzyme activity."},
  {name: "METTL3 knockout", description: "METTL3 knockout is a genetic modification that inactivates the METTL3 gene, used to study its role in m6A RNA methylation and pluripotency regulation."},
  {name: "Minicircle/LINE-1 integration", description: "Minicircle/LINE-1 integration is a genomic insertion event where Trypanosoma cruzi minicircle DNA integrates into LINE-1 retrotransposons."},
  {name: "Minicircle/LINE-1 integration at p15", description: "Minicircle/LINE-1 integration at p15 is an insertional mutation affecting the p15 locus."},
  {name: "Minicircle/LINE-1 mutation", description: "Minicircle/LINE-1 mutation is a genomic alteration involving integration of Trypanosoma cruzi minicircle DNA into LINE-1 retrotransposons."},
  {name: "MLH1 mutation", description: "MLH1 mutation is a germline alteration in the MLH1 gene that causes Lynch syndrome."},
  {name: "Mobile element-associated event", description: "Mobile element-associated events are structural variations caused by the insertion or deletion of transposable elements in the genome."},
  {name: "MORC2 depletion", description: "MORC2 depletion is a reduction or loss of MORC2 protein function that impairs leukemia cell proliferation and attenuates AML progression."},
  {name: "MPP8 deficiency", description: "MPP8 deficiency is a genetic condition that impedes tumor development by reactivating LINE-1 retrotransposons in acute myeloid leukemia."},
  {name: "MPP8 loss", description: "MPP8 loss is a genetic alteration resulting in the absence or reduction of MPP8 protein function."},
  {name: "MTHFR rs1801133/rs1801131", description: "MTHFR rs1801133/rs1801131 are single nucleotide polymorphisms in the MTHFR gene associated with increased early pregnancy loss risk."},
  {name: "mutant SAMHD1", description: "Mutant SAMHD1 refers to altered forms of the SAMHD1 protein associated with Aicardi-Goutières syndrome patients, which are defective in inhibiting LINE-1 retrotransposition."},
  {name: "mutation", description: "Mutation is a change in the DNA sequence that can be caused by LINE-1 transposition."},
  {name: "mutation at site A", description: "mutation at site A is a genetic alteration in the L1 sequence that causes loss of promoter activity."},
  {name: "Mutation in Ha-ra", description: "Mutation in Ha-ras is a genetic alteration in the Ha-ras gene induced by DMBA in skin tumorigenesis."},
  {name: "Mutation in harmful region", description: "Mutation in harmful region refers to a genetic alteration occurring in specific areas of transposable elements that significantly reduces transpositional activity."},
  {name: "Mutations in VEGFR-3", description: "Mutations in VEGFR-3 are genetic alterations identified in patients with primary lymphoedema."},
  {name: "NEIL1 c.C844T variant", description: "NEIL1 c.C844T variant is a germline mutation in the NEIL1 gene leading to a premature stop codon."},
  {name: "NEXMIF loss", description: "NEXMIF loss refers to the knockout or deficiency of the NEXMIF gene, leading to functional impairments in cells."},
  {name: "nonsense mutation", description: "Nonsense mutation is a type of mutation that introduces a premature stop codon in a gene."},
  {name: "NRAS mutation", description: "NRAS mutation is a genetic abnormality in the NRAS gene associated with juvenile myelomonocytic leukemia."},
  {name: "nucleotide change", description: "Nucleotide changes are alterations in DNA sequence that can affect retrotransposon jumping activity."},
  {name: "nucleotide substitution", description: "Nucleotide substitution is a type of mutation where one nucleotide is replaced by another in a DNA sequence."},
  {name: "ORF1p coiled-coil domain mutation", description: "ORF1p coiled-coil domain mutation is a genetic alteration that reduces levels of ORF1p in L1 ribonucleoprotein particles."},
  {name: "ORF1p mutant", description: "ORF1p mutants are variants of the ORF1 protein that affect ribonucleoprotein particle formation and retrotransposition efficiency."},
  {name: "ORF1p polymorphism", description: "ORF1p polymorphism is a genetic variation in the LINE-1 ORF1 protein that affects retrotransposition efficiency and aggregation dynamics."},
  {name: "ORF1p RNA binding mutant", description: "ORF1p RNA binding mutant is a variant of the ORF1 protein with impaired RNA binding ability."},
  {name: "ORF1p RNA recognition motif mutation", description: "ORF1p RNA recognition motif mutation is a genetic alteration that reduces levels of ORF1p in L1 ribonucleoprotein particles."},
  {name: "ORF2p cysteine-rich domain mutation", description: "ORF2p cysteine-rich domain mutation is a genetic alteration that reduces levels of ORF2p in L1 ribonucleoprotein particles."},
  {name: "P53 ablation", description: "P53 ablation is an experimental inactivation of the TP53 gene leading to desynchronized replication and chromothripsis."},
  {name: "P53 dysfunction", description: "P53 dysfunction refers to the loss of function in the TP53 gene, which exacerbates retroelement derepression in cancer."},
  {name: "p53 gene deletion", description: "p53 gene deletion is the loss of one allele of the p53 gene."},
  {name: "p53 inactivation", description: "p53 inactivation is a loss-of-function alteration in the p53 protein that inhibits apoptosis induction."},
  {name: "p53 loss", description: "p53 loss is a genetic alteration resulting in the absence or dysfunction of the p53 protein."},
  {name: "P53 mutation", description: "P53 mutation is a germline mutation in the TP53 gene associated with hereditary breast cancer susceptibility."},
  {name: "P53 mutation R175H", description: "P53 mutation R175H is a TP53 mutation that manifests oncogenic characteristics by activating transposable element promoters in a cell type-specific manner."},
  {name: "P53 mutation R273H", description: "P53 mutation R273H is a TP53 mutation that manifests oncogenic characteristics by activating transposable element promoters in a cell type-specific manner."},
  {name: "P53 nonsense mutation", description: "P53 nonsense mutation is a type of mutation in the TP53 gene that results in absent p53 protein expression."},
  {name: "p53 point mutation", description: "p53 point mutation is a specific nucleotide change in the p53 gene."},
  {name: "p53 rearrangement", description: "p53 rearrangement is a genetic alteration involving the p53 gene."},
  {name: "p53 rs1042522", description: "TP53 rs1042522 is a single nucleotide polymorphism in the TP53 gene linked to early pregnancy loss risk."},
  {name: "PAI-1 4G/4G genotype", description: "PAI-1 4G/4G genotype is a genetic polymorphism in the promoter region of the PAI-1 gene associated with increased risk of atherothrombotic stroke."},
  {name: "PAIP2 knockdown", description: "PAIP2 knockdown is a reduction in PAIP2 expression that increases L1 retrotransposition."},
  {name: "PiggyBac insertion in GPR160", description: "PiggyBac insertion in GPR160 is a transposon-mediated mutation in the gpr160 gene that reduces bacterial entry into macrophages."},
  {name: "PIWIL2 depletion", description: "PIWIL2 depletion refers to the loss or reduction of PIWIL2 expression, which promotes transposon activity and tumorigenic phenotypes in colon cancer."},
  {name: "PIWIL4 mutation (R269W)", description: "PIWIL4 mutation (R269W) is a missense variant in the PIWIL4 gene associated with nonobstructive azoospermia."},
  {name: "PMM2 mutation", description: "PMM2 mutation is a genetic alteration in the PMM2 gene associated with congenital disorders of glycosylation type Ia."},
  {name: "PNLDC1 mutation", description: "PNLDC1 mutation is a genetic alteration in the PNLDC1 gene associated with nonobstructive azoospermia."},
  {name: "Poc1a disruption", description: "Poc1a disruption is a mutation caused by LINE-1 retrotransposon-mediated insertion into the Poc1a gene."},
  {name: "poly(A) microsatellite", description: "poly(A) microsatellites are tandem repeats of adenine bases that are abundant in the genome and undergo rapid shortening, creating somatic and germline mosaicism."},
  {name: "Polymorphic TEs in constrained gene", description: "Polymorphic TEs in constrained genes are transposable elements that vary between individuals and are located in genes under selective pressure."},
  {name: "PTPN11 mutation", description: "PTPN11 mutation is a genetic abnormality in the PTPN11 gene associated with juvenile myelomonocytic leukemia."},
  {name: "random mutation", description: "Random mutation refers to spontaneous genetic changes that can generate transposase variants or affect transposon behavior."},
  {name: "RARB2 hypermethylation", description: "RARB2 hypermethylation is an epigenetic alteration associated with lymph node involvement in urothelial carcinoma."},
  {name: "rearrangement", description: "Rearrangement is a structural alteration of genomic DNA that can result from LINE-1 transposition."},
  {name: "recessive mutation", description: "Recessive mutation is a type of genetic mutation that results in loss of gene product and is associated with recessive inheritance."},
  {name: "Recombination of Alu", description: "Recombination of Alus is a genetic recombination event involving Alu retrotransposons that can lead to exon deletions."},
  {name: "Reference LINE-1 insertion polymorphism", description: "Reference LINE-1 insertion polymorphisms are polymorphic variations in the presence or absence of LINE-1 retrotransposons in the human genome."},
  {name: "Retroelement-induced mutagenesis", description: "Retroelement-induced mutagenesis refers to genetic changes caused by retroelement activity, leading to various human diseases."},
  {name: "Retrotransposon insertion polymorphisms (RIPs)", description: "Retrotransposon insertion polymorphisms (RIPs) are genetic polymorphisms resulting from retrotransposon insertions that can underlie diseases and are used as biomarkers."},
  {name: "RHOXF2 mutant", description: "RHOXF2 mutants are genetic variants in the RHOXF2 gene associated with human infertility."},
  {name: "RNase H2 deficiency", description: "RNase H2 deficiency is a condition resulting from mutations in RNase H2, leading to accumulation of cytosolic DNA and autoimmune disorders."},
  {name: "RNASEH2 mutation", description: "RNASEH2 mutation refers to hypomorphic mutations in the RNase H2 enzyme that cause Aicardi-Goutières syndrome."},
  {name: "rNMPs in DNA", description: "rNMPs in DNA are ribonucleoside monophosphates incorporated into DNA during synthesis, leading to genomic instability."},
  {name: "rs1414273", description: "rs1414273 is a single nucleotide polymorphism at the base of the microRNA stem-loop that affects recognition by Drosha and DGCR8."},
  {name: "SAMHD1 mutation", description: "SAMHD1 mutation is a genetic alteration frequently associated with cancer development."},
  {name: "SAMHD1 phosphorylation at S33", description: "SAMHD1 phosphorylation at S33 is a post-translational modification required for inhibiting LINE-1 retrotransposition."},
  {name: "SAMHD1 S33A mutation", description: "SAMHD1 S33A mutation is a single nucleotide polymorphism that abolishes the ability to inhibit LINE-1 retrotransposition."},
  {name: "sequence divergence", description: "Sequence divergence refers to differences in nucleotide sequences between homologous genes or transcripts across species."},
  {name: "SFRP1 hypermethylation", description: "SFRP1 hypermethylation is an epigenetic inactivation event linked to lack of gene expression in urothelial carcinoma."},
  {name: "Single G duplication in AluSz6", description: "Single G duplication in AluSz6 is a mutation that provides a new canonical 5' splicing site, leading to lineage-specific expression of the Alu-exonized transcript."},
  {name: "single-nucleotide substitution", description: "Single-nucleotide substitutions are point mutations resulting from nucleotide changes in DNA."},
  {name: "SIRT7 deficiency", description: "SIRT7 deficiency is a condition characterized by reduced SIRT7 expression, accelerating senescence in human mesenchymal stem cells."},
  {name: "SLX4 deficiency", description: "SLX4 deficiency is a genetic condition causing cytoplasmic DNA accumulation and increased LINE-1 activity in Fanconi Anemia."},
  {name: "SMARCB1 mutation", description: "SMARCB1 mutation is a genetic alteration in the SMARCB1 gene that can lead to loss of protein expression in atypical teratoid/rhabdoid tumor."},
  {name: "SNP rs12191876 G allele", description: "SNP rs12191876 G allele is a derived allele associated with increased OPRM1 expression in the cerebellum."},
  {name: "SOD1 mutation", description: "SOD1 mutation is an amyotrophic lateral sclerosis-associated genetic alteration in the SOD1 gene."},
  {name: "SOX10 mutation", description: "SOX10 mutation is a genetic alteration in the SOX10 gene that causes Waardenburg syndrome."},
  {name: "species-specific differentially methylated region", description: "Species-specific differentially methylated regions are genomic regions with DNA methylation differences between species, often associated with retrotransposon insertions."},
  {name: "SPG11 mutation", description: "SPG11 mutation is a genetic alteration in the SPG11 gene associated with neurodegenerative disorders."},
  {name: "Structural variation", description: "Structural variation refers to differences in the genome structure, such as insertions or deletions, often involving repetitive DNA sequences."},
  {name: "Sub1 loss-of-function mutation", description: "Sub1 loss-of-function mutation is a recurrent somatic alteration identified in gliomas."},
  {name: "SVA CCCTCT repeat instability", description: "SVA CCCTCT repeat instability is a somatic mutation in the SVA retrotransposon associated with repeat expansion diseases."},
  {name: "SVA insertion in B4GALT1", description: "SVA insertion in B4GALT1 is a retrotransposon insertion polymorphism disrupting an enhancer in the B4GALT1 gene."},
  {name: "SVA insertion in BRCA1", description: "SVA insertion in BRCA1 is a retrotransposon insertion mutation causing splicing aberrations in the BRCA1 gene."},
  {name: "SVA insertion in BTK", description: "SVA insertion in BTK is a retrotransposon insertion mutation at a specific site in the BTK gene coding region."},
  {name: "SVA insertion in CHM", description: "SVA insertion in CHM is a hemizygous retrotransposon insertion mutation in exon 2 of the CHM gene causing choroideremia."},
  {name: "SVA insertion in FKTN", description: "SVA insertion in FKTN is a founder variant involving a 3-kb retrotransposon insertion that causes a splicing disorder in Fukuyama congenital muscular dystrophy."},
  {name: "SVA insertion in fukutin", description: "SVA insertion in fukutin is a retrotransposon insertion mutation in the fukutin gene causing Fukuyama muscular dystrophy."},
  {name: "SVA insertion in GNA", description: "SVA insertion in GNAS is a retrotransposon insertion mutation upstream of the first exon of A/B in the GNAS locus."},
  {name: "SVA insertion in MSH2", description: "SVA insertion in MSH2 is a retrotransposon insertion mutation in exon 3 of the MSH2 gene causing aberrant RNA splicing in Lynch syndrome."},
  {name: "SVA insertion in MSH6", description: "SVA insertion in MSH6 is a retrotransposon insertion mutation in exon 5 of the MSH6 gene causing aberrant RNA splicing in Lynch syndrome."},
  {name: "SVA insertion in NEK1", description: "SVA insertion in NEK1 is a rare retrotransposon insertion mutation in the NEK1 gene associated with amyotrophic lateral sclerosis."},
  {name: "SVA insertion in SOX10", description: "SVA insertion in SOX10 is a retrotransposon insertion mutation in the SOX10 gene associated with Waardenburg syndrome."},
  {name: "SVA insertion in SRCAP", description: "SVA insertion in SRCAP is a de novo transposon insertion mutation in exon 13 of the SRCAP gene causing neurodevelopmental disorder."},
  {name: "SVA insertion in TAF1", description: "SVA insertion in TAF1 is a retrotransposon insertion mutation that causes X-linked dystonia parkinsonism."},
  {name: "SVA insertion-associated deletion", description: "SVA insertion-associated deletion is a large genomic copy number change caused by retrotransposon insertion."},
  {name: "SVA-E insertion in CASP8", description: "SVA-E insertion in CASP8 is a retrotransposon insertion mutation in the CASP8 gene associated with altered splicing and protection against prostate cancer."},
  {name: "SVA-E insertion in SMARCB1", description: "SVA-E insertion in SMARCB1 is a germline retrotransposon insertion that disrupts splicing and causes biallelic inactivation in atypical teratoid rhabdoid tumors."},
  {name: "SVA_D insertion in ATP7A", description: "SVA_D insertion in ATP7A is a retrotransposon insertion mutation deep within an intron of the ATP7A gene that causes aberrant mRNA splicing and leads to occipital horn syndrome."},
  {name: "SVA_E insertion in ASPA", description: "SVA_E insertion in ASPA is a deep intronic retrotransposition event causing pathogenic variants in the ASPA gene."},
  {name: "SVA_F insertion in NMNAT1", description: "SVA_F insertion in NMNAT1 is a splice-altering pathogenic variant involving retrotransposon integration that introduces a premature stop codon."},
  {name: "SVA_F insertion in PMS2", description: "SVA_F insertion in PMS2 is a LINE-1-mediated retrotranspositional insertion causing Lynch syndrome."},
  {name: "SVA_F insertion in TAF1", description: "SVA_F insertion in TAF1 is a pathogenic retrotransposon insertion mutation in the TAF1 gene causing X-linked Dystonia-Parkinsonism."},
  {name: "SVA_F1 insertion in EBP", description: "SVA_F1 insertion in EBP is a retrotransposition event disrupting the EBP gene in X-linked dominant chondrodysplasia punctata."},
  {name: "TALENs-corrected iPSC clone", description: "TALENs-corrected iPSC clones are induced pluripotent stem cell clones with corrected HBB gene mutations using TALENs."},
  {name: "Target site triplications (TSTs)", description: "Target site triplications (TSTs) are genomic structural variations where three copies of a repeat sequence are present due to unequal homologous recombination."},
  {name: "TBCD mutation", description: "TBCD mutation is a pathogenic biallelic variant in the TBCD gene associated with PEBAT-related endophenotypes."},
  {name: "Tctn3 knockout", description: "Tctn3 knockout is a genetic mutation that results in the loss of Tctn3 function in mice."},
  {name: "TDRD9 mutation", description: "TDRD9 mutation is a 4 bp deletion frameshift mutation in the TDRD9 gene causing non-obstructive azoospermia."},
  {name: "Tead2 loss-of-function mutation", description: "Tead2 loss-of-function mutation is a recurrent somatic alteration identified in gliomas."},
  {name: "Templated sequence insertion polymorphism (TSIP)", description: "Templated sequence insertion polymorphism (TSIP) is a form of polymorphic insertion in the human genome where inserted sequences are templated from distant genomic regions."},
  {name: "Templated Sequence Insertion Polymorphism (TSIP) formation", description: "TSIP formation is a process involving insertion of templated sequences into the genome, mediated by mechanisms like LINE-1 ORF2 protein or DNA repair."},
  {name: "TIA1 depletion", description: "TIA1 depletion is a reduction in TIA1 protein levels that abrogates stress granule formation."},
  {name: "TIA1 knockdown", description: "TIA1 knockdown is a reduction in TIA1 protein expression that abolishes MxB inhibition of LINE-1 retrotransposition."},
  {name: "Transposase N-terminal phosphorylation", description: "Transposase N-terminal phosphorylation is a post-translational modification that inhibits piggyBac transposition by preventing transposase-DNA interactions."},
  {name: "TREX1 mutation", description: "TREX1 mutation is a genetic alteration linked to Aicardi-Goutières syndrome that fails to inhibit LINE1-triggered immune activation."},
  {name: "TRIM5α H43Y variant", description: "TRIM5α H43Y variant is a frequent SNP in the RING domain of TRIM5α that enhances innate immune response against LINE-1 elements."},
  {name: "Trp53 loss-of-function mutation", description: "Trp53 loss-of-function mutation is a recurrent somatic alteration identified in gliomas."},
  {name: "truncating NEIL1 mutation", description: "Truncating NEIL1 mutation is a genetic alteration that results in a prematurely terminated NEIL1 protein."},
  {name: "TTC28-LINE-1 transduction", description: "TTC28-LINE-1 transductions are DNA rearrangements mediated by LINE-1 retrotransposons, originating within the TTC28 gene and associated with endometriosis-related ovarian cancers."},
  {name: "Undermethylation of LINE-1 5' end", description: "Undermethylation of LINE-1 5' end is an epigenetic modification associated with increased expression of LINE-1 elements."},
  {name: "UXT depletion", description: "UXT depletion is a loss of UXT expression associated with prostate cancer progression and genome instability."},
  {name: "XPA deficiency", description: "XPA deficiency is a genetic condition caused by mutations in the XPA gene, impairing nucleotide excision repair."},
  {name: "XPF deficiency", description: "XPF deficiency is a genetic condition associated with reduced XPF protein function, leading to increased LINE-1 retrotransposition."},
  {name: "YY1 binding site", description: "YY1 binding site is a conserved transcription factor binding site that mediates L1 promoter DNA methylation."},
  {name: "YY1 binding site mutation", description: "YY1 binding site mutation is a mutation in the YY1 binding site that leads to hypomethylation of young L1s."},
  {name: "ZNF611 deletion", description: "ZNF611 deletion is a genetic mutation involving the removal of the ZNF611 gene, which does not result in SVA activation unlike ZNF91 deletion."},
  {name: "ZNF689 deficiency", description: "ZNF689 deficiency is a deficiency state that reactivates LINE-1 retrotransposition to promote genomic instability and intratumor heterogeneity."},
  {name: "ZNF91 deletion", description: "ZNF91 deletion is a genetic alteration that exacerbates the molecular phenotype associated with XDP-SVA insertion."}
] AS row
MERGE (n:Mutation {name: row.name})
SET n.description = row.description, n.source_group = "mutations";

