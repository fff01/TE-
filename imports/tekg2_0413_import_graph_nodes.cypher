  {name: "Reciprocal translocation", description: "LINE-1-mediated reciprocal translocations."},
  {name: "recognition of self versus non-self dsRNA", description: "The process of distinguishing endogenous from exogenous double-stranded RNA."},
  {name: "Recombination", description: "Recombination is the process of genetic material exchange between DNA molecules."},
