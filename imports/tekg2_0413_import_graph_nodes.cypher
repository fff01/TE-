  {name: "Generation of stable transfectant", description: "A technique for isolating stable cell LINE expressing genes of interest."},
  {name: "genes and HERVs/MaLRs modulation", description: "The regulation of gene and transposon expression levels."},
  {name: "genetic change", description: "Genetic changes are alterations in the DNA sequence."},
  {name: "genetic correction", description: "Genetic correction is the process of repairing disease-causing mutations in cells."},
  {name: "genetic damage", description: "Damage to the genome, such as that potentially caused by uncontrolled retrotransposition."},
  {name: "Genetic differentiation", description: "Genetic differentiation is the process of genetic divergence between populations."},
  {name: "genetic diversification", description: "Genetic diversification refers to the process of generating genetic variation within populations."},
  {name: "Genetic diversity", description: "Genetic diversity refers to the total number of genetic characteristics in a population."},
  {name: "Genetic diversity generation", description: "LINE-1 retrotransposition creates intra- and inter-individual genetic variation."},
  {name: "Genetic diversity production", description: "Active transposons produce genetic diversity in human populations."},
  {name: "genetic drift", description: "Genetic drift is a mechanism of evolution causing allele frequency changes in small populations."},
  {name: "Genetic engineering", description: "Novel piggyBac family members may be useful in genetic engineering of many organisms."},
  {name: "Genetic engineering of primary T cell", description: "The process of modifying the genome of primary human T cells for adoptive T-cell therapies."},
  {name: "Genetic evolution", description: "The process of change in the genetic composition of a population."},
  {name: "genetic information recycling", description: "LTRs can recycle processed pseudogenes into functional mRNAs or lncRNAs."},
  {name: "genetic innovation", description: "Genetic innovation refers to the creation of new genetic material or functions."},
  {name: "genetic instability", description: "Genetic instability refers to an increased propensity for DNA alterations, such as deletions or duplications, at a specific genomic locus."},
  {name: "genetic load", description: "The burden of deleterious mutations imposed by LINE-1 activity, subject to negative selection."},
  {name: "genetic mapping", description: "Genetic mapping is the process of determining the location of genes on chromosomes."},
  {name: "genetic modification", description: "Process of altering the genetic material of an organism."},
  {name: "genetic modification of clinical cell", description: "Altering genomes of cells relevant for therapeutic applications."},
