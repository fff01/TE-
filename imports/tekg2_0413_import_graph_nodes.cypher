  {name: "exhaustion", description: "Exhaustion is a dysfunctional state in T cells marked by reduced effector function and increased inhibitory receptor expression."},
  {name: "Exit from quiescence", description: "The process by which cells, such as haematopoietic stem cells, transition from a dormant state to an active, cycling state."},
  {name: "Exogenous DNA integration", description: "Integration of foreign DNA into the genome of target cells."},
  {name: "Exogenous retrovirus replication block", description: "Blocking by receptor interference or antisense mRNA."},
  {name: "Exon definition", description: "A traditional molecular mechanism for recognizing exons during splicing."},
  {name: "Exon deletion", description: "Exon deletion is a mechanism leading to the loss of exons from a gene."},
  {name: "Exon inclusion", description: "Exon inclusion is a splicing event where an exon is retained in the mature mRNA."},
  {name: "Exon inversion", description: "A genetic rearrangement resulting in the reversal of an exon's orientation."},
  {name: "exon selection", description: "Process of selecting exons for inclusion in mature mRNA."},
  {name: "exon shuffling", description: "A mechanism for the evolution of new genes, potentially mediated by LINE-1 retrotransposition of non-LINE-1 sequences."},
  {name: "Exon skipping", description: "Exon skipping is a splicing abnormality where an exon is omitted from the mature mRNA."},
  {name: "Exon transduction", description: "Process where LINE-1 retrotransposition transduces exons."},
  {name: "exon trapping", description: "Exon-trapping is a mechanism where an intronic element captures and mobilizes upstream exons."},
  {name: "Exon-acquisition", description: "Exon-acquisition is the gain of new exons."},
  {name: "Exonic deletion", description: "Deletion of one or more exons within a gene."},
  {name: "Exonic insertions causing loss-of-function mutation", description: "Mechanism through which SVA insertions can cause disease."},
  {name: "Exonization", description: "Exonization is the process by which intronic sequences, such as transposable elements, become new exons."},
  {name: "exonization via alternative splicing", description: "Promotion of evolution and proteome diversity through exon creation."},
  {name: "expansion", description: "Expansion refers to the increase in copy number of transposable elements."},
