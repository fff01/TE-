  {name: "gene transfer in vivo", description: "Delivery of genetic material directly into living organisms."},
  {name: "gene transposition", description: "The movement of a gene from one chromosomal location to another."},
  {name: "gene upregulation", description: "Gene upregulation is the increase in expression level of a gene."},
