  {name: "Repeat expression regulation", description: "Regulation of repetitive DNA element expression during human embryogenesis."},
  {name: "repeat silencing", description: "Epigenetic repression of repetitive genomic elements."},
  {name: "Repeat to gene expression ratio", description: "Repeat to gene expression ratios are a quantitative measure comparing the expression levels of repeat elements to gene transcripts, used for risk stratification in acute myeloid leukemia."},
  {name: "Repeat-induced gene activation (RIGA)", description: "A process where repeat sequences activate co-amplified genes."},
  {name: "Repeat-induced gene silencing (RIGS)", description: "A process that silences transgenes and prevents transposon spread."},
  {name: "Replication", description: "Replication is the process of duplicating DNA."},
  {name: "Replication mechanism of retroposon", description: "Replication mechanism of retroposons depends on long terminal repeats and a tRNA binding site."},
  {name: "replication restart", description: "A cellular process to restart stalled DNA replication forks."},
  {name: "Replication slippage", description: "Mutational mechanism causing sequence duplications and repeat expansions."},
  {name: "replication stress", description: "Retrotransposition-associated replication stress is a potential molecular vulnerability."},
  {name: "replication stress alleviation", description: "Replication stress alleviation is the reduction of obstacles during DNA replication."},
  {name: "Replication-coupled DNA repair", description: "Replication-coupled DNA repair is a pathway that fixes DNA damage during replication."},
  {name: "Replication-fork restart", description: "Replication-fork restart is the process of resuming DNA synthesis after a stalled replication fork."},
  {name: "Replication-stress signaling", description: "Replication-stress signaling is a cellular response to stalled or stressed DNA replication forks."},
  {name: "replicative cellular senescence", description: "Replicative cellular senescence is an important tumor suppression mechanism."},
  {name: "Replicative origin", description: "Replicative origin is a site where DNA replication initiates."},
  {name: "replicative senescence", description: "Cell proliferation arrest due to telomere shortening."},
  {name: "Repress mobile element activity", description: "piRNAs function to repress mobile element activity."},
  {name: "repress transposable element", description: "piRNAs function to repress transposable elements in animal germ LINE."},
  {name: "repression", description: "Repression is the inhibition of retrotransposon activity."},
  {name: "repression of interferon-stimulated gene", description: "Repression of interferon-stimulated genes is a biological process that downregulates the expression of genes activated by interferon signaling."},
  {name: "Repression of promoter activity", description: "The ability to reduce transcriptional activity from a gene promoter."},
  {name: "repression of retrotransposon", description: "Repression of SVA activity."},
  {name: "repression of the 8C state", description: "Prevention of reversion to an 8-cell-like cell state."},
  {name: "Repression of transposable element", description: "Repression of transposable elements is the silencing of transposon expression and mobility."},
