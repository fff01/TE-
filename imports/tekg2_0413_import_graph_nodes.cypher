  {name: "reverse transcriptase activity", description: "Reverse transcriptase activity is necessary for the dispersion of mammalian retroelements."},
  {name: "reverse transcriptase inhibition", description: "Reverse transcriptase inhibition is a process that reduces the activity of reverse transcriptase enzyme, leading to decreased proliferation and increased differentiation in breast cancer cells."},
  {name: "Reverse transcriptase-mediated DNA damage response", description: "DNA damage response triggered by reverse transcriptase activity."},
  {name: "Reverse transcription", description: "RNA reverse transcription is involved in the amplification of mobile genetic elements."},
  {name: "Reverse transcription and integration", description: "The process of copying RNA into DNA and inserting it into a new genomic site."},
  {name: "Reverse transcription and reintegration", description: "Reverse transcription and reintegration is a mechanism for retrotransposon movement."},
  {name: "reverse transcription initiation", description: "The initiation of LINE-1 reverse transcription, guided by molecular rules involving primer complementarity."},
  {name: "reverse transcription of LINE-1 mRNA", description: "The process of synthesizing cDNA from LINE-1 mRNA, initiated by primers such as telomeric ends."},
  {name: "reverse transcription of LINE-1 RNA 5'-CAP", description: "Process explaining extra G nucleotides upstream of LINE-1 elements."},
  {name: "reverse transcription priming", description: "Priming of reverse transcription at the target site."},
  {name: "reverse transcriptional translocation", description: "LINE-1 can undergo reverse transcriptional translocation in neurons and neuroglial cells."},
  {name: "reversible genetic modification", description: "Reversible genetic modification allows for the removal of introduced genetic material without leaving mutations."},
  {name: "reversible immortalization", description: "A process to amplify primary cells that can be reversed to their original state."},
  {name: "reward processing", description: "Reward processing is a biological function modulated by mu-opioid receptors."},
  {name: "RHAG enhancer", description: "RHAG enhancer is a DNA regulatory element that enhances erythroid-specific expression of the RHAG gene."},
  {name: "ribonucleoprotein (RNP) formation", description: "The assembly of a ribonucleoprotein complex involving the LINE-1 transcript and its encoded proteins."},
  {name: "ribonucleoprotein (RNP) particle formation", description: "The process of forming retrotransposon ribonucleoprotein particles."},
  {name: "Ribonucleoprotein complex formation", description: "p40 complex is a ribonucleoprotein complex containing L1Hs RNA(s)."},
  {name: "ribonucleoprotein complex stability", description: "Stability of the p40 RNP-complex against nucleases and high salt."},
  {name: "ribonucleoprotein complexe", description: "Ribonucleoprotein complexes are cellular structures composed of RNA and proteins, such as those associated with APOBEC3F and APOBEC3G."},
  {name: "ribonucleoprotein particle (RNP) formation", description: "The assembly of LINE-1-encoded proteins with their encoding RNA into a proposed retrotransposition intermediate."},
  {name: "ribonucleoprotein particle formation", description: "The formation of ribonucleoprotein particles is a step in LINE-1 retrotransposition."},
  {name: "Ribonucleotide Excision Repair (RER)", description: "RER is a DNA repair pathway that removes ribonucleoside monophosphates (rNMPs) incorporated into DNA."},
  {name: "ribosomal association", description: "The localization of Alu RNA to ribosomes, which is part of its retrotransposition mechanism."},
  {name: "Ribosomal biogenesis", description: "Ribosomal biogenesis is the process of making ribosomes."},
  {name: "ribosome related gene function", description: "Ribosome related gene function involves protein synthesis and ribosomal components."},
  {name: "ribosome stalling", description: "Ribosome stalling is the halting of translation elongation on an mRNA."},
  {name: "RIG-I-dependent interferon response", description: "A lethal immune response triggered by dsRNA recognition."},
  {name: "RIG-I-like receptor signaling", description: "RLR signaling triggers type-I interferon response to dsRNA."},
  {name: "RNA 3' processing", description: "Post-transcriptional modification of the 3' end of an RNA molecule."},
  {name: "RNA 3'-end polyadenylation", description: "A post-transcriptional RNA processing step."},
  {name: "RNA 3'-end uridylation", description: "A post-transcriptional RNA modification."},
  {name: "RNA binding", description: "Sequence-specific, single-strand RNA binding activity."},
  {name: "RNA binding metabolism", description: "A pathway highly represented in XDP proteomic analysis."},
  {name: "RNA chaperone activity", description: "Activity of the LINE-1-ORF1p retrotransposon protein."},
  {name: "RNA circularization", description: "RNA circularization is the process of forming circular RNA molecules."},
  {name: "RNA decay", description: "A post-transcriptional RNA regulation process."},
  {name: "RNA degradation", description: "RNA degradation of Alu retrotransposons depends on sequence features and evolutionary history."},
  {name: "RNA editing", description: "RNA editing is a post-transcriptional process that alters the nucleotide sequence of an RNA molecule."},
  {name: "RNA editing A-to-I", description: "Deamination of adenosines to inosines within double-stranded RNA regions."},
  {name: "RNA interference", description: "Gene silencing mechanism involving small RNAs."},
  {name: "RNA interference (RNAi)", description: "RNAi is a biological process where RNA molecules inhibit gene expression."},
  {name: "RNA ligation", description: "A known mechanism for forming chimeric insertions, involving the joining of RNA molecules."},
  {name: "RNA m6A modification", description: "A common RNA modification that can influence RNA stability, splicing, and translation."},
  {name: "RNA metabolism", description: "Cellular processes involving RNA synthesis, processing, and degradation."},
  {name: "RNA methylation", description: "Post-transcriptional modification of RNA, specifically N6-methylation of adenine."},
  {name: "RNA nuclear localization", description: "Embedded TEs modulate lncRNA nuclear localization."},
  {name: "RNA packaging", description: "Process of encapsidating cellular RNAs into virions."},
  {name: "RNA Pol II enrichment at LINE-1", description: "LINE-1 can enrich RNA polymerase II, which is inhibited by SAFB binding to LINE-1 transcripts."},
  {name: "RNA polymerase II transcription", description: "RNA polymerase II transcription is a biological process for synthesizing mRNA, regulated by motifs like CCAAT, TATA, and ATTAAA."},
  {name: "RNA polymerase III activity", description: "RNA polymerase III activity is the transcription of genes encoding tRNAs, 5S rRNA, and other small RNAs."},
  {name: "RNA polymerase III promoter adaptation", description: "Adaptation of RNA polymerase III promoter to bind RNA polymerase II."},
  {name: "RNA polymerase III termination signal", description: "RNA polymerase III termination signal is a sequence that directs transcription termination and inhibits RNA 3' processing in pol III transcripts."},
  {name: "RNA polymerase III transcription", description: "RNA polymerase III transcribes small RNAs, including Alus."},
  {name: "RNA processing", description: "Removal of the A-rich and 3'-terminal regions from B1/Alu RNAs."},
  {name: "RNA processing alteration", description: "Changes in splicing or other RNA maturation steps."},
  {name: "RNA quality control", description: "RNA quality control pathway enriched in LINE-1-SIRT6 network."},
  {name: "RNA recognition by LINE RT", description: "The mechanism by which LINE-encoded reverse transcriptase recognizes transposon RNA."},
  {name: "RNA recombination", description: "A possible mechanism for the origin and evolution of the LINE-1."},
  {name: "RNA reverse transcription", description: "Involves reverse transcribing cellular RNAs."},
  {name: "RNA secondary structure conservation", description: "Conservation of the folded structure of Alu-derived RNA among Alu families."},
  {name: "RNA secondary structure formation", description: "The formation of structures like stem-loops from single-stranded RNA molecules."},
  {name: "RNA sensing", description: "RNA sensing is the detection of RNA molecules by cellular receptors to initiate immune signaling."},
  {name: "RNA silencing", description: "A cellular mechanism for regulating gene expression by degrading or inhibiting RNA."},
  {name: "RNA splicing", description: "The removal of introns and joining of exons in RNA transcripts."},
  {name: "RNA stability regulation", description: "Process of controlling RNA degradation or stabilization."},
  {name: "RNA stabilization", description: "RNA stabilization is a process that increases the half-life of RNA molecules."},
  {name: "RNA surveillance", description: "RNA surveillance is a cellular mechanism for monitoring RNA processing and translation."},
  {name: "RNA synthesis", description: "Autonomous RNA synthesis performed by cfChP concatemers."},
  {name: "RNA targeting", description: "A biological process involving the specific recognition and interaction with RNA molecules."},
  {name: "RNA template switching", description: "RNA template switching is a mechanism during reverse transcription where the enzyme switches from one RNA template to another."},
  {name: "RNA transcription", description: "RNA transcription of Alu retrotransposons depends on sequence features and evolutionary history."},
  {name: "RNA transport", description: "RNA transport is the movement of RNA molecules within the cell."},
  {name: "RNA transport into nucleu", description: "RNA transport into the nucleus is the process of moving RNA from the cytoplasm into the nucleus."},
  {name: "RNA virus sensor pathway", description: "Pathway sensing RNA viruses, involving RIG-I."},
  {name: "RNA-chromatin crosstalk", description: "Interactions between RNA molecules and chromatin that regulate gene expression."},
  {name: "RNA-dependent physical interaction", description: "A physical association between proteins that requires RNA as a scaffold or mediator."},
  {name: "RNA-DNA hybrid formation", description: "RNA-DNA hybrid formation is controlled by endogenous reverse transcriptase activity and serves as a translational repressor."},
  {name: "RNA-mediated dispersion", description: "RNA-mediated dispersion is a mechanism for the spread of repetitive DNA in genomes."},
  {name: "RNA-mediated DNA repair", description: "A proposed ancestral mechanism associated with non-LTR retrotransposons, possibly used before the acquisition of an endonuclease domain."},
  {name: "RNA-mediated gene insertion", description: "Capability of LINE-1 element to insert genes via RNA."},
