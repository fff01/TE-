  {name: "Triacylglycerol metabolism", description: "Triacylglycerol metabolism is a biochemical process involving the breakdown and synthesis of triacylglycerols."},
  {name: "TRIM28 multimerization", description: "TRIM28 multimerization is the assembly of TRIM28 protein into multi-unit complexes."},
  {name: "trimerization", description: "Formation of a protein complex consisting of three subunits."},
  {name: "trophoblast cell fusion", description: "Fusion of trophoblast cells to form multinucleate syncytiotrophoblast."},
  {name: "trophoblast differentiation", description: "The differentiation of cytotrophoblast cells into syncytiotrophoblast."},
  {name: "Trophoblast gene regulation", description: "The control of gene expression programs specific to trophoblast cells."},
  {name: "trophoblast syncytialization", description: "The formation of multinucleated syncytiotrophoblasts (STBs) in the placenta."},
  {name: "truncated LINE-1 retrotransposition", description: "A mechanism of FOXR2 activation involving incomplete retrotransposon insertion."},
  {name: "TSE", description: "TSE is a trophoblast-specific enhancer region regulating placental expression."},
  {name: "tumor and metastasis suppression", description: "BAP1 functions as a tumor and metastasis suppressor."},
  {name: "tumor control", description: "The ability to suppress or eliminate tumors."},
  {name: "Tumor dedifferentiation", description: "Tumor dedifferentiation is a process where cancer cells lose their specialized features."},
  {name: "tumor development", description: "The process by which normal cells transform and proliferate to form tumors."},
  {name: "Tumor development control", description: "Copper might control tumor development by decreasing HERV activation."},
  {name: "tumor genome plasticity", description: "The dynamic ability of the tumor genome to change, contributed to by LINE-1 activity and retrotransposition."},
  {name: "Tumor growth", description: "Tumor growth is the process of cancer cell proliferation."},
  {name: "Tumor growth promotion", description: "Copper exposure might promote tumor growth by inducing HERVs."},
  {name: "tumor immune evasion", description: "Tumor immune evasion is a mechanism by which tumors avoid immune destruction."},
  {name: "tumor immune microenvironment modulation", description: "Alteration of the immune landscape within the tumor."},
  {name: "Tumor immunity", description: "Immune responses against tumors, bridging innate and adaptive immunity."},
  {name: "Tumor infiltration", description: "Tumor infiltration is the migration and accumulation of immune cells into tumor tissue."},
  {name: "Tumor initiation", description: "The initial steps in the development of a tumor."},
  {name: "Tumor invasion", description: "Cancer cells invading surrounding tissues."},
  {name: "Tumor metastasis", description: "Tumor metastasis is the spread of cancer cells to distant sites."},
  {name: "Tumor progression", description: "Tumor progression is the process by which a tumor advances in growth and malignancy."},
  {name: "tumor progression inhibition", description: "VGLL4 competes with YAP to inhibit tumor progression."},
  {name: "Tumor promotion", description: "Stage of carcinogenesis where initiated cells expand."},
  {name: "Tumor suppression", description: "A biological process that inhibits tumor development."},
  {name: "tumor vascularisation", description: "Tumor vascularisation is the development of blood vessels within a tumor."},
  {name: "Tumor-cell killing", description: "Cytotoxic activity of CAR-T cells against tumor cells."},
  {name: "tumor-promoting function", description: "Activities that enhance the growth, survival, or spread of tumor cells."},
  {name: "Tumor-suppressive mechanism", description: "Processes that inhibit the development of tumors."},
  {name: "Tumorigenesis", description: "Tumorigenesis is the process of tumor formation."},
  {name: "Tumorigenesis reduction", description: "Tumorigenesis reduction is a substantial decrease in liver tumor formation."},
  {name: "Tumorigenic mechanism", description: "Processes that promote the development of tumors."},
  {name: "Tumorigenicity", description: "The ability to form tumors."},
  {name: "Tumour conversion to immunological hot state", description: "Conversion of tumor to an immunologically active state."},
  {name: "tumour heterogeneity characterization", description: "Characterization of heterogeneity within tumors."},
  {name: "twin priming", description: "A proposed mechanism for the creation of inversions in LINE-1 retrotransposition."},
  {name: "twin-priming mechanism", description: "Twin-priming is a mechanism that can cause rearrangements of LINE-1 elements."},
  {name: "Two-hit tumorigenesis pathway", description: "Classic model requiring two mutations to initiate cancer."},
  {name: "Type I interferon (IFN-1) response", description: "An immune response triggered by type I interferons, involved in antiviral defense and anti-tumor activity."},
  {name: "Type I interferon expression", description: "Expression of interferon-stimulated genes (ISGs) triggered by cytosolic nucleic acids."},
  {name: "Type I interferon induction", description: "Type I interferon induction is the production of IFN-alpha/beta."},
  {name: "Type I interferon system activation", description: "Activation of the immune signaling pathway involving type I interferons."},
  {name: "type-I interferon response", description: "An immune response triggered by cytoplasmic LINE-1 cDNA."},
  {name: "Type-I interferon signaling", description: "Type-I IFN signaling is an anti-viral and anti-tumor immune response."},
  {name: "U6/LINE-1 chimera formation", description: "The formation of chimeric RNAs consisting of U6 RNA conjoined to a truncated LINE-1."},
  {name: "U6/LINE-1 pseudogene formation", description: "The creation of pseudogenes via retrotransposition of U6/LINE-1 chimeric RNAs."},
  {name: "Ubiquitin binding", description: "The ability of a protein to bind to ubiquitin or ubiquitinated proteins, often involved in protein degradation or signaling."},
  {name: "ubiquitin-proteasome degradation", description: "Ubiquitin-proteasome degradation is a cellular process for targeted protein breakdown."},
  {name: "ubiquitination", description: "A post-translational modification involving the attachment of ubiquitin to a protein."},
  {name: "Ultrasound-targeted microbubble destruction (UTMD)", description: "UTMD is a nonviral method to deliver vectors to hepatocytes via acoustic cavitation."},
  {name: "uncontrolled inflammatory condition", description: "Systemic immune response generating inflammation."},
  {name: "Uncontrolled TE activity", description: "Uncontrolled TE activity is a process where transposable elements mobilize without regulation, potentially causing mutations and disease."},
  {name: "unconventional translation", description: "ORF2 is translated by an unconventional termination/reinitiation mechanism."},
  {name: "under-quantification", description: "Under-quantification is a bias in transcriptomic analysis where repetitive gene families are inaccurately measured."},
  {name: "under-quantification of repetitive gene families", description: "Under-quantification of repetitive gene families is a bias in RNA-seq data analysis affecting genes like MHC class I and II."},
  {name: "underrepresentation in epigenetic study", description: "Underrepresentation in epigenetic studies is a bias where genomic elements like transposable elements are inadequately analyzed."},
  {name: "underrepresentation of recently active transposable element", description: "Underrepresentation of recently active transposable elements is a bias in epigenetic studies due to ignoring multimappers."},
  {name: "undesired immune response", description: "Undesired immune responses are potentially harmful immune reactions."},
  {name: "unequal crossing over", description: "Unequal crossing over between Alus can cause mutations."},
  {name: "unequal crossover", description: "Unequal crossover is a recombination event between misaligned repetitive sequences, leading to deletions or duplications."},
  {name: "unequal homologous recombination", description: "Unequal homologous recombination is a DNA recombination event between misaligned sequences."},
  {name: "unequal recombination", description: "Unequal recombination is a process that can lead to deletions or duplications between repeat elements."},
  {name: "unscheduled DNA synthesis", description: "Unscheduled DNA synthesis is DNA replication occurring outside of the normal S phase."},
  {name: "URE", description: "URE is an upstream regulatory element acting as a tissue-specific enhancer in placenta cells."},
  {name: "uridylation", description: "Addition of uridine residues to RNA 3' ends."},
  {name: "use of additional copying mechanism", description: "Use of additional copying mechanisms describes the processes beyond reinfection that contribute to the proliferation of HERV families."},
  {name: "utilization of cellular enzymes for replication", description: "A process where retrotransposons make use of cellular enzymes, including DNA repair machinery, to complete their replication cycles."},
  {name: "V(D)J recombination", description: "V(D)J recombination is a site-specific recombination process that generates diverse antigen receptor genes in lymphocytes."},
  {name: "Vaccination", description: "Vaccination is the administration of antigenic material to stimulate an immune response."},
  {name: "Vaccine development", description: "Vaccine development involves modifying viral proteins for stability and antigenicity."},
  {name: "vascular development", description: "The biological process of forming the vascular system."},
  {name: "Vascular homeostasis", description: "The maintenance of stable conditions in the vascular system."},
  {name: "vascular network self-assembly", description: "The ability of endothelial cells to form new microvessels."},
  {name: "vascular smooth muscle cell differentiation", description: "The process by which pluripotent stem cells become vascular smooth muscle cells."},
  {name: "Vasculogenesis", description: "The de novo formation of blood vessels."},
  {name: "Venous invasion", description: "Venous invasion is the invasion of cancer cells into veins."},
  {name: "ventricular enlargement", description: "Increase in the size of the heart's ventricles."},
  {name: "VGLL4-TEAD1-TET2 axi", description: "VGLL4-TEAD1-TET2 axis is a signaling pathway that promotes vascular smooth muscle cell differentiation from human pluripotent stem cells."},
  {name: "viral DNA replication", description: "Viral DNA replication is the process of copying viral DNA."},
  {name: "Viral infection defense", description: "Biological processes that protect the host from viral pathogens."},
  {name: "Viral infectivity", description: "Viral infectivity is the ability of HIV-1 to infect cells."},
  {name: "viral integration", description: "Viral integration is the insertion of viral DNA into the host genome."},
  {name: "Viral mimicry", description: "Cellular presentation of pathogen-associated molecular patterns (PAMPs) that mimic viral infection, stimulating innate immunity."},
  {name: "Viral post-transcription", description: "Viral post-transcription is a step in the HIV-1 life cycle."},
  {name: "Viral production", description: "Viral production is the generation of infectious HIV-1 virions."},
  {name: "Viral replication", description: "Viral replication is the process by which a virus produces copies of itself."},
  {name: "Virion packaging", description: "Virion packaging is the process of incorporating components into a viral particle."},
  {name: "virus budding", description: "Virus budding is the release of enveloped viruses from host cells."},
  {name: "virus defense", description: "Biological processes that protect against viral infection."},
  {name: "virus-free cell-engineering system", description: "Virus-free cell-engineering system is a function that enables genetic modification of cells without using viral vectors."},
  {name: "Virus-host genome integration", description: "Integration of viral DNA into the host genome."},
  {name: "Viviparous reproduction", description: "A reproductive system where embryos develop inside the mother's body."},
  {name: "VNTR expansion/contraction", description: "A microhomology-driven mechanism mediates changes in the VNTR domain length at the DNA level."},
  {name: "volumetric transport", description: "Volumetric transport is the cellular transport of volume, such as salt and water."},
  {name: "Warburg effect", description: "The Warburg effect is aerobic glycolysis, a metabolic shift in cancer cells."},
  {name: "Weakened interaction with phospholipid membrane", description: "Weakened interaction with phospholipid membranes is a functional impairment in binding to lipid surfaces."},
  {name: "Whole genome amplification", description: "Whole genome amplification (WGA) is a method to amplify the entire genome from a single cell."},
  {name: "Wnt signaling", description: "A signaling pathway involved in embryonic development and tissue homeostasis."},
  {name: "Wnt/β-catenin signaling", description: "Wnt/β-catenin signaling is a pathway involved in stem cell regulation."},
  {name: "wound healing", description: "Wound healing is the biological process of tissue repair."},
  {name: "X chromosome inactivation", description: "X chromosome inactivation is a process to silence one X chromosome in female cells."},
  {name: "X-inactivation", description: "Process of silencing one X chromosome in females."},
  {name: "X-Y transposition", description: "Transposition of a segment from the X to the Y chromosome."},
  {name: "Xenobiotic metabolism", description: "Xenobiotic metabolism involves the biotransformation of foreign compounds (phases I and II)."},
  {name: "xenotransplantation", description: "Xenotransplantation is the transplantation of cells or tissues from one species to another."},
  {name: "young LINE-1 activation", description: "Activation of young LINE-1 retrotransposons in human preimplantation embryos."},
  {name: "young LINE-1 demethylation", description: "young LINE-1 demethylation is a process involving the loss of 5-methylcytosine methylation on evolutionarily young long interspersed nuclear elements 1, associated with aging and cancer."},
  {name: "Yp inversion", description: "Inversion on the short arm of the Y chromosome."},
  {name: "YY1 binding site", description: "YY1-binding site is a DNA sequence that functions as a component of the LINE-1 core promoter to direct accurate transcription initiation."},
  {name: "Z-RNA formation", description: "Formation of left-handed double-stranded RNA (Z-RNA) conformation."},
  {name: "Zinc transport", description: "Zinc transport is the biological process of moving zinc ions across membranes."},
  {name: "ZNF91 expression reduction", description: "ZNF91 expression reduction is an age-related decrease in ZNF91 levels that correlates with progressive neurodegeneration in XDP."},
  {name: "zygotic genome activation", description: "ZGA is the onset of embryonic gene expression."},
  {name: "β-amyloidosis", description: "Pathological accumulation of β-amyloid protein."},
  {name: "γ-retroviral vector production", description: "γ-retroviral vector production is the manufacturing of viral vectors for gene therapy."}
] AS row
MERGE (n:Function {name: row.name})
SET n.description = row.description, n.source_group = "functions";

