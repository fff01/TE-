  {name: "ESCRT-dependent virus budding", description: "ESCRT-dependent virus budding utilizes the host ESCRT pathway for viral release."},
  {name: "Establish topological domain structure", description: "A role in establishing the topological domain structure of the genome."},
  {name: "establishing expression landscape", description: "Establishing expression landscape refers to setting up the pattern of gene expression in early embryos."},
  {name: "Establishment of chromatin domain", description: "Establishment of chromatin domains involves organizing chromatin into distinct regulatory regions."},
  {name: "Estrogen receptor signaling", description: "Signaling pathway implicated in the sex bias of autism spectrum disorder."},
  {name: "evasion", description: "LINE-1 evaded capture by host defense genes during evolution."},
  {name: "Evolution", description: "A major driving force for evolution, influenced by Alus."},
  {name: "Evolution of functional RNA", description: "The process by which novel functional repeat-derived RNAs evolve from non-coding RNAs via retrotransposition and sequence diversification."},
  {name: "evolution of human-specific L1", description: "The evolutionary process and diversification of LINE-1 elements specific to the human lineage."},
  {name: "Evolution of MHC class I duplicon", description: "The evolutionary process involving tandem duplications that shaped the MHC class I gene region."},
  {name: "evolution of new exon", description: "The process by which new exons, such as those derived from Alus, emerge and become fixed in primate genomes."},
  {name: "evolution of novel regulatory network", description: "Evolution of novel regulatory networks refers to the development of new gene regulatory circuits during evolution."},
  {name: "Evolution of the Alu", description: "The evolutionary process of the Alu transposon family, involving sequence remodeling and stabilization."},
  {name: "Evolution of the genome", description: "Evolution of the genome is the process of genetic change over time."},
