  {name: "Epigenomic dysregulation", description: "Abnormal regulation of gene activity via epigenetic mechanisms."},
  {name: "Epimutagenic event", description: "Heritable changes in gene function not due to changes in DNA sequence, often involving DNA methylation."},
  {name: "Epistatic capture", description: "A mode of molecular evolution where an ancestral TFBS is stabilized and fixed due to epistatic interactions with derived TFBSs."},
  {name: "Epithelial transformation", description: "Process leading to malignant cellular transformation."},
