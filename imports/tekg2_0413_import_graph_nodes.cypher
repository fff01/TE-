  {name: "Tigger3", description: "Tigger3 is a human DNA transposon belonging to the Tigger family, homologous to Drosophila pogo."},
  {name: "Tigger3a", description: "Tigger3a is a human transposon subfamily identified as a regulatory element in pluripotent/stem cells and prostate cancer."},
  {name: "Tip100", description: "hAT-Tip100 is a DNA transposon family."},
  {name: "Transposable element", description: "Transposable elements (TEs) are mobile genetic sequences that constitute a significant portion of the human genome and can contribute to cryptic exon activation in genetic diseases."},
  {name: "Transposon", description: "Transposon systems are non-viral gene delivery tools that enable stable genomic integration of therapeutic genes."},
  {name: "U6-LINE-1 chimeric retrotransposon", description: "U6-LINE-1 chimeric retrotransposon is a composite retrotransposon formed by fusion of U6 and LINE-1 elements, analogous to MINE in Magnaporthe grisea."},
  {name: "X6A_LINE", description: "X6A_LINE is a human transposon subfamily."}
] AS row
MERGE (n:TE {name: row.name})
SET n.description = row.description, n.source_group = "transposons";

