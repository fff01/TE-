  {name: "response to stress", description: "Response to stress is a biological process activated by cellular or environmental stressors."},
  {name: "response to stress and infection", description: "Response to stress and infection involves cellular defense mechanisms against pathogens and stressors."},
  {name: "restraint", description: "Restraint refers to host mechanisms that limit transposable element activity."},
