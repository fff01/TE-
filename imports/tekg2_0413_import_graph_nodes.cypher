  {name: "Interferon antiviral response", description: "A mechanism for restricting viral infections."},
  {name: "interferon gamma pathway", description: "Interferon gamma pathway is a signaling pathway involved in immune responses."},
  {name: "interferon gamma production", description: "Interferon gamma production is a cytokine response by T cells upon stimulation."},
  {name: "Interferon induction", description: "Process leading to the production of interferons."},
  {name: "Interferon response", description: "An immune response mediated by interferons, often triggered by viral infection or dsRNA."},
  {name: "interferon signaling", description: "Interferon signaling is a genetic pathway related to LINE-1 regulation in cancer."},
  {name: "interferon signaling and response", description: "A biological process involving interferon-mediated cellular signaling and gene activation."},
  {name: "interferon system activation", description: "Interferon system activation is a key antiviral response."},
  {name: "interferon-inducible expression", description: "Gene expression that is upregulated in response to interferon signaling."},
  {name: "interferon-like response", description: "An interferon-like response is an innate immune signaling pathway."},
  {name: "interferon-γ secretion", description: "Interferon-γ secretion is an effector function of T cells."},
  {name: "interindividual genetic variation", description: "Interindividual genetic variation refers to genetic differences between individuals."},
  {name: "internal priming", description: "Internal priming is an alternative retrotransposition mechanism initiating reverse transcription upstream of the poly-A tail."},
  {name: "Internal priming on DNA break", description: "Mechanism for initiating reverse transcription at DNA break sites."},
  {name: "Internal ribosomal entry-site (IRES) activity", description: "IRES activity is a cap-independent translation initiation mechanism."},
  {name: "Internal ribosome entry site (IRES)-mediated translation", description: "Cap-independent translation initiation mechanism via an internal ribosome entry site."},
  {name: "interplasmid transposition", description: "Interplasmid transposition is a method to demonstrate transposon mobility."},
  {name: "interrupted bilirubin uptake", description: "Interrupted bilirubin uptake is a disrupted cellular process in hepatocytes leading to hyperbilirubinemia."},
  {name: "intra-chromosomal translocation", description: "Rearrangements of chromosomal segments within the same chromosome."},
  {name: "intra-element recombination", description: "Recombination within a transposon element."},
  {name: "Intracellular defence against retrotransposition", description: "Host cellular mechanisms that limit the proliferation of retrotransposons."},
  {name: "intracellular defense against retroelement", description: "Cellular mechanisms that restrict the mobility and deleterious effects of retrotransposons."},
  {name: "Intracellular trafficking", description: "Intracellular trafficking is a key role played by Rab proteins."},
  {name: "intrachromosomal recombination", description: "Recombination events occurring within the same chromosome, mediated by distant LINE-1 elements."},
  {name: "intragenomic conflict", description: "Evolutionary battle between selfish DNA and host containment systems."},
  {name: "intrapatient tumor heterogeneity", description: "Variation in tumor characteristics within the same patient, substantially contributed to by LINE-1 retrotransposition."},
  {name: "Intraspecific divergence", description: "The extent of sequence variation among Alus within a species."},
  {name: "intrastrand tetraplex formation", description: "The ability of a G-rich polypurine tract to form one or more intrastrand tetraplex structures."},
  {name: "Intratumor heterogeneity", description: "Presence of distinct cell populations with different genotypes/phenotypes within a tumor."},
  {name: "intratumoral homing", description: "Intratumoral homing is the migration and accumulation of immune cells within a tumor."},
  {name: "intrinsic antiretroviral activity", description: "Intrinsic antiretroviral activity is the cellular defense against retroviruses."},
  {name: "intrinsic antiviral inhibition", description: "Intrinsic antiviral inhibition is a cell-intrinsic mechanism that restricts viral replication."},
  {name: "Intrinsic immunity", description: "Host defense against endogenous retroelements."},
  {name: "Intrinsic promoter activity", description: "Promoter activity exhibited by SVAs."},
  {name: "introducing alternative splice site", description: "Alus can introduce alternative splice sites in genes."},
  {name: "intron evolution", description: "Intron evolution involves changes in intron number and size during eukaryotic genome evolution."},
  {name: "Intron expansion", description: "Intron expansion is the increase in intron size over evolutionary time."},
  {name: "Intron instability", description: "Instability within introns that can lead to structural rearrangements like exon deletion."},
  {name: "Intron mapping", description: "A technique to determine the number, size, and order of introns in a gene."},
  {name: "Intron removal", description: "Intron removal is the process of splicing out introns from pre-mRNA."},
  {name: "Intron retention", description: "Intron retention is a form of alternative splicing where introns are not removed from the mature mRNA."},
  {name: "intronization", description: "Alu insertion into an exon creates a new intron in the 3' UTR."},
  {name: "invasion", description: "Cancer cell spread into surrounding tissues."},
  {name: "invasive activity", description: "Invasive activity refers to the ability of cells to invade surrounding tissues."},
  {name: "Inversion-deletion event", description: "An event resulting in a 5' inverted poly(A) tail in LINE-1 insertions."},
  {name: "inversion-duplication transposition", description: "A DNA rearrangement event involving inversion and duplication of a sequence segment."},
  {name: "IR/DR regulation", description: "IR/DR regulation is a mechanism that controls the assembly and activity of transposons through inverted repeat/direct repeat structures to ensure fidelity."},
  {name: "IRES-mediated translation", description: "Translation initiation via internal ribosome entry sequences, used by the LINE-1 dicistronic mRNA."},
  {name: "IRF transcriptional activity", description: "IRF transcriptional activity is stimulated by innate immune signaling pathways."},
  {name: "IRF3 K48 ubiquitination degradation", description: "Proteasomal degradation of IRF3 via K48-linked polyubiquitination."},
  {name: "IRF3/7 binding", description: "Interferon regulatory factors 3 and 7 bind to DNA to regulate gene expression."},
  {name: "IRGM pseudogenization", description: "IRGM pseudogenization is the evolutionary event where the IRGM gene lost its functional open reading frame due to an Alu retrotransposition."},
  {name: "IRGM resurrection", description: "IRGM resurrection refers to the evolutionary process where the IRGM gene regained its open reading frame and functional expression after pseudogenization."},
  {name: "Isochore maintenance", description: "Isochore maintenance refers to the preservation of large genomic regions with homogeneous GC content."},
  {name: "isogenic control", description: "Creation of genetically matched control cell LINE, such as iPSCs, for comparative studies."},
  {name: "jumping activity", description: "Jumping activity refers to the ability of transposons to mobilize within the genome."},
  {name: "KAP1 binding to ERVL-MaLR", description: "KAP1 binding to ERVL-MaLR is the interaction between the KAP1 protein and the ERVL-MaLR long terminal repeat."},
  {name: "KAP1 knockdown", description: "KAP1 knockdown is an experimental reduction of KAP1 protein levels, inducing expression of certain L1 lineages in human embryonic stem cells."},
  {name: "KAP1 repression of ERV", description: "KAP1 represses ERVes during development and in adult cells."},
  {name: "kDNA integration", description: "Integration of Trypanosoma cruzi kinetoplast DNA into the host genome."},
  {name: "keratinocyte differentiation", description: "Keratinocyte differentiation is the process by which stem cells develop into keratinocytes."},
  {name: "kidney morphogenesis", description: "Regulation of kidney development and structure formation."},
  {name: "kidney regeneration", description: "Kidney regeneration aims to restore kidney function through cellular or tissue repair."},
  {name: "Killing effect", description: "Killing effect is the cytotoxic activity against target cells."},
  {name: "KRASG12D expression", description: "KRASG12D expression is the transcriptional or translational activity of the KRAS gene with a G12D mutation."},
  {name: "L1H promoter activity modulation", description: "Regulation of the transcriptional activity of the L1H promoter."},
  {name: "L1Hs antisense promoter (ASP) activity", description: "Promoter activity in the L1Hs 5'UTR that drives transcription in the opposite direction."},
  {name: "L1Hs ASP-driven transcription", description: "Transcription of adjacent cellular genes initiated from the L1Hs antisense promoter."},
  {name: "L1Hs expression", description: "Expression of the human LINE-1 (L1Hs) element."},
  {name: "L1Hs retrotransposition", description: "The process of human LINE-1 retrotransposon copying and reinsertion into the genome."},
  {name: "L1Hs transcription", description: "Transcription of the human LINE-1 retrotransposon from its 5'UTR promoter."},
  {name: "L1P1 and L1PA1 insertion", description: "L1P1 and L1PA1 insertions are retrotransposons inserted upstream of the OPRM1 gene."},
  {name: "Lack of LINE-1 repression", description: "Lack of LINE-1 repression is a functional state where retrotransposon silencing mechanisms are reduced, potentially contributing to genome instability in cancer."},
  {name: "Laminin binding", description: "The interaction between a protein and laminin in the extracellular matrix."},
  {name: "Large genomic copy number change", description: "Deletions of hundreds of kilobases associated with SVA insertion."},
  {name: "large genomic deletion", description: "New genomic rearrangements, such as large deletions, generated upon LINE-1 insertion."},
  {name: "large intragenic deletion", description: "Large intragenic deletion is a genetic mutation event."},
  {name: "large nuclear aggregate", description: "Large nuclear aggregates are distinctive nuclear structures where SVA RNA concentrates, often ringing nucleoli."},
  {name: "Large-scale duplication", description: "Amplification of large genomic regions."},
  {name: "latency reactivation", description: "Latency reactivation is the process of reawakening dormant viral or cellular elements."},
  {name: "Lateral DNA transfer", description: "Interspecies DNA transfer from parasite to host."},
  {name: "lateral transmission", description: "Lateral transmission refers to the transfer of genetic material, such as retroviruses, between different host species."},
  {name: "lentivirus replication", description: "Lentivirus replication is the process by which lentiviruses, such as HIV, reproduce."},
  {name: "let-7 processing and maturation", description: "Processing and maturation of let-7 miRNA."},
  {name: "leukemia cell mobilization", description: "Leukemia cell mobilization is the movement of leukemia cells into circulation."},
  {name: "Leukemogenesis", description: "The process by which normal hematopoietic cells transform into leukemic cells."},
  {name: "Library screening", description: "Library screening identifies mutations that improve protein properties."},
  {name: "LINE expression", description: "LINE expression can affect protein sequences, splicing patterns and expression of human genes."},
  {name: "LINE insertion dynamic", description: "LINE insertion dynamics are influenced by selection and host demography."},
  {name: "LINE integration", description: "The molecular mechanism of long interspersed element (LINE) integration into the genome."},
  {name: "LINE retrotransposition", description: "The process of LINE element mobilization via reverse transcription and integration."},
  {name: "LINE transposition", description: "LINE transposition is the movement of LINE elements in the genome."},
  {name: "LINE-1 3' end dynamic", description: "The processes affecting the non-templated 3' ends of LINE-1 mRNA, including poly(A) tail length and uridylation."},
  {name: "LINE-1 activation", description: "LINE-1 activation is a functional process involving the reactivation of retrotransposon transcription and mobility, observed in human cancers."},
  {name: "LINE-1 activity", description: "LINE-1 activity refers to the retrotransposition process of L1 elements in the human genome."},
  {name: "LINE-1 activity-dependent lethality", description: "Reduced cell viability dependent on LINE-1 activity."},
  {name: "LINE-1 amplification", description: "The process of LINE-1 retrotransposon copy number increase in a genome."},
  {name: "LINE-1 antisense promoter (ASP) activity", description: "The LINE-1 5' UTR contains antisense promoter activity, generating LINE-1-gene chimeric transcripts."},
  {name: "LINE-1 antisense promoter (ASP) transcription", description: "Transcription from the LINE-1 antisense promoter, producing LINE-1-gene chimeric RNAs."},
  {name: "LINE-1 antisense promoter activation", description: "Mechanism generating LINE-1-gene chimeric transcripts."},
  {name: "LINE-1 antisense promoter activity", description: "Activity of the LINE-1 antisense promoter driving transcription of chimeric transcripts."},
  {name: "LINE-1 ASP activity", description: "LINE-1 antisense promoter (ASP) activity drives the production of LINE-1-gene chimeric RNAs."},
  {name: "LINE-1 association with the nuclear lamina", description: "Anchoring of LINE-1 elements to the nuclear envelope/lamina."},
  {name: "LINE-1 cDNA degradation", description: "LINE-1 cDNA degradation is the breakdown of LINE-1 cDNA."},
  {name: "LINE-1 cDNA resolution", description: "Resolution of LINE-1 retrotransposition intermediates by DNA repair pathways."},
  {name: "LINE-1 chimeric transcript (LCT) expression", description: "Expression of transcripts composed of the LINE-1 5' UTR and adjacent genomic sequence, driven by the LINE-1 antisense promoter."},
  {name: "LINE-1 chimeric transcription", description: "LINE-1 can express chimeric transcripts and create contact domain boundaries in human cells."},
  {name: "LINE-1 chromosome painting", description: "Using fluorescence in-situ hybridization (FISH) to examine the genomic distribution of LINE-1 elements."},
  {name: "LINE-1 copy number variation calculation", description: "Method to calculate copy number variation of L1s with respect to a reference genome."},
  {name: "LINE-1 copy number variation quantification", description: "Method for measuring LINE-1 copy number variation using droplet digital PCR."},
  {name: "LINE-1 de novo retrotransposition", description: "LINE-1 de novo retrotransposition is the process of new LINE-1 insertions into the genome."},
  {name: "LINE-1 demethylation", description: "LINE-1 demethylation is a process that triggers LINE-1 expression leading to genomic instability."},
  {name: "LINE-1 derepression", description: "LINE-1 derepression is the loss of transcriptional or posttranscriptional restriction on LINE-1 activity."},
  {name: "LINE-1 detection", description: "Accurate quantification of LINE-1 copies in biological specimens using pattern matching methodology."},
  {name: "LINE-1 diversification", description: "The emergence of multiple LINE-1 lineages with different 5'UTRs."},
  {name: "LINE-1 DNA:RNA hybrid metabolization", description: "The process of breaking down LINE-1 DNA:RNA hybrids."},
  {name: "LINE-1 down-regulation", description: "LINE-1 down-regulation is a reduction in the expression or activity of LINE-1 retrotransposons, which affects malignant cell growth and epithelial mesenchymal transition."},
  {name: "LINE-1 dysregulation", description: "LINE-1 dysregulation is abnormal control of LINE-1 retrotransposon activity."},
  {name: "LINE-1 element silencing", description: "The process of repressing LINE-1 retrotransposon activity."},
  {name: "LINE-1 element-dependent retrotransposition", description: "Retrotransposition mediated by LINE-1 elements."},
  {name: "LINE-1 endonuclease activity", description: "The nicking activity of the LINE-1 ORF2p on target DNA."},
  {name: "LINE-1 endonuclease cleavage", description: "LINE-1 endonuclease cleavage is a specific DNA cleavage event that creates a nick for retrotransposon insertion."},
  {name: "LINE-1 endonuclease cutting activity", description: "Activity that generates somatic deletions."},
  {name: "LINE-1 endonuclease-dependent integration", description: "Generates short target site duplications (TSDs)."},
  {name: "LINE-1 endonuclease-dependent retrotransposition", description: "Retrotransposition mechanism requiring LINE-1 endonuclease activity."},
  {name: "LINE-1 endonuclease-independent retrotransposition", description: "Retrotransposition mechanism not requiring LINE-1 endonuclease activity."},
  {name: "LINE-1 endonuclease-mediated de novo insertion", description: "Retrotransposon insertion mediated by LINE-1 endonuclease activity."},
  {name: "LINE-1 endonuclease-mediated retrotransposition", description: "The process by which LINE-1 elements mobilize themselves and non-autonomous elements (Alu, SVA) via an endonuclease-dependent mechanism."},
  {name: "LINE-1 epigenetic setting", description: "LINE-1 epigenetic setting is a molecular process fine-tuned in the perinatal brain, representing a sensitive and vulnerable window."},
  {name: "LINE-1 evasion of repression", description: "Mechanism by which LINE-1 escapes epigenetic silencing."},
  {name: "LINE-1 evolution", description: "Evolutionary changes and diversification of LINE-1 elements in the genome."},
  {name: "LINE-1 exon shuffling", description: "LINE-1-mediated exon shuffling events identified in the genome."},
  {name: "LINE-1 expression", description: "LINE-1 expression refers to the transcriptional activity of the LINE-1 retrotransposon, which can be altered in diseases like bladder cancer."},
  {name: "LINE-1 extinction", description: "The loss of active LINE-1 retrotransposon lineages in a species."},
  {name: "LINE-1 fixation", description: "LINE-1 fixation is the process by which LINE-1 insertions become fixed in a population."},
  {name: "LINE-1 hyperactivity", description: "LINE-1 hyperactivity is the increased activity of LINE1 retrotransposons due to p53 loss or binding site removal."},
  {name: "LINE-1 hypomethylation", description: "LINE-1 hypomethylation is the loss of DNA methylation on LINE-1 elements."},
  {name: "LINE-1 inhibition", description: "The suppression of LINE-1 retrotransposition activity."},
  {name: "LINE-1 insert generation", description: "LINE-1 insert generation is the creation of new LINE-1 integrations in the genome."},
  {name: "LINE-1 insertion", description: "Process of LINE-1 retrotransposon integration into the genome."},
  {name: "LINE-1 insertion length", description: "LINE-1 insertion length is a measure of the genomic size of L1 retrotransposon insertions, which correlates with retrotransposition frequency."},
  {name: "LINE-1 insertion polymorphism (LIP)-mediated genomic variation", description: "LINE-1 insertion polymorphism-mediated genomic variation can alter the transcriptome and contribute to the divergence of human phenotypes."},
  {name: "LINE-1 integration", description: "The process of LINE-1 insertion into the host genome during retrotransposition."},
  {name: "LINE-1 life cycle", description: "The stages and processes involved in LINE-1 retrotransposon activity, including nuclear entry and integration."},
  {name: "LINE-1 lifecycle", description: "The process of LINE-1 retrotransposition, including reverse transcription and genomic insertion."},
  {name: "LINE-1 lineage evolution", description: "LINE-1 lineage evolution refers to the dynamics of how active LINE-1 progenitor elements give rise to offspring lineages."},
  {name: "LINE-1 methylation", description: "The degree and pattern of LINE-1 methylation are related to disease risk and prognosis."},
  {name: "LINE-1 methylation heterogeneity", description: "Variation in LINE-1 methylation across cell types, families, and loci."},
  {name: "LINE-1 mobility", description: "The capacity of LINE-1 elements to move within the genome."},
  {name: "LINE-1 mobilization", description: "The process of LINE-1 retrotransposition and insertion into new genomic locations."},
  {name: "LINE-1 mosaicism", description: "Presence of different LINE-1 insertion patterns among cells in an individual."},
  {name: "LINE-1 mutagenesis", description: "Mutagenesis caused by LINE-1 retrotransposition activity."},
  {name: "LINE-1 ORF2p translation", description: "Translation of the LINE-1 ORF2p, which is essential for LINE-1 retrotransposition."},
  {name: "LINE-1 overexpression", description: "LINE-1 overexpression is the increased expression of LINE-1 mobile genetic elements, which can trigger oxidative stress-induced DNA strand breaks."},
  {name: "LINE-1 population dynamic", description: "The changes in the number and activity of LINE-1 elements within the human population over evolutionary time."},
  {name: "LINE-1 promoter block", description: "A strong block of the LINE-1 promoter is triggered by TRIM5α signaling."},
  {name: "LINE-1 promoter demethylation", description: "LINE-1 promoter demethylation is linked to high LINE-1 retrotransposon activity."},
  {name: "LINE-1 promoter DNA methylation", description: "Methylation of the LINE-1 promoter region."},
  {name: "LINE-1 promoter hypomethylation", description: "LINE-1 promoter hypomethylation is a reduction in DNA methylation at LINE-1 promoters, correlating with LINE-1 activity."},
  {name: "LINE-1 promoter methylation", description: "Methylation of the LINE-1 promoter region."},
  {name: "LINE-1 promoter repression", description: "Mediated by DNA methylation."},
  {name: "LINE-1 propagation", description: "Copying and insertion of LINE-1 retrotransposons into DNA."},
  {name: "LINE-1 protein machinery activity", description: "Activity of proteins encoded by autonomous LINE-1 retrotransposons."},
  {name: "LINE-1 reactivation", description: "A novel mechanism of LINE-1 reactivation mediated by failure of corepressor recruitment and loss of epigenetic marks."},
  {name: "LINE-1 reduction", description: "LINE-1 reduction refers to a decrease in the activity or expression of LINE-1 transposons, which is associated with beneficial effects on cardiac regeneration."},
  {name: "LINE-1 regulation", description: "Regulation of LINE-1 activity."},
  {name: "LINE-1 replication", description: "The process by which LINE-1 retrotransposons copy their RNA transcript into genomic DNA."},
  {name: "LINE-1 replication cycle", description: "The replication cycle of the LINE-1 retrotransposon."},
  {name: "LINE-1 repression", description: "A novel mechanism of LINE-1 repression contributes to the maintenance of genome stability."},
  {name: "LINE-1 restriction", description: "Host restriction factors silence LINE-1 expression during early embryogenesis."},
  {name: "LINE-1 retroposition", description: "The mechanism by which LINE-1 elements propagate via reverse transcription and integration."},
  {name: "LINE-1 retrotransposition", description: "LINE-1 retrotransposition is the process of LINE-1 element mobilization."},
  {name: "LINE-1 retrotransposition (LINE-1-RTP)", description: "The process by which competent LINE-1 elements copy and paste themselves into new genomic locations."},
  {name: "LINE-1 retrotransposition assay", description: "A cell culture-based reporter assay to study LINE-1 mobilization."},
  {name: "LINE-1 retrotransposition event", description: "LINE-1 retrotransposition events are processes involving the insertion of LINE-1 retrotransposons into new genomic locations via reverse transcription."},
  {name: "LINE-1 retrotransposition frequency", description: "LINE-1 retrotransposition frequency is the rate at which L1 elements mobilize and insert into the genome, measured using a cell culture assay."},
  {name: "LINE-1 retrotransposition inhibition", description: "LINE-1 retrotransposition inhibition is a cellular function that restricts the mobility of LINE-1 retrotransposons."},
  {name: "LINE-1 retrotransposition suppression", description: "LINE-1 retrotransposition suppression is a biological process that inhibits the mobilization of LINE-1 retrotransposons to preserve genome integrity."},
  {name: "LINE-1 retrotransposition suppression in senescent cell", description: "LINE-1 retrotransposition suppression in senescent cells is a regulatory function mediated by nuclear cGAS to repress retrotransposition in cells induced by DNA damage agents."},
  {name: "LINE-1 retrotransposition-induced mutagenesis", description: "LINE-1 retrotransposition-induced mutagenesis contributes to mutational signature ID2."},
  {name: "LINE-1 retrotransposon activation", description: "LINE-1 retrotransposon activation is the reactivation of LINE-1 expression and retrotransposition."},
  {name: "LINE-1 retrotransposon activity", description: "LINE-1 retrotransposon activity is linked to promoter demethylation and mutagenesis."},
  {name: "LINE-1 reverse transcriptase activity", description: "The enzymatic activity of LINE-1 ORF2p to reverse transcribe LINE-1 RNA into cDNA."},
  {name: "LINE-1 reverse transcription", description: "The reverse transcription process mediated by LINE-1 ORF2p within LINE-1 ribonucleoproteins."},
  {name: "LINE-1 ribonucleoprotein (RNP) complex formation", description: "The assembly of an LINE-1 RNA-protein complex essential for retrotransposition."},
  {name: "LINE-1 ribonucleoprotein complex integrity", description: "LINE-1 ribonucleoprotein complex integrity is important for LINE-1 retrotransposition."},
  {name: "LINE-1 RNA co-expression", description: "LINE-1 RNA co-expression is the simultaneous expression of LINE-1 RNA alongside Alu RNA under stress conditions."},
  {name: "LINE-1 RNA depletion", description: "LINE-1 RNA depletion is an experimental reduction of LINE-1 RNA levels that disrupts chromatin interactions and downregulates associated genes."},
  {name: "LINE-1 RNP assembly", description: "The formation of ribonucleoprotein complexes containing ORF1p, ORF2p, and LINE-1 RNA."},
  {name: "LINE-1 RNP complex assembly", description: "Formation of the LINE-1 ribonucleoprotein complex."},
  {name: "LINE-1 RNP formation", description: "Formation of the LINE-1 ribonucleoprotein complex."},
  {name: "LINE-1 RNP reverse transcription", description: "LINE-1 RNP reverse transcription is a process mediated by ORF2p for LINE-1 retrotransposition."},
  {name: "LINE-1 RNP translocation", description: "Movement of the LINE-1 ribonucleoprotein complex in the host cell."},
  {name: "LINE-1 RT activity", description: "LINE-1 RT activity is the reverse transcriptase function required for LINE-1 retrotransposon insertions."},
  {name: "LINE-1 silencing", description: "Repression of LINE-1 expression through redundant pathways."},
  {name: "LINE-1 splicing", description: "Splicing of LINE-1 mRNA, including intra-5'UTR or 5'UTR/ORF1 splicing."},
  {name: "LINE-1 suppression", description: "Suppression of LINE-1 retrotransposon activity."},
  {name: "LINE-1 transcription", description: "Transcription of the human LINE-1 retrotransposon."},
  {name: "LINE-1 transcription initiation", description: "Accurate initiation of transcription from the LINE-1 promoter."},
  {name: "LINE-1 transcription regulation", description: "Regulation of LINE-1 gene expression, particularly in cancer cells."},
  {name: "LINE-1 transcription repression", description: "Repression of LINE-1 transcription by DNA methylation."},
  {name: "LINE-1 transcriptional activation", description: "LINE-1 transcriptional activation in somatic cells is governed by individual-, locus-, and cell-type-specific determinants."},
  {name: "LINE-1 transcriptional repression", description: "LINE-1 transcriptional repression is observed in EBV-associated gastric cancer compared to EBV-negative gastric cancer."},
  {name: "LINE-1 transposition", description: "LINE-1 transposition is the retrotransposition mechanism of LINE-1 elements."},
  {name: "LINE-1 transposition suppression", description: "The biological process of inhibiting the mobilization of LINE-1 transposable elements."},
  {name: "LINE-1-centric chromatin interaction", description: "LINE-1-centric chromatin interactions are chromatin interactions centered around LINE-1 loci that regulate gene expression in cancer cells."},
  {name: "LINE-1-cGAS-STING signaling", description: "LINE-1-cGAS-STING signaling is a pathway where LINE1 activation triggers cGAS-STING-mediated inflammation, leading to PASMCs senescence."},
  {name: "LINE-1-expressing germ cell", description: "LINE-1-expressing germ cells are a subset of human fetal germ cells that exhibit active expression of the L1 transposon family."},
  {name: "LINE-1-host interaction", description: "Interactions between the LINE-1 transposon and host cellular factors."},
  {name: "LINE-1-induced damage", description: "Damage caused by LINE-1 retrotransposition activity."},
  {name: "LINE-1-induced gamma-H2AX foci", description: "LINE-1-induced gamma-H2AX foci are DNA damage markers formed in response to double-strand breaks caused by L1 retrotransposon expression."},
  {name: "LINE-1-initiated mutagenesis", description: "LINE-1-initiated mutagenesis is a process where LINE-1 retrotransposition causes mutations."},
  {name: "LINE-1-mediated 3' transduction", description: "A mechanism where LINE-1 retrotransposition carries adjacent genomic sequences to a new location."},
  {name: "LINE-1-mediated cell toxicity", description: "LINE-1-mediated cell toxicity is contributed to by nuclear ORF1p driving nuclear envelope alterations."},
  {name: "LINE-1-mediated gene disruption", description: "Molecular mechanisms by which LINE-1 retrotransposition disrupts gene function."},
  {name: "LINE-1-mediated mobilization", description: "LINE-1-mediated mobilization is the process by which LINE-1 elements retrotranspose and contribute to genome evolution."},
  {name: "LINE-1-mediated mutation", description: "Acquisition of new mutations caused by LINE-1 retrotransposition activity."},
  {name: "LINE-1-mediated retrotransposition", description: "Retrotransposition mechanism mediated by the LINE-1 endonuclease."},
  {name: "LINE-1-mediated transduction", description: "Process where LINE-1 retrotransposition carries flanking unique genomic sequence to a new location."},
  {name: "LINE-1-mediated tumorigenesis", description: "Oncogenic processes driven by LINE-1 retrotransposon activity."},
  {name: "LINE-1-ORF1p expression", description: "LINE-1-ORF1p expression is the production of the L1-ORF1 protein, which is widespread in many cancers."},
  {name: "LINE-1-ORF1p-mediated luciferase activity", description: "Luciferase activity driven by the LINE-1-ORF1p protein binding to its target sequence."},
  {name: "LINE-2 retrotransposition", description: "LINE-2 retrotransposition is a specific retrotransposition activity associated with LINE2 elements."},
  {name: "LINE-LINE-mediated NAHR", description: "LINE-LINE-mediated NAHR is a mechanism of nonallelic homologous recombination facilitated by long interspersed element retrotransposons, contributing to structural genomic rearrangements."},
  {name: "LINE-mediated recombination", description: "Recombination mediated by LINE-1 elements in non-homologous regions."},
  {name: "LINE-mediated retrotransposition", description: "Process of generating processed pseudogenes via LINE machinery."},
  {name: "lineage conversion", description: "Lineage conversion is a process where leukemia cells switch from lymphoid to myeloid phenotype."},
  {name: "Lineage-inappropriate activation of oncogene", description: "Activation of oncogenes in cell types where they are not normally expressed."},
  {name: "Lineage-specific change", description: "Genomic changes unique to a specific evolutionary lineage."},
  {name: "lineage-specific craniofacial evolution", description: "Lineage-specific craniofacial evolution refers to the fine-tuning of regulatory networks contributing to species-specific traits."},
  {name: "lineage-specific differentiation", description: "Lineage-specific differentiation is the directed development of stem cells into specific cell types."},
