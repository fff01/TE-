  {name: "X-linked dilated cardiomyopathy", description: "XLDCM is a clinical phenotype of dystrophinopathy with preferential myocardial involvement.", disease_class: ""},
  {name: "X-linked dominant chondrodysplasia punctata", description: "X-linked dominant chondrodysplasia punctata (CDPX2) is a rare congenital disorder.", disease_class: ""},
  {name: "X-linked Dystonia-Parkinsonism", description: "XDP is a neurodegenerative disorder characterized by dystonia followed by parkinsonism.", disease_class: ""},
  {name: "X-linked Kallmann syndrome", description: "X-linked Kallmann syndrome is a genetic disorder characterized by hypogonadotropic hypogonadism and anosmia.", disease_class: ""},
  {name: "X-linked retinitis pigmentosa", description: "X-linked retinitis pigmentosa (XLRP) is a progressive retinal degeneration.", disease_class: ""},
  {name: "XDP molecular phenotype", description: "XDP molecular phenotype is the dysregulated transcriptional state caused by the SVA retrotransposon in the TAF1 gene in X-linked dystonia-parkinsonism.", disease_class: ""},
  {name: "xeroderma pigmentosum", description: "Xeroderma pigmentosum is a DNA repair-deficiency disorder.", disease_class: ""},
  {name: "Yolk sac tumor", description: "A type of germ cell tumor with yolk sac tumor cells.", disease_class: ""},
  {name: "α1-antitrypsin deficiency", description: "α1-antitrypsin deficiency is a genetic disorder caused by mutations in the SERPINA1 gene.", disease_class: ""},
  {name: "β-thalassemia", description: "β-thalassemia is a common genetic disease caused by mutations in the HBB gene.", disease_class: ""}
] AS row
MERGE (n:Disease {name: row.name})
SET n.description = row.description, n.source_group = "diseases", n.disease_class = row.disease_class;

