SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

// Import Gene -> Peptide relations
UNWIND [
  {source: "CGβ", predicate: "encode", target: "novel short peptide from Type II CGβ", pmids: ["22545241"], description: "The Type II CGβ gene can generate a novel short peptide."},
  {source: "NRSF", predicate: "bind", target: "PHxxYSPDLAPxD peptide", pmids: ["26939020"], description: "An NRSF binding site overlaps a motif coding for the conserved PHxxYSPDLAPxD peptide in mariner transposases."}
] AS row
MATCH (s:Gene {name: row.source})
MATCH (t:Peptide {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

// Import Gene -> Pharmaceutical relations
UNWIND [
  {source: "CAR transgene", predicate: "express", target: "CAR-T cell", pmids: ["31814915"], description: "CAR transgene is expressed in engineered T cells."}
] AS row
MATCH (s:Gene {name: row.source})
MATCH (t:Pharmaceutical {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

