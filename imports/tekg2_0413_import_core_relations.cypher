  {source: "ORF2p cysteine-rich domain mutation", predicate: "affect", target: "LINE-1 RNP assembly", pmids: ["20949108"], description: "Mutations in the cysteine-rich domain of ORF2p reduce levels of ORF1p and/or ORF2p in LINE-1 RNPs."},
