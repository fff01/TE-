  {source: "LTR", predicate: "associate with", target: "LINE", pmids: ["29914366"], description: "Both LTRs and LINE are overrepresented in regions marked by H3K9me3."},
  {source: "MIR", predicate: "cooccur with", target: "Alu", pmids: ["19324900"], description: "MIR and Alu exons are compared in terms of splicing activity."},
  {source: "MIR", predicate: "cooccur with", target: "LINE-1", pmids: ["19324900"], description: "MIR and LINE-1 are both groups of old transposable elements."},
  {source: "MIR", predicate: "interact with", target: "LINE-2", pmids: ["30455182"], description: "MIR and LINE-2 elements co-evolved and interact in shaping regulatory networks."},
  {source: "MIR", predicate: "regulate", target: "LINE-2", pmids: ["30455182"], description: "One MIR repressed the enhancer activity of an LINE-2 element in a pairing."},
  {source: "MLT1A1", predicate: "create", target: "ERVL-MaLR", pmids: ["38131004"], description: "All primate-specific MaLR members descend from the MLT1A1 retrotransposon."},
  {source: "SINE", predicate: "associate with", target: "LINE", pmids: ["41477637"], description: "Ancient SINE and LINE frequencies show a positive correlation."},
  {source: "SVA", predicate: "cooccur with", target: "LINE-1", pmids: ["32676128"], description: "SVA mobilization co-occurs with LINE-1 activity."},
  {source: "THE1", predicate: "insert into", target: "HERV-16", pmids: ["10229571"], description: "THE1 elements inserted into HERV-16 copies."}
] AS row
MATCH (s:TE {name: row.source})
MATCH (t:TE {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';
