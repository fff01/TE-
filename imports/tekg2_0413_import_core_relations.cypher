  {source: "Whole genome amplification", predicate: "associate with", target: "LINE-1", pmids: ["27658049"], description: "A PCR on LINE-1 retrotransposons was performed on DNA after WGA to verify the absence of free-floating DNA."}
] AS row
MATCH (s:Function {name: row.source})
MATCH (t:TE {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

