MATCH (s:Gene {name: row.source})
MATCH (t:Disease {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

