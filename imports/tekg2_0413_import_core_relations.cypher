  {source: "LINE-1 insertion in ATRN", predicate: "participate in", target: "Regulation of cell interaction", pmids: ["10811918"], description: "The insertion provides an evolutionary mechanism for regulating cell interactions during inflammation."},
  {source: "LINE-1 insertion in CC2D2A", predicate: "lead to", target: "frameshift", pmids: ["36970932"], description: "The insertion leads to retention of intronic sequences, causing a frameshift."},
  {source: "LINE-1 insertion in CYBB", predicate: "involve in", target: "Insertional mutagenesis", pmids: ["10980575"], description: "The insertion of the LINE-1 element illustrates a new mechanism by which these elements can modify the transcribed coding sequence of genes."},
  {source: "LINE-1 insertion in CYBB", predicate: "lead to", target: "Abnormal splicing", pmids: ["35997928"], description: "The LINE-1 insertion led to abnormal splicing and pseudoexon insertion."},
  {source: "LINE-1 insertion in CYBB", predicate: "lead to", target: "Alternative splicing", pmids: ["10980575"], description: "The insertion introduced new splice sites, resulting in a highly heterogeneous splicing pattern."},
  {source: "LINE-1 insertion in CYBB", predicate: "lead to", target: "somatic mosaicism", pmids: ["35997928"], description: "Clonal analysis demonstrated that the patient had somatic mosaicism due to the de novo insertion."},
  {source: "LINE-1 insertion in Dystrophin", predicate: "lead to", target: "Exon skipping", pmids: ["8387534"], description: "The insertion resulted in skipping of exon 44 during splicing of the dystrophin transcript."},
  {source: "LINE-1 insertion in IL23R", predicate: "lead to", target: "Alternative splicing", pmids: ["18615094"], description: "The insertion leads to an alternative splicing event, creating a novel exon insertion variant."},
  {source: "LINE-1 insertion in RB1", predicate: "lead to", target: "Aberrant and noncanonical mRNA splicing", pmids: ["26763876"], description: "The insertion caused a highly heterogeneous splicing pattern of RB1 mRNA, including noncanonical acceptor splice sites."},
  {source: "LINE-1 insertion in SLCO1B3", predicate: "lead to", target: "deleterious splicing", pmids: ["25546334"], description: "The intronic LINE-1 insertion induced deleterious splicing of SLCO1B3 pre-mRNA."},
  {source: "LINE-1 insertion in ST18", predicate: "disrupt", target: "Negative feedback loop", pmids: ["23540693", "23665280"], description: "The LINE-1 interrupted a negative feedback loop by blocking ST18 repression of its enhancer."},
  {source: "LINE-1 insertion in STC1", predicate: "lead to", target: "Cis-enhancer supply", pmids: ["29949758"], description: "The intronic LINE-1 insertion supplied a novel cis-enhancer to STC1."},
  {source: "LINE-1 insertion into NACC2", predicate: "affect", target: "HDM2/P53/RB regulatory axi", pmids: ["40707718"], description: "LINE-1 insertion into NACC2 disrupts the HDM2/P53/RB regulatory axis."},
  {source: "LINE-1 insertion into NACC2", predicate: "promote", target: "Lung oncogenic signaling", pmids: ["40707718"], description: "LINE-1 insertion into NACC2 activates lung oncogenic signaling."},
  {source: "LINE-1 methylation", predicate: "participate in", target: "DNA methylation", pmids: ["29393154"], description: "The extent of LINE-1 methylation is regarded as a surrogate marker of global DNA methylation."},
  {source: "LINE-1 mosaicism", predicate: "associate with", target: "hippocampal neuron", pmids: ["25860606"], description: "Pervasive LINE-1 mosaicism occurs at genomic loci expressed in hippocampal neurons."},
  {source: "LINE-1 polymorphism", predicate: "associate with", target: "Disease susceptibility", pmids: ["34304633"], description: "LINE-1 polymorphisms may define inter-individual differences in susceptibility to disease."},
  {source: "LINE-1 retrotransposition", predicate: "lead to", target: "somatic mutation", pmids: ["26901440"], description: "LINE-1 retrotransposition causes somatic mutations."},
  {source: "LINE-1/Alu singleton", predicate: "associate with", target: "Cell cycle alteration", pmids: ["39314493"], description: "Transcriptional analysis highlighted potential cell cycle alterations in a subset of samples harboring LINE-1/Alu singletons."},
  {source: "Loss of DHX9", predicate: "lead to", target: "transcriptional rewiring", pmids: ["28355180"], description: "Loss of DHX9 leads to transcriptional rewiring of susceptible loci."},
  {source: "Loss of DHX9", predicate: "lead to", target: "translational repression", pmids: ["28355180"], description: "Loss of DHX9 leads to translational repression of reporters containing inverted-repeat Alus."},
