  {source: "THE1C", predicate: "express", target: "T3-1 transcript", pmids: ["19669628"], description: "THE1C promoter drives expression of the T3-1 transcript."},
  {source: "Tigger2", predicate: "create", target: "Oct-1Z transcript", pmids: ["34552146"], description: "Tigger2 insertion led to the formation of an additional Z-exon, creating the primate-specific Oct-1Z transcript."},
  {source: "Transposable element", predicate: "express", target: "TE-embedded miRNA", pmids: ["35732404"], description: "TEs are dynamically expressed and give rise to TE-embedded miRNAs."}
] AS row
MATCH (s:TE {name: row.source})
MATCH (t:RNA {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

// Import TE -> Toxin relations
UNWIND [
  {source: "AluYb8", predicate: "associate with", target: "traffic-derived elemental carbon", pmids: ["23855992"], description: "AluYb8 DNA methylation was higher in truck drivers exposed to traffic-derived elemental carbon."},
  {source: "L1PA2", predicate: "associate with", target: "air benzene", pmids: ["23855992"], description: "L1PA2 DNA methylation was lower in gas station attendants exposed to air benzene."},
  {source: "L1PA2", predicate: "associate with", target: "metal-rich particulate matter (PM10)", pmids: ["23855992"], description: "L1PA2 DNA methylation was lower in steel workers exposed to PM10."}
] AS row
MATCH (s:TE {name: row.source})
MATCH (t:Toxin {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

