  {source: "Tctn3 knockout", predicate: "cause", target: "Neural tube defect", pmids: ["29725084"], description: "Loss of Tctn3 causes neural tube defects in mice."},
  {source: "TDRD9 mutation", predicate: "cause", target: "Non-obstructive azoospermia", pmids: ["28536242"], description: "A recessive deleterious mutation in TDRD9 causes non-obstructive azoospermia."},
  {source: "Templated sequence insertion polymorphism (TSIP)", predicate: "associate with", target: "Genetic disease", pmids: ["25745018", "27900318"], description: "TSIPs may be important for the generation of human diversity and genetic diseases."},
  {source: "TREX1 mutation", predicate: "cause", target: "Aicardi-Goutières syndrome", pmids: ["29525183"], description: "Genetic mutations in TREX1 are attributed to AGS."},
  {source: "truncating NEIL1 mutation", predicate: "associate with", target: "primary carcinoma", pmids: ["26095805"], description: "Primary carcinomas containing a truncating NEIL1 mutation show an increased number of somatic mutations."},
  {source: "TTC28-LINE-1 transduction", predicate: "associate with", target: "Endometriosis associated ovarian cancer", pmids: ["29032825"], description: "TTC28-LINE-1 transductions were near ubiquitous across the tumors, suggesting early activation in cancer development."},
  {source: "UXT depletion", predicate: "associate with", target: "Prostate cancer", pmids: ["30774773"], description: "Loss of UXT expression in primary prostate cancer is associated with high Gleason grade and poor relapse-free survival."},
  {source: "UXT depletion", predicate: "increase risk", target: "Prostate cancer", pmids: ["30774773"], description: "Loss of UXT is an early event during prostate cancer progression."},
  {source: "UXT depletion", predicate: "promote", target: "High grade prostatic intraepithelial neoplasia", pmids: ["30774773"], description: "Prostate-specific Uxt KO mice developed PIN by 4-6 months."},
  {source: "XPF deficiency", predicate: "associate with", target: "Genome instability", pmids: ["18396111"], description: "xpf individuals exhibit genetic instability phenotypes."},
  {source: "ZNF91 deletion", predicate: "affect", target: "XDP molecular phenotype", pmids: ["39102544"], description: "Deletion of ZNF91 exacerbates the XDP molecular phenotype."}
] AS row
MATCH (s:Mutation {name: row.source})
MATCH (t:Disease {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

