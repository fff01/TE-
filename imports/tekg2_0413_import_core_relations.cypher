  {source: "SVA", predicate: "express", target: "leptin receptor isoform 219.1", pmids: ["14739249"], description: "The SVA sequence forms the C-terminal coding exon of the human leptin receptor isoform 219.1."},
  {source: "SVA", predicate: "insert into", target: "fukutin", pmids: ["21979053"], description: "SVA is inserted into the 3' UTR of the fukutin gene."},
  {source: "SVA", predicate: "insert into", target: "SRCAP", pmids: ["35768521"], description: "A de novo SVA insertion in exon 13 of the SRCAP gene."},
  {source: "SVA", predicate: "insert into", target: "TAF1", pmids: ["33315879", "35868859", "38042508"], description: "Disease-specific SVA insertion occurs within intron 32 of TAF1."},
  {source: "SVA-D", predicate: "bind", target: "SOX15", pmids: ["32884136"], description: "SVA_D might have binding capacity for the transcription factor SOX15."},
  {source: "SVA-D", predicate: "bind", target: "SOX17", pmids: ["32884136"], description: "SVA_D might have binding capacity for the transcription factor SOX17."},
  {source: "SVA-D", predicate: "insert into", target: "ATP7A", pmids: ["38960580"], description: "An SVA_D retrotransposon inserts deep within an intron of the ATP7A gene."},
  {source: "THE1B", predicate: "interact with", target: "DLX3", pmids: ["30231016"], description: "THE1B interacts with the transcription factor DLX3 at its 5' insertion site."},
  {source: "THE1B", predicate: "regulate", target: "CRH", pmids: ["30231016"], description: "THE1B controls placental expression of CRH."},
  {source: "THE1C", predicate: "associate with", target: "NF-κB", pmids: ["32075553"], description: "THE1C instances harbor binding motifs for the transcription factor NF-κB."},
  {source: "Tigger3", predicate: "associate with", target: "CENP-B", pmids: ["15170229"], description: "The Tigger3 transposase is very similar to the centromere protein CENP-B."},
  {source: "Transposon", predicate: "associate with", target: "RNA binding protein", pmids: ["34390351"], description: "The presence of TE sequences within a transcript correlates with differential association with RBPs."}
] AS row
MATCH (s:TE {name: row.source})
MATCH (t:Protein {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

