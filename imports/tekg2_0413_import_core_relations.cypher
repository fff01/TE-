  {source: "Lead", predicate: "inhibit", target: "LINE-1", pmids: ["20064768"], description: "Patella lead levels were inversely associated with LINE-1 methylation (beta = -0.25; p < 0.01)."},
  {source: "mercury", predicate: "activate", target: "LINE-1", pmids: ["24240092"], description: "Mercury specifically induces LINE-1 activity in a human neuroblastoma cell line."},
  {source: "Methyl tert-butyl ether (MTBE)", predicate: "associate with", target: "Alu", pmids: ["29649143"], description: "A negative association between urinary MTBE and Alu-YD6 methylation was observed."},
  {source: "Methyl tert-butyl ether (MTBE)", predicate: "associate with", target: "LINE-1", pmids: ["29649143"], description: "A negative association between urinary MTBE and LINE-1-Ta methylation was observed."},
  {source: "Nickel chloride", predicate: "associate with", target: "LINE-1", pmids: ["16249005"], description: "Nickel chloride stimulates LINE-1 retrotransposition."},
  {source: "organochloride pesticide", predicate: "activate", target: "L1HS", pmids: ["11971989"], description: "Treatment with organochloride pesticides increased beta-galactosidase activity from L1Hs promoters."},
  {source: "prenatal environmental exposure", predicate: "activate", target: "Transposable element", pmids: ["40326043"], description: "Prenatal environmental exposures may activate TEs."},
  {source: "trans,trans-muconic acid (tt-MA)", predicate: "associate with", target: "LINE-1", pmids: ["29649143"], description: "Increased tt-MA was associated with increased LINE-1 (LINE-1)-5'UTR expression."},
  {source: "UVB", predicate: "induce", target: "LINE-1", pmids: ["38002016"], description: "UVB irradiation induces LINE-1 reactivation."},
  {source: "welding PM2.5", predicate: "associate with", target: "LINE-1", pmids: ["25512264"], description: "PM2.5 was positively associated with LINE-1 DNA methylation levels."}
] AS row
MATCH (s:Toxin {name: row.source})
MATCH (t:TE {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.description = row.description, r.source_group = 'tekg2_core_relation';

