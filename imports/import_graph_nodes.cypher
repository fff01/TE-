  {name: "premature chromatid separation (PCS)/mosaic variegated aneuploidy (MVA) syndrome", description: "A genetic disorder characterized by premature separation of sister chromatids and mosaic aneuploidy, often associated with BUB1B gene mutations.", disease_class: "Developmental anomalies"},
  {name: "primary carcinomas", description: "Primary carcinomas are malignant tumors originating from epithelial cells in various tissues.", disease_class: "Neoplasms"},
  {name: "Primary effusion lymphoma", description: "Primary effusion lymphoma (PEL) is a lymphoma caused by Kaposi's sarcoma-associated herpesvirus (KSHV).", disease_class: "Neoplasms"},
  {name: "Primary immunodeficiency", description: "Primary immunodeficiency refers to a group of disorders where part of the body's immune system is missing or does not function properly.", disease_class: "Diseases of the immune system"},
  {name: "Primary lymphoedema", description: "Primary lymphoedema is a genetic disorder characterized by swelling due to impaired lymphatic system function.", disease_class: "Diseases of the circulatory system"},
  {name: "progressive supranuclear palsy", description: "Progressive supranuclear palsy is a neurodegenerative disease and a type of tauopathy.", disease_class: "Diseases of the nervous system"},
  {name: "prostate cancer", description: "Prostate cancer is a cancer that occurs in the prostate gland.", disease_class: "Neoplasms"},
  {name: "prostate carcinoma", description: "Prostate carcinoma (PCa) is a malignant tumor of the prostate gland.", disease_class: "Neoplasms"},
  {name: "prostate tumor", description: "A type of cancer that forms in the tissues of the prostate gland.", disease_class: "Neoplasms"},
  {name: "Pseudohypoparathyroidism type 1B (PHP1B)", description: "Pseudohypoparathyroidism type 1B is an imprinting disorder characterized by resistance to parathyroid hormone, often associated with loss of methylation at the GNAS locus.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "psychiatric disorders", description: "A broad category of mental health conditions that affect mood, thinking, and behavior.", disease_class: "Mental, behavioural or neurodevelopmental disorders"},
  {name: "psychological disorders", description: "Psychological disorders are mental health conditions characterized by abnormal thoughts, feelings, and behaviors.", disease_class: "Mental, behavioural or neurodevelopmental disorders"},
  {name: "Pure fibrolamellar hepatocellular carcinoma", description: "Pure fibrolamellar hepatocellular carcinoma (FL-HCC) is a subtype of liver cancer that typically occurs in patients aged < 30 years and often presents with lymph node metastasis and extrahepatic recurrences.", disease_class: "Neoplasms"},
  {name: "pyruvate dehydrogenase complex deficiency", description: "Pyruvate dehydrogenase complex (PDHc) deficiency is a genetic disorder affecting energy metabolism.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "Pyruvate kinase deficiency", description: "Pyruvate kinase deficiency (PKD) is the most frequent red blood cell enzyme abnormality of the glycolytic pathway and the most common cause of hereditary nonspherocytic hemolytic anemia.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "radiation-associated tumors", description: "Radiation-associated tumors are neoplasms that develop as a consequence of prior radiation therapy.", disease_class: "Neoplasms"},
  {name: "Rectal cancer", description: "Rectal cancer is a type of cancer that forms in the tissues of the rectum.", disease_class: "Neoplasms"},
  {name: "recurrent pregnancy loss", description: "Recurrent pregnancy loss is the occurrence of two or more consecutive pregnancy losses.", disease_class: "Diseases of the genitourinary system"},
  {name: "Recurrent pregnancy loss (RPL)", description: "Recurrent pregnancy loss (RPL) refers to the experience of multiple consecutive spontaneous abortions.", disease_class: "Diseases of the genitourinary system"},
  {name: "refractory Philadelphia chromosome-positive acute lymphoblastic leukemia", description: "Refractory Philadelphia chromosome-positive acute lymphoblastic leukemia refers to Ph(+)ALL that is resistant to standard treatments, including tyrosine kinase inhibitors.", disease_class: "Neoplasms"},
  {name: "relapsing-remitting multiple sclerosis", description: "Relapsing-remitting multiple sclerosis (RRMS) is a form of multiple sclerosis characterized by clearly defined attacks of new or increasing neurologic symptoms.", disease_class: "Diseases of the nervous system"},
  {name: "renal cancer", description: "Renal cancer is a type of cancer that begins in the kidneys.", disease_class: "Neoplasms"},
  {name: "renal carcinoma", description: "Renal carcinoma (RCC) is a type of kidney cancer that originates in the lining of the proximal convoluted tubule.", disease_class: "Neoplasms"},
  {name: "renal cell carcinoma", description: "Renal cell carcinoma is a type of kidney cancer that originates in the lining of the proximal convoluted tubule.", disease_class: "Neoplasms"},
  {name: "repeat expansion diseases", description: "Repeat expansion diseases are a class of disorders characterized by the instability of causative repeat mutations.", disease_class: "others"},
  {name: "retinal degenerations", description: "A group of eye diseases characterized by the progressive loss of retinal cells.", disease_class: "Diseases of the visual system"},
  {name: "Retinitis pigmentosa", description: "Retinitis pigmentosa is a group of inherited degenerative retinal disorders.", disease_class: "Diseases of the visual system"},
  {name: "retinitis pigmentosa-2", description: "Retinitis pigmentosa-2 is a form of retinitis pigmentosa, a group of inherited retinal degenerative diseases.", disease_class: "Diseases of the visual system"},
  {name: "retinitis punctata albescens", description: "A form of retinitis pigmentosa characterized by white dots in the retina.", disease_class: "Diseases of the visual system"},
  {name: "Retinoblastoma", description: "Retinoblastoma (RB, MIM 180200) is a hereditary cancer of the retina, often caused by mutations in the RB1 gene.", disease_class: "Neoplasms"},
  {name: "Rett syndrome", description: "Rett syndrome is a rare genetic neurological and developmental disorder that affects the way the brain develops.", disease_class: "Diseases of the nervous system"},
  {name: "Rhabdomyolysis", description: "Rhabdomyolysis is a condition involving the breakdown of damaged skeletal muscle, which can lead to complications such as acute kidney injury.", disease_class: "Diseases of the nervous system"},
  {name: "Rheumatoid arthritis", description: "Rheumatoid arthritis is an autoimmune disease characterized by chronic inflammation of the joints.", disease_class: "Diseases of the immune system"},
  {name: "Rotor syndrome", description: "Rotor syndrome is a benign recessive disease characterized by conjugated hyperbilirubinemia, caused by the homozygous inactivation of the SLCO1B1 and SLCO1B3 genes.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "sarcoid myopathy", description: "Sarcoid myopathy is a muscle disease associated with sarcoidosis.", disease_class: "Diseases of the immune system"},
  {name: "sarcoidosis", description: "Sarcoidosis is a systemic inflammatory disease characterized by the formation of non-caseous granulomas.", disease_class: "Diseases of the immune system"},
  {name: "Sarcomatoid renal cell carcinoma", description: "Sarcomatoid renal cell carcinoma is an aggressive histological subtype of RCC characterized by spindle cells and poor prognosis.", disease_class: "Neoplasms"},
  {name: "SARS-CoV-2 infection", description: "Infection caused by the SARS-CoV-2 virus, including Delta and Omicron variants.", disease_class: "Certain infectious or parasitic diseases"},
  {name: "schizophrenia", description: "Schizophrenia is a chronic mental disorder characterized by distortions in thinking, perception, emotions, language, sense of self, and behavior.", disease_class: "Mental, behavioural or neurodevelopmental disorders"},
  {name: "Scrapie", description: "A fatal neurodegenerative disease in sheep and goats, a member of the transmissible spongiform encephalopathies.", disease_class: "Diseases of the nervous system"},
  {name: "secondary malignancies", description: "Secondary malignancies are cancers that develop in patients exposed to genotoxic agents, such as during cancer therapy.", disease_class: "Neoplasms"},
  {name: "senescence-associated diseases", description: "A class of diseases associated with cellular senescence.", disease_class: "others"},
  {name: "Sepsis", description: "Sepsis is a life-threatening condition caused by the body's extreme response to an infection.", disease_class: "Certain infectious or parasitic diseases"},
  {name: "Septic shock", description: "Septic shock is a severe form of sepsis characterized by profound circulatory, cellular, and metabolic abnormalities.", disease_class: "Certain infectious or parasitic diseases"},
  {name: "serous tubal intraepithelial carcinoma (STIC)", description: "Precursor lesions found in the fallopian tubes, often associated with high-grade serous ovarian cancer.", disease_class: "Neoplasms"},
  {name: "sickle cell disease", description: "Sickle cell disease is a genetic blood disorder characterized by abnormal hemoglobin and sickle-shaped red blood cells.", disease_class: "Diseases of the blood or blood-forming organs"},
  {name: "single-gene disease", description: "Monogenic diseases are disorders caused by mutations in a single gene.", disease_class: "others"},
  {name: "skin cancer", description: "Skin cancer is a disease characterized by the uncontrolled growth of abnormal skin cells.", disease_class: "Neoplasms"},
  {name: "skin tumor", description: "Skin tumors induced by 7,12-dimethylbenz[a]anthracene (DMBA) plus 12-O-tetradecanoylphorbol-13-acetate (TPA) in a multistep carcinogenesis model.", disease_class: "Neoplasms"},
  {name: "Small bowel adenocarcinoma", description: "Small bowel adenocarcinoma (SBA) is a type of cancer that can be associated with conditions like Coeliac disease.", disease_class: "Neoplasms"},
  {name: "solid cancers", description: "Solid cancers are a broad category of malignancies characterized by the formation of solid tumors, as opposed to liquid cancers like leukemias.", disease_class: "Neoplasms"},
  {name: "solid tumors", description: "Solid tumors are abnormal masses of tissue that usually do not contain cysts or liquid areas.", disease_class: "Neoplasms"},
  {name: "Spinal muscular atrophy", description: "Spinal muscular atrophy (SMA) is an autosomal recessive motor neuron disease.", disease_class: "Diseases of the nervous system"},
  {name: "Spinocerebellar ataxia type 10", description: "A neurodegenerative disorder caused by ATTCT repeat expansion in the ATXN10 gene.", disease_class: "Diseases of the nervous system"},
  {name: "spinocerebellar ataxia type 12", description: "Spinocerebellar ataxia type 12 (SCA12) is a neurodegenerative disorder caused by an expanded CAG repeat in the PPP2R2B gene.", disease_class: "Diseases of the nervous system"},
  {name: "Spontaneous abortion", description: "Spontaneous abortion refers to the natural loss of a pregnancy before the 20th week of gestation.", disease_class: "Pregnancy, childbirth or the puerperium"},
  {name: "Spontaneous Genetic Disorder", description: "Genetic diseases caused by new mutations that are not inherited from parents.", disease_class: "others"},
  {name: "sporadic diseases", description: "Sporadic diseases are caused by LINE-1 insertion into new genomic loci.", disease_class: "Certain infectious or parasitic diseases"},
  {name: "sporadic genetic diseases", description: "Sporadic genetic diseases are genetic disorders that occur in individuals with no family history of the condition, often due to de novo mutations.", disease_class: "others"},
  {name: "squamous cell carcinoma", description: "Squamous cell carcinoma is a subtype of non-small cell lung cancer.", disease_class: "Neoplasms"},
  {name: "squamous cell lung cancer", description: "Squamous cell lung cancer is a subtype of lung cancer where the association between LINE-1 methylation levels and antitumor therapy effect was more pronounced.", disease_class: "Neoplasms"},
  {name: "stomach cancer", description: "Stomach cancer is a malignant neoplasm originating from the stomach.", disease_class: "Neoplasms"},
  {name: "stomach tumors", description: "Tumors originating in the stomach.", disease_class: "Neoplasms"},
  {name: "Substance abuse disorders", description: "Substance abuse disorders are conditions characterized by the harmful use of substances such as alcohol, drugs, or medications, leading to significant impairment or distress.", disease_class: "Mental, behavioural or neurodevelopmental disorders"},
  {name: "Substance-use disorders", description: "Substance-use disorders are conditions characterized by the harmful use of psychoactive substances such as methamphetamine or cocaine.", disease_class: "Mental, behavioural or neurodevelopmental disorders"},
  {name: "systemic autoimmune disease", description: "Systemic autoimmune diseases are conditions where the immune system mistakenly attacks the body's own tissues.", disease_class: "Diseases of the immune system"},
  {name: "Systemic lupus erythematosus", description: "Systemic lupus erythematosus is a chronic autoimmune disease that can affect various parts of the body.", disease_class: "Diseases of the immune system"},
  {name: "T-cell leukemia", description: "T-cell leukemia is a cancer of the T lymphocytes.", disease_class: "Neoplasms"},
  {name: "tauopathies", description: "Tauopathies are a group of neurodegenerative diseases characterized by the aggregation of tau protein.", disease_class: "Mental, behavioural or neurodevelopmental disorders"},
  {name: "Tauopathy", description: "Tauopathy is a group of neurodegenerative disorders pathologically characterized by deposits of tau protein in the brain.", disease_class: "Mental, behavioural or neurodevelopmental disorders"},
  {name: "Temple syndrome", description: "Temple syndrome is a genomic imprinting disease caused by maternal duplication of human chromosome 14.", disease_class: "Developmental anomalies"},
  {name: "teratoma", description: "Teratoma is a type of tumor that can contain several different types of tissue.", disease_class: "Neoplasms"},
  {name: "testicular germ cell tumors", description: "Testicular germ cell tumors are cancers that develop in the testicles.", disease_class: "Neoplasms"},
  {name: "testicular germ cell tumours", description: "Testicular germ cell tumours (TGCTs) are cancers that develop from germ cells in the testis.", disease_class: "Neoplasms"},
  {name: "thyroid cancer", description: "Thyroid cancer is a cancer that starts in the thyroid gland.", disease_class: "Neoplasms"},
  {name: "tonsillar carcinoma", description: "Tonsillar carcinoma is a type of cancer that originates in the tonsils.", disease_class: "Neoplasms"},
  {name: "transitional cell carcinoma", description: "Transitional cell carcinoma (TCC) is a type of cancer that arises from the transitional epithelium, commonly found in the bladder.", disease_class: "Neoplasms"},
  {name: "Transmissible spongiform encephalopathies", description: "A group of progressive neurodegenerative disorders, including scrapie, attributed to prions.", disease_class: "Certain infectious or parasitic diseases"},
  {name: "Triple-negative breast cancer", description: "Triple-negative breast cancer (TNBC) is an aggressive subtype of breast cancer characterized by the lack of estrogen receptor, progesterone receptor, and HER2 expression.", disease_class: "Neoplasms"},
  {name: "Trisomy", description: "Trisomy is a type of aneuploidy where there are three copies of a particular chromosome instead of the normal two.", disease_class: "Diseases of the skin"},
  {name: "tuberous sclerosis", description: "Tuberous sclerosis is a neurodevelopmental disorder.", disease_class: "Neoplasms"},
  {name: "tumor", description: "Tumor refers to an abnormal mass of tissue resulting from uncontrolled cell growth.", disease_class: "Neoplasms"},
  {name: "tumor diseases", description: "Tumor diseases refer to various types of cancers or neoplasms.", disease_class: "Neoplasms"},
  {name: "tumor progression", description: "Tumor progression refers to the process by which a tumor grows, invades surrounding tissues, and potentially metastasizes.", disease_class: "Neoplasms"},
  {name: "tumorigenesis", description: "Tumorigenesis is the process by which normal cells are transformed into cancer cells.", disease_class: "Neoplasms"},
  {name: "tumors", description: "Tumors are abnormal growths of tissue that can be benign or malignant.", disease_class: "Neoplasms"},
  {name: "Turner syndrome", description: "Turner syndrome is a chromosomal disorder characterized by the partial or complete absence of one X chromosome in females.", disease_class: "Diseases of the skin"},
  {name: "Type 1 diabetes mellitus", description: "Type 1 diabetes mellitus is an autoimmune disorder characterized by the destruction of insulin-producing beta cells in the pancreas.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "type 2 diabetes (T2D)", description: "Type 2 diabetes is a chronic metabolic disorder characterized by insulin resistance and relative insulin deficiency.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "type 2 diabetes mellitus", description: "Type 2 diabetes mellitus (T2DM) is a chronic metabolic disorder characterized by insulin resistance and relative insulin deficiency.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "ulcerative colitis", description: "Ulcerative colitis is an inflammatory bowel disease that causes inflammation and ulcers in the digestive tract.", disease_class: "Diseases of the digestive system"},
  {name: "upper gastrointestinal cancer", description: "Upper gastrointestinal cancer includes esophageal and gastric cancers.", disease_class: "Neoplasms"},
  {name: "Urothelial carcinoma", description: "Urothelial carcinoma is a type of cancer that originates in the urothelial cells lining the urinary tract, including the bladder.", disease_class: "Neoplasms"},
  {name: "Uterine corpus endometrial carcinoma (UCEC)", description: "Uterine Corpus Endometrial Carcinoma.", disease_class: "Neoplasms"},
  {name: "uveal melanoma", description: "Uveal melanoma is a type of cancer that forms in the eye's uvea.", disease_class: "Neoplasms"},
  {name: "various severe diseases", description: "Various severe diseases can be caused by LINE-1 retrotransposition.", disease_class: "others"},
  {name: "Waardenburg syndrome", description: "Waardenburg syndrome is a genetic disorder characterized by sensorineural hearing loss and pigmentary abnormalities, often associated with neural crest cell defects.", disease_class: "Diseases of the skin"},
  {name: "well-differentiated liposarcoma", description: "Well-differentiated liposarcoma is the most common subtype of liposarcoma, a soft tissue sarcoma.", disease_class: "Neoplasms"},
  {name: "Williams syndrome", description: "Williams syndrome is a developmental disorder that affects many parts of the body, characterized by mild to moderate intellectual disability or learning problems.", disease_class: "Developmental anomalies"},
  {name: "Williams-Beuren syndrome", description: "Williams-Beuren syndrome is a developmental disorder caused by a microdeletion on chromosome 7q11.23.", disease_class: "Developmental anomalies"},
  {name: "X-linked agammaglobulinemia", description: "X-linked agammaglobulinemia is an immunodeficiency disorder caused by mutations in the BTK gene.", disease_class: "Diseases of the immune system"},
  {name: "X-linked dilated cardiomyopathy", description: "X-linked dilated cardiomyopathy (XLDCM) is a clinical phenotype of dystrophinopathy characterized by preferential myocardial involvement without overt clinical signs of skeletal myopathy.", disease_class: "Diseases of the circulatory system"},
  {name: "X-linked dystonia parkinsonism", description: "X-linked dystonia-parkinsonism (XDP) is a movement disorder endemic to the Philippines, also known as DYT3.", disease_class: "Diseases of the nervous system"},
  {name: "X-linked dystonia parkinsonism (XDP)", description: "X-linked dystonia-parkinsonism (XDP, DYT3) is a neurodegenerative disorder characterized by the clinical onset with dystonia followed by parkinsonism, endemic in the Philippine island of Panay.", disease_class: "Diseases of the nervous system"},
  {name: "X-linked Kallmann syndrome", description: "X-linked Kallmann syndrome is a genetic disorder characterized by hypogonadotropic hypogonadism and anosmia.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "X-linked retinitis pigmentosa 2", description: "X-linked retinitis pigmentosa 2 is a form of progressive retinal degeneration caused by mutations in the RP2 gene.", disease_class: "Diseases of the visual system"},
  {name: "xeroderma pigmentosum", description: "Xeroderma pigmentosum is a DNA repair-deficiency disorder characterized by extreme sensitivity to ultraviolet light and a high risk of skin cancer.", disease_class: "Neoplasms"},
  {name: "yolk sac tumor", description: "Yolk sac tumor is a type of malignant germ cell tumor.", disease_class: "Neoplasms"},
  {name: "α-1 antitrypsin deficiency", description: "α-1 antitrypsin deficiency is a genetic disorder caused by mutations in the SERPINA1 gene.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "α1-antitrypsin deficiency", description: "α1-antitrypsin deficiency is a genetic disorder caused by mutations in the SERPINA1 gene, leading to lung and liver disease.", disease_class: "Endocrine, nutritional or metabolic diseases"},
  {name: "β-thalassemia", description: "β-thalassemia is one of the most common genetic diseases worldwide, caused by mutations in the human hemoglobin beta (HBB) gene.", disease_class: "Diseases of the blood or blood-forming organs"}
] AS row
MERGE (n:Disease {name: row.name})
SET n.description = row.description, n.source_group = "diseases", n.disease_class = row.disease_class;

// Import functions
UNWIND [
  {name: "3' end processing", description: "3' end processing refers to the molecular mechanism that determines the termination point of LINE-1 retrotransposition, which can involve bypassing the primary polyadenylation signal."},
  {name: "3' flanking sequence mobilization", description: "The process by which retrotransposition-competent L1s can mobilize and retrotranspose non-L1 sequences located downstream (3') of their own genomic location to new genomic sites."},
  {name: "3' poly(A) tract requirement", description: "The presence of a 3' polyadenosine tract is critical for the retrotransposition of LINE-1 and its trans-mobilized targets."},
  {name: "3' transduction", description: "A process mediated by the L1 machinery where neighboring, nonrepetitive sequences are mobilized along with the L1 element."},
  {name: "3' UTR stem-loop structure", description: "A conserved RNA secondary structure at the 3' untranslated region (UTR) of L1 and Alu elements, hypothesized to be recognized by the LINE-1 reverse transcriptase."},
  {name: "3' UTR-mediated posttranscriptional gene regulation", description: "Posttranscriptional control of mRNA subcellular localization, stability, and translation mediated via recognition of a given mRNA transcript's 3' untranslated region (UTR) by microRNAs and RNA-binding proteins."},
  {name: "3'-end stem-loop formation", description: "3'-end stem-loop formation refers to the folding of the 3' end of an RNA or DNA molecule into a secondary structure consisting of a base-paired stem and a single-stranded loop."},
  {name: "3D chromatin architecture", description: "3D chromatin architecture refers to the three-dimensional organization of chromatin within the nucleus."},
  {name: "3D chromatin structure formation", description: "3D chromatin structure formation refers to the spatial organization of chromatin within the nucleus, which influences gene regulation."},
  {name: "3D genome architecture influence", description: "The process by which transposons affect the three-dimensional spatial organization of the genome within the nucleus."},
  {name: "3D genome reorganization", description: "3D genome reorganization refers to changes in the three-dimensional architecture of chromatin, including enhancer-promoter loops and topologically associating domain (TAD) boundaries."},
  {name: "3D nuclear organization", description: "3D nuclear organization refers to the spatial arrangement of chromatin and nuclear compartments within the nucleus."},
  {name: "5' and 3' transduction", description: "5' and 3' transductions refer to the non-L1 genomic sequences flanking an L1 insertion, which are co-mobilized during retrotransposition."},
  {name: "5' end microhomology", description: "5' end microhomology refers to short stretches of sequence identity between the 5' end of a new L1 integrant and the target DNA sequence."},
  {name: "5' flanking sequence transduction", description: "5' flanking sequence transduction is a process where SVA elements acquire and transduce 5' promoter sequences from external cellular promoters."},
  {name: "5' integration", description: "5' integration refers to the molecular mechanism by which the 5' end of a LINE element is integrated into the host chromosome during retrotransposition."},
  {name: "5' inversion", description: "A genomic rearrangement where the 5' segment of a retrotransposed element is inverted relative to the 3' segment, resulting in a head-to-head orientation."},
  {name: "5' junction formation", description: "5' junction formation refers to the mechanism for joining the retrotransposon to the target site at the 5' end during retrotransposition."},
  {name: "5' transduction", description: "5'-transduction is a mechanism where a retrotransposon captures and mobilizes upstream genomic sequences during its insertion."},
  {name: "5' truncation", description: "5' truncation is a common outcome of LINE-1 retrotransposition, often generating elements with truncated 5' ends flanked by target site duplications (TSDs)."},
  {name: "5'-end attachment", description: "The process of linking the 5'-end of a nascent retrotransposon copy to its genomic target site."},
  {name: "5'-end joining", description: "The molecular mechanism responsible for generating the 5' junctions of LINE inserts."},
  {name: "5'-end-joining pathway", description: "The 5'-end-joining pathway is a molecular mechanism involved in the integration of LINE elements into host chromosomal DNA."},
  {name: "5'-inverted insertion", description: "A type of retrotransposed insertion structure characterized by an inverted 5' end."},
  {name: "5'-truncated insertion", description: "5'-truncated insertion is a type of de novo LINE-1 insertion where the 5' end of the element is missing."},
  {name: "5-methylcytosine-associated mutations (MAM)", description: "Mutations, specifically C to T transitions, that are potentially associated with the deamination of 5-methylcytosine."},
  {name: "A-tail expansion", description: "The lengthening of the poly(A) tail of a retrotransposon, which in Alu elements occurs during insertion due to slippage by the L1 ORF2 protein."},
  {name: "A-to-I RNA editing", description: "Adenosine-to-inosine editing of RNA, which can affect RNA structure and stability."},
  {name: "aberrant activation", description: "Aberrant activation refers to the abnormal or dysregulated expression or activity of a gene or element, such as HERVs."},
  {name: "aberrant activity", description: "Aberrant activity refers to abnormal or dysregulated biological function, such as uncontrolled transposition."},
  {name: "aberrant DNA methylation", description: "Aberrant DNA methylation refers to abnormal patterns of DNA methylation, such as the hypomethylation of retrotransposons, which occurs during malignant cell transformation."},
  {name: "Aberrant epigenetic changes", description: "Aberrant epigenetic changes refer to abnormal patterns of DNA methylation, histone modification, or chromatin structure that disrupt normal gene regulation."},
  {name: "aberrant expression", description: "Aberrant expression refers to abnormal levels of gene or transposon expression, which can be either overexpression or underexpression compared to normal conditions."},
  {name: "Aberrant gene expression", description: "Aberrant gene expression refers to abnormal levels or patterns of gene transcription."},
  {name: "aberrant gene regulation", description: "Aberrant gene regulation refers to the disruption of normal gene expression patterns."},
  {name: "aberrant immune responses", description: "Aberrant immune responses are inappropriate or chronic immune system reactions."},
  {name: "Aberrant mRNA splicing", description: "Aberrant mRNA splicing refers to the production of abnormal mRNA transcripts due to disruptions in the normal splicing process."},
  {name: "aberrant oncogene activation", description: "Aberrant oncogene activation is the inappropriate or dysregulated transcriptional activation of genes that can promote cancer development."},
  {name: "Aberrant proliferation", description: "Aberrant proliferation refers to abnormal and uncontrolled cell division."},
  {name: "aberrant reactivation", description: "Aberrant reactivation refers to the inappropriate re-expression of normally silenced genetic elements."},
  {name: "Aberrant recombination", description: "Aberrant recombination refers to abnormal genetic recombination events, which can be facilitated by elements like LINE-1."},
  {name: "aberrant regulation", description: "Aberrant regulation of transposable elements can result in deleterious effects."},
  {name: "Aberrant RNA splicing", description: "Aberrant RNA splicing is a process where errors in pre-mRNA splicing lead to the production of abnormal mRNA isoforms."},
  {name: "aberrant splice-site activation", description: "Aberrant splice-site activation is the process where a cryptic or non-canonical splice site is used, often due to mutations, leading to altered mRNA splicing."},
  {name: "Aberrant splicing", description: "Aberrant splicing refers to the formation of non-canonical RNA transcripts due to the use of alternative splice or polyadenylation signals."},
  {name: "aberrant THE1B fusion transcript expression", description: "Aberrant THE1B fusion transcript expression refers to the elevated or dysregulated expression of THE1B-containing fusion transcripts in disease states."},
  {name: "Aberrant transcription", description: "Aberrant transcription refers to abnormal gene expression patterns, such as decreased expression of specific isoforms."},
  {name: "Aberrant transcription start site (TSS) usage", description: "Initiation of transcription from non-canonical or alternative start sites."},
  {name: "Aberrant upregulation", description: "Aberrant upregulation refers to an abnormal increase in the expression level of a gene or genomic element."},
  {name: "abnormal DNA rearrangement", description: "Abnormal DNA rearrangement refers to genomic alterations such as deletions, insertions, or translocations that deviate from the normal structure."},
  {name: "abnormal gene expression", description: "Abnormal gene expression refers to the dysregulation of gene transcription levels."},
  {name: "Abnormal overexpression", description: "Abnormal overexpression refers to the significantly increased expression level of a gene or element compared to normal conditions."},
  {name: "abnormal programming", description: "Abnormal programming refers to the incorrect establishment or alteration of epigenetic or other regulatory patterns during development."},
  {name: "Abnormal splicing", description: "Abnormal splicing is a disruption of the normal RNA splicing process, often leading to aberrant transcripts."},
  {name: "abscopal effect", description: "The abscopal effect is a phenomenon where localized radiotherapy induces systemic anti-tumor effects at distant, non-irradiated sites."},
  {name: "Accumulation", description: "Accumulation refers to the process of gathering or increasing in number over time."},
  {name: "Accumulation of heritable L1 insertions", description: "The accumulation of heritable L1 insertions refers to the build-up of LINE-1 insertions that are passed on to offspring."},
  {name: "Accumulation of somatic insertions", description: "Accumulation of somatic insertions refers to the time-dependent increase in the number of new transposon insertions within the genomes of somatic cells."},
  {name: "accumulation on the X chromosome", description: "The process by which transposable elements, such as LINE-1, become enriched on the X chromosome."},
  {name: "Acquired chromosomal aberrations", description: "Acquired chromosomal aberrations are structural or numerical changes in chromosomes that occur somatically, not inherited through the germline."},
  {name: "Acquisition of erythroid dominant expression", description: "Acquisition of erythroid dominant expression refers to the evolutionary gain of tissue-specific (erythroid) gene expression patterns, potentially mediated by regulatory element insertion."},
  {name: "activating oncogenic transcriptional factors", description: "Activating oncogenic transcriptional factors is a process that increases the activity of transcription factors that promote cancer development."},
  {name: "Activating p120-ctn/Rac1/Cdc42 axis", description: "Triggering the activation of the Rho GTPase signaling pathway downstream of p120-catenin, involving Rac1 and Cdc42."},
  {name: "Activation", description: "The process of becoming active or expressed, as observed for transposable elements in the blood of C9orf72 expansion carriers."},
  {name: "activation mutagenesis screen", description: "Activation mutagenesis screen is a forward genetic approach using transposons to randomly activate gene expression and identify genes conferring specific phenotypes, such as drug resistance."},
  {name: "activation of cGAS-STING pathway", description: "The process of triggering the cyclic GMP-AMP synthase (cGAS)-stimulator of interferon genes (STING) innate immune signaling pathway."},
  {name: "activation of dormant repeat elements", description: "Activation of dormant repeat elements refers to the undesirable reactivation of transposable elements due to loss of epigenetic silencing."},
  {name: "Activation of gene expression", description: "The process of increasing the transcription of cellular genes."},
  {name: "activation of L1s", description: "Activation of L1s refers to the process by which LINE-1 retrotransposons become transcriptionally and transpositionally active, often due to epigenetic changes like hypomethylation."},
  {name: "activation of MDA5", description: "The process by which the innate immune receptor MDA5 is activated, typically by binding to double-stranded RNA."},
  {name: "Activation of mobile elements", description: "Activation of mobile elements refers to the process by which transposons become transcriptionally and/or transpositionally active in somatic cells."},
  {name: "Activation of p120-ctn/Rac1/Cdc42 axis", description: "LncMER52A triggers the activation of Rho GTPase downstream of p120-catenin, specifically the p120-ctn/Rac1/Cdc42 axis."},
  {name: "activation of pluripotency genes", description: "Activation of pluripotency genes refers to the process of turning on genes that are essential for maintaining the pluripotent state of stem cells."},
  {name: "Activation of proinflammatory transposable elements", description: "The process by which transposable elements are activated and contribute to an inflammatory state."},
  {name: "Activation of the cGAS-STING cascade", description: "Activation of the cGAS-STING cascade is an innate immune response pathway triggered by cytoplasmic nucleic acids, such as those from transposable elements."},
  {name: "Activation of the host genome", description: "The process of initiating transcriptional activity in the host genome during developmental stages like totipotency."},
  {name: "activation of the innate immune system", description: "Activation of the innate immune system is a cellular response that can be triggered by transposable element activity."},
  {name: "activation of tumor-suppressive mechanisms", description: "The initiation of cellular processes, such as p53 and interferon responses, that inhibit tumor development."},
  {name: "Activation of young LINE-1", description: "The process by which young LINE-1 elements become transcriptionally active and potentially mobile."},
  {name: "Active L1 unit", description: "The 'active L1 unit' refers to the actively transposable form of the LINE-1 element, which may retain features enabling recent transposition."},
  {name: "Active LINE-1 expression", description: "Active LINE-1 expression refers to transcription initiated from the internal promoter of a LINE-1 element."},
  {name: "active retrotransposition", description: "Active retrotransposition refers to the ongoing process of LINE-1 elements copying and inserting themselves into new genomic locations."},
  {name: "Active reverse transcriptase activity", description: "Active reverse transcriptase activity refers to the enzymatic function that synthesizes DNA from an RNA template, essential for retrotransposition."},
  {name: "Adaptive evolution", description: "Adaptive evolution is the process by which organisms become better suited to their environment through genetic changes."},
  {name: "ADAR1 editing", description: "ADAR1 editing refers to the adenosine-to-inosine RNA editing activity performed by ADAR1, which can alter RNA structure and sequence."},
  {name: "adenosinergic immunometabolic suppression", description: "Adenosinergic immunometabolic suppression refers to the immunosuppressive effects mediated by adenosine in the tumor microenvironment."},
  {name: "adjacent genes expression", description: "Adjacent genes expression refers to the transcriptional activity of genes located near LINE-1 insertion sites."},
  {name: "Adoptive immunotherapy", description: "Adoptive immunotherapy is a treatment that uses a patient's own immune cells, such as T cells, to fight disease."},
  {name: "adoptive NK cell immunotherapy", description: "Adoptive NK cell immunotherapy involves the transfer of engineered or activated natural killer cells to a patient to treat diseases such as cancer."},
  {name: "Affect gene expression", description: "LINE elements can modulate the transcription levels of human genes."},
  {name: "affect gene transcription", description: "Affect gene transcription refers to the process by which transposable elements can influence the expression of genes."},
  {name: "Affect neighboring gene expression", description: "The process by which the activity of a genetic element influences the expression levels of genes located in its genomic vicinity."},
  {name: "Affect protein sequences", description: "LINE elements can alter the amino acid sequence of proteins."},
  {name: "affect somatic genome structure and function", description: "The process by which LINE-1 activity influences the architecture and operation of somatic cell genomes."},
  {name: "Affect splicing patterns", description: "LINE elements can influence the alternative splicing of gene transcripts."},
  {name: "affecting gene expression or regulation", description: "This refers to the process by which the insertion of a transposon can alter the normal expression patterns or regulatory mechanisms of nearby genes."},
  {name: "Affecting gene regulation", description: "Influencing the control of when, where, and how much a gene is expressed."},
  {name: "Age estimation of retrotransposon subfamilies", description: "Age estimation of retrotransposon subfamilies is a method to determine the time since a retrotransposon subfamily began proliferating in a genome."},
  {name: "Aging", description: "Aging is the progressive decline in physiological function associated with the passage of time."},
  {name: "aging-associated myeloid-biased hematopoiesis", description: "A shift in blood cell production towards the myeloid lineage that occurs with aging."},
  {name: "AGO2-mediated repression", description: "Gene repression mediated by Argonaute 2 (AGO2) targeting intronic L1 pre-mRNA complexes."},
  {name: "AhR signaling", description: "AhR signaling is a pathway activated by ligands binding to the aryl hydrocarbon receptor, influencing gene expression."},
  {name: "AKT signaling activation", description: "AKT signaling activation is a beneficial pathway for cardiac regeneration."},
  {name: "alter gene expression", description: "Alteration of gene expression refers to changes in the level at which a gene is transcribed."},
  {name: "alteration of epigenetic regulations", description: "Alteration of epigenetic regulations involves changes in heritable gene expression patterns not caused by changes in DNA sequence."},
  {name: "Alteration of expression profile", description: "Alteration of expression profile refers to changes in the pattern, level, or timing of gene expression."},
  {name: "alteration of gene expression", description: "Alteration of gene expression refers to changes in the level or pattern of gene transcription, which can be caused by transposon insertion into regulatory regions."},
  {name: "alteration of genomic landscape", description: "Changes to the structure and organization of the genome, contributed by the mobilization of transposable elements."},
  {name: "Alteration of splicing", description: "Alteration of splicing refers to changes in the process that removes introns and joins exons from pre-mRNA to form mature mRNA."},
  {name: "Alteration of target gene expression", description: "Changes in the expression levels of genes, potentially caused by the insertion or activity of nearby elements like transposons."},
  {name: "Alteration of transcription initiation", description: "Alteration of transcription initiation refers to changes in the process that determines where and when gene transcription begins."},
  {name: "alterations in target gene expression", description: "Alterations in target gene expression refer to changes in the level or pattern of gene expression, potentially caused by retrotransposon insertion."},
  {name: "alterations to normal splicing patterns", description: "A mechanism where SVA insertions disrupt the normal process of RNA splicing."},
  {name: "altered DNA methylation", description: "Altered DNA methylation is a change in the methylation pattern of DNA."},
  {name: "altered expression", description: "Altered expression refers to changes in the normal level of transcription or activity of transposable elements."},
  {name: "Altered gene expression", description: "Altered gene expression refers to changes in the transcription or splicing of a gene, potentially leading to abnormal transcript isoforms."},
  {name: "Altered gene transcription", description: "Altered gene transcription refers to changes in the rate or pattern of gene expression."},
  {name: "altered genetic networks", description: "Altered genetic networks refer to changes in the complex interactions between genes and their products."},
  {name: "Altered retrotransposon expression", description: "Changes in the expression levels of retrotransposons, which may be associated with disease states."},
  {name: "Altered splicing", description: "Altered splicing refers to changes in the RNA splicing patterns, which can be caused by transposon insertions."},
  {name: "altering gene expression", description: "The process by which retrotransposons modify the level or pattern of gene transcription."},
  {name: "alternate transcript activation", description: "Alternate transcript activation refers to the initiation of transcription from an alternative promoter or start site, leading to a different RNA transcript."},
  {name: "Alternative endonuclease activity (alt-EN)", description: "An endonuclease activity associated with the L1 ORF2p protein that is distinct from the canonical endonuclease domain activity and is evolutionarily conserved within the reverse transcriptase fold."},
  {name: "alternative lengthening of telomeres (ALT)", description: "Alternative lengthening of telomeres (ALT) is a telomere maintenance mechanism used by some cancer cells that do not express telomerase."},
  {name: "alternative mRNA transcript formation", description: "Alternative mRNA transcript formation is the generation of different mRNA variants from a single gene."},
  {name: "Alternative promoter", description: "Alternative promoter refers to the use of different transcription start sites for a gene."},
  {name: "alternative promoter activation", description: "Alternative promoter activation refers to the initiation of transcription from a non-canonical promoter site, such as those within transposable elements."},
  {name: "Alternative promoter function", description: "L1 ASP can function as an alternative promoter for host genes, generating chimeric transcripts with coding regions identical to the host gene's ORF."},
  {name: "alternative promoter usage", description: "Alternative promoter usage is a mechanism where different promoters drive the expression of distinct isoforms of the same gene."},
  {name: "alternative promoters identification", description: "The process of identifying different transcription start sites for a single gene, leading to variant transcripts."},
  {name: "alternative protein isoform production", description: "The production of alternative protein isoforms from a single gene, often driven by different promoters, leading to proteins with distinct functions."},
  {name: "Alternative RNA splicing at cryptic splice sites", description: "Alternative RNA splicing at cryptic splice sites is a mechanism involved in SVA-mediated 5' transduction events."},
  {name: "Alternative sense promoter activity", description: "A potential promoter activity within the internal part of the LINE-1 5'-UTR that may drive the synthesis of a 5'-truncated mRNA."},
  {name: "Alternative splicing", description: "Alternative splicing is a process that generates different mRNA isoforms from a single gene, with specific events altered in SETMAR knockout cell lines."},
  {name: "Alternative splicing and polyadenylation", description: "Alternative splicing and polyadenylation is a mechanism that generates multiple RNA transcripts from a single gene locus."},
  {name: "Alternative transcriptional termination", description: "Alternative transcriptional termination refers to the use of different transcription termination sites for a gene."},
  {name: "Alu insertion", description: "Alu insertion is the process by which Alu retrotransposons integrate into new genomic locations, often mediated by the LINE-1 machinery."},
  {name: "Alu insertion polymorphism", description: "Alu insertion polymorphism refers to the presence or absence of an Alu element at a specific genomic locus, representing a form of genetic variation in human populations."},
  {name: "Alu mobilization", description: "Alu mobilization is the process of Alu retrotransposition, which is driven by the LINE-1 ORF2 protein."},
  {name: "Alu recombination-mediated deletion (ARMD)", description: "Alu recombination-mediated deletion is a genomic deletion event caused by recombination between Alu elements."},
  {name: "Alu replication cycle shunt", description: "A proposed alternative pathway for Alu element propagation involving cytoplasmic cDNA synthesis, distinct from canonical retrotransposition."},
  {name: "Alu retrotransposition", description: "Alu retrotransposition is the process by which Alu elements mobilize within the genome via an RNA intermediate."},
  {name: "Alu trans-mobilization", description: "Alu trans-mobilization is the process by which the LINE-1 ORF2 protein machinery mobilizes non-autonomous Alu elements."},
  {name: "Alu transcription", description: "Alu transcription is the process of generating RNA from the Alu promoter."},
  {name: "Alu-Alu recombination", description: "Alu-Alu recombination is a form of unequal homologous recombination between Alu elements that can lead to genomic rearrangements."},
  {name: "Alu-induced mutagenesis", description: "The process of mutation generation caused by the insertion or activity of Alu retrotransposons."},
  {name: "Alu-mediated deletion", description: "Alu-mediated deletion is a genomic deletion event caused by recombination between Alu elements."},
  {name: "Alu-mediated recombination", description: "Alu-mediated recombination is a genomic rearrangement process facilitated by homologous sequences between Alu elements."},
  {name: "Alu/Alu homologous recombination", description: "A recombination event between homologous Alu elements, which can lead to genomic rearrangements."},
  {name: "Amber suppression", description: "Amber suppression is a technique that allows the incorporation of noncanonical amino acids into proteins by reassigning the amber stop codon (UAG) to code for an amino acid."},
  {name: "amino acid substitution", description: "Amino acid substitution refers to changes in the protein sequence of a gene, which can indicate evolutionary selection pressure."},
  {name: "AMPK activation", description: "AMPK activation is the process of activating AMP-activated protein kinase, a master metabolic regulator, often in response to cellular stress."},
  {name: "AMPK signaling", description: "AMPK signaling is a cellular energy-sensing pathway activated by exercise and metabolic stress."},
  {name: "Amplification", description: "Amplification refers to the process of increasing the copy number of a gene or DNA sequence."},
  {name: "Amplification burst", description: "Amplification burst refers to a period of high activity and copy number increase for a transposable element family."},
  {name: "ancestral insertion", description: "Ancestral insertion refers to a transposon insertion event that occurred in a common ancestor of a population and is now fixed or polymorphic in that population."},
  {name: "Ancestral recombination", description: "Ancestral recombination refers to historical recombination events that have shaped the mosaic structure of haplotypes."},
  {name: "anchorage-independent growth", description: "Anchorage-independent growth is the ability of cells to proliferate without being attached to a solid surface, a hallmark of cellular transformation."},
  {name: "Aneuploidy", description: "A condition characterized by an abnormal number of chromosomes in a cell."},
  {name: "aneuploidy generation", description: "Aneuploidy generation is the process leading to an abnormal number of chromosomes in a cell."},
  {name: "angiogenesis", description: "Angiogenesis is the physiological process through which new blood vessels form from pre-existing vessels."},
  {name: "Annealing pathway", description: "The annealing pathway is one of the proposed mechanisms for joining the 5'-end of LINE elements to host chromosomal DNA during retrotransposition."},
  {name: "Antigen-antibody response", description: "An immune response where antibodies bind to specific antigens, here demonstrated using LINE-1 proteins against antibodies in patient serum."},
  {name: "Antiretroelement activity", description: "Antiretroelement activity refers to the ability of host proteins to inhibit the replication or mobilization of retroelements."},
  {name: "antisense promoter (ASP) activity", description: "The antisense promoter activity is a function located in the L1Hs 5' untranslated region that drives transcription in the opposite direction."},
  {name: "antisense promoter (ASP)-driven transcription", description: "The antisense promoter of LINE-1 drives transcription in the opposite direction into adjacent cellular sequences, yielding chimeric transcripts."},
  {name: "antisense promoter (L1-ASP) activity", description: "The antisense promoter (L1-ASP) of LINE-1 elements drives the transcription of chimeric transcripts from the opposite strand."},
  {name: "antisense promoter activity of L1Hs 5'UTR", description: "The promoter activity in the 5' untranslated region (5'UTR) of L1Hs that drives transcription in the antisense direction."},
  {name: "antisense RNA expression", description: "Transcription of RNA from the strand opposite to the sense strand of a gene."},
  {name: "Antisense RNA production", description: "L1 ASP can produce antisense RNAs complementary to host gene mRNAs."},
  {name: "Antisense transcript creation", description: "The process of generating novel antisense transcripts, which can influence the sense partner gene function."},
  {name: "antisense transcription", description: "Antisense transcription refers to the production of RNA from the non-coding strand of a DNA sequence, which may regulate gene expression."},
  {name: "Antiviral immune activation", description: "Antiviral immune activation refers to the host's immune response mechanisms triggered to combat viral infections."},
  {name: "Antiviral immune response", description: "An antiviral immune response can be elicited by endogenous nucleic acid sensing pathways activated by LINE-1."},
  {name: "Antiviral response", description: "The biological process by which the host organism defends against viral infections."},
  {name: "antiviral signaling", description: "Antiviral signaling is the innate immune pathway activated by detection of viral or viral-like nucleic acids, such as dsRNA."},
  {name: "AP-1 binding motif", description: "AP-1 binding motif is a specific DNA sequence recognized and bound by the AP-1 transcription factor complex."},
  {name: "APOBEC3-mediated LINE-1 inhibition", description: "APOBEC3-mediated LINE-1 inhibition refers to the restriction of LINE-1 retrotransposition by members of the APOBEC3 family of cytosine deaminases."},
  {name: "Apoptosis", description: "Apoptosis is a form of programmed cell death."},
  {name: "apoptosis induction", description: "Apoptosis induction refers to the triggering of programmed cell death."},
  {name: "arachidonic acid metabolic pathway activation", description: "Arachidonic acid (AA) metabolic pathway activation involves the upregulation of metabolic processes related to arachidonic acid."},
  {name: "Arginine methylation", description: "Arginine methylation is a post-translational modification where methyl groups are added to arginine residues in proteins."},
  {name: "arms race", description: "The evolutionary conflict between transposons and host defense mechanisms, such as KRAB-zinc finger genes."},
  {name: "Arms race model", description: "An arms race model describes the evolutionary conflict between transposable elements and host defense mechanisms, such as zinc finger genes."},
  {name: "ARNT1-mediated L1 retrotransposition", description: "A cellular machinery involving ARNT1 that mediates LINE-1 retrotransposition."},
  {name: "ASP hypomethylation", description: "A reduction in DNA methylation at the LINE-1 antisense promoter region."},
  {name: "ASP-driven transcription of adjacent genes", description: "The L1Hs antisense promoter drives the transcription of adjacent cellular genes."},
  {name: "Assembly of RNA polymerase II complex", description: "The formation of a multi-protein complex containing RNA polymerase II at a specific genomic locus to initiate transcription."},
  {name: "association with the nuclear lamina", description: "The physical anchoring or localization of genomic regions, such as L1 elements, to the nuclear periphery, a heterochromatic compartment."},
  {name: "Asymmetric non-CG methylation", description: "Asymmetric non-CG methylation refers to the maintenance of cytosine methylation at non-CG sites on one DNA strand but not the complementary strand."},
  {name: "asymmetric segregation of H3K9me3 at replication forks", description: "Preferential transfer of parental H3K9me3 onto the leading strands of replication forks during DNA replication."},
  {name: "ATM-MRN-SMC S phase checkpoint pathway", description: "The ATM-MRN-SMC S phase checkpoint pathway is a specific DNA damage response pathway activated by double-strand breaks during the S phase of the cell cycle."},
  {name: "ATM-signaling pathway activation", description: "Activation of the cellular response pathway mediated by the ataxia-telangiectasia mutated (ATM) kinase, often in response to DNA damage."},
  {name: "Attenuation of anti-tumor immune response", description: "Attenuation of anti-tumor immune response is a process where the suppression of certain repeat elements, like endogenous retrotransposons, weakens the body's immune attack against tumors."},
  {name: "Autoantibody generation", description: "The production of antibodies (IgG, IgA) by the immune system that target self-antigens, such as transposon-encoded proteins."},
  {name: "autonomous L1 transcription", description: "Autonomous L1 transcription is the process by which the L1 element's internal promoter drives its own expression, which is critical for initiating retrotransposition."},
  {name: "autonomous LINE-1 activity", description: "The process by which LINE-1 elements actively retrotranspose within the genome."},
  {name: "autonomous replication", description: "Autonomous replication is the ability of LINE-1 elements to copy and move themselves within the genome."},
  {name: "autonomous retrotransposition", description: "Autonomous retrotransposition is the process by which transposons, such as LINE-1, encode the proteins necessary for their own mobilization within the genome."},
  {name: "autonomous transposition", description: "A small number of LINE-1 copies remain capable of autonomous transposition."},
  {name: "Autophagy", description: "Autophagy is a cellular degradation process that can target cytoplasmic components, including RNP complexes."},
  {name: "Autophagy activation", description: "Autophagy activation is the initiation of the cellular process of degrading and recycling cellular components."},
  {name: "basic biological processes", description: "Basic biological processes are fundamental cellular and molecular activities essential for life."},
  {name: "Bax activation", description: "Bax activation is a pro-apoptotic event involving the conformational change and oligomerization of the Bax protein, leading to mitochondrial outer membrane permeabilization."},
  {name: "Biased genomic distribution", description: "The non-homogeneous distribution of transposable elements, such as Alu elements, across different genomic regions like GC-rich and AT-rich isochores."},
  {name: "Bidirectional promoter activity", description: "A regulatory function where a genomic locus, such as a transposable element, can initiate transcription in both directions."},
  {name: "Bidirectional promoter activity of L1-5'UTR", description: "The 5' untranslated region (5'UTR) of L1 contains both sense and antisense promoters that can drive transcription."},
  {name: "Bidirectional transcription", description: "Transcription that occurs in both directions from a common regulatory region."},
  {name: "Binding to ITRs", description: "Binding to ITRs refers to the specific interaction between a transposase and the inverted terminal repeats (ITRs) of its cognate transposon."},
  {name: "Biological aging", description: "Biological aging refers to the progressive decline in physiological function over time."},
  {name: "biomarker detection", description: "Biomarker detection is the identification of biological molecules that indicate a specific physiological or pathological state."},
  {name: "biomarkers identification", description: "The process of discovering measurable indicators of a biological state or condition, often for disease diagnosis or prognosis."},
  {name: "Biomolecular fluorescence complementation (BiFC)", description: "BiFC is a technique to visualize protein-protein interactions by splitting a fluorescent protein and fusing the fragments to potential interacting partners."},
  {name: "Bipartite exon formation", description: "Bipartite exon formation is the creation of a new exon from sequences derived from two separate introns, often facilitated by genomic rearrangements."},
  {name: "Bipartite regulatory element", description: "A composite regulatory element consisting of a cAMP-inducible retroviral promoter (from the ERVWE1 5' LTR) and a cellular enhancer (the upstream regulatory element, URE)."},
  {name: "bivalent histone mark regulation", description: "The process involving both activating and repressive histone modifications to control gene or element activity."},
  {name: "Brain development", description: "Brain development is the complex process by which the brain forms, grows, and matures, involving neural progenitor proliferation, differentiation, and migration."},
  {name: "Brain evolution", description: "Brain evolution refers to the evolutionary changes and development of the brain structure and function across species."},
  {name: "Brain-specific genetic mosaicism", description: "Brain-specific genetic mosaicism refers to increased genetic variation between neurons in the brain, partly due to somatic retrotransposition."},
  {name: "Brain-specific L1 insertion", description: "Brain-specific L1 insertion refers to the preferential insertion of LINE-1 elements into the genome of brain cells, particularly neurons."},
  {name: "breakage-fusion-bridge cycle", description: "Breakage-fusion-bridge cycle is a mechanism of genomic instability where a broken chromosome end fuses to another, leading to bridge formation and breakage during cell division, causing amplifications or deletions."},
  {name: "broad TE upregulation", description: "Broad TE upregulation refers to a widespread increase in the transcription levels of various transposable elements."},
  {name: "broad-spectrum suppression", description: "Broad-spectrum suppression refers to a mechanism that inhibits a wide range of targets, such as multiple TE families."},
  {name: "C-to-U editing", description: "C-to-U editing is a deamination process converting cytosine to uracil in DNA or RNA, mediated by AID/APOBEC enzymes."},
  {name: "calcium homeostasis dysregulation", description: "Calcium homeostasis dysregulation refers to the impairment of normal calcium ion balance within cells, which is critical for neuronal function and survival."},
  {name: "cAMP-responsive promoter activity", description: "The ability of the core promoter region within the ERVWE1 5' LTR to initiate transcription in response to cyclic AMP signaling."},
  {name: "cancer cell type-specific gene expression", description: "Cancer cell type-specific gene expression refers to the unique pattern of gene activity in particular types of cancer cells."},
  {name: "Cancer gene therapy", description: "Cancer gene therapy involves the introduction of genetic material into cells to treat or prevent cancer."},
  {name: "cancer genome evolution", description: "Cancer genome evolution refers to the dynamic process of genomic changes that occur during tumor development and progression."},
  {name: "cancer genome remodeling", description: "Cancer genome remodeling refers to the extensive structural and sequence alterations that reshape the genome of cancer cells."},
  {name: "Cancer genomic heterogeneity", description: "Cancer genomic heterogeneity refers to the genetic diversity among cancer cells within a tumor, which can drive tumor evolution and therapy resistance."},
  {name: "cancer progression", description: "Cancer progression refers to the advancement and worsening of cancer."},
  {name: "canonical NF-κB signaling activation", description: "Canonical NF-κB signaling activation is a pathway that leads to the expression of pro-inflammatory and anti-apoptotic genes."},
  {name: "Cap-dependent translation initiation", description: "Cap-dependent translation initiation is a mechanism of protein synthesis initiation that requires a 5' cap structure on the mRNA."},
  {name: "CAR-T cell construction", description: "The process of engineering T cells to express chimeric antigen receptors (CARs) for cancer immunotherapy."},
  {name: "CAR-T cell manufacturing", description: "CAR-T cell manufacturing is the process of producing chimeric antigen receptor T cells for therapeutic use."},
  {name: "carcinogenesis", description: "Carcinogenesis is the process by which normal cells are transformed into cancer cells."},
  {name: "Cardiomyocyte migration", description: "The movement of heart muscle cells."},
  {name: "Catalysis by Mg2+ cation", description: "The role of magnesium ions in facilitating the DNA cleavage reaction catalyzed by L1-Endonuclease."},
  {name: "cDNA synthesis", description: "The synthesis of complementary DNA from an RNA template, a key step in LINE-1 retrotransposition mediated by the ORF2p protein."},
  {name: "cDNA synthesis initiation", description: "cDNA synthesis initiation is the beginning of complementary DNA synthesis from an RNA template, as performed by the L1 ORF2p enzyme during retrotransposition."},
  {name: "CEBP binding motif", description: "CEBP binding motif is a specific DNA sequence recognized and bound by the CEBP family of transcription factors."},
  {name: "Cell amplification", description: "Cell amplification refers to the process of generating a large number of cells from a limited starting population."},
  {name: "Cell cycle alterations", description: "Changes in the normal progression of the cell cycle, potentially linked to transposable element activity."},
  {name: "cell cycle arrest", description: "A process where the progression of the cell cycle is halted at a specific checkpoint."},
  {name: "cell cycle exit", description: "Cell cycle exit refers to the process where cells cease proliferation and enter a quiescent or differentiated state."},
  {name: "cell cycle progression", description: "Cell cycle progression is the series of events that take place in a cell leading to its division and duplication."},
  {name: "cell cycle regulation", description: "Cell cycle regulation is the process that controls the progression of a cell through the cell cycle."},
  {name: "Cell death", description: "Cell death is the process by which a cell ceases to function, which can be triggered by various stresses including energy depletion."},
  {name: "cell differentiation", description: "Cell differentiation is the process by which a less specialized cell becomes a more specialized cell type."},
  {name: "Cell engineering", description: "Cell engineering involves the genetic modification of cells to confer new functions or properties."},
  {name: "Cell fate control", description: "The process that determines the developmental pathway and final identity of a cell."},
  {name: "cell growth", description: "Cell growth refers to the increase in cell number or size."},
  {name: "cell growth promotion", description: "Cell growth promotion refers to the process of stimulating or accelerating the proliferation of cells."},
  {name: "cell invasion", description: "Cell invasion is the ability of cells, particularly cancer cells, to migrate and penetrate into surrounding tissues."},
  {name: "cell lineage tracking", description: "Cell lineage tracking is the use of genetic markers, such as somatic mutations, to trace the developmental history and clonal relationships of cells."},
  {name: "Cell migration", description: "Cell migration is the movement of cells, a process critical for cancer invasion and metastasis."},
  {name: "cell proliferation", description: "Cell proliferation is the process of cell growth and division."},
  {name: "Cell reprogramming", description: "Cell reprogramming is the process of converting somatic cells into induced pluripotent stem cells."},
  {name: "Cell senescence", description: "Cell senescence is a state of stable cell cycle arrest that can act as a tumor-protective mechanism."},
  {name: "cell targeting", description: "The process of directing a molecule or particle to a specific cell type."},
  {name: "Cell toxicity", description: "A process that leads to damage or death of cells."},
  {name: "Cell type specific expression", description: "Cell type specific expression refers to the pattern of gene expression that is restricted to particular cell types."},
  {name: "cell type-specific binding", description: "Transcription factor binding events that occur specifically in certain cell types, often associated with a cell type-specific epigenetic landscape."},
  {name: "Cell type-specific transcription termination", description: "Cell type-specific transcription termination refers to termination events that occur selectively in particular cell types."},
  {name: "Cell-cell fusion", description: "Cell-cell fusion is the process by which individual cells merge to form a multinucleated syncytium."},
  {name: "cell-specific gene transfer", description: "The process of transferring genetic information specifically between certain types of cells."},
  {name: "Cell-type-independent expression", description: "Gene or transposon expression that occurs across different cell types without restriction."},
  {name: "Cellular aging", description: "Cellular aging refers to the progressive decline in cellular function and viability over time."},
  {name: "cellular control of LINE-1 replication", description: "Cellular control of LINE-1 replication refers to host mechanisms that suppress LINE-1 retrotransposition."},
  {name: "Cellular damage", description: "Damage to cellular components or functions, which can be associated with retrotransposition."},
  {name: "cellular differentiation", description: "Cellular differentiation is the process by which a less specialized cell becomes a more specialized cell type."},
  {name: "cellular functions", description: "Cellular functions refer to the normal biological processes carried out by cells, which can be disrupted by transposon activity."},
  {name: "cellular identity alteration", description: "A change in the defining characteristics or state of a cell, such as its differentiation status or functional properties."},
  {name: "cellular pathways", description: "Cellular pathways are series of molecular interactions within a cell that lead to a specific product or change in the cell."},
  {name: "Cellular phosphorylation regulatory cascades", description: "Cellular phosphorylation regulatory cascades are pathways that L1 activity is dependent on and integrated with."},
  {name: "Cellular plasticity", description: "Cellular plasticity refers to the ability of a cell to change its phenotype, such as during processes like epithelial-to-mesenchymal transition (EMT)."},
  {name: "cellular proliferation", description: "Cellular proliferation refers to the process of cell growth and division."},
  {name: "Cellular regulation of retrotransposition", description: "The mechanisms by which host cells control or modulate the activity of LINE-1 retrotransposition."},
  {name: "Cellular reprogramming", description: "Cellular reprogramming is the process of converting differentiated cells into induced pluripotent stem cells (iPSCs)."},
  {name: "cellular self-renewal", description: "Cellular self-renewal is the process by which stem cells divide to generate more stem cells."},
  {name: "Cellular senescence", description: "A state of irreversible cell cycle arrest, often associated with aging and tissue dysfunction."},
  {name: "Cellular stress response", description: "Cellular stress response refers to the changes in gene expression patterns when cells are exposed to various stress conditions, such as hypoxia, oxidative stress, or UV stress."},
  {name: "CENP-A binding", description: "CENP-A binding refers to the incorporation of the histone H3 variant CENP-A into chromatin, which is a hallmark of centromeric identity."},
  {name: "Centromere evolution", description: "Centromere evolution refers to the processes that shape the structure and function of centromeric DNA sequences over time."},
  {name: "Centromere function disruption", description: "Centromere function disruption refers to the impairment or loss of the centromere's ability to ensure proper chromosome segregation."},
  {name: "Centromere remodeling", description: "Centromere remodeling refers to structural and functional changes in the centromeric region of a chromosome."},
  {name: "centromere structural function", description: "Centromere structural function refers to the role of centromeres in chromosome segregation and stability during cell division."},
  {name: "Centrosome amplification", description: "Centrosome amplification is the abnormal increase in the number of centrosomes, which can lead to chromosome missegregation and genomic instability."},
  {name: "cerebral organoid development", description: "The growth and maturation of three-dimensional in vitro models that recapitulate aspects of human brain development."},
  {name: "cfDNA loss at genomic loci", description: "Relative loss of cell-free DNA at specific genomic locations with age."},
  {name: "cGAS-STING pathway", description: "A cytosolic DNA sensing pathway that triggers innate immune responses."},
  {name: "cGAS-STING pathway activation", description: "cGAS-STING pathway activation is an innate immune response triggered by cytoplasmic DNA, leading to interferon expression."},
  {name: "change in gene expression", description: "Modulation of the levels at which genes are transcribed, which can be influenced by nearby transposon insertions."},
  {name: "change in genome integrity", description: "Modifications to the stability and fidelity of the genome, potentially caused by transposon activity."},
  {name: "changes in gene expression", description: "Changes in gene expression refer to alterations in the level at which a gene is transcribed and translated into a functional product."},
  {name: "changes in transcription", description: "Changes in transcription refer to significant alterations in gene transcription caused by retroelement insertions."},
  {name: "chaperone function", description: "Chaperone function involves assisting in the proper folding, assembly, or stabilization of other proteins."},
  {name: "characteristic translocation events", description: "Specific chromosomal rearrangements that are associated with secondary malignancies, potentially influenced by the nonrandom distribution of retrotransposable elements."},
  {name: "Chimera formation", description: "Chimera formation refers to the generation of hybrid sequences between transposons and other genomic elements."},
  {name: "Chimeric antigen receptor T cell generation", description: "Chimeric antigen receptor T cell generation is the process of engineering T cells to express a synthetic receptor that targets specific antigens on cancer cells."},
  {name: "Chimeric gene creation", description: "Chimeric gene creation is the formation of a new gene from parts of distinct genes, often through mechanisms like retrotransposition-mediated exon shuffling."},
  {name: "Chimeric gene formation", description: "The creation of hybrid genes, which can result from LINE-1 insertions into gene sequences."},
  {name: "Chimeric insertion formation", description: "The process where LINE-1 forms hybrid insertions with non-coding RNAs and mRNAs."},
  {name: "Chimeric L1 formation", description: "Chimeric L1 formation is a process resulting in a hybrid L1 element containing sequences from both an endogenous L1 and an engineered L1."},
  {name: "Chimeric protein formation", description: "Chimeric protein formation refers to the creation of a novel protein by the fusion of coding sequences from different genes or genetic elements."},
  {name: "Chimeric retrogene formation", description: "Chimeric retrogene formation is the process of creating bipartite elements composed of DNA copies of cellular transcripts fused to each other or to the 3' part of a LINE retrotransposon."},
  {name: "Chimeric retrotranscript formation", description: "Chimeric retrotranscript formation is the process of generating fused DNA copies of different RNAs, including mRNAs, through RNA-RNA recombination during L1 reverse transcription."},
  {name: "Chimeric retrotransposon formation", description: "The process by which a composite retrotransposon is created through the fusion of distinct genetic elements, such as a non-coding RNA and a truncated retrotransposon."},
  {name: "chimeric TE-gene transcript formation", description: "Chimeric TE-gene transcript formation is the process where transposable element sequences become incorporated into gene transcripts."},
  {name: "Chimeric transcript formation", description: "The generation of a hybrid RNA molecule from the fusion of sequences from different genomic loci, such as a transposon and a host gene."},
  {name: "Cholesterol ester accumulation", description: "Cholesterol ester accumulation is the buildup of cholesterol esters within cells."},
  {name: "chromatin accessibility", description: "Chromatin accessibility refers to the degree to which nuclear macromolecules can physically access and bind to chromatinized DNA."},
  {name: "chromatin accessibility alteration", description: "Alteration in chromatin accessibility refers to changes in the compactness of chromatin structure, affecting the ability of transcription factors and other proteins to access DNA."},
  {name: "Chromatin accessibility for LTR expression", description: "Chromatin accessibility is crucial for the expression of LTR-derived transcripts like lncMER52A."},
  {name: "Chromatin accessibility landscape regulation", description: "The process of modulating the openness or compaction of chromatin, which influences gene expression."},
  {name: "chromatin acetylation", description: "Chromatin acetylation is an epigenetic modification that typically relaxes chromatin structure and promotes gene expression."},
  {name: "chromatin architecture opening", description: "Chromatin architecture opening refers to the transition of chromatin from a condensed to a more accessible state."},
  {name: "chromatin architecture regulation", description: "Chromatin architecture regulation involves the organization and modification of chromatin structure, which influences gene expression."},
  {name: "Chromatin binding", description: "Chromatin binding is the process by which proteins specifically associate with chromatin, the complex of DNA and proteins in the nucleus."},
  {name: "Chromatin changes in aging", description: "Global and local chromatin changes associated with human aging."},
  {name: "chromatin compartmentalization", description: "The process of organizing the genome into distinct three-dimensional compartments, such as euchromatin and heterochromatin."},
  {name: "chromatin contact", description: "Chromatin contact refers to the physical proximity between different genomic regions."},
  {name: "chromatin decondensation", description: "Chromatin decondensation refers to the relaxation of chromatin structure, increasing its accessibility."},
  {name: "chromatin environment shaping", description: "Chromatin environment shaping refers to the process of influencing the structure and accessibility of chromatin."},
  {name: "chromatin folding", description: "Chromatin folding is the three-dimensional organization of chromatin within the nucleus."},
  {name: "chromatin landscape remodeling", description: "Chromatin landscape remodeling refers to the extensive reprogramming and reorganization of chromatin structure."},
  {name: "Chromatin looping mediated by homologous Alu elements", description: "Chromatin looping mediated by homologous Alu elements is a process that brings distal DNA regions into close proximity."},
  {name: "chromatin modifications", description: "Chromatin modifications refer to changes in chromatin structure, such as DNA methylation and chromatin accessibility, that regulate gene expression."},
  {name: "chromatin opening", description: "Chromatin opening refers to the process of making genomic regions more accessible for transcription."},
  {name: "chromatin organization", description: "Chromatin organization refers to the structural arrangement of DNA and proteins within the nucleus."},
  {name: "chromatin organization influence", description: "The process by which transposons affect the packaging and arrangement of DNA and histones into chromatin."},
  {name: "chromatin regulation through RNA-scaffold complexes", description: "Chromatin regulation through RNA-scaffold complexes involves transposon-derived RNAs forming complexes with chromatin regulators to modulate chromatin state."},
  {name: "Chromatin remodeling", description: "Chromatin remodeling is the dynamic modification of chromatin architecture to allow access of condensed genomic DNA to the regulatory transcription machinery proteins."},
  {name: "chromatin topology remodeling", description: "Chromatin topology remodeling involves changes in the three-dimensional organization of chromatin, such as loop formation."},
  {name: "Chromatin unfolding", description: "Chromatin unfolding refers to the decompaction or increased accessibility of chromatin structure."},
  {name: "chromatin-associated function of LINE-1 RNAs", description: "A function where LINE-1 RNAs are involved in organizing chromatin architecture."},
  {name: "Chromatinization", description: "The dynamic epigenetic process of DNA being incorporated into nucleosomes, forming chromatin."},
  {name: "chromosomal breaks and rearrangements", description: "Chromosomal breaks and rearrangements are structural changes to chromosomes that can result from recombination events between retrotransposons."},
  {name: "Chromosomal distribution", description: "Chromosomal distribution describes the pattern of how transposon insertions are spread across different chromosomes."},
  {name: "chromosomal instability", description: "Chromosomal instability is a state of increased rate of chromosomal aberrations, including rearrangements and copy number changes."},
  {name: "chromosomal integration site selection", description: "The process of selecting a specific site in the genome for transposon integration."},
  {name: "Chromosomal inversion", description: "Chromosomal inversion is a structural rearrangement where a segment of a chromosome is reversed end to end."},
  {name: "Chromosomal rearrangement", description: "Chromosomal rearrangement is a structural change in chromosomes."},
  {name: "chromosomal rearrangements", description: "Chromosomal rearrangements are structural changes in chromosomes, including deletions, duplications, inversions, and translocations."},
  {name: "chromosomal structure remodeling", description: "Chromosomal structure remodeling refers to the dynamic changes in chromatin architecture and organization."},
  {name: "Chromosomal translocation", description: "Chromosomal translocation is a structural rearrangement where a segment of one chromosome is transferred to another chromosome."},
  {name: "chromosome deletion", description: "Chromosome deletion is a type of mutation where a segment of a chromosome is lost."},
  {name: "Chromosome instability", description: "Chromosome instability refers to a high rate of chromosome missegregation and structural rearrangements, a hallmark of many cancers."},
  {name: "Chromosome rearrangements", description: "Chromosome rearrangements are structural changes in chromosomes, which can be caused by events like recombination between transposons."},
  {name: "Chromosome segregation", description: "Chromosome segregation is the process during cell division where sister chromatids or homologous chromosomes are separated and distributed into daughter cells."},
  {name: "chromosome structure influence", description: "The process by which transposons affect the physical organization and architecture of chromosomes."},
  {name: "chromosome-wide replication timing control", description: "The process that regulates the temporal order of DNA replication across an entire chromosome."},
  {name: "Chromothripsis", description: "A catastrophic cellular event involving massive, clustered genomic rearrangements confined to one or a few chromosomes."},
  {name: "chronic inflammation", description: "Chronic inflammation is a prolonged and dysregulated immune response that can contribute to tissue damage and disease."},
  {name: "Chronic marrow inflammation", description: "Chronic marrow inflammation is a persistent inflammatory state within the bone marrow niche, often driven by immune dysregulation and cytokine secretion."},
  {name: "Circular RNA formation", description: "Circular RNA formation is a process where RNA molecules form covalently closed loops."},
  {name: "circulating DNA methylation analysis", description: "The quantitative measurement of DNA methylation levels in cell-free DNA circulating in the blood."},
  {name: "Cis preference", description: "Cis preference is the concept that the proteins encoded by a particular L1 preferentially act upon their own encoding RNA."},
  {name: "cis retrotransposition", description: "Cis retrotransposition is the process where LINE-1 retrotransposes a copy of its own RNA."},
  {name: "cis-acting transcriptional control", description: "A mechanism of transcriptional regulation where a DNA sequence influences the expression of nearby genes."},
  {name: "cis-activity", description: "cis-activity refers to the autonomous retrotransposition capability of LINE-1 elements."},
  {name: "cis-element spread", description: "The spread of cis-regulatory elements refers to their distribution across the genome through mechanisms such as transposon mobilization."},
  {name: "Cis-enhancer supply", description: "Cis-enhancer supply refers to the provision of a regulatory element that increases gene expression from the same DNA molecule."},
  {name: "Cis-preferential reverse transcription", description: "The process where the LINE-1 reverse transcriptase (ORF2p) preferentially uses its own encoding RNA as a template for reverse transcription."},
  {name: "cis-regulatory activity", description: "The ability of a DNA sequence to regulate the expression of nearby genes."},
  {name: "cis-regulatory element", description: "A cis-regulatory element is a non-coding DNA sequence that regulates the expression of nearby genes."},
  {name: "Cis-regulatory element acquisition", description: "Cis-regulatory element acquisition is the evolutionary process of gaining DNA sequences that regulate nearby gene expression."},
  {name: "cis-regulatory element activity", description: "Cis-regulatory element (CRE) activity refers to the functional state of DNA sequences that regulate the transcription of nearby genes."},
  {name: "cis-regulatory element domestication", description: "The process by which transposable elements are co-opted into functional cis-regulatory elements, such as enhancers."},
  {name: "cis-regulatory element provision", description: "Cis-regulatory element provision is the process by which transposons supply regulatory sequences that control nearby gene expression."},
  {name: "cis-regulatory element transformation", description: "The process by which transposable elements are transformed into cis-regulatory elements such as enhancers or promoters."},
  {name: "cis-regulatory function", description: "The ability of a genomic element to regulate the expression of nearby or distant genes."},
  {name: "cis-regulatory impact", description: "The cis-regulatory impact refers to the ability of a genetic element, such as a transposon, to influence the expression of nearby genes."},
  {name: "cis-regulatory mechanism", description: "A cis-regulatory mechanism involves DNA sequences that regulate the expression of nearby genes."},
  {name: "cis-regulatory remodeling", description: "Cis-regulatory remodeling involves alterations in the regulatory regions of genes that affect their expression."},
  {name: "cis-regulatory role", description: "A cis-regulatory role refers to the function of a DNA sequence in regulating the expression of nearby genes."},
  {name: "Cleavage", description: "Cleavage refers to the enzymatic cutting of DNA strands, such as at the ends of a transposon during transposition."},
  {name: "Cleavage-stage transcriptional program", description: "Cleavage-stage transcriptional program refers to the specific set of genes and elements activated during the early cleavage stages of embryonic development."},
  {name: "clonal amplification", description: "Clonal amplification refers to the expansion of a cell lineage containing a specific genetic alteration, such as a retrotransposon insertion."},
  {name: "Clonal expansion", description: "Clonal expansion is the process by which a cell with a specific mutation gives rise to a population of identical daughter cells."},
  {name: "clonal fixation", description: "Clonal fixation refers to a somatic mutation becoming present in all cells of a tumor clone."},
  {name: "Cluster-independent piRNA production", description: "A mode of piRNA production that targets young TEs without involving piRNA clusters, present at both prenatal and postnatal stages of spermatogenesis."},
  {name: "Clustered transposon insertion", description: "Clustered transposon insertion is the phenomenon where multiple transposon insertions occur in close genomic proximity."},
  {name: "CNCC specification", description: "Cranial neural crest cell (CNCC) specification is the process critical for vertebrate craniofacial development where cells acquire their specific identity and fate."},
  {name: "Co-evolution", description: "Coevolution refers to the reciprocal evolutionary change between interacting species or genetic elements, such as between LINE-1 and Alu."},
  {name: "co-expression of transposable elements", description: "Co-expression of transposable elements refers to the simultaneous transcription of different transposon families or sub-families within the same cell."},
  {name: "co-expression of TRPV1 and TRPV3", description: "The coordinated expression of the TRPV1 and TRPV3 genes in multiple human tissues."},
  {name: "co-expression with downstream genes", description: "Co-expression with downstream genes refers to the coordinated transcription of a transposable element and neighboring genes."},
  {name: "Co-integration", description: "Co-integration is the process where two or more distinct DNA sequences are integrated together into a new genomic location."},
  {name: "Co-option", description: "Co-option is the evolutionary process by which a transposable element is recruited for a new function, such as gene regulation."},
  {name: "co-option/exaptation", description: "The evolutionary process where a genetic sequence, originally with one function (or no function), is recruited for a new, beneficial function in the host organism."},
  {name: "Co-repression of genes", description: "Co-repression of genes refers to the joint silencing of genes by multiple factors."},
  {name: "Coating the RNA", description: "Coating the RNA is a proposed role for the ORF1 protein (ORF1p) during L1 retrotransposition."},
  {name: "Coclustering", description: "Coclustering refers to the tendency of most Alu elements to be located near each other in the genome."},
  {name: "coding sequence disruption", description: "Coding sequence disruption occurs when a retrotransposon inserts into a gene and interrupts its coding sequence."},
  {name: "Cognitive function", description: "Cognitive function refers to mental processes in the brain, including attention, impulsivity, and working memory."},
  {name: "Coiled-coil domain stability and dynamics", description: "The structural integrity and conformational flexibility of the three-stranded coiled-coil (3SCC) domain in ORF1p."},
  {name: "Colocalization with immune response genes", description: "The genomic positioning of HERV and MaLR loci near genes that are involved and modulated in the immune response."},
  {name: "Colonization of the human genome by mobile genetic elements", description: "The process by which mobile genetic elements, such as retrotransposons, accumulate and occupy a significant portion of the human genome."},
  {name: "Compartmentalization of translation", description: "The spatial organization of protein synthesis, such as translation on free cytoplasmic ribosomes versus membrane-bound ribosomes."},
  {name: "competitive endogenous RNA (ceRNA) activity", description: "Competitive endogenous RNAs (ceRNAs) compete for the binding of the same set of miRNAs targeting protein coding genes, thereby regulating their expression."},
  {name: "Competitive recruitment of transcription factors", description: "A process where a DNA element binds and sequesters transcription factors, affecting their availability at other genomic sites."},
  {name: "Competitive relationships between TEs", description: "Interactions where different transposable elements may compete for host resources or regulatory systems."},
  {name: "Complementation in trans", description: "Complementation in trans is a copying mechanism where elements are copied by other elements of the same family."},
  {name: "Complex assembly", description: "Complex assembly is a divalent metal ion-dependent step involving transposase and the transposon end(s) prior to the first catalytic step."},
  {name: "complex rearrangement", description: "Complex rearrangement refers to a genomic alteration involving multiple breakpoints and/or non-homologous end joining, often leading to deletions or duplications."},
  {name: "complex translocation", description: "Complex translocation involves the exchange of genetic material between two or more chromosomes in a non-reciprocal or intricate manner."},
  {name: "computational analysis of NGS data", description: "Bioinformatic methods used to process and interpret data from next-generation sequencing experiments."},
  {name: "Concerted evolution", description: "Concerted evolution is a process that maintains sequence homogeneity among members of a multigene family, such as the RNU2 locus."},
  {name: "Conditional knockout", description: "Conditional knockout is a method to inactivate a gene in a specific tissue or at a specific time."},
  {name: "Conformational change", description: "A significant conformational change between first- and second-strand cleavage at each transposon end is proposed for mariner excision."},
  {name: "Conservation", description: "The evolutionary process by which a genetic feature is maintained in a population due to selective pressure."},
  {name: "Conserved expression", description: "Conserved expression refers to the pattern of gene or transcript expression that is maintained across different species."},
  {name: "Constitutive splicing", description: "Constitutive splicing refers to exons that are always included in the mature mRNA transcript."},
  {name: "Contact domain boundary formation", description: "The creation of boundaries between topologically associating domains (TADs) in the genome."},
  {name: "containment of regulatory elements", description: "The property of SVA retrotransposons, such as SVA D, to harbor DNA sequences that can regulate reporter gene expression in vitro."},
  {name: "Contribute coding sequences", description: "The process by which retrotransposons provide protein-coding sequences to the genome."},
  {name: "Contribute regulatory sequences", description: "The process by which retrotransposons provide regulatory elements (e.g., promoters, enhancers) to the genome."},
  {name: "Contribute to phenotypic heterogeneity", description: "SINEs can serve as beneficial building blocks that contribute to diversity in observable traits."},
  {name: "contributing to aging", description: "L1's contributions to aging processes is an area of active research."},
  {name: "contributing to aging diseases", description: "L1's contributions to aging diseases is an area of active research."},
  {name: "contributing to genetic innovation", description: "The role of retrotransposons in introducing new genetic material or regulatory sequences that can drive evolutionary change."},
  {name: "Contributing to regulatory elements near quantitative trait loci (QTLs)", description: "The function of being part of genomic elements that regulate gene expression and are located near loci associated with quantitative traits."},
  {name: "control expression of protein-coding genes", description: "Control of expression of protein-coding genes refers to the regulation of transcription levels of genes that encode proteins."},
  {name: "control of stemness", description: "Control of stemness refers to the regulation of properties associated with stem cells, such as self-renewal and pluripotency."},
  {name: "Convergent evolution of gene expression", description: "The independent evolution of similar gene expression patterns in different lineages through distinct molecular mechanisms."},
  {name: "Converging transcription of antisense-oriented genes", description: "A mechanism contributing to the origin of genic postnatal prepachytene piRNA clusters."},
  {name: "coordinated expression with type I IFNs", description: "Coordinated expression with type I IFNs indicates that the expression levels of certain genes or elements change in a correlated manner with type I interferons."},
  {name: "Copper(I) binding", description: "The process by which the ORF1p coiled-coil domain binds copper(I) ions with high affinity."},
  {name: "Copy number alterations", description: "Changes in the number of copies of a specific genomic region, such as aneuploidies."},
  {name: "Copy number variation", description: "Copy number variation (CNV) is a type of structural variation where sections of the genome are repeated and the number of repeats varies between individuals."},
  {name: "copy number variation (CNV)", description: "Copy number variation is a type of structural variation where the number of copies of a specific DNA segment varies among individuals."},
  {name: "Copy number variations", description: "Copy number variations are a type of structural variation involving changes in the number of copies of a particular genomic region."},
  {name: "Copying by non-HERV machinery", description: "Copying by non-HERV machinery is a mechanism where HERV elements are copied by cellular machinery not specific to HERVs."},
  {name: "Core decidual regulatory network", description: "The core decidual regulatory network is a set of molecular interactions and pathways that govern the decidualization process in endometrial stromal cells."},
  {name: "Coretropose", description: "Coretropose is the process by which LINE-1 elements mobilize and integrate various non-autonomous RNAs into the genome."},
  {name: "Cotranscription", description: "Cotranscription refers to the simultaneous transcription of two or more genetic elements from a shared promoter or regulatory region."},
  {name: "cotranscriptional splicing", description: "Cotranscriptional splicing refers to significant alterations in splicing caused by retroelement insertions."},
  {name: "CpA to TpA mutation", description: "A specific type of 5-methylcytosine-associated mutation."},
  {name: "CpG dinucleotide mutation", description: "CpG dinucleotides are hypermutable sites in the genome, often undergoing cytosine methylation and subsequent deamination."},
  {name: "CpG DNA methylation", description: "CpG DNA methylation is an epigenetic modification primarily occurring at CpG dinucleotides, crucial for silencing transposons."},
  {name: "CpG hypomethylation", description: "CpG hypomethylation refers to a decrease in the methylation level of cytosine nucleotides in CpG dinucleotide contexts, often associated with genomic instability and altered gene expression."},
  {name: "CpG island creation", description: "The process by which retrotransposition events lead to the formation of new CpG islands in the genome."},
  {name: "CpG island hypermethylation", description: "CpG island hypermethylation is an epigenetic modification involving the addition of methyl groups to cytosine residues in CpG-rich regions, often associated with gene silencing."},
  {name: "CpG methylation", description: "CpG methylation is an epigenetic modification involving the addition of a methyl group to the cytosine nucleotide in a CpG dinucleotide, often associated with gene silencing."},
  {name: "CpG methylation in L1 promoter", description: "DNA methylation at CpG sites within the promoter region of LINE-1 elements, which regulates their expression."},
  {name: "CpG methylation-mediated repression", description: "CpG methylation-mediated repression is an epigenetic mechanism that silences gene expression, including that of retrotransposable elements."},
  {name: "CpG mutation", description: "CpG mutation refers to the high mutation rate of CpG dinucleotides, often resulting in their conversion to TpG or CpA."},
  {name: "CpG to TpG mutation", description: "A specific type of 5-methylcytosine-associated mutation."},
  {name: "CpT to TpT mutation", description: "A specific type of 5-methylcytosine-associated mutation."},
  {name: "create chimeric transcripts with host genes", description: "Creation of chimeric transcripts with host genes refers to the formation of fusion RNAs that include sequences from both a transposable element and a host gene."},
  {name: "creating genetic variation", description: "Retrotransposons are responsible for creating genetic variation within the human genome."},
  {name: "Creation of chimeric retrotranscripts", description: "The process of generating fused retrotranscripts, such as U6-L1, using the L1 integration machinery."},
  {name: "creation of new exon", description: "Creation of a new exon refers to the process by which a DNA sequence is incorporated into a gene's transcript as a coding or non-coding segment."},
  {name: "Creation of new microsatellites", description: "The creation of new microsatellites is a genomic consequence of L1 insertions."},
  {name: "CREB activation", description: "Activation of cAMP response element-binding protein (CREB) is a cellular signaling event that can regulate gene expression."},
  {name: "CRISPR interference (CRISPRi) silencing", description: "A technique using a catalytically dead Cas9 protein to repress gene expression by blocking transcription."},
  {name: "CRISPR-Cas9-mediated gene activation (CRISPRa)", description: "CRISPRa is a technique that uses a dCas9 fused to transcriptional activators to upregulate gene expression."},
  {name: "CRISPR-Cas9-mediated gene interference (CRISPRi)", description: "CRISPRi is a technique that uses a catalytically dead Cas9 (dCas9) to repress gene expression by blocking transcription."},
  {name: "CRISPR/Cas9-induced DSB formation", description: "CRISPR/Cas9-induced double-strand break (DSB) formation is a DNA damage mechanism triggered by the CRISPR/Cas9 genome editing tool."},
  {name: "CRISPR/Cas9-mediated integration", description: "CRISPR/Cas9-mediated integration is a genome editing technique that uses the Cas9 nuclease guided by RNA to create targeted double-strand breaks, enabling precise insertion of DNA sequences."},
  {name: "Cryptic exon activation", description: "Cryptic exon activation refers to the inclusion of a normally non-coding intronic sequence into a mature mRNA transcript due to the creation of a new splice site."},
  {name: "Cryptic exon inclusion", description: "Cryptic exon inclusion is a splicing abnormality where a normally non-coding intronic sequence is incorporated into the mature mRNA."},
  {name: "Cryptic polyadenylation", description: "Cryptic polyadenylation refers to the use of non-canonical or suboptimal polyadenylation signals within a transcript, leading to premature termination of transcription."},
  {name: "cryptic promoter activation", description: "Cryptic promoter activation is the process by which a normally silent or inactive promoter region becomes transcriptionally active, often due to a genomic alteration."},
  {name: "Cryptic promoter activity", description: "Cryptic promoter activity refers to the initiation of transcription from sequences not normally functioning as promoters, which can be activated by nearby genomic alterations."},
  {name: "Cryptic splice site activation", description: "Cryptic splice site activation refers to the unmasking and utilization of normally silent splice sites within introns or exons, often due to mutations."},
  {name: "Cryptic splicing variation", description: "Cryptic splicing variation refers to alternative splicing events caused by sequence variation within intronic regions, such as VNTRs."},
  {name: "CTCF-binding", description: "CTCF-binding is a molecular mechanism where the CTCF protein binds to DNA, often involved in chromatin organization and gene regulation."},
  {name: "ctDNA integration", description: "The process by which circulating tumor DNA (ctDNA) is inserted into the genome of a recipient cell."},
  {name: "cut-and-paste mechanism", description: "A transposon-based mechanism involving the excision and reinsertion of genetic material."},
  {name: "cut-and-paste transposition", description: "A mechanism of transposition where the transposon is excised from its original location and inserted into a new one."},
  {name: "Cytidine deamination", description: "An enzymatic process that converts cytidine to uridine, which can be a restriction mechanism against retrotransposons."},
  {name: "Cytoplasmic accumulation of RNA-DNA hybrids", description: "Cytoplasmic accumulation of RNA-DNA hybrids is a process where RNA-DNA hybrid molecules derived from retrotransposons accumulate in the cytoplasm."},
  {name: "Cytoplasmic aggregation", description: "The formation of protein aggregates in the cytoplasm, a feature of the LINE-1 ORF1p protein."},
  {name: "Cytoplasmic DNA accumulation", description: "Cytoplasmic DNA accumulation refers to the buildup of DNA, including from active LINE-1 elements, in the cell cytoplasm."},
  {name: "Cytoplasmic expression of ORF1p/ORF2p", description: "The localization of LINE-1 encoded ORF1p and ORF2p proteins within the cell cytoplasm."},
  {name: "Cytoplasmic foci localization", description: "Cytoplasmic foci localization is the process where L1-encoded proteins and L1 RNA accumulate in cytoplasmic foci, often associated with stress granules."},
  {name: "Cytoplasmic sequestration", description: "Cytoplasmic sequestration refers to the process of trapping or confining molecules, such as RNA, in the cytoplasm away from their site of action."},
  {name: "cytoplasmic synthesis of Alu complementary DNA", description: "The process of reverse transcribing Alu RNA into complementary DNA (cDNA) in the cytoplasm, independently of genomic integration."},
  {name: "Cytosine methylation", description: "Cytosine methylation is an epigenetic modification involving the addition of a methyl group to cytosine residues in DNA, often associated with gene silencing."},
  {name: "Cytosine methylation of L1 promoters", description: "A cellular mechanism involving high-density cytosine methylation to downregulate the expression of L1 proteins."},
  {name: "cytosolic priming", description: "Cytosolic priming refers to the initiation of reverse transcription in the cell cytoplasm, potentially by short RNAs or hairpins."},
  {name: "Cytosolic ribonuclease (RNase) degradation", description: "Cytosolic ribonuclease degradation is a pathway for degrading LINE-1 RNA, identified as a major regulatory mechanism in the model."},
  {name: "Cytotoxicity", description: "Cytotoxicity refers to the quality of being toxic to cells, causing cell damage or death."},
  {name: "De novo DNA methylation", description: "De novo DNA methylation is the process of establishing new DNA methylation marks, often at transposable elements, to repress their transcription."},
  {name: "de novo genetic variation", description: "De novo genetic variation refers to new genetic changes that arise in an individual's germline or somatic cells and are not inherited from parents."},
  {name: "de novo genomic insertions", description: "De novo genomic insertions are new insertions of transposable elements into the genome, which can be detected as evidence of retrotransposition activity."},
  {name: "De novo insertion", description: "De novo insertion refers to the integration of a transposon into a new genomic location."},
  {name: "de novo L1 insertion", description: "De novo L1 insertion refers to a new insertion event of a LINE-1 element into the genome."},
  {name: "de novo L1 integration", description: "De novo L1 integration is the process by which a new LINE-1 copy inserts into the genome, initiated by the endonuclease domain nicking a specific DNA sequence."},
  {name: "de novo LINE-1 insertion", description: "New insertions of LINE-1 elements into the genome, which can potentially drive tumorigenesis."},
  {name: "De novo mutation", description: "De novo mutation refers to a new genetic alteration that is present for the first time in a family member, caused by an error in DNA replication or repair."},
  {name: "De novo repression", description: "De novo repression refers to the initial silencing of genetic elements."},
  {name: "De novo retrotransposition", description: "De novo retrotransposition is the process by which a retrotransposon generates a new genomic insertion through reverse transcription and integration."},
  {name: "de novo somatic retrotransposition", description: "De novo somatic retrotransposition is a new retrotransposition event occurring in somatic cells of an individual."},
  {name: "De novo transposon insertion", description: "De novo transposon insertion refers to a new insertion event of a transposon into the genome that was not present in the parental genomes."},
  {name: "De-differentiation", description: "De-differentiation is a cellular process where specialized cells revert to a less specialized state."},
  {name: "De-repression", description: "De-repression is the process by which silenced transposable elements become active or accessible."},
  {name: "deamination-dependent inhibition", description: "Deamination-dependent inhibition is a mechanism of inhibiting LINE-1 retrotransposition that relies on the cytosine deaminase activity of APOBEC3 proteins, leading to cDNA degradation."},
  {name: "deamination-independent restriction", description: "Deamination-independent restriction is a mechanism of inhibiting LINE-1 retrotransposition that does not rely on the cytosine deaminase activity of APOBEC3 proteins."},
  {name: "Decidualization", description: "Decidualization is the process of endometrial stromal cell differentiation, a key event in establishing endometrial receptivity for embryo implantation."},
  {name: "Decrease of RNA levels", description: "Decrease of RNA levels refers to a reduction in the amount of specific RNA transcripts."},
  {name: "decreased degradation of L1 DNA or RNA", description: "Decreased degradation of L1 DNA or RNA refers to the reduced breakdown of LINE-1 nucleic acids."},
  {name: "Decreased gene expression", description: "Decreased gene expression refers to a reduction in the level of transcription or translation of a specific gene."},
  {name: "Decreased global DNA methylation", description: "Decreased global DNA methylation is an epigenetic state characterized by a reduction in the overall level of DNA methylation across the genome."},
  {name: "Decreased transcription", description: "Decreased transcription refers to a reduction in the rate or level of gene transcription."},
  {name: "defending virus infection", description: "Defending virus infection is a function where retrotransposons may play a role in the cellular antiviral response."},
  {name: "Defense mechanism against transposons", description: "A biological process, such as DNA methylation, that suppresses the activity or deleterious effects of transposable elements."},
  {name: "defining chromatin TAD and loop boundaries", description: "Defining chromatin topologically associating domain (TAD) and loop boundaries refers to the role of sequences in organizing the 3D structure of chromatin."},
  {name: "Degradation assessment", description: "Degradation assessment is the qualitative measure of the extent of DNA degradation in a sample."},
  {name: "degradation of LINE-1 RNA", description: "Degradation of LINE-1 RNA is a host control mechanism that reduces the availability of the RNA template required for LINE-1 retrotransposition."},
  {name: "Deletion", description: "Deletion is the process by which a transposable element is removed from a genomic location."},
  {name: "deletion of target genomic DNA", description: "The loss of a segment of DNA at the site of an L1 insertion."},
  {name: "deletions", description: "Deletions are genetic alterations involving the loss of DNA sequences, which can be associated with transposon activity."},
  {name: "demethylation", description: "Demethylation is the removal of a methyl group from a molecule, such as DNA, which can lead to changes in gene expression."},
  {name: "demethylation of repetitive elements", description: "Demethylation of repetitive elements, including LINE-1, is a process contributing to genome-wide hypomethylation in cancers."},
  {name: "Depletion of mRNA and protein levels", description: "Depletion of mRNA and protein levels refers to a significant reduction in the quantity of specific mRNA transcripts and their corresponding proteins."},
  {name: "deposition of repressive histone marks", description: "Deposition of repressive histone marks is an epigenetic mechanism that leads to gene silencing."},
  {name: "deposition of repressive histone modifications", description: "The addition of chemical marks to histone proteins that lead to a compact, transcriptionally inactive chromatin state."},
  {name: "deregulation of let-7 miRNA expression", description: "Deregulation of let-7 miRNA expression refers to abnormal levels or activity of the let-7 microRNA family."},
  {name: "derepression in cancer", description: "Derepression in cancer refers to the loss of normal silencing mechanisms, leading to the reactivation or increased expression of genes or transposons in cancer cells."},
  {name: "Derepression of retrotransposons", description: "The process by which retrotransposons, such as LINE-1, are released from transcriptional silencing and become active."},
  {name: "Derepression of transposable elements", description: "Derepression of transposable elements refers to the loss of normal silencing mechanisms, leading to increased expression and potential activity of these elements."},
  {name: "Determination of chronological order and relative ages", description: "A method to infer the chronological order and relative ages of human transposable elements spanning over 100 million years based on their insertion/fragmentation patterns."},
  {name: "Developmental control", description: "Developmental control refers to the regulation of processes that guide the growth and differentiation of an organism from an embryo."},
  {name: "developmental plasticity", description: "Developmental plasticity is the ability of cells to change their phenotype during development."},
  {name: "Developmental program repression", description: "The process of suppressing or silencing gene expression programs associated with earlier stages of development."},
  {name: "Developmental regulation", description: "The control of processes during organism development."},
  {name: "developmental reversion", description: "Developmental reversion refers to the process where cells revert to an earlier developmental state, such as naive human embryonic stem cells reverting to 8-cell-like cells."},
  {name: "developmentally programmed genetic switches", description: "Permanent and heritable changes in DNA that control precise gene expression during embryonic development."},
  {name: "dGTP-triggered tetramer formation", description: "dGTP-triggered tetramer formation is a structural change in the SAMHD1 protein required for its dNTPase activity and LINE-1 regulation."},
  {name: "DICER-dependent destruction of L1 mRNAs", description: "A cellular mechanism involving DICER to downregulate the expression of L1 proteins by destroying L1 mRNAs."},
  {name: "Dicer-mediated RNA interference (RNAi) silencing", description: "Dicer-mediated RNA interference (RNAi) silencing is a cellular defense mechanism that uses small interfering RNAs to limit the expansion of retrotransposons."},
  {name: "Dicistronic structure", description: "A dicistronic structure refers to an mRNA that contains two open reading frames (ORFs) that can be translated into two separate proteins."},
  {name: "differential DNA methylation", description: "Differential DNA methylation refers to changes in the methylation status of specific genomic loci, which can alter gene expression."},
  {name: "Differential expression", description: "Differential expression refers to the condition where a gene or element is expressed at different levels between two or more conditions, such as tumor versus healthy tissue."},
  {name: "Differential expression of miRNAs", description: "Differential expression of miRNAs, such as the let-7 family, involves changes in their levels, which can regulate genes involved in EMT and metastasis."},
  {name: "differential expression of proximal genes", description: "Differential expression of proximal genes refers to changes in the expression levels of genes located near a genomic locus, such as a retrotransposon."},
  {name: "Differential gene expression", description: "Differential gene expression refers to changes in the level of gene transcription, as identified in SETMAR knockout cell lines."},
  {name: "Differential methylation", description: "Differential methylation refers to differences in DNA methylation patterns, such as between alleles or genomic regions."},
  {name: "differential transposon insertion", description: "The presence or absence of a transposon insertion at a specific genomic locus when comparing two genomes."},
  {name: "Differentiation", description: "Differentiation is the process by which pluripotent stem cells develop into specialized cell types."},
  {name: "Differentiation of sex chromosomes", description: "Differentiation of sex chromosomes refers to the evolutionary process where homologous chromosomes (X and Y) accumulate differences and stop recombining over most of their length."},
  {name: "differentiation potential", description: "Differentiation potential is the ability of a cell to develop into more specialized cell types."},
  {name: "Differentiation repression", description: "Differentiation repression is a process that maintains pluripotency by inhibiting the transition of stem cells into specialized cell types."},
  {name: "Direct occupation", description: "Direct occupation refers to transcription factors binding to specific genomic sites, such as LTR sequences."},
  {name: "Direct reprogramming", description: "Direct reprogramming is a process of converting one cell type directly into another without passing through a pluripotent intermediate state."},
  {name: "Disease progression", description: "Disease progression refers to the worsening or advancement of a disease over time."},
  {name: "disease-causing mutation", description: "Retrotransposons are responsible for creating disease-causing mutations within the human genome."},
  {name: "Dispersion mechanism", description: "The molecular and cellular processes by which transposable elements spread to new genomic locations."},
  {name: "disrupt gene function", description: "Disruption of gene function refers to the impairment of a gene's normal activity, often through mutation."},
  {name: "disruption", description: "The interruption or alteration of a genomic sequence or gene function caused by a transposon insertion."},
  {name: "Disruption of coding region", description: "Disruption of a coding region occurs when a genetic element inserts into an exon, altering the protein-coding sequence."},
  {name: "disruption of heterochromatin structure", description: "Alteration or destabilization of the condensed, transcriptionally repressive chromatin structure."},
  {name: "disruption of mesenchymal to epithelial transition", description: "Disruption of mesenchymal to epithelial transition refers to the interference with the cellular process where mesenchymal cells transform into epithelial cells, which is crucial for organogenesis."},
  {name: "disruption of nuclear integrity", description: "Impairment of the structural and functional integrity of the cell nucleus, including the nuclear envelope."},
  {name: "disruption of nucleocytoplasmic transport", description: "Impairment of the transport of molecules between the nucleus and the cytoplasm."},
  {name: "Disruption of open reading frame (ORF)", description: "Disruption of the open reading frame (ORF) refers to mutations that prevent the translation of a functional protein from a gene."},
  {name: "Distal enhancer activity", description: "The function of a non-coding DNA sequence located far from the gene it regulates to increase the transcription of that gene."},
  {name: "distal enhancer function", description: "A role in regulating gene expression from a distance, typically by looping to interact with gene promoters."},
  {name: "distal enhancer regulation", description: "The process of controlling gene expression from regulatory elements located far from the gene promoter."},
  {name: "disturbance of normal gene expression", description: "Disturbance of normal gene expression refers to the abnormal activation or repression of gene transcription, potentially contributing to disease."},
  {name: "Divergence-based insertion time estimation", description: "A method to estimate the insertion time of an LTR retrotransposon by measuring the sequence divergence between its two LTRs, which were identical at the time of insertion."},
  {name: "Diversification", description: "Diversification refers to the process by which genomic segments or sequences become more varied over time."},
  {name: "Diversification of transcriptional profiles", description: "The process of generating variation in the patterns of gene expression across different conditions or cell types."},
  {name: "DNA 5-methylcytosine (5mC) methylation", description: "DNA 5-methylcytosine (5mC) methylation is an epigenetic modification involved in the silencing of transposable elements."},
  {name: "DNA bending and minor groove widening", description: "A structural mechanism induced by the βB6-βB5 hairpin loop of L1-Endonuclease, which protrudes into the DNA minor groove, causing bending and widening to position the scissile bond for cleavage."},
  {name: "DNA binding", description: "DNA binding is the molecular function of proteins or other molecules to attach to specific sequences or structures of DNA."},
  {name: "DNA binding site spread", description: "The spread of DNA binding sites refers to their distribution across the genome through mechanisms such as transposon mobilization."},
  {name: "DNA break repair via homology-dependent pathway", description: "A pathway for repairing DNA double-strand breaks that uses a homologous DNA sequence as a template, such as homologous recombination."},
  {name: "DNA break repair via nonhomologous end joining", description: "A pathway for repairing DNA double-strand breaks by directly ligating the broken ends, often resulting in small insertions or deletions."},
  {name: "DNA breaks", description: "DNA breaks are physical discontinuities in the DNA backbone, which can be single-strand or double-strand breaks."},
  {name: "DNA cleavage", description: "DNA cleavage is the enzymatic process of breaking phosphodiester bonds in DNA."},
  {name: "DNA cleavage activity", description: "DNA cleavage activity refers to the enzymatic ability to cut DNA strands."},
  {name: "DNA cleavage by L1 endonuclease", description: "DNA cleavage by L1-endonuclease refers to the enzymatic activity of LINE-1 endonuclease that introduces DNA breaks."},
  {name: "DNA clustering", description: "DNA clustering refers to the phenomenon where specific genome elements are non-randomly grouped together in the genome."},
  {name: "DNA crosslink repair", description: "DNA crosslink repair is a pathway that resolves interstrand crosslinks, and the Fanconi anemia pathway is a key component of this process."},
  {name: "DNA damage", description: "DNA damage refers to alterations in the chemical structure of DNA, such as breaks or modifications."},
  {name: "DNA damage accumulation", description: "DNA damage accumulation refers to the increase in genomic lesions."},
  {name: "DNA damage repair", description: "DNA damage repair is a cellular process that identifies and corrects damage to DNA molecules to maintain genome integrity."},
  {name: "DNA damage response", description: "DNA damage response is a cellular mechanism activated by DNA damage."},
  {name: "DNA damage signaling", description: "DNA damage signaling refers to the cellular pathways that detect and respond to DNA lesions, such as double-strand breaks."},
  {name: "DNA damage signaling pathway activation", description: "DNA damage signaling pathway activation is the cellular response triggered by DNA lesions, such as double-strand breaks, leading to the recruitment of repair proteins."},
  {name: "DNA damage-mediated programmed cell death", description: "DNA damage-mediated programmed cell death is a cell death pathway triggered by genomic damage, such as that potentially caused by retrotransposon activity."},
  {name: "DNA deamination-independent mechanism", description: "A mechanism of L1 inhibition that does not involve cytidine deamination."},
  {name: "DNA deletions", description: "DNA deletions are genetic alterations involving the loss of a segment of DNA."},
  {name: "DNA demethylation", description: "DNA demethylation is an active process of removing methyl groups from cytosine bases in DNA, often mediated by enzymes like TET."},
  {name: "DNA double strand breaks (DNA DSBs)", description: "DNA double strand breaks (DNA DSBs) are a type of severe DNA damage where both strands of the DNA helix are severed."},
  {name: "DNA double-strand break (DSB) formation", description: "DNA double-strand break formation is a type of DNA damage involving breaks in both strands of the DNA double helix."},
  {name: "DNA double-strand break (DSB) repair", description: "DNA double-strand break repair is a cellular mechanism to fix breaks in both strands of the DNA molecule."},
  {name: "DNA double-strand break repair", description: "A cellular process for repairing DNA double-strand breaks, which may be utilized by endonuclease-independent L1 insertions."},
  {name: "DNA double-strand break repair by non-homologous end joining", description: "Non-homologous end joining (NHEJ) is a pathway that repairs double-strand breaks in DNA by directly ligating the broken ends together."},
  {name: "DNA double-strand breaks", description: "DNA double-strand breaks are a type of DNA damage that can be caused by retrotransposon expression."},
  {name: "DNA double-strand breaks (DSBs)", description: "DNA double-strand breaks are a form of severe DNA damage where both strands of the DNA helix are severed."},
  {name: "DNA double-stranded breaks", description: "A type of DNA damage where both strands of the DNA double helix are severed."},
  {name: "DNA duplication", description: "DNA duplication is a process that occurs more frequently in Alu- and GC-rich chromosomal regions."},
  {name: "DNA elongation", description: "The process of extending a DNA strand by adding nucleotides, a key step in reverse transcription."},
  {name: "DNA gain", description: "DNA gain refers to the accumulation of non-coding DNA sequences, including transposable elements, in the genome."},
  {name: "DNA hypomethylation", description: "A reduction in the level of DNA methylation, often associated with increased transcriptional activity of repetitive elements."},
  {name: "DNA loss", description: "DNA loss refers to the removal of non-coding DNA sequences from the genome."},
  {name: "DNA melting", description: "DNA melting refers to the local unwinding or separation of the DNA double helix."},
  {name: "DNA methylation", description: "An epigenetic modification that represses transcription, including that of transposable elements."},
  {name: "DNA methylation analysis", description: "DNA methylation analysis is a method to assess the methylation status of cytosine residues in DNA, often at CpG sites."},
  {name: "DNA methylation changes", description: "DNA methylation changes refer to alterations in the pattern of DNA methylation, which is an epigenetic modification."},
  {name: "DNA methylation pattern redistribution", description: "DNA methylation pattern redistribution refers to changes in the distribution of methylated cytosines across the genome or within specific genomic elements."},
  {name: "DNA methylation variation", description: "DNA methylation variation refers to differences in methylation levels between individuals or conditions."},
  {name: "DNA methylation-based repression", description: "A repression mechanism involving DNA methyltransferases that silences transposon expression by adding methyl groups to DNA."},
  {name: "DNA nicking", description: "DNA nicking is the process of cleaving one strand of a DNA duplex, which is a critical step in LINE-1 retrotransposition."},
  {name: "DNA polymerization", description: "DNA polymerization refers to the synthesis of DNA strands, specifically catalyzed by the L1 reverse transcriptase (L1 RT) on its own L1 RNA template in vitro."},
  {name: "DNA quantitation", description: "DNA quantitation is the process of determining the amount of amplifiable DNA in a biological sample."},
  {name: "DNA recognition and binding", description: "DNA recognition and binding is the process by which a protein specifically interacts with a DNA sequence."},
  {name: "DNA recognition by L1 endonuclease", description: "The physical basis of L1 endonuclease DNA recognition, which is specific for unusual DNA structural features at TpA junctions of A-tracts."},
  {name: "DNA recombination", description: "DNA recombination is the process of breaking and rejoining DNA strands to produce new combinations of genetic material."},
  {name: "DNA release", description: "DNA release refers to the process by which DNA is released from cells into the extracellular space, such as into plasma."},
  {name: "DNA repair", description: "DNA repair is a collection of processes by which a cell identifies and corrects damage to the DNA molecules that encode its genome."},
  {name: "DNA repair response", description: "DNA repair response is a cellular mechanism that corrects DNA damage."},
  {name: "DNA replication", description: "DNA replication is the process of copying a cell's DNA to produce two identical DNA molecules."},
  {name: "DNA replication and repair", description: "A recurring theme for retrotransposons is their tie-in to DNA replication and repair processes within the host cell."},
  {name: "DNA replication restart", description: "A cellular process involving specific proteins that reinitiate DNA synthesis at stalled or collapsed replication forks."},
  {name: "DNA sequence-specific recruitment", description: "A recruitment mechanism where a protein complex is targeted to specific genomic loci based on recognition of particular DNA sequences."},
  {name: "DNA strand breaks", description: "The occurrence of breaks in the DNA double helix."},
  {name: "DNA target recognition", description: "DNA target recognition refers to the process by which mobile genetic elements identify specific sequences or structures in the genome for insertion."},
  {name: "DNA target site recognition", description: "The process by which the LINE-1 endonuclease identifies and binds to specific DNA sequences for nicking."},
  {name: "DNA transposition", description: "DNA transposition is the movement of DNA transposons within the genome, typically involving a 'cut-and-paste' mechanism."},
  {name: "DNA transposon activity", description: "DNA transposon activity refers to the mobilization of DNA transposons via a 'cut-and-paste' mechanism."},
  {name: "DNA-binding and looping activity", description: "DNA-binding and looping activity refers to the ability of a protein to bind DNA and bring distant sites together, forming a loop."},
  {name: "DNA:RNA heteroduplex formation", description: "DNA:RNA heteroduplex formation is a molecular structure consisting of one strand of DNA and one strand of RNA, which can be an intermediate or product of reverse transcription."},
  {name: "DNA:RNA hybrid formation", description: "DNA:RNA hybrid formation refers to the generation of structures where RNA molecules anneal to complementary DNA sequences."},
  {name: "dNTPase activity", description: "dNTPase activity is the enzymatic function of hydrolyzing deoxynucleoside triphosphates."},
  {name: "Domain shuffling", description: "Domain shuffling is a mechanism of gene creation where new combinations of functional domains are assembled."},
  {name: "Domestication", description: "Domestication refers to the evolutionary process by which transposable element-derived sequences are co-opted by the host genome to perform new cellular functions."},
  {name: "Domestication of TFBS", description: "Domestication of TFBS refers to the hypothesized evolutionary process where transcription factor binding sites within ERVs/LRs are co-opted and reshaped by the host genome for regulatory functions."},
  {name: "Donor-specific assembly", description: "Donor-specific assembly is a method to construct genome sequences specific to an individual or sample."},
  {name: "Double template switch", description: "A specific type of RNA template switching event where the reverse transcriptase jumps between two different RNA templates, resulting in a tripartite chimeric cDNA."},
  {name: "double-strand break", description: "A double-strand break is a type of DNA damage where both strands of the DNA double helix are severed."},
  {name: "Double-strand break (DSB) generation", description: "Double-strand break generation refers to the creation of DNA double-strand breaks, which can be induced by the endonuclease activity of LINE-1 ORF2p during target-primed reverse transcription."},
  {name: "Double-strand break (DSB) repair", description: "Double-strand break repair is a cellular mechanism to fix DNA double-strand breaks, crucial for genomic stability."},
  {name: "Double-strand break formation", description: "The generation of breaks in both strands of the DNA double helix."},
  {name: "Double-strand break initiation", description: "Double-strand break initiation is an event that can lead to homologous recombination."},
  {name: "double-strand break repair (DSBR)", description: "Double-strand break repair is a cellular mechanism to fix DNA double-strand breaks."},
  {name: "double-strand breaks", description: "Double-strand breaks are a type of DNA damage where both strands of the DNA double helix are severed."},
  {name: "double-strand breaks (DSBs)", description: "Double-strand breaks are a type of DNA damage where both strands of the DNA double helix are severed."},
  {name: "Double-strand DNA break induction", description: "Double-strand DNA break induction refers to the creation of breaks in both strands of the DNA duplex, which can be caused by the L1 endonuclease during target site cleavage."},
  {name: "Double-strand DNA breaks", description: "Double-strand DNA breaks are a type of severe DNA damage where both strands of the DNA helix are severed."},
  {name: "Double-stranded DNA break (DSB)", description: "Double-stranded DNA breaks (DSBs) are a severe form of genotoxic stress that threaten genome integrity and can activate cell cycle checkpoints or cause cell death."},
  {name: "double-stranded RNA formation", description: "Double-stranded RNA formation refers to the process where complementary RNA strands base-pair to form dsRNA structures."},
  {name: "down-regulation", description: "Down-regulation refers to a decrease in the expression level of a gene or element."},
  {name: "Down-regulation of LINE-1 promoter activity", description: "TRIM5α-induced signaling activates transcription factors AP-1 and NF-κB, leading to the down-regulation of LINE-1 promoter activity."},
  {name: "Downregulation of pro-survival signaling", description: "A decrease in the activity of signaling pathways that promote cell survival, such as those involving AKT, mTORC1, and AMPK."},
  {name: "Drive evolution", description: "The ability of retrotransposons to contribute to genomic changes and species-specific adaptations over time."},
  {name: "driving mutation", description: "Driving mutation refers to genetic alterations that contribute to the initiation or progression of a disease, such as tumorigenesis."},
  {name: "Drug resistance", description: "Drug resistance is the reduction in effectiveness of a medication in treating a disease."},
  {name: "Drug selection-based enrichment", description: "Drug selection-based enrichment is a method to isolate cells that have undergone a desired genetic modification by applying selective pressure."},
  {name: "dsRNA formation", description: "Transposable elements can fold into double-stranded RNAs (dsRNAs)."},
  {name: "dsRNA-mediated regulation of L1-5'UTR promoter activity", description: "A regulatory mechanism for L1-5'UTR promoter activity involving double-strand RNA (dsRNA)."},
  {name: "Dual priming", description: "A postulated mechanism that could generate truncated L1s with a poly(T) simple repeat at the 5' end of the insertion."},
  {name: "Duplication", description: "Duplication refers to the process of copying genomic segments, which can include transposons."},
  {name: "duplication event", description: "A duplication event is the process by which a segment of DNA is copied and inserted elsewhere in the genome."},
  {name: "Duplicative transposition", description: "Duplicative transposition is a process that can lead to genomic instability and potential genome destruction."},
  {name: "Dynamic regulation", description: "Dynamic regulation refers to the temporal control of gene or element activity, such as transient activation followed by suppression."},
  {name: "dysfunctional metabolism", description: "Dysfunctional metabolism refers to abnormal cellular metabolic processes, such as those involved in energy production."},
  {name: "Dysregulation", description: "The disruption of normal regulation, leading to abnormal expression levels or activity of genetic elements."},
  {name: "dysregulation of cell energy metabolism", description: "Dysregulation of cell energy metabolism refers to abnormal control of cellular processes that generate energy, such as glycolysis and oxidative phosphorylation."},
  {name: "dysregulation of cytokine/chemotaxin transcription", description: "Dysregulation of cytokine/chemotaxin transcription refers to abnormal expression of signaling molecules involved in immune cell recruitment and activation."},
  {name: "Dysregulation of DNA methylation", description: "Dysregulation of DNA methylation refers to abnormal patterns of DNA methylation, including hypomethylation or hypermethylation, which can affect gene expression and genomic stability."},
  {name: "Dysregulation of retrotransposon activity", description: "Dysregulation of retrotransposon activity refers to the abnormal control of retrotransposon transcription and mobilization."},
  {name: "Early DNA replication", description: "The process by which specific genomic regions are replicated early during the S phase of the cell cycle."},
  {name: "Early embryonic control of L1", description: "The evolutionary dynamic process by which newly emerged L1 lineages are suppressed in early embryogenesis."},
  {name: "early embryonic development", description: "Early embryonic development refers to the initial stages of embryo formation following fertilization."},
  {name: "early human brain development", description: "Early human brain development is the biological process involving the formation and maturation of the brain during embryonic and fetal stages."},
  {name: "Early termination", description: "Early termination refers to the premature cessation of protein translation, often resulting in a truncated, non-functional protein."},
  {name: "Ectopic excision", description: "A proposed mechanism for the nonrandom genomic distribution of transposons involving imprecise removal and relocation."},
  {name: "Ectopic expression", description: "Ectopic expression refers to the expression of a gene or element in an abnormal location, cell type, or at an abnormal time."},
  {name: "Ectopic gene expression", description: "The abnormal expression of a gene in a tissue, cell type, or developmental stage where it is not normally expressed."},
  {name: "Ectopic L1 incorporation", description: "Ectopic L1 incorporation refers to the insertion of LINE-1 elements into the genome at new locations."},
  {name: "ectopic recombination", description: "Ectopic recombination is a genetic rearrangement caused by recombination between non-allelic sequences, such as those mediated by transposable elements."},
  {name: "Efficient delivery of non-viral vectors", description: "Efficient delivery of non-viral vectors involves methods to introduce genetic material (e.g., transposons, mRNA, plasmids) into target cells without using viral particles."},
  {name: "eIF2 kinase regulation", description: "eIF2 kinase regulation involves the control of kinases that phosphorylate eukaryotic initiation factor 2 (eIF2), a key regulator of protein synthesis."},
  {name: "elevated expression", description: "Elevated expression refers to an increase in the transcription or abundance of a gene or element."},
  {name: "Elevated retrotransposon activity", description: "Elevated retrotransposon activity refers to an increased rate of retrotransposition or expression of retrotransposons."},
  {name: "Elimination", description: "Elimination refers to the rapid removal of 'stand-alone' Alu elements from the genome."},
  {name: "Elimination of repeats", description: "Elimination of repeats refers to the removal or deletion of members of a transposable element family from the genome."},
  {name: "embryo development", description: "Embryo development is the process of growth and differentiation from a fertilized egg to a mature organism."},
  {name: "Embryogenesis", description: "Embryogenesis is the process by which the embryo forms and develops."},
  {name: "EMT programming", description: "Epithelial-to-mesenchymal transition (EMT) programming is a process involved in cancer progression."},
  {name: "EN-independent retrotransposition (ENi)", description: "A mechanism of L1 retrotransposition that does not require the L1 endonuclease activity, instead utilizing pre-existing 3'-OH groups at genomic DNA lesions, dysfunctional telomeres, or stalled replication forks to prime reverse transcription."},
  {name: "Enabling survival and thriving through evolution", description: "The role of retrotransposon-mediated genomic changes in providing adaptive advantages over evolutionary time."},
  {name: "Endo-siRNA-mediated silencing", description: "A regulatory pathway where endo-siRNAs directly regulate LINE-1 expression and silence it through DNA methylation."},
  {name: "endo-siRNAs mediated silencing", description: "endo-siRNAs mediated silencing is a mechanism by which endogenous small interfering RNAs regulate gene expression or transposon activity."},
  {name: "endogenous dsRNA accumulation", description: "The accumulation of double-stranded RNA (dsRNA) originating from endogenous sources, such as transposable element-containing mRNAs."},
  {name: "endogenous L1 machinery", description: "The endogenous L1 machinery refers to the proteins (ORF1p and ORF2p) encoded by active LINE-1 elements that are necessary for their own retrotransposition."},
  {name: "Endogenous L1 retrotransposition", description: "Endogenous L1 retrotransposition is the process by which human LINE-1 elements copy and paste themselves into new genomic locations."},
  {name: "Endogenous mutagenesis", description: "Endogenous mutagenesis is the process of generating mutations within an organism's genome by internal factors, such as transposable elements."},
  {name: "Endogenous oncogenic mutagenesis", description: "Endogenous oncogenic mutagenesis refers to the process by which endogenous elements, such as retrotransposons, cause mutations that can lead to cancer."},
  {name: "endogenous ORF2p enzymatic activity", description: "Endogenous ORF2p enzymatic activity refers to the reverse transcriptase and endonuclease functions of the ORF2 protein encoded by LINE-1 elements."},
  {name: "Endogenous retrotransposition", description: "Endogenous retrotransposition refers to the mobilization of the host's own retrotransposons."},
  {name: "endogenous reverse transcriptase activity", description: "The enzymatic activity that converts retrotransposon RNA into cDNA, which is induced in response to DNA damage."},
  {name: "Endometrial prolactin expression", description: "The expression of the prolactin (PRL) gene in the endometrium during pregnancy, which is essential for pregnancy in some mammals."},
  {name: "Endometrial receptivity", description: "Endometrial receptivity refers to the state of the uterine lining that allows for successful embryo implantation."},
  {name: "endonuclease (EN) activity", description: "Endonuclease activity of LINE-1 creates DNA breaks to facilitate retrotransposition."},
  {name: "Endonuclease activity", description: "Endonuclease activity refers to the enzymatic function that cleaves DNA, which is utilized by LINE-1 ORF2 to nick the target site for insertion during retrotransposition."},
  {name: "Endonuclease cleavage", description: "Endonuclease cleavage is the process where the L1 ribonucleoprotein particle uses its endonuclease to nick the genomic DNA, generating a DNA end for priming reverse transcription."},
  {name: "Endonuclease-dependent DNA breaks", description: "Endonuclease-dependent DNA breaks are DNA double-strand breaks generated by the endonuclease activity of the LINE-1 ORF2p protein."},
  {name: "Endonuclease-dependent insertion", description: "Endonuclease-dependent insertion is the mechanism by which L1 uses its encoded endonuclease to cleave DNA for integration."},
  {name: "endonuclease-dependent retrotransposition", description: "An insertion mechanism for LINE-1 elements termed target-primed reverse transcription."},
  {name: "endonuclease-independent (ENi) retrotransposition", description: "An alternative pathway for LINE-1 retrotransposition that does not require the endonuclease activity of ORF2p."},
  {name: "Endonuclease-independent insertion", description: "Endonuclease-independent insertion is a possible alternative retrotransposition pathway for NLRs."},
  {name: "Endonuclease-independent retrotransposition", description: "Endonuclease-independent retrotransposition is an alternative L1 integration pathway that does not require the canonical endonuclease cleavage."},
  {name: "Endonuclease-like activity", description: "A putative function associated with the 5'-end domain of the LINE ORF2 protein, dispensable for reverse transcription in this assay."},
  {name: "Endonucleolytic activity", description: "Enzymatic activity that cleaves phosphodiester bonds within a polynucleotide chain."},
  {name: "Endonucleolytic nicking", description: "Endonucleolytic nicking is the process where the LINE-1-encoded endonuclease creates single-strand breaks at specific consensus sequences in the target DNA to initiate integration."},
  {name: "endothelial cell migration", description: "Endothelial cell migration is the movement of endothelial cells, a key process in angiogenesis."},
  {name: "endothelial cell proliferation", description: "Endothelial cell proliferation is the process of endothelial cells dividing and increasing in number."},
  {name: "Energy consumption", description: "Energy consumption refers to the utilization of cellular ATP by various biological processes, including retrotransposon activity."},
  {name: "Engineered retrotransposition assay", description: "Engineered retrotransposition assays are experimental systems designed to study the regulation and mechanisms of retrotransposition in cultured cells."},
  {name: "Enhancement of Alu retrotransposition by ORF1p", description: "The process by which the LINE-1 ORF1 protein increases the efficiency or frequency of Alu SINE retrotransposition."},
  {name: "Enhancer activity", description: "Enhancer activity refers to the function of a DNA sequence in regulating gene expression by increasing the transcription of target genes."},
  {name: "Enhancer association", description: "Enhancer association refers to the localization of genomic elements within or near enhancer regions."},
  {name: "Enhancer binding", description: "The process where a transcription factor binds to genomic enhancer regions to regulate gene expression."},
  {name: "Enhancer co-option", description: "Enhancer co-option is the process by which genomic sequences, such as transposons, are repurposed to function as transcriptional enhancers."},
  {name: "enhancer function", description: "Enhancer function refers to the role of DNA sequences in increasing the transcription of associated genes."},
  {name: "enhancer recruitment", description: "Enhancer recruitment is the process by which enhancer elements are brought into proximity with a promoter to activate transcription."},
  {name: "Enhancer region", description: "An enhancer region is a short region of DNA that can be bound by proteins to increase the likelihood that transcription of a particular gene will occur."},
  {name: "enhancer state", description: "Enhancer state refers to a chromatin configuration associated with gene activation."},
  {name: "Enhancer-like activity", description: "The ability of a genomic element to increase the transcription of a gene or genes, often from a distance."},
  {name: "enhancer-like function", description: "Enhancer-like function refers to the ability of a DNA sequence to increase the transcription of associated genes, similar to an enhancer element."},
  {name: "enhancer-mediated gene regulation", description: "Enhancer-mediated gene regulation involves changes in gene expression caused by disruption or alteration of tissue-specific enhancer elements."},
  {name: "enhancers identification", description: "The process of identifying genomic regions that can increase the transcription of associated genes."},
  {name: "envelope protein function", description: "Envelope protein function refers to the biological activity of viral envelope proteins, which in some cases have been co-opted for host physiological processes."},
  {name: "Environmental adaptation", description: "Environmental adaptation refers to the process by which organisms adjust to changes in their environment, potentially involving mechanisms like retrotransposition."},
  {name: "Epigenetic alterations during aging", description: "Epigenetic alterations during aging are changes in epigenetic marks, such as DNA methylation, that occur with organismal and cellular senescence."},
  {name: "epigenetic and transcriptional interplay", description: "The epigenetic and transcriptional interplay describes the complex regulatory relationship between retrotransposons and their host genome."},
  {name: "Epigenetic biomarker", description: "An epigenetic biomarker is a measurable indicator of epigenetic modifications, such as DNA methylation, that can be associated with biological states or processes."},
  {name: "Epigenetic changes", description: "Heritable changes in gene expression that do not involve changes to the underlying DNA sequence."},
  {name: "Epigenetic control", description: "Epigenetic control refers to the regulation of gene expression through mechanisms such as DNA methylation, without altering the DNA sequence."},
  {name: "epigenetic control of differentiation", description: "Epigenetic control of differentiation involves the regulation of cell fate through chromatin modifications without altering the DNA sequence."},
  {name: "epigenetic control of expression", description: "The regulation of gene or transposon expression through mechanisms that do not involve changes to the DNA sequence, such as DNA methylation or histone modification."},
  {name: "Epigenetic defense", description: "Epigenetic defense mechanisms suppress transposable element activity through modifications such as DNA methylation and histone modifications."},
  {name: "epigenetic derepression", description: "Epigenetic derepression is the loss of epigenetic silencing marks, leading to the reactivation of gene or transposon expression."},
  {name: "Epigenetic drift", description: "Epigenetic drift refers to age-related changes in epigenetic patterns, such as DNA methylation."},
  {name: "epigenetic dysfunction", description: "Epigenetic dysfunction refers to the general disruption of epigenetic regulation, commonly seen in cancer cells."},
  {name: "epigenetic dysregulation", description: "Aberrant changes in epigenetic modifications, such as DNA methylation or histone marks, that can be induced by transposon activity."},
  {name: "Epigenetic field defect", description: "An epigenetic field defect refers to a pre-cancerous state in a tissue characterized by widespread epigenetic alterations, such as DNA methylation changes, that predispose to cancer development."},
  {name: "epigenetic landscape reshaping", description: "Epigenetic landscape reshaping involves changes in the patterns of epigenetic modifications that regulate gene expression."},
  {name: "Epigenetic methylation", description: "Epigenetic methylation, particularly cytosine methylation, is a mechanism involved in the transmission of gene expression states from parent to daughter cells."},
  {name: "epigenetic modification", description: "Epigenetic modification refers to chemical changes to DNA or histones that regulate gene expression without altering the DNA sequence."},
  {name: "Epigenetic modulation", description: "Epigenetic modulation involves changes in gene expression or cellular phenotype caused by mechanisms other than changes in the underlying DNA sequence, such as DNA methylation."},
  {name: "epigenetic reactivation", description: "Epigenetic reactivation refers to the reversal of epigenetic silencing, leading to the re-expression of genes or genetic elements."},
  {name: "epigenetic regulation", description: "Epigenetic regulation refers to the modification of DNA or associated proteins that affects gene expression without altering the DNA sequence."},
  {name: "epigenetic regulation of gene expression", description: "Epigenetic regulation of gene expression involves heritable changes in gene activity without altering the DNA sequence."},
  {name: "epigenetic regulation via DNA methylation", description: "A host defense mechanism that silences transposons by adding methyl groups to their DNA."},
  {name: "epigenetic remodeling", description: "Epigenetic remodeling refers to changes in chromatin structure, such as histone modifications and DNA methylation, that regulate gene expression."},
  {name: "epigenetic remodelling", description: "The alteration of the chromatin landscape and associated gene expression patterns through epigenetic mechanisms."},
  {name: "epigenetic repression", description: "The suppression of gene or element activity through epigenetic modifications, such as those mediated by CRISPR-interference (CRISPRi)."},
  {name: "Epigenetic reprogramming", description: "Epigenetic reprogramming is a process that occurs immediately after fertilization and in germ cells, making the genome vulnerable."},
  {name: "epigenetic silencing", description: "Epigenetic silencing involves the deposition of repressive marks, such as H3K9me3, to inhibit gene or transposon expression."},
  {name: "Epigenetic silencing by DNA methylation", description: "Epigenetic silencing by DNA methylation is a mechanism that can repress gene expression."},
  {name: "Epigenetic silencing of L1", description: "Epigenetic silencing of L1 involves the suppression of LINE-1 activity through mechanisms such as DNA methylation and histone modifications."},
  {name: "epigenetic transcriptional repression", description: "A process of gene silencing mediated by modifications to chromatin structure, such as histone deacetylation."},
  {name: "epigenetic transposon control", description: "Epigenetic transposon control refers to the repression of transposon activity through mechanisms such as histone modification (e.g., H3K9me3 deposition)."},
  {name: "Epigenetic variation", description: "Epigenetic variation refers to differences in gene expression or cellular phenotype caused by mechanisms other than changes in the underlying DNA sequence, such as DNA methylation."},
  {name: "epistatic capture", description: "A mode of molecular evolution involving the stabilization of an ancestral transcription factor binding site due to epistatic interactions with derived binding sites."},
  {name: "epithelial mesenchymal transition", description: "Epithelial mesenchymal transition (EMT) is a process where epithelial cells lose their cell polarity and cell-cell adhesion, and gain migratory and invasive properties to become mesenchymal stem cells."},
  {name: "epithelial transformation", description: "Epithelial transformation is the process by which normal epithelial cells acquire malignant properties."},
  {name: "Epithelial-mesenchymal transition (EMT)", description: "Epithelial-mesenchymal transition (EMT) is a process where epithelial cells lose their characteristics and acquire mesenchymal, stem-like features, playing a critical role in cancer metastasis."},
  {name: "Epithelial-to-mesenchymal transition (EMT)", description: "Epithelial-to-mesenchymal transition (EMT) is a process by which epithelial cells lose their cell polarity and cell-cell adhesion, and gain migratory and invasive properties to become mesenchymal stem cells."},
  {name: "epithelial-to-mesenchymal transition (EMT) disruption", description: "Disruption of epithelial-to-mesenchymal programming was seen irrespective of the RT phenotype in HepG2 cells expressing L1."},
  {name: "ERV-specific repression", description: "ERV-specific repression is a targeted mechanism that inhibits the expression and activity of specific endogenous retrovirus subfamilies."},
  {name: "erythropoiesis", description: "The process of red blood cell production."},
  {name: "Escape from repression", description: "The process by which retrotransposons mutate to evade host repression mechanisms."},
  {name: "escape from suppression", description: "The process by which LINE-1 elements become transcriptionally active and mobile when epigenetic repression is relaxed."},
  {name: "ESCRT complex interaction", description: "ESCRT (endosomal sorting complex required for transport) complex interaction refers to the conserved interaction between LINE-1 and the host ESCRT membrane budding machinery, which facilitates L1 replication."},
  {name: "Establish topological domain structure", description: "The process of defining the boundaries and organization of megabase-sized chromatin interaction domains in the genome."},
  {name: "Esterase (ES) domain function", description: "A domain encoded in ORF1 of LINEs in the CR1 and L2 clades that enhances retrotransposition."},
  {name: "evasion of capture", description: "The process by which transposons, through nucleotide substitutions, avoid recognition and silencing by host defense proteins."},
  {name: "Event-free survival", description: "Event-free survival is the length of time after treatment during which a patient remains free of specific negative events (e.g., disease progression)."},
  {name: "Evolution", description: "Evolution is the process of change in heritable characteristics of biological populations over successive generations, which may be driven by mechanisms like retrotransposition."},
  {name: "evolution of gene regulation", description: "Evolution of gene regulation refers to the changes in regulatory mechanisms over evolutionary time."},
  {name: "Evolution of microRNA family", description: "The process by which a family of microRNAs, such as hsa-mir-548ac, evolved from a transposable element."},
  {name: "Evolution of transposon elements", description: "The evolutionary development and diversification of transposable elements within genomes."},
  {name: "Evolutionary amplification", description: "The process by which transposable elements increase their copy number within a genome over evolutionary time."},
  {name: "Evolutionary arms race", description: "The evolutionary arms race describes the dynamic conflict between transposable elements and host defense mechanisms, leading to co-evolution."},
  {name: "evolutionary conflict", description: "Evolutionary conflict refers to the ongoing battle between transposons and host repressor mechanisms across species."},
  {name: "Evolutionary conservation", description: "Evolutionary conservation refers to the preservation of a specific genomic feature, such as the distribution pattern of transposable elements, across different species over time."},
  {name: "evolutionary fine-tuning of transcriptome", description: "A hypothesized role where L1 can serve as an evolutionary fine-tuner of the human transcriptome."},
  {name: "evolutionary processes", description: "Evolutionary processes are mechanisms that drive genetic change and adaptation over time."},
  {name: "Exaptation", description: "Exaptation is the process by which a genomic sequence, such as an intronic sequence, acquires a new function."},
  {name: "Exaptation as promoters", description: "The evolutionary process by which transposon sequences are co-opted to serve as gene promoters."},
  {name: "exchange between repetitive elements", description: "Exchange between repetitive elements refers to recombination events occurring between dispersed repetitive sequences in the genome."},
  {name: "excision of selection cassette", description: "Excision of a selection cassette is the removal of a DNA segment containing selectable marker genes after they have served their purpose in genetic manipulation, allowing for seamless genome editing."},
  {name: "Excision reaction", description: "Excision reaction is the process by which a transposon is cut out from its original genomic location."},
  {name: "exit from quiescence", description: "The process by which a cell, such as a haematopoietic stem cell, transitions from a dormant, non-dividing state to an active, cycling state."},
  {name: "Exogenous retroelement integration", description: "The process by which retroelements originating from outside the cell are incorporated into the host genome."},
  {name: "Exogenous retrovirus replication blockade", description: "Exogenous retrovirus replication blockade refers to the inhibition of replication of infectious retroviruses entering from outside the body."},
  {name: "exon definition", description: "Exon definition is a traditional molecular mechanism that may explain retroelement mutagenic effects."},
  {name: "Exon deletion", description: "Exon deletion is the loss of one or more exons from a gene, potentially disrupting its function."},
  {name: "Exon derivation", description: "Exon derivation refers to the process by which a genomic sequence, such as a transposon, evolves to become part of a gene's coding exon."},
  {name: "Exon duplication", description: "Exon duplication is a genomic event involving the copying of one or more exons."},
  {name: "Exon insertion", description: "Exon insertion is a genetic alteration where an extra exon is incorporated into a gene's transcript."},
  {name: "Exon inversion", description: "Exon inversion is a structural variant where the orientation of an exon is reversed relative to its normal sequence."},
  {name: "exon selection", description: "Exon selection is the process by which specific exons are included or excluded from the mature mRNA during splicing."},
  {name: "Exon shuffling", description: "Exon shuffling is a mechanism for the evolution of new genes, involving the mobilization and insertion of exons into existing genes."},
  {name: "Exon skipping", description: "Exon skipping is a splicing defect where an exon is omitted from the mature mRNA."},
  {name: "exon transduction", description: "A process where a transposon captures and mobilizes exonic sequences from a host gene during its retrotransposition."},
  {name: "Exon trapping", description: "Exon-trapping is a mechanism where an intronic SVA element can capture and incorporate upstream exons through aberrant splicing."},
  {name: "Exon-acquisition", description: "Exon-acquisition is the evolutionary process by which new exons are added to a gene."},
  {name: "Exon-interrupting insertion", description: "Exon-interrupting insertion is a type of mobile element insertion that disrupts a protein-coding exon."},
  {name: "Exonic insertion", description: "Exonic insertion refers to the insertion of a transposon into the coding region of a gene."},
  {name: "exonic insertions causing loss-of-function mutations", description: "A mechanism where SVA insertions into exons disrupt gene function."},
  {name: "Exonization", description: "Exonization is the process by which transposable elements (TEs) are incorporated into mature mRNA transcripts, potentially creating new exons."},
  {name: "exonization using cryptic splice sites", description: "Exonization using cryptic splice sites is a mechanism by which retroelements interfere with gene expression."},
  {name: "Expand genomic space", description: "SINEs substantially increase the amount of non-coding or regulatory sequences in the genome."},
  {name: "Expansion", description: "Expansion refers to the increase in copy number of a genetic element within a genome."},
  {name: "Expressed single nucleotide variation (SNV)", description: "Expressed single nucleotide variation (SNV) refers to a nucleotide change present in the RNA transcripts of a genetic element."},
  {name: "Expression", description: "Expression refers to the process by which genetic information is used to synthesize a functional gene product, such as RNA or protein."},
  {name: "Expression and mobilization", description: "The expression and subsequent mobilization of transposable elements can exert pathological effects on their hosts."},
  {name: "Expression correlation with nearby genes", description: "Expression correlation with nearby genes describes a statistical relationship between the expression levels of repetitive elements and adjacent genes."},
  {name: "expression dysregulation", description: "Abnormal expression levels of genes, either overexpression or underexpression."},
  {name: "Expression in cancer cells", description: "Expression in cancer cells refers to the aberrant transcription and translation of genes specifically within tumor cells."},
  {name: "Expression in early embryos", description: "The process of transposons being transcribed and producing RNA in early embryonic stages."},
  {name: "Expression in immune cells", description: "The expression of transposon-encoded proteins, such as L1 ORF1p (p40), within specific immune cell populations."},
  {name: "Expression level variation", description: "Expression level variation refers to changes in the transcriptional output of genetic elements, such as transposons."},
  {name: "Expression modulation", description: "The process by which LINE-1 retrotransposons can alter the expression levels of genes."},
  {name: "Expression modulation in immune system activation", description: "The change in expression levels of LTR retrotransposons in response to immune system activation, such as by lipopolysaccharide."},
  {name: "expression of genetic information", description: "Expression of genetic information is the process by which information from a gene is used to synthesize a functional gene product, such as RNA or protein."},
  {name: "expression of truncated ORF1 proteins", description: "The expression of truncated ORF1 proteins from L1 loci containing stop codons in their ORF1 sequence."},
  {name: "Expression profiling", description: "The identification and quantification of transcriptionally active genomic loci for SINE transcripts at single-locus resolution."},
  {name: "Expression quantitative trait loci (eQTL) regulation", description: "eQTL regulation refers to the process by which genetic variants influence the expression levels of genes."},
  {name: "Expression regulation", description: "Expression regulation refers to the control of gene or transposon transcription, often involving transcription factors and epigenetic modifications."},
  {name: "Expression suppression", description: "Expression suppression refers to the inhibition of protein expression, such as that of L1 proteins."},
  {name: "Expression up-regulation", description: "Expression up-regulation refers to an increase in the level of gene or element transcription."},
  {name: "extensive secondary structure formation", description: "Extensive secondary structure formation refers to the folding of nucleic acid sequences into complex intramolecular structures."},
  {name: "Extinction", description: "Extinction refers to the cessation of proliferation and eventual disappearance of a transposable element family from active circulation in a genome."},
  {name: "Extra nucleotide addition", description: "Extra nucleotide addition refers to the presence of a short stretch of non-templated nucleotides at the 5' end of some new L1 insertions, potentially resulting from template-jumping by the L1-encoded reverse transcriptase."},
  {name: "Extra nucleotide insertion", description: "Extra nucleotide insertion refers to the addition of non-templated nucleotides during the integration of a retrotransposon."},
  {name: "extracellular vesicle (EV) secretion", description: "Extracellular vesicle secretion is the process by which cells release membrane-bound vesicles into the extracellular space."},
  {name: "Extracellular vesicle-mediated delivery", description: "Extracellular vesicle-mediated delivery is a mechanism by which RNA transcripts, including those from retrotransposons, are packaged into vesicles (exosomes and microvesicles) and transferred to recipient cells."},
  {name: "Extrachromosomal DNA accumulation", description: "Extrachromosomal DNA accumulation refers to the build-up of DNA molecules, such as L1 cDNA, that are not integrated into the host cell's chromosomes."},
  {name: "Extrusion during NETosis", description: "Extrusion during NETosis refers to the release of cellular contents, including ORF1p granules, during the formation of neutrophil extracellular traps (NETs)."},
  {name: "Facilitating embryonic stem cell self-renewal", description: "Facilitating embryonic stem cell self-renewal is the process of maintaining the pluripotent state and proliferative capacity of embryonic stem cells."},
  {name: "Facilitating preimplantation development", description: "Facilitating preimplantation development is the process of supporting the growth and differentiation of the embryo before implantation in the uterus."},
  {name: "Factor delivery", description: "Factor delivery refers to the methods and systems used to introduce reprogramming factors into cells for iPSC generation."},
  {name: "Fatty acid metabolism pathway", description: "Fatty acid metabolism pathway involves the synthesis and degradation of fatty acids, which can be regulated in cancer cells."},
  {name: "Feedback inhibition of retrotransposition", description: "Feedback inhibition of retrotransposition is a cellular adaptation where chronic expression of retrotransposons leads to changes that ultimately restrict their own mobility."},
  {name: "field cancerization", description: "Field cancerization is a phenomenon where a tissue develops multiple patches of cells with genetic and/or epigenetic alterations, increasing the risk of cancer development in that area."},
  {name: "First strand cDNA synthesis", description: "First strand cDNA synthesis is a step in the retrotransposition process, which can occur from an internal priming event."},
  {name: "First-strand nicking", description: "First-strand nicking is a rapid step in the transposition reaction of Hsmar1."},
  {name: "fixation", description: "Fixation is the process by which a genetic variant, such as a transposon insertion, becomes permanently established in a population."},
  {name: "Fixation of restrictive alleles", description: "Fixation of restrictive alleles is a mechanism where specific genetic variants that inhibit transposon activity become established in a population, leading to the element's extinction."},
  {name: "flank transduction", description: "The capture and mobilization of genomic sequences flanking a transposon during its insertion."},
  {name: "Fluorescence in-situ hybridization (FISH)", description: "A technique used to visualize the genomic distribution of transposons from a chromosomal perspective."},
  {name: "Formation of chimeric retroelements", description: "The generation of non-canonical retropseudogenes composed of DNA copies from different cellular transcripts fused together."},
  {name: "Formation of copy-number variant (CNV) deletions", description: "The process leading to deletions that result in a variation in the number of copies of a particular genomic segment."},
  {name: "formation of G-quadruplex DNA", description: "The ability of SVA sequences, particularly in the central tandem repeat and 5' hexamer, to form specific secondary DNA structures called G-quadruplexes."},
  {name: "Formation of L1 RNA-DNA hybrids", description: "Formation of L1 RNA-DNA hybrids is a step in the LINE-1 retrotransposition cycle involving the annealing of L1 RNA to its complementary DNA strand."},
  {name: "Formation of persistent DNA damage foci", description: "Formation of persistent DNA damage foci is the accumulation of DNA repair proteins at sites of unrepaired DNA damage."},
  {name: "Formation of processed pseudogenes", description: "The generation of pseudogenes through the retrotransposition of cellular RNAs, such as snRNAs, mediated by LINE-1."},
  {name: "formation of ribonucleoprotein complex", description: "The assembly of a complex consisting of RNA and proteins, which is essential for the retrotransposition process of LINE-1."},
  {name: "Formation of RNA-protein complexes (RNP)", description: "The process by which RNA-binding proteins, such as L1-ORF1p, interact with RNA to form ribonucleoprotein complexes."},
  {name: "Formation of secondary structure", description: "Formation of secondary structure refers to the folding of nucleic acid sequences into specific shapes, such as hairpins or loops."},
  {name: "Formation of tightly compacted nucleic acid-bound complex", description: "A slower phase of ORF1p binding to ssDNA, resulting in a highly compacted state, which is associated with retrotransposition competence."},
  {name: "forming chimeric L1 transcripts", description: "Forming chimeric L1 transcripts involves the creation of fusion RNAs that combine L1 sequences with host gene sequences."},
  {name: "forward genetic screen", description: "Forward genetic screen is a method to identify genes involved in a biological process by analyzing the phenotypes of random mutations."},
  {name: "Frameshift mutation", description: "Frameshift mutation is a type of genetic mutation caused by insertions or deletions that shift the reading frame of a gene."},
  {name: "Full-length insertion", description: "Full-length insertion is a type of de novo LINE-1 insertion containing the complete element, including ORF1 and ORF2."},
  {name: "full-length replication", description: "Full-length replication refers to the successful copying of the entire LINE-1 element during retrotransposition."},
  {name: "Functional constraint", description: "Evolutionary pressure that preserves the function of a DNA sequence, limiting its rate of change."},
  {name: "Functional diversification of the brain", description: "L1-derived transcripts contribute to the functional diversification of the human brain."},
  {name: "functional diversity between cells", description: "Functional diversity between cells refers to differences in the roles or activities of different cells."},
  {name: "Functional enrichment analysis bias", description: "Standard bioinformatic pipelines that disregard multimappers introduce inherent biases into routine functional enrichment analyses of genomic and transcriptomic data."},
  {name: "Functional genomics", description: "Functional genomics is the study of gene function and interaction on a genome-wide scale."},
  {name: "functional protein provision", description: "Functional protein provision refers to the process where transposons encode proteins that are utilized by the host."},
  {name: "fusion transcript formation", description: "Fusion transcript formation is the process by which sequences from different genes or genetic elements are joined together in a single RNA molecule."},
  {name: "G-quadruplex (G4) formation", description: "G-quadruplex (G4) formation refers to the folding of guanine-rich DNA sequences into stable secondary structures that can impede transcription."},
  {name: "G-quadruplex (G4) structure formation", description: "G-quadruplex (G4) structures are non-canonical nucleic acid secondary structures formed in guanine-rich sequences."},
  {name: "G-quadruplex formation", description: "G-quadruplexes (G4s) are non-canonical nucleic acid structures that form in guanine (G)-rich genomic regions."},
  {name: "G-to-A hypermutation", description: "G-to-A hypermutation is a cytidine deamination-mediated mutation pattern often associated with APOBEC3 protein activity on viral or retrotransposon substrates."},
  {name: "G0/G1 cell cycle arrest", description: "G0/G1 cell cycle arrest is a halt in the cell cycle at the G0 or G1 phase, preventing cell division."},
  {name: "G4 DNA formation", description: "G4 DNA formation refers to the ability of certain DNA sequences to fold into non-B DNA structures called G-quadruplexes."},
  {name: "Gain in chromatin accessibility", description: "Gain in chromatin accessibility refers to the opening of chromatin structure, making DNA more accessible for transcription or other processes."},
  {name: "gain of function", description: "Gain of function refers to a mutation that confers new or enhanced activity on a gene product."},
  {name: "GA→AA mutation", description: "GA→AA mutation is a specific G-to-A mutation pattern induced by APOBEC3F and other APOBEC3 members within the nucleotide context GA."},
  {name: "gene activation", description: "Gene activation is a genetic event caused by the insertion of transposable elements."},
  {name: "Gene activity regulation", description: "Gene activity regulation refers to the process where LINE-1 repeats affect the activity of genes."},
  {name: "Gene amplification", description: "Gene amplification is the process by which the copy number of a gene increases within a genome."},
  {name: "Gene co-expression modulation", description: "Gene co-expression modulation refers to the coordinated regulation of multiple genes' expression levels."},
  {name: "Gene conversion", description: "Gene conversion is a non-reciprocal transfer of genetic information from one DNA sequence to another."},
  {name: "Gene conversion between LTRs", description: "A non-reciprocal recombination process that can homogenize the sequences of the two LTRs of a retrotransposon, reducing their divergence."},
  {name: "gene conversion-mediated deletion", description: "Gene conversion-mediated deletion is a mechanism of genome alteration created by retrotransposable elements."},
  {name: "Gene correction", description: "Gene correction refers to the process of precisely editing a gene to fix disease-causing mutations."},
  {name: "Gene creation", description: "Gene creation refers to the formation of novel genes through mechanisms such as retrotransposition and domain fusion."},
  {name: "Gene deletion", description: "Gene deletion is a mutation where a part of a chromosome or a sequence of DNA is missing."},
  {name: "Gene delivery", description: "Gene delivery is the process of introducing foreign genetic material into host cells."},
  {name: "Gene disruption", description: "Gene disruption refers to the process where a transposon insertion interferes with the normal structure or function of a gene."},
  {name: "Gene downregulation", description: "Gene downregulation refers to the reduction in the level of gene expression."},
  {name: "Gene duplication", description: "Gene duplication is an event that creates an extra copy of a gene or genomic region."},
  {name: "gene dysregulation", description: "Gene dysregulation refers to the abnormal expression or function of genes."},
  {name: "Gene editing", description: "Gene editing is a technique used to modify the DNA sequence of a genome, such as correcting mutations."},
  {name: "Gene engineering", description: "Gene engineering involves the modification of an organism's genetic material, such as T cells, to express specific therapeutic constructs like chimeric antigen receptors (CARs)."},
  {name: "gene expression", description: "Gene expression is the process by which information from a gene is used to synthesize a functional gene product, such as a protein."},
  {name: "Gene expression ablation", description: "Gene expression ablation refers to the complete loss of gene expression."},
  {name: "gene expression alteration", description: "Gene expression alteration refers to changes in the level or pattern of gene expression."},
  {name: "gene expression characterization", description: "The process of determining the complete set of genes expressed in a specific tissue or condition."},
  {name: "gene expression control", description: "Gene expression control refers to the regulation of the transcription and translation of a gene."},
  {name: "Gene expression depletion", description: "Gene expression depletion refers to a significant reduction in the level of mRNA or protein produced from a specific gene."},
  {name: "gene expression deregulation", description: "Gene expression deregulation refers to the abnormal or altered expression levels of genes, which can contribute to disease states such as cancer."},
  {name: "Gene expression disruption", description: "Gene expression disruption refers to the alteration of normal gene transcription or translation levels."},
  {name: "Gene expression disturbances", description: "Gene expression disturbances refer to abnormal changes in the levels or patterns of gene transcription, which can contribute to disease states like cancer."},
  {name: "Gene expression during oogenesis", description: "Gene expression during oogenesis refers to the transcription of specific genes in the final stages of human oocyte maturation."},
  {name: "Gene expression fine-tuning", description: "Gene expression fine-tuning refers to the subtle modulation of gene expression levels."},
  {name: "gene expression influence", description: "Gene expression influence refers to the effect that transposable elements can have on the expression levels of neighboring genes."},
  {name: "gene expression modification", description: "Gene expression modification involves changes in the level or pattern of gene expression, which can be differentially influenced by LINE-1 elements."},
  {name: "Gene expression modulation", description: "Gene expression modulation refers to the process of altering the level or pattern of gene expression."},
  {name: "gene expression reduction", description: "Gene expression reduction refers to a decrease in the level of RNA or protein produced from a specific gene."},
  {name: "Gene expression regulation", description: "The process by which the information from a gene is used to direct the synthesis of a functional gene product."},
  {name: "Gene expression regulation after irradiation", description: "The process by which LINE-1 retrotransposition events regulate the expression of different genes following X-ray irradiation."},
  {name: "Gene expression remodeling", description: "The process by which LTRs supply promoters and first exons, thereby altering gene expression patterns."},
  {name: "gene expression repression", description: "Gene expression repression is the process of reducing or silencing the transcription of a gene."},
  {name: "gene expression reprogramming", description: "Gene expression reprogramming refers to the alteration of the pattern of genes expressed by a cell."},
  {name: "Gene expression suppression", description: "Gene expression suppression is the process of reducing the expression level of a specific gene."},
  {name: "gene family expansion", description: "Gene family expansion refers to the process by which multiple copies of a gene are generated from a single ancestral gene over evolutionary time."},
  {name: "gene formation by shuffling", description: "Gene formation by shuffling is a mechanism for creating new genes by combining parts of pre-existing transcribed sequences through processes like template switching during retrotransposition."},
  {name: "gene function disruption", description: "Gene function disruption refers to the impairment of normal gene activity, which can be critical for processes like embryogenesis."},
  {name: "gene fusion", description: "Gene fusion is the process by which parts of two separate genes are joined to form a new chimeric gene."},
  {name: "Gene inactivation", description: "Gene inactivation refers to the loss of function of a gene, which can be caused by mechanisms such as insertional mutagenesis by retrotransposable elements."},
  {name: "gene inactivation by direct disruption", description: "A mechanism by which transposons can inactivate genes through direct insertion and disruption of the coding sequence."},
  {name: "Gene insertion", description: "Gene insertion is the process of introducing a new gene into a genome, often facilitated by vectors like transposons."},
  {name: "Gene integration", description: "Gene integration is the process of inserting exogenous DNA into a host genome, which can be mediated by transposon systems."},
  {name: "Gene introduction", description: "Gene introduction refers to the process of inserting exogenous genes into a genome."},
  {name: "Gene knockout", description: "Gene knockout is a genetic technique that inactivates a specific gene."},
  {name: "Gene loss", description: "Gene loss is the process by which a gene is deleted or becomes non-functional in a genome."},
  {name: "gene mutation", description: "Gene mutation is a change in the DNA sequence of a gene, which can alter its function."},
  {name: "gene mutations", description: "Gene mutations are alterations in the DNA sequence that can affect gene function."},
  {name: "Gene organization", description: "Gene organization refers to the arrangement and structure of genes within the genome."},
  {name: "Gene overexpression", description: "Gene overexpression refers to the production of abnormally high levels of a gene product, often due to regulatory changes."},
  {name: "gene perturbation", description: "Gene perturbation refers to the disruption of gene integrity, which can occur when a transposon inserts into or near a gene."},
  {name: "gene promoter DNA methylation", description: "Gene promoter DNA methylation is an epigenetic modification involving the addition of a methyl group to cytosine residues in CpG islands near gene transcription start sites, often associated with transcriptional repression."},
  {name: "Gene regulation", description: "The process of controlling the rate or manner of gene expression."},
  {name: "gene regulatory change", description: "Gene regulatory change refers to TE-induced alterations in gene expression, such as down-regulation."},
  {name: "Gene regulatory differences", description: "Gene regulatory differences refer to inter-individual variations in the expression levels of genes."},
  {name: "Gene regulatory functions", description: "SINE ncRNAs possess novel gene regulatory functions."},
  {name: "gene regulatory mechanism", description: "A gene regulatory mechanism is a process that controls the expression of genes."},
  {name: "gene regulatory network diversification", description: "The process of increasing the complexity and variation in the interactions between genes and their regulators, contributing to morphological innovation."},
  {name: "gene regulatory network innovation", description: "The process of creating new or modified gene regulatory networks, often through the introduction of novel regulatory elements."},
  {name: "gene regulatory network organization", description: "The organization of gene regulatory networks involves the spatial and functional arrangement of cis-regulatory elements and DNA binding sites."},
  {name: "Gene regulatory network rewiring", description: "Gene regulatory network rewiring is the process by which changes in transcription factor binding sites alter the connections and outputs of gene regulatory networks."},
  {name: "gene repression", description: "Gene repression is the process of decreasing or inhibiting the expression of a gene."},
  {name: "gene silencing", description: "Gene silencing refers to the repression of gene expression, preventing the production of the gene's protein product."},
  {name: "Gene silencing and translational repression", description: "The biological function performed by miRNAs, generally through the RNA interference pathway."},
  {name: "gene tagging", description: "Gene tagging is a technique used to identify and study genes."},
  {name: "Gene targeting", description: "Gene targeting is a technique used to modify a specific gene sequence in the genome, often for research or therapeutic purposes."},
  {name: "Gene therapy", description: "Gene therapy is an experimental technique that uses genes to treat or prevent disease."},
  {name: "Gene therapy vector", description: "Gene therapy vectors are engineered vehicles designed to deliver therapeutic genes to specific locations in the genome."},
  {name: "gene transactivation", description: "Gene transactivation is the process by which a transcription factor like p53 activates the expression of target genes."},
  {name: "gene transcription", description: "Gene transcription is the process of copying a segment of DNA into RNA by the enzyme RNA polymerase."},
  {name: "gene transfer", description: "Gene transfer is the process of introducing foreign genetic material into a cell."},
  {name: "Gene trap", description: "A gene trap is a method that uses a transposon to randomly insert a reporter gene into the genome, creating gene fusions to identify gene function or interactions."},
  {name: "gene upregulation", description: "Gene upregulation is the process of increasing the expression of a gene."},
  {name: "Gene-breaking", description: "A mechanism where a full-length L1 element inserted in antisense orientation into an intron splits the host gene's transcript into two smaller transcripts."},
  {name: "Gene-trapping", description: "Gene-trapping is a mechanism where an inserted element disrupts normal gene transcription."},
  {name: "Generate new parts of genes", description: "SINEs can contribute to the creation of novel gene components or exons."},
  {name: "generating antisense and/or regulatory noncoding RNAs", description: "Generating antisense and/or regulatory noncoding RNAs is a mechanism by which retroelements can promote or inhibit gene transcription."},
  {name: "generating endo-siRNAs", description: "Generating endo-siRNAs refers to the production of endogenous small interfering RNAs from transposon transcripts, which can silence gene expression."},
  {name: "generating insertion mutations", description: "The process by which retrotransposons create new mutations in the genome through their insertion."},
  {name: "generating structural variations", description: "Generating structural variations refers to the creation of large-scale genomic alterations, such as insertions or deletions."},
  {name: "Generation of 5' extra nucleotides", description: "Generation of 5' extra nucleotides is a mechanism where integrants of LINE elements produce extra nucleotides at their 5' ends that originate from flanking sequences."},
  {name: "Generation of chimeric L1s", description: "A form of genetic instability resulting from the resolution of L1 cDNA retrotransposition intermediates."},
  {name: "generation of differentially methylated regions (DMR)", description: "A mechanism by which retrotransposons can influence the epigenetic landscape of the host genome."},
  {name: "generation of germinal and somatic heterogeneity", description: "This process involves the creation of genetic diversity within germline and somatic cell populations, partly through transposable element activity."},
  {name: "generation of long non-coding RNAs (lncRNAs)", description: "Transposable elements can give rise to or be incorporated into long non-coding RNAs, which are transcripts longer than 200 nucleotides with limited protein-coding potential."},
  {name: "Generation of mammalian-specific genes", description: "The process by which LTR retrotransposons contribute to the creation of novel, mammalian-specific genes."},
  {name: "Generation of neurons' plasticity", description: "Generation of neurons' plasticity refers to the process of forming or modifying neural connections, which underlies learning and memory."},
  {name: "Generation of novel transcript variants", description: "The process by which new forms of RNA transcripts are created, potentially altering gene function or regulation."},
  {name: "Generation of processed pseudogenes", description: "A mechanism by which LINE-1 retrotransposition creates processed pseudogenes."},
  {name: "generation of transcriptome diversity", description: "The process of creating a wide variety of RNA transcripts from the genome, contributing to functional complexity."},
  {name: "genes and HERVs/MaLRs modulation", description: "The alteration or regulation of gene and transposon expression levels or activity."},
  {name: "Genetic alteration", description: "Changes in the DNA sequence, which can be caused by events such as retrotransposition."},
  {name: "genetic changes in repetitive sequences", description: "Genetic changes in repetitive sequences refer to alterations in the DNA sequence of repetitive genomic regions."},
  {name: "Genetic correction", description: "Genetic correction refers to the process of repairing or replacing a defective gene sequence to restore normal function."},
  {name: "Genetic damage", description: "Damage to the genome, which can be associated with retrotransposition."},
  {name: "Genetic defects", description: "Genetic defects refer to abnormalities in the genome that can be caused by LINE-1 activity."},
  {name: "genetic diversity", description: "Genetic diversity refers to the variation in genetic makeup within a population, which can be generated by active transposition events."},
  {name: "genetic diversity generation", description: "The process by which LINE-1 retrotransposition creates variation within and between individuals."},
  {name: "genetic diversity production", description: "Active transposons continue to produce genetic diversity in human populations."},
  {name: "Genetic drift", description: "Genetic drift is a mechanism of evolution that causes random changes in allele frequencies in small populations."},
  {name: "Genetic editing", description: "Genetic editing refers to the process of making precise modifications to the genome using technologies like CRISPR/Cas9 and transposon systems."},
  {name: "Genetic engineering", description: "Genetic engineering involves the direct manipulation of an organism's genes using biotechnology, such as introducing foreign DNA via vectors."},
  {name: "Genetic evolution", description: "Genetic evolution refers to the process by which the genetic makeup of a cell population changes over time, often through the accumulation of mutations."},
  {name: "genetic heterogeneity", description: "Genetic heterogeneity refers to the presence of diverse genetic alterations within a cell population or tumor."},
  {name: "genetic heterogeneity in tumors", description: "Genetic heterogeneity in tumors refers to the diversity of genetic alterations within a tumor."},
  {name: "Genetic information recycling", description: "The process by which LTRs facilitate the conversion of processed pseudogenes into functional mRNAs or regulatory lncRNAs."},
  {name: "genetic instability", description: "Genetic instability refers to a high frequency of mutations within the genome of a cellular lineage."},
  {name: "Genetic load", description: "Genetic load refers to the burden of deleterious mutations or elements, such as active transposons, that reduce the fitness of a population."},
  {name: "Genetic manipulation", description: "Genetic manipulation refers to the deliberate modification of an organism's genetic material using biotechnology."},
  {name: "Genetic mapping", description: "Genetic mapping is a technique used to determine the relative positions of genes on chromosomes based on recombination frequencies."},
  {name: "Genetic marker", description: "Genetic marker is a new class of marker for human evolution studies, represented by the insertion of mobile elements like L1 into the genome."},
  {name: "Genetic modification", description: "Genetic modification refers to the process of altering the genetic material of an organism, such as introducing a chimeric antigen receptor into T cells."},
  {name: "Genetic modification of immune cells", description: "Genetic modification of immune cells refers to the process of altering the genome of immune cells, such as T cells, to confer new functions, such as expressing chimeric antigen receptors (CARs)."},
  {name: "Genetic mutation", description: "Genetic mutation refers to a permanent alteration in the DNA sequence that can be caused by various mechanisms, including retrotransposon insertion."},
  {name: "genetic rearrangement", description: "Genetic rearrangement refers to structural changes in the genome, such as deletions, insertions, inversions, or translocations."},
  {name: "Genetic rearrangements", description: "Genetic rearrangements are structural changes in the genome, such as deletions, duplications, inversions, or translocations."},
  {name: "Genetic screening", description: "Genetic screening is the process of testing individuals to identify those at risk for a genetic disorder or to detect genetic alterations."},
  {name: "genetic switches", description: "Mechanisms that control the on/off state of gene expression, similar to those used in immunoglobulin and protocadherin gene families."},
  {name: "genetic variability", description: "Genetic variability refers to the diversity in genetic makeup among individuals or within a population."},
  {name: "genetic variation", description: "Genetic variation refers to differences in DNA sequence among individuals, which can be caused by retrotransposition."},
  {name: "genome annotation", description: "The process of identifying the locations and functions of genes and other features in a genome sequence."},
  {name: "genome architecture", description: "Genome architecture refers to the three-dimensional organization and structural features of the genome."},
  {name: "Genome damage", description: "Genome damage refers to the disruption of the integrity of the genome."},
  {name: "Genome defence", description: "Genome defence mechanisms are cellular processes that suppress the activity of transposable elements to maintain genomic integrity."},
  {name: "genome defence responses", description: "Genome defence responses are cellular mechanisms that protect genomic integrity, such as silencing repetitive elements."},
  {name: "Genome destabilization", description: "Genome destabilization refers to the process by which the stability of an organism's genome is compromised, often leading to increased mutation rates or structural variations."},
  {name: "Genome diversity and variation", description: "Genome diversity and variation refer to the differences in genetic makeup among individuals or species, which can be influenced by factors like retrotransposon activity."},
  {name: "genome dynamics", description: "Genome dynamics refers to the processes that cause changes in genome structure and organization over time."},
  {name: "Genome dynamics shaping", description: "Genome dynamics shaping refers to the active processes that contribute to the structural and functional evolution of a genome."},
  {name: "Genome editing", description: "Genome editing is a technology that allows scientists to change an organism's DNA."},
  {name: "Genome engineering", description: "Genome engineering refers to the targeted modification of an organism's genetic material."},
  {name: "genome evolution", description: "Genome evolution refers to the processes that change the structure and content of genomes over time."},
  {name: "genome expansion", description: "Genome expansion refers to the increase in genome size, which can be driven by retrotransposon activity."},
  {name: "Genome function", description: "The biological operations and processes carried out by the genome, which LINE-1 elements are suggested to have affected."},
  {name: "Genome innovation", description: "The process of acquiring new genes, new gene isoforms, or changes in gene expression patterns that contribute to genome evolution."},
  {name: "Genome insertion", description: "The mechanism by which retrotransposons integrate their cDNA copies into new genomic locations."},
  {name: "genome instability", description: "Genomic instability refers to an increased tendency for alterations in the genome during cell division, including mutations, rearrangements, and aneuploidy."},
  {name: "genome instability suppression", description: "Genome instability suppression refers to mechanisms that prevent or reduce the occurrence of genomic rearrangements and damage."},
  {name: "Genome integration", description: "Genome integration is the process by which a transposon inserts its DNA copy into the host genome."},
  {name: "Genome integrity", description: "Genome integrity refers to the maintenance of the structural and functional stability of the genome."},
  {name: "Genome integrity alteration", description: "Disruption or damage to the normal structure and stability of the genome."},
  {name: "genome integrity defense", description: "Genome integrity defense encompasses the cellular mechanisms that protect the genome from damage, such as uncontrolled transposon mobilization."},
  {name: "genome integrity disruption", description: "L1 relies upon L1-encoded endonuclease and reverse transcriptase (RT) activities to compromise genome integrity."},
  {name: "genome integrity maintenance", description: "Genome integrity maintenance involves processes that prevent or repair alterations to the DNA sequence to ensure genetic stability."},
  {name: "Genome integrity protection", description: "Genome integrity protection involves cellular mechanisms that prevent DNA damage and maintain genomic stability, including suppression of transposable element activity."},
  {name: "Genome invasion", description: "Genome invasion refers to the process by which transposable elements (TEs) proliferate and spread within a host genome."},
  {name: "Genome manipulation", description: "Genome manipulation refers to the use of tools to alter the genetic material of an organism."},
  {name: "Genome mapping", description: "Genome mapping is a technique used to determine the location of genes and other sequences on a chromosome."},
  {name: "genome mobilization", description: "Genome mobilization refers to the process of moving genetic elements within the genome, often mediated by transposon machinery."},
  {name: "genome modeling", description: "The process by which retrotransposons shape and modify the structure of the genome."},
  {name: "Genome modification", description: "Genome modification refers to the alteration of the genome's size, structure, or sequence content."},
  {name: "genome mutagenesis", description: "Genome mutagenesis refers to the process of introducing mutations into the genome."},
  {name: "genome mutation", description: "A change in the DNA sequence, which can include deletions and point mutations."},
  {name: "Genome organization", description: "Genome organization refers to the spatial and functional arrangement of DNA sequences within the nucleus."},
  {name: "Genome organization, structure and function", description: "Retroelements play a crucial role in shaping the organization, structure, and function of the genome."},
  {name: "Genome plasticity", description: "Genome plasticity refers to the ability of the genome to undergo structural changes, such as rearrangements, insertions, or deletions."},
  {name: "Genome plasticity and evolution", description: "Genome plasticity and evolution refers to the ability of genomes to change and adapt over time, influenced by various genetic elements."},
  {name: "genome plasticity regulation", description: "L1 is established as a key regulator of genome plasticity via mechanisms independent of RT activity."},
  {name: "Genome rearrangement", description: "Genome rearrangement refers to the process of altering the structure of the genome, such as through the insertion or movement of genetic elements."},
  {name: "genome rearrangements", description: "Genome rearrangements are structural changes in the genome, such as deletions, duplications, inversions, or translocations."},
  {name: "genome regulation", description: "Processes that control gene expression and maintain genomic stability."},
  {name: "Genome remodeling", description: "Genome remodeling involves structural and functional changes to the genome over evolutionary time."},
  {name: "Genome reprogramming", description: "Genome reprogramming refers to the process of altering gene expression patterns, often to a more embryonic state."},
  {name: "Genome shaping", description: "Genome shaping refers to the role of L1 retrotransposons in influencing the structure and evolution of mammalian genomes."},
  {name: "genome shuffling through recombination", description: "A process by which transposons can rearrange the genome via recombination events."},
  {name: "Genome size variation", description: "Genome size variation refers to differences in the total DNA content among individuals or populations of a species."},
  {name: "genome stability", description: "Genome stability is affected by retrotransposition."},
  {name: "Genome stability maintenance", description: "Genome stability maintenance refers to the cellular processes that prevent DNA damage and mutations, including against retroelement transposition."},
  {name: "Genome structural variation", description: "Genome structural variation refers to alterations in the genome structure, such as insertions, deletions, and rearrangements, which can be caused by retrotransposon activity."},
  {name: "Genome structure", description: "The organization and arrangement of genetic material, which LINE-1 elements are suggested to have affected."},
  {name: "Genome structure impact", description: "The process by which LINE-1 retrotransposition alters the architecture and sequence composition of mammalian genomes."},
  {name: "genome variation", description: "Genome variation refers to changes in the DNA sequence, including structural variations."},
  {name: "Genome-wide binding", description: "Genome-wide binding refers to the pattern of protein-DNA interactions across the entire genome."},
  {name: "Genome-wide defragmentation analysis", description: "A novel genome-wide analysis of transposable element organization and fragmentation used to estimate TE age independently of sequence divergence."},
  {name: "genome-wide demethylation", description: "Genome-wide demethylation refers to a global reduction in DNA methylation across the genome."},
  {name: "genome-wide gene expression regulation", description: "A proposed model where L1 affects gene expression across the entire genome by acting as a 'molecular rheostat' of target genes."},
  {name: "genome-wide hypomethylation", description: "Genome-wide hypomethylation is a widespread reduction in DNA methylation levels across the genome."},
  {name: "Genome-wide target profiling", description: "Genome-wide target profiling is a method to identify the chromosomal insertion sites of transposons across the genome."},
  {name: "genomic alterations", description: "Genomic alterations refer to changes in the DNA sequence, such as insertions and deletions."},
  {name: "Genomic architecture change", description: "Genomic architecture change refers to alterations in the structure and organization of the genome."},
  {name: "Genomic deletion", description: "Genomic deletion is the loss of a segment of DNA from a chromosome."},
  {name: "genomic deletions and rearrangements", description: "Structural variations in the genome involving the loss or reorganization of DNA sequences."},
  {name: "Genomic distribution", description: "The pattern of how transposons are arranged and located within a genome."},
  {name: "Genomic diversity", description: "Genomic diversity refers to the variation in DNA sequences among individuals within a species."},
  {name: "genomic diversity regulation", description: "Genomic diversity regulation involves processes that control the generation and maintenance of genetic variation within a genome."},
  {name: "Genomic DNA damage", description: "Genomic DNA damage refers to alterations in the DNA sequence, which can be induced by processes such as retrotransposition."},
  {name: "Genomic DNA deletion", description: "Genomic DNA deletion refers to the loss of DNA sequence at the target site during or as a consequence of a retrotransposition event."},
  {name: "Genomic DNA hypomethylation", description: "A reduction in the methylation level of genomic DNA, which can lead to increased gene expression and genomic instability."},
  {name: "genomic DNA instability", description: "Genomic DNA instability refers to an increased tendency for alterations in the genome, such as mutations or structural changes."},
  {name: "Genomic duplication", description: "Genomic duplication is a process that results in the copying of a segment of DNA, including genes and transposable elements."},
  {name: "Genomic evolution", description: "Genomic evolution encompasses the processes that drive changes in genome structure and content over time."},
  {name: "Genomic excision", description: "Genomic excision is the process by which a DNA transposon is cut out from its original genomic location."},
  {name: "Genomic expansion", description: "Genomic expansion refers to the increase in the number of specific genetic elements, such as LINE-1, within the genome."},
  {name: "Genomic functional change", description: "Genomic functional change refers to alterations in the activity or regulation of genomic elements, potentially affecting gene expression or other cellular processes."},
  {name: "Genomic functionality", description: "Genomic functionality refers to the acquisition of a beneficial role by a transposable element within the host genome."},
  {name: "genomic heterogeneity", description: "Genomic heterogeneity refers to the state where cells may have a different genetic makeup than others."},
  {name: "Genomic hypomethylation", description: "A reduction in the level of DNA methylation across the genome, often associated with increased transposon activity."},
  {name: "Genomic imprinting", description: "Genomic imprinting is an epigenetic process that leads to parent-of-origin-specific gene expression."},
  {name: "genomic innovation", description: "Genomic innovation refers to the generation of new genetic sequences or regulatory elements that contribute to genome evolution."},
  {name: "Genomic insertion", description: "Genomic insertion is the process by which a DNA sequence integrates into the genome."},
  {name: "genomic integration", description: "Genomic integration is the process by which a transposable element inserts a copy of itself into a new location in the host genome."},
  {name: "genomic integrity erosion", description: "Genomic integrity erosion refers to the slow degradation of genomic stability, which in the context of this paper is proposed to be caused by LINE-1 activity competing with double-strand break repair mechanisms."},
  {name: "Genomic invasion", description: "The process of HERV/LTRs invading the genome, during which regulatory elements may be gained or lost."},
  {name: "Genomic inversion", description: "Genomic inversion is a chromosomal rearrangement where a segment of DNA is reversed end to end."},
  {name: "Genomic inversions", description: "Genomic inversions are a form of genome instability where a segment of DNA is reversed end to end."},
  {name: "genomic library construction", description: "Genomic library construction is a molecular biology technique for cloning and representing the entire genome of an organism."},
  {name: "genomic LINE-1 methylation", description: "Genomic LINE-1 methylation is an epigenetic modification that typically represses the expression and activity of LINE-1 elements."},
  {name: "Genomic loss of SINEs", description: "The observed loss of SINE elements from genomes, potentially due to recombination events between them."},
  {name: "Genomic marker for evolutionary reconstruction", description: "The remnants of retrotransposon sequences serve as useful genomic markers for reconstructing the evolutionary history of duplicated gene families."},
  {name: "Genomic mosaicism", description: "Genomic mosaicism refers to the presence of two or more populations of cells with different genotypes in one individual, arising from postzygotic mutations."},
  {name: "genomic mutagenesis", description: "Genomic mutagenesis refers to the process of introducing mutations into the genome."},
  {name: "genomic mutation", description: "Changes in the DNA sequence, which can be caused directly by DNA damage or indirectly by the activation of mutagenic mobile elements."},
  {name: "Genomic plasticity", description: "Variation in genomic DNA sequences and alterations in the transcriptome of individual cells, potentially generated by new somatic L1 insertions."},
  {name: "Genomic polymorphism", description: "Genomic polymorphism refers to variations in the DNA sequence among individuals, which can serve as markers for population genetics studies."},
  {name: "Genomic rearrangement", description: "Genomic rearrangement is a structural change in the genome, such as deletions, duplications, inversions, or translocations."},
  {name: "Genomic rearrangements", description: "Genomic rearrangements are structural changes in the genome that can be caused by LINE-1 activity."},
  {name: "Genomic rearrangements via homologous recombination", description: "Genomic rearrangements can be caused by homologous recombination events between heterologous sites of identical L1 copies."},
  {name: "Genomic recombination", description: "Genomic recombination is the process by which genetic material is rearranged, often involving the exchange of DNA sequences."},
  {name: "Genomic remodeling", description: "Genomic remodeling refers to structural changes in the genome, such as rearrangements caused by transposon activity."},
  {name: "genomic stability", description: "Genomic stability refers to the maintenance of the integrity of the genome."},
  {name: "Genomic stability maintenance", description: "Genomic stability maintenance refers to the cellular processes that prevent mutations and preserve the integrity of the genome."},
  {name: "Genomic structural change", description: "Genomic structural change refers to alterations in the architecture of the genome, such as insertions, deletions, or rearrangements."},
  {name: "Genomic structural variation", description: "Genomic structural variation refers to large-scale differences in the DNA sequence of individuals, including deletions, duplications, and insertions."},
  {name: "Genomic variability", description: "Genomic variability refers to the diversity in DNA sequences among individuals or within an individual's cells."},
  {name: "genomic variation", description: "Genomic variation refers to differences in DNA sequence among individuals."},
  {name: "Genotoxic stress", description: "Genotoxic stress refers to conditions that damage DNA, such as the generation of double-stranded DNA breaks (DSBs)."},
  {name: "Genotoxicity", description: "Genotoxicity refers to the property of chemical agents or processes that damage the genetic information within a cell, potentially leading to mutations or cancer."},
  {name: "Genotyping", description: "The process of determining differences in the genetic makeup (genotype) of an individual by examining the individual's DNA sequence."},
  {name: "Germ line transmission", description: "The inheritance of endogenous retroviruses from generation to generation through the germ line."},
  {name: "Germline expression", description: "Expression of genes or transcripts in germline cells, which is crucial for heritable retroposition events."},
  {name: "Germline gene expression alteration", description: "Germline gene expression alteration involves changes in gene expression patterns in germ cells or their precursors."},
  {name: "Germline insertion", description: "Germline insertion refers to the integration of a transposable element into the genome of germ cells, making it heritable."},
  {name: "Germline methylation", description: "Germline methylation refers to the DNA methylation patterns established in germ cells (e.g., sperm)."},
  {name: "Germline mobilization", description: "Germline mobilization refers to the activity of retrotransposons in the germ line, leading to heritable genetic variation."},
  {name: "germline mutagenesis", description: "Germline mutagenesis refers to the generation of new retrotransposon insertions in the germline."},
  {name: "Germline pathogenesis", description: "Germline pathogenesis refers to the process by which retrotransposon activity causes disease or genetic disorders in the germline."},
  {name: "germline retrotransposition", description: "Retrotransposition events that occur in germ cells and can be inherited by offspring."},
  {name: "Germline retrotransposon insertion", description: "Germline retrotransposon insertion refers to de novo insertions of retrotransposons that occur in the germline and can cause disease."},
  {name: "Germline silencing", description: "Germline silencing refers to the repression of transposon activity in germ cells to maintain genomic integrity."},
  {name: "germline structural variant", description: "Germline structural variants are large-scale genomic rearrangements present in the germline cells."},
  {name: "Germline TE insertion", description: "Germline TE insertion refers to a transposable element insertion that is present in the germline and can be inherited."},
  {name: "germline transposition", description: "Germline transposition is the process by which transposable elements (TEs) insert into the genome of germ cells, creating heritable polymorphisms."},
  {name: "Germline variation", description: "Germline variation refers to genetic differences present in the germ cells that are heritable and contribute to the genetic diversity of offspring."},
  {name: "germline-transmitted retrotransposon insertion polymorphism (RIP)", description: "Germline-transmitted retrotransposon insertion polymorphism (RIP) refers to heritable variation in the human population caused by retrotransposon insertions."},
  {name: "Gestational length alteration", description: "The process that influences the duration of pregnancy and the timing of birth."},
  {name: "GG→AG mutation", description: "GG→AG mutation is a specific G-to-A mutation pattern induced by APOBEC3G within the nucleotide context GG."},
  {name: "gliosis", description: "Gliosis is a reactive change of glial cells in response to damage to the central nervous system, often involving astrocyte proliferation."},
  {name: "Global chromosome rearrangement", description: "Global chromosome rearrangement refers to large-scale, genome-wide structural changes in chromosomes."},
  {name: "Global cytosine DNA methylation", description: "Global cytosine DNA methylation refers to the overall level of DNA methylation across the genome, often assessed using repetitive elements as surrogates."},
  {name: "global DNA hypomethylation", description: "Global DNA hypomethylation refers to a genome-wide reduction in DNA methylation levels."},
  {name: "Global DNA methylation", description: "Global DNA methylation refers to the overall level of DNA methylation across the genome, often assessed using surrogate markers like retrotransposon methylation."},
  {name: "Global DNA methylation analysis", description: "Global DNA methylation analysis is a method to assess the overall methylation status of the genome, often using repetitive elements like transposons as indicators."},
  {name: "global DNA methylation changes", description: "Global DNA methylation changes refer to alterations in the overall pattern of DNA methylation across the genome."},
  {name: "Global genome methylation", description: "Global genome methylation refers to the overall level of DNA methylation across the genome, often assessed using repetitive elements like LINE-1."},
  {name: "Global genome methylation assessment", description: "Global genome methylation assessment refers to the measurement of the overall level of DNA methylation across the genome."},
  {name: "global genomic instability", description: "Global genomic instability refers to a state of increased frequency of mutations and chromosomal aberrations across the entire genome."},
  {name: "global hypomethylation", description: "Global hypomethylation is a phenomenon in which repetitive DNA sequences, including retrotransposons, become hypomethylated in human cancers."},
  {name: "global hypomethylation of genomic DNA", description: "Global hypomethylation of genomic DNA refers to a widespread reduction in DNA methylation levels, which can lead to genomic instability and activation of retrotransposons."},
  {name: "Global methylation", description: "Global methylation refers to the overall level of DNA methylation across the genome, often assessed using surrogate markers like repetitive elements."},
  {name: "Global sperm genome methylation analysis", description: "A method to assess the overall DNA methylation status of the sperm genome, often using repetitive elements like LINE1 as a proxy."},
  {name: "Globin gene switching", description: "The developmental stage-specific change in expression from fetal gamma-globin to adult beta-globin genes."},
  {name: "Granule formation", description: "Granule formation refers to the assembly of proteins and nucleic acids into cytoplasmic aggregates, such as those containing ORF1p."},
  {name: "Gross deletion", description: "Gross deletion refers to a large-scale deletion of a segment of DNA, which is a type of genomic lesion."},
  {name: "Gross insertion", description: "Gross insertion is a type of mutation involving the insertion of a DNA sequence longer than 20 base pairs into the genome."},
  {name: "Guanine quadruplex formation", description: "Guanine quadruplex formation is the adoption of four-stranded DNA or RNA structures by guanine-rich sequences."},
  {name: "H2AX phosphorylation", description: "H2AX phosphorylation is a marker of DNA damage, particularly double-strand breaks."},
  {name: "H3K18 deacetylation", description: "The removal of an acetyl group from the lysine 18 residue of histone H3, a modification associated with transcriptional repression."},
  {name: "H3K27me3-marked repression", description: "Gene repression associated with the histone modification trimethylation of lysine 27 on histone H3."},
  {name: "H3K27me3-mediated gene repression", description: "H3K27me3-mediated gene repression is a transcriptional silencing mechanism involving trimethylation of histone H3 at lysine 27."},
  {name: "H3K4me3 gain", description: "An increase in the histone modification H3K4me3, which is associated with active gene promoters."},
  {name: "H3K4me3 loss", description: "A decrease in the histone modification H3K4me3, which is associated with active gene promoters."},
  {name: "H3K4me3 modification", description: "H3K4me3 is a histone modification (trimethylation of lysine 4 on histone H3) associated with active gene transcription."},
  {name: "H3K9 trimethylation", description: "H3K9 trimethylation (H3K9me3) is a histone modification associated with transcriptional repression and heterochromatin formation."},
  {name: "H3K9me3", description: "H3K9me3 is the trimethylation of histone H3 at lysine 9, a repressive histone mark associated with heterochromatin formation and gene silencing."},
  {name: "H3K9me3 deposition", description: "H3K9me3 deposition is the epigenetic modification of histone H3 lysine 9 trimethylation, associated with transcriptional repression."},
  {name: "H3K9me3 modification", description: "H3K9me3 is a histone modification (trimethylation of lysine 9 on histone H3) associated with heterochromatin formation and transcriptional repression."},
  {name: "H3K9me3-marked repression", description: "Gene repression associated with the histone modification trimethylation of lysine 9 on histone H3."},
  {name: "H3K9me3-mediated silencing", description: "A mechanism for silencing transposable elements through trimethylation of histone H3 lysine 9."},
  {name: "H3K9me3-mediated transcriptional silencing", description: "Transcriptional silencing of repetitive DNA sequences through histone H3 lysine 9 trimethylation (H3K9me3)."},
  {name: "H4K16bio enrichment", description: "H4K16bio enrichment refers to the overrepresentation of biotinylation at lysine 16 of histone H4 at specific genomic loci."},
  {name: "haematopoietic regeneration", description: "The process of restoring the haematopoietic system, including stem cells and blood cells, after injury or stress such as chemotherapy."},
  {name: "Haploidy", description: "Haploidy refers to the state of having a single copy of a genomic segment or chromosome."},
  {name: "Haploinsufficiency", description: "Haploinsufficiency is a mechanism of disease where a single functional copy of a gene is insufficient to maintain normal function."},
  {name: "Haplotype association", description: "Haplotype association refers to the co-occurrence of specific alleles (e.g., transposon insertion and HLA allele) on the same chromosome segment."},
  {name: "Haplotype phasing", description: "Haplotype phasing is a computational method to determine the parental origin of alleles on a chromosome."},
  {name: "Haplotype structural variation", description: "Haplotype structural variation refers to differences in the genomic organization and arrangement of DNA segments among haplotypes."},
  {name: "Harboring transcription factor binding motifs", description: "The function of containing DNA sequence motifs that serve as binding sites for transcription factors."},
  {name: "harmful mutagenesis", description: "Harmful mutagenesis refers to genetic changes that are deleterious to the cell or organism."},
  {name: "harmful mutation region", description: "Specific regions within a transposable element's consensus sequence where mutations dramatically decrease its transpositional activity."},
  {name: "HCC progression and angiogenesis", description: "The processes of tumor growth, advancement, and the formation of new blood vessels (angiogenesis) in hepatocellular carcinoma."},
  {name: "Hemi-methylation at CG dinucleotides", description: "Hemi-methylation at CG dinucleotides is a state where only one strand of a CG dinucleotide is methylated."},
  {name: "Hemimethylation", description: "Hemimethylation refers to DNA methylation present on only one strand of the double helix."},
  {name: "Hepatic expression", description: "Hepatic expression refers to the production of a protein, such as factor IX, in liver cells (hepatocytes)."},
  {name: "heritable insertion", description: "Heritable insertion refers to the integration of a transposable element into the germline genome, which can be passed on to offspring."},
  {name: "Heritable retrotransposition", description: "Heritable retrotransposition events allow transposons to exert an ongoing influence upon genome evolution."},
  {name: "heritable structural variation", description: "Heritable structural variation refers to genomic alterations, such as insertions or deletions, that can be passed from parents to offspring."},
  {name: "HERV activation", description: "HERV activation refers to the process by which normally silenced HERV elements become transcriptionally or translationally active."},
  {name: "HERV dis-regulation", description: "HERV dis-regulation refers to the abnormal expression or activity of human endogenous retroviruses, which may contribute to disease mechanisms."},
  {name: "HERV transposition", description: "HERV transposition is the process by which HERV elements move within the genome."},
  {name: "HERV-encoded protein expression", description: "HERV-encoded protein expression refers to the translation of proteins from HERV open reading frames."},
  {name: "Heterochromatin decondensation", description: "Heterochromatin decondensation is the relaxation of tightly packed heterochromatin, which can lead to the reactivation of silenced genes and transposable elements."},
  {name: "Heterochromatin erosion", description: "The loss or disruption of condensed, transcriptionally repressive chromatin structures."},
  {name: "Heterochromatin formation", description: "Heterochromatin formation is the establishment of a condensed, transcriptionally repressive chromatin state, often marked by H3K9me3."},
  {name: "Heterochromatin loss", description: "Heterochromatin loss is the reduction of condensed, transcriptionally repressive chromatin regions."},
  {name: "heterochromatinization", description: "Heterochromatinization is the process of forming transcriptionally repressive heterochromatin."},
  {name: "Heterochromatization", description: "Heterochromatization is the process of forming heterochromatin, a tightly packed form of DNA associated with transcriptional repression."},
  {name: "Hierarchical clustering", description: "Hierarchical clustering describes a genome landscape where clusters of elements can themselves be grouped into higher-order super-clusters."},
  {name: "High salt sensitivity", description: "The property of a complex being disrupted or dissociated upon treatment with high concentrations of salt."},
  {name: "Higher order genome structure", description: "The organization of DNA sequences, including repetitive elements, into large-scale chromosomal domains that influence genome function."},
  {name: "higher-order chromatin structure formation", description: "The establishment of three-dimensional chromatin architecture during development."},
  {name: "Histone acetylation alteration", description: "Histone acetylation alteration is a change in the acetylation status of histone proteins, which can influence gene expression."},
  {name: "Histone biotinylation", description: "Histone biotinylation is a post-translational modification where biotin is covalently attached to lysine residues on histone proteins."},
  {name: "Histone deacetylation", description: "Histone deacetylation is an epigenetic modification that removes acetyl groups from histones, leading to chromatin compaction and transcriptional repression."},
  {name: "histone H3 acetylation", description: "Histone H3 acetylation is a post-translational modification that relaxes chromatin structure and promotes gene transcription."},
  {name: "Histone methylation", description: "Histone methylation is a post-translational modification that involves the addition of methyl groups to histone proteins, influencing gene expression."},
  {name: "histone modification (H4K20me3)", description: "H4K20me3 is a histone modification involving trimethylation of lysine 20 on histone H4, often associated with transcriptional repression."},
  {name: "histone modification at L1 promoter", description: "The deposition of repressive histone marks (H3K9me3, H3K27me3) and prevention of activating marks (H3K4me3, H3K9ac) at the LINE-1 5'UTR, leading to transposon silencing."},
  {name: "Hitchhiking on retrotransposition", description: "Hitchhiking on retrotransposition refers to the process where non-autonomous DNA sequences are mobilized by active retrotransposons."},
  {name: "HIV-1 inhibition", description: "HIV-1 inhibition refers to the suppression or prevention of HIV-1 replication and infection."},
  {name: "HLA-I-bound peptide encoding", description: "HLA-I-bound peptide encoding refers to the process by which a DNA sequence is transcribed and translated to produce peptides that are presented on the cell surface by HLA class I molecules."},
  {name: "Homologous recombination", description: "Homologous recombination is a type of genetic recombination where nucleotide sequences are exchanged between two similar or identical molecules of DNA."},
  {name: "Homologous recombination (HR)", description: "Homologous recombination is a high-fidelity DNA repair pathway that uses a homologous template to repair double-strand breaks."},
  {name: "Homologous recombination-mediated gene targeting", description: "Homologous recombination-mediated gene targeting is a precise method for modifying specific genomic loci."},
  {name: "Homology-directed repair (HDR)", description: "Homology-directed repair is a precise DNA repair mechanism that uses a donor DNA template to introduce specific genetic changes."},
  {name: "Homology-independent DSB repair", description: "Homology-independent DSB repair is a mechanism for repairing DNA double-strand breaks that does not rely on extensive sequence homology, such as non-homologous end joining (NHEJ)."},
  {name: "Homology-mediated rearrangement", description: "Homology-mediated rearrangement is a process of genomic rearrangement that utilizes regions of sequence homology, such as repetitive elements, for breakpoint resolution."},
  {name: "homotypic clustering", description: "The spatial aggregation of similar genomic elements, such as repeats of the same class, within the nucleus."},
  {name: "homotypic pairing", description: "Homotypic pairing refers to the physical coupling of identical transposable elements."},
  {name: "homozygous tumor suppressor gene disruption", description: "Homozygous tumor suppressor gene disruption refers to the complete inactivation of both alleles of a tumor suppressor gene, which can contribute to cancer development."},
  {name: "Horizontal gene transfer", description: "Horizontal gene transfer is the movement of genetic material between organisms other than by vertical transmission from parent to offspring."},
  {name: "Horizontal gene transfer (HGT)", description: "Horizontal gene transfer is the movement of genetic material between organisms other than by vertical transmission from parent to offspring."},
  {name: "Horizontal transfer", description: "Horizontal transfer refers to the movement of genetic material between organisms other than by vertical inheritance."},
  {name: "Horizontal transmission", description: "Horizontal transmission refers to the transfer of genetic material between organisms in a manner other than traditional reproduction."},
  {name: "host cellular protection mechanisms", description: "Cellular processes that protect the genome from excessive or harmful LINE-1-mediated retrotransposition events."},
  {name: "host defense mechanism", description: "Host defense mechanisms are cellular processes that protect the host genome from foreign or mobile genetic elements."},
  {name: "host defense mechanisms", description: "Host defense mechanisms, including epigenetic silencing and DNA repair, normally limit LINE-1 retrotransposition."},
  {name: "host defense restriction", description: "Cellular mechanisms, involving factors like APOBEC3, MOV10, and SAMHD1, that inhibit or restrict the mobility of retrotransposons."},
  {name: "Host defense system", description: "The host defense system comprises biological processes and mechanisms that protect an organism from pathogens and other threats."},
  {name: "Host factor interaction", description: "Interactions between L1 retrotransposons and both permissive and repressive host factors that occur throughout the L1 life cycle."},
  {name: "host factor regulation of retrotransposition", description: "Host factor regulation of retrotransposition refers to the cellular mechanisms that control the mobilization of retrotransposons."},
  {name: "Host gene capture by viral genomes", description: "The mechanism by which viruses incorporate host genes into their own genomes."},
  {name: "Host gene expression regulation", description: "Host gene expression regulation involves the control of the transcription and translation of host genes."},
  {name: "Host gene regulation", description: "The process by which transposable elements influence the expression patterns of host genes."},
  {name: "Host genome instability", description: "Host genome instability refers to increased susceptibility to mutations, rearrangements, or other genetic alterations within the host's genome."},
  {name: "Host genome integrity", description: "The maintenance of genomic stability, which can be compromised by transposon activity."},
  {name: "host genomic DNA mutation and rearrangement", description: "Host genomic DNA mutation and rearrangement are alterations in the host genome caused by LINE-1 replication."},
  {name: "Host immune response", description: "The host immune response is the body's defense system against infection and disease."},
  {name: "Host interaction", description: "The interactions between LINE-1 elements and their mammalian hosts."},
  {name: "Host locus transcriptional activity", description: "Host locus transcriptional activity refers to the expression level of the genomic region in which a transposon is located."},
  {name: "host protein interaction", description: "L1 RNPs interact with diverse host proteins, some repressive and others required for the L1 lifecycle."},
  {name: "Host repression of transposition", description: "Host repression of transposition refers to the mechanisms by which the host genome limits or controls the activity of transposable elements."},
  {name: "Host restriction of L1 integration", description: "Host processes that act to restrict L1 integration in cultured human cells."},
  {name: "Host-cell defense", description: "Cellular mechanisms that combat rampant retrotransposon spread to protect the host genome."},
  {name: "Host-retrovirus interaction", description: "Host-retrovirus interaction describes the dynamic relationship between a host organism and endogenous or exogenous retroviruses."},
  {name: "HP1β-mediated binding of H3K9 trimethylated histones", description: "A recruitment mechanism where the HP1β protein binds to histone H3 trimethylated at lysine 9 (H3K9me3) to target protein complexes to specific genomic loci."},
  {name: "Human embryo development", description: "Human embryo development refers to the early stages of embryogenesis, including preimplantation stages."},
  {name: "human embryonic genome activation", description: "Human embryonic genome activation is the process where the zygotic genome begins widespread transcription during early embryogenesis."},
  {name: "Human evolution", description: "The evolutionary process of the human species, to which repeat sequences have contributed by becoming functional elements."},
  {name: "Human genome evolution", description: "Human genome evolution refers to the changes in the structure and content of the human genome over time."},
  {name: "human placental morphogenesis", description: "Human placental morphogenesis is the process of placenta formation and development."},
  {name: "human placentation", description: "Human placentation is the process of forming the placenta, a vital organ for fetal development during pregnancy."},
  {name: "Human-specific brain development", description: "L1s are implicated in human-specific developmental processes in the brain."},
  {name: "human-specific regulatory loci (HSRL) creation", description: "The process by which novel regulatory sequences, specifically in the human lineage, are generated."},
  {name: "Human-specific tandem repeat expansion", description: "Human-specific tandem repeat expansion refers to the increase in copy number of short tandem repeats (STRs) or variable number tandem repeats (VNTRs) that occurred specifically in the human lineage."},
  {name: "HUSH complex assembly", description: "HUSH complex assembly is the process by which the TASOR, MPP8, and Periphilin subunits come together to form the functional HUSH complex."},
  {name: "HUSH complex interaction with Pol ε", description: "The human silencing hub (HUSH) complex interacts with the leading-strand DNA polymerase Pol ε."},
  {name: "HuSH-mediated silencing", description: "HuSH-mediated silencing is a conserved mechanism for repressing transposable elements in vertebrates."},
  {name: "Hybrid provirus formation", description: "The process where sequences from different HERV families (e.g., HERV-K14I and HERV-W) combine to form a provirus that can produce progeny in the genome."},
  {name: "Hybridization", description: "Hybridization is the process of interbreeding between individuals from different species or populations."},
  {name: "Hypermethylation", description: "A high level of methylation of cytosines in CpG dinucleotides, typically associated with gene silencing."},
  {name: "Hypermutation", description: "Hypermutation refers to an unusually high rate of mutation, in this context induced by APOBEC3 enzymes on retroelement sequences."},
  {name: "hypo-methylation", description: "Hypomethylation refers to a decrease in DNA methylation levels, often associated with genomic instability and altered gene expression."},
  {name: "IFN-response", description: "IFN-response refers to the cellular signaling and gene expression program activated by interferons, typically in response to viral infection or other danger signals."},
  {name: "IFN-α induction", description: "IFN-α induction refers to the process of stimulating the expression of type I interferon alpha, which is part of the innate immune response."},
  {name: "IFNβ production", description: "IFNβ production is the synthesis of interferon-beta, a key cytokine in innate immune responses."},
  {name: "illegitimate recombination", description: "A type of abnormal genetic recombination that occurs between non-homologous or misaligned DNA sequences."},
  {name: "Immortalization", description: "Immortalization is the process of bypassing replicative senescence to allow indefinite cell proliferation."},
  {name: "immune activation", description: "Immune activation refers to the initiation or enhancement of an immune response."},
  {name: "immune evasion", description: "Immune evasion is a process by which cancer cells avoid detection and destruction by the immune system."},
  {name: "immune infiltration", description: "Immune infiltration refers to the presence and abundance of immune cells within a tumor microenvironment."},
  {name: "immune modulation", description: "Immune modulation refers to the process of altering or regulating the activity of the immune system."},
  {name: "immune pathway triggering", description: "Immune pathway triggering is the activation of innate or adaptive immune signaling cascades in response to stimuli."},
  {name: "Immune regulation", description: "The process of modulating immune responses, including immunosuppression or immune activation."},
  {name: "Immune regulatory network control", description: "The role of HERV/LTR regulatory elements in controlling the immune regulatory network."},
  {name: "immune response", description: "Immune response is the body's defense mechanism against pathogens and foreign substances."},
  {name: "immune response activation", description: "A scenario of activation of the immune system, which was used to study the expression and modulation of HERVs and MaLRs."},
  {name: "Immune response regulation", description: "Immune response regulation involves the control of pathways and genes that mediate the body's defense against pathogens."},
  {name: "immune response to tumor-associated antigens", description: "Immune response to tumor-associated antigens is the process by which the immune system recognizes and reacts to antigens expressed by tumor cells."},
  {name: "immune system priming", description: "Immune system priming refers to the initial activation or sensitization of the immune system to a specific stimulus."},
  {name: "Immune-related functions", description: "SINE ncRNAs possess novel immune-related functions."},
  {name: "Immunogenicity", description: "Immunogenicity is the ability of a substance, such as a tumor or virus, to provoke an immune response."},
  {name: "Immunopeptidome diversification", description: "Immunopeptidome diversification refers to the expansion of the repertoire of peptides presented by HLA molecules."},
  {name: "immunostimulatory double-strand RNA formation", description: "Immunostimulatory double-strand RNA (dsRNA) formation refers to the generation of dsRNA structures from endogenous repeats that can be recognized by pattern recognition receptors."},
  {name: "Immunosuppression", description: "Immunosuppression refers to the reduction of the activation or efficacy of the immune system."},
  {name: "Immunotherapy resistance", description: "Immunotherapy resistance is the phenomenon where tumors fail to respond or become resistant to immunotherapeutic treatments."},
  {name: "Immunotoxic cascade activation", description: "Immunotoxic cascade activation refers to the induction of inflammatory and immune responses that can lead to cellular damage."},
  {name: "impact neuronal transcriptional expression", description: "The process by which de novo L1 insertions can alter the transcriptional output in neurons."},
  {name: "impact on genomic stability", description: "Impact on genomic stability refers to the influence of processes, such as transposition, that can alter the integrity and structure of the genome."},
  {name: "Impaired neurogenesis", description: "Impaired neurogenesis refers to a decline or dysfunction in the generation of new neurons in the adult brain."},
  {name: "Impaired piRNA biogenesis", description: "Impaired piRNA biogenesis is a defect in the production of piRNAs, which are crucial for transposon silencing in germ cells."},
  {name: "Impaired preimplantation development", description: "A disruption or failure in the normal development of an embryo during the stages before it implants in the uterine wall."},
  {name: "imprint erasure", description: "Imprint erasure is the removal of genomic imprints, which are parent-of-origin-specific DNA methylation marks, during primordial germ cell development."},
  {name: "in vitro retrotransposition activity", description: "The measurable ability of a LINE-1 element to undergo retrotransposition in a controlled laboratory setting."},
  {name: "in vivo tracing", description: "The process of tracking or monitoring cells, molecules, or biological processes within a living organism over time."},
  {name: "inactivation", description: "Inactivation refers to the process by which a transposon loses its ability to mobilize or function."},
  {name: "inactivation of tumor-suppressive genes", description: "Inactivation of tumor-suppressive genes is a process that can lead to the loss of function of genes that normally suppress tumor growth."},
  {name: "Inactive histone tail modifications", description: "Inactive histone tail modifications are post-translational changes to histone proteins that are associated with a condensed, transcriptionally repressive chromatin state."},
  {name: "Incomplete lineage sorting", description: "Incomplete lineage sorting is an evolutionary phenomenon where ancestral genetic polymorphisms persist through speciation events."},
  {name: "incomplete retrotransposition", description: "A retrotransposition event that is initiated but not successfully completed, potentially leading to DNA damage."},
  {name: "Incorporation of retroelements", description: "Incorporation of retroelements refers to the integration of retrotransposon sequences into the host genome."},
  {name: "increased expression", description: "Increased expression refers to a higher level of gene or element transcription."},
  {name: "Increased expression of L1 mRNA and protein", description: "Increased expression of L1 mRNA and protein indicates elevated levels of LINE-1 transcripts and encoded proteins, such as ORF1p, in specific cell types."},
  {name: "increased frequency of recombinations", description: "An increased frequency of recombinations refers to a higher rate of genetic recombination events, which can contribute to genomic rearrangements."},
  {name: "Increased gene expression", description: "Increased gene expression refers to an elevation in the level of transcription or abundance of mRNA for a specific gene."},
  {name: "increased L1 expression", description: "Increased L1 expression refers to the elevated transcription or presence of LINE-1 elements."},
  {name: "increased TE expression", description: "Increased transposable element expression refers to elevated levels of TE-derived RNA transcripts."},
  {name: "increases in recombination", description: "Increases in recombination refer to a higher frequency of genetic recombination events."},
  {name: "Increasing gene versatility", description: "Enhancing the functional diversity or regulatory complexity of a gene."},
  {name: "Increasing genomic diversity", description: "The contribution of retrotransposon activity to generating variation within a genome."},
  {name: "indel event", description: "An indel event refers to the insertion or deletion of nucleotides in a DNA sequence."},
  {name: "Indel mutation", description: "Indel mutation refers to the insertion or deletion of nucleotides in the genome, often resulting from non-homologous end joining repair."},
  {name: "Individual variation in mobilization capability", description: "Individual variation in mobilization capability refers to the differences in the efficiency of L1 retrotransposition among different human individuals."},
  {name: "Inducible cDNA rescue", description: "Inducible cDNA rescue is a technique to restore gene function in a controlled manner."},
  {name: "Inducible enhancer activity", description: "Inducible enhancer activity is the ability of an enhancer to become active in response to specific signals or conditions."},
  {name: "Inducible expression", description: "Inducible expression refers to a system where gene expression can be controlled or turned on by an external stimulus."},
  {name: "Inducible gene expression", description: "Inducible gene expression is a system where the expression of a target gene can be controlled by an external stimulus, such as a chemical inducer."},
  {name: "inducing alternative splicing via exon skipping", description: "Inducing alternative splicing via exon skipping is a mechanism by which retroelements interfere with gene expression."},
  {name: "Induction of neurotoxic retroviral proteins", description: "Induction of neurotoxic retroviral proteins refers to the expression of retroviral proteins that are harmful to neurons."},
  {name: "inflammation", description: "Inflammation is a biological response of body tissues to harmful stimuli, such as pathogens or damaged cells."},
  {name: "inflammation induction", description: "Inflammation induction is the process of initiating an inflammatory response."},
  {name: "inflammatory response", description: "A biological response triggered by the immune system to harmful stimuli, often involving cytokine release."},
  {name: "inflammatory response induction", description: "Inflammatory response induction refers to the triggering of an immune system reaction."},
  {name: "Influence chromatin structure", description: "Transcribed LINE-1 RNAs can influence the structure of chromatin."},
  {name: "Influence gene function", description: "The capacity of genetic elements to affect the expression or activity of neighboring cellular genes."},
  {name: "Influence on chromosome integrity", description: "The ability of L1 elements to affect the structural stability of chromosomes upon reinsertion."},
  {name: "influence on microRNAs", description: "Influence on microRNAs refers to the regulatory impact that retrotransposons can have on the expression or function of microRNAs, which are often derived from them."},
  {name: "Influence transcription of neighbouring genes", description: "The ability of transposable elements to affect the expression levels of genes located nearby in the genome."},
  {name: "Inhibition of DNA repair proteins", description: "Inhibition of DNA repair proteins refers to the suppression of enzymes responsible for detecting and repairing DNA damage."},
  {name: "inhibition of LINE-1", description: "The process of specifically inhibiting the activity or retrotransposition of LINE-1 elements."},
  {name: "Inhibition of retrotransposition", description: "Inhibition of retrotransposition refers to the negative regulation of the LINE-1 copy-and-paste mechanism."},
  {name: "Initiate transcription of flanking genomic DNA", description: "The process where promoters within transposable elements drive the expression of adjacent host genomic sequences."},
  {name: "Initiation of reverse transcription", description: "Initiation of reverse transcription refers to the precise start site for the synthesis of cDNA from the RNA template of a retrotransposon, which is critical for accurate retrotransposition."},
  {name: "Initiator (Inr) element formation", description: "A promoter mechanism where the L1 5'-UTR is able to form an initiator element that reaches into upstream flanking sequence, reminiscent of TATA-less promoters for cellular genes."},
  {name: "Innate antiviral immunity", description: "Innate antiviral immunity is the first line of host defense against viral infections."},
  {name: "innate antiviral pathway", description: "The innate antiviral pathway is a host defense mechanism triggered by pattern recognition receptors (e.g., RIG-I, MDA5) sensing viral components."},
  {name: "Innate antiviral response", description: "Innate antiviral response is the body's first line of defense against viral infections, often involving interferon signaling."},
  {name: "Innate immune activation", description: "Innate immune activation is the triggering of the body's first line of defense against pathogens, which can be stimulated by endogenous nucleic acids like retrotransposon-derived sequences."},
  {name: "innate immune control", description: "The regulation of the innate immune system to prevent inappropriate activation."},
  {name: "innate immune pathway activation", description: "Activation of innate immune pathways, such as type I interferon signaling, in response to cellular stress or foreign nucleic acids."},
  {name: "innate immune response", description: "Innate immune response is the body's first line of defense against pathogens and other stimuli."},
  {name: "Innate immune response activation", description: "Innate immune response activation is the triggering of the body's first line of defense against pathogens or cellular stress."},
  {name: "innate immune response modulation", description: "Innate immune response modulation involves the regulation of the body's first line of defense against pathogens, often triggered by nucleic acids like those from TEs."},
  {name: "Innate immune restriction", description: "Innate immune restriction refers to mechanisms by which the innate immune system limits the activity of retrotransposons."},
  {name: "Innate immune signaling", description: "Innate immune signaling refers to the activation of immune response pathways, such as NF-κB and AP-1, upon detection of cytoplasmic pathogens or danger signals."},
  {name: "innate immune signaling activation", description: "Innate immune signaling activation involves triggering host defense pathways, such as the cGAS/STING pathway, in response to foreign or aberrant nucleic acids."},
  {name: "Innate immune signaling activation via cGAS-STING pathway", description: "Activation of the innate immune response through the cytosolic DNA sensor cGAS and its downstream signaling adaptor STING."},
  {name: "Innate immune system activation", description: "Innate immune system activation refers to the triggering of the body's first line of defense against pathogens or cellular damage."},
  {name: "Innate immune system interaction", description: "Innate immune system interaction refers to the engagement and modulation of the body's first line of defense against pathogens."},
  {name: "Innate immunity", description: "Innate immunity is a form of immune defense that includes cellular factors that control retroelement transposition."},
  {name: "insect transformation", description: "Insect transformation is a genetic engineering technique used to modify insects."},
  {name: "insertion", description: "Insertion refers to the integration of a transposable element into a new genomic location."},
  {name: "Insertion and deletion (indel)", description: "Insertions and deletions are mutations involving the addition or loss of nucleotides in the genome."},
  {name: "Insertion as exon", description: "The integration of a DNA sequence into a gene region that is subsequently spliced into mature mRNA as an exon."},
  {name: "Insertion at TTAA sites", description: "Insertion at TTAA sites is a characteristic target site preference exhibited by piggyBac-like transposases during integration."},
  {name: "Insertion bias", description: "A non-random pattern in the orientation or location of retrotransposon insertions within the genome."},
  {name: "Insertion during evolution", description: "Insertion during evolution refers to the integration of a genetic element, such as a retrotransposon, into a genome over evolutionary time, potentially conferring new functions."},
  {name: "Insertion event", description: "An insertion event refers to the integration of a transposon into a new genomic location."},
  {name: "Insertion in sense orientation", description: "The process where a retrotransposon inserts into a gene in the same transcriptional orientation as the gene."},
  {name: "Insertion into alphoid satellite DNA", description: "Insertion into alphoid satellite DNA refers to the integration of retrotransposons into the repetitive alpha satellite sequences found at centromeres."},
  {name: "Insertion into DNA lesions", description: "The integration of retrotransposons into sites of DNA damage."},
  {name: "insertion into exons and introns", description: "Insertion into exons and introns of genes is a mechanism by which retroelements induce genetic disease."},
  {name: "Insertion into genes", description: "Insertion into genes refers to the event where a transposon integrates into the coding or regulatory region of a gene."},
  {name: "Insertion into introns", description: "Insertion into introns is the process by which genetic elements, such as transposons, integrate into the intronic regions of genes."},
  {name: "insertion into new loci", description: "Insertion into new loci refers to the process where LINE-1 elements integrate into new genomic locations."},
  {name: "Insertion into ribosomal DNA", description: "The process by which a retrotransposon integrates into specific sites within ribosomal DNA."},
  {name: "Insertion into synapse- and schizophrenia-related genes", description: "This refers to the process where retrotransposed LINE-1 elements insert into genes that are involved in synaptic function and are associated with schizophrenia susceptibility."},
  {name: "Insertion into transcribed genes", description: "The process by which retrotransposons insert themselves into actively transcribed regions of the genome."},
  {name: "Insertion into transcriptionally repressed genomic sites", description: "Insertion into transcriptionally repressed genomic sites refers to LINE-1 retrotransposition events that occur in genomic regions where the reporter gene promoter is inactive."},
  {name: "Insertion mechanism", description: "Insertion mechanism refers to the process by which transposable elements integrate into new genomic locations."},
  {name: "insertion mutagenesis", description: "The generation of mutations caused by the insertion of a DNA sequence, such as a transposon, into a gene or regulatory region."},
  {name: "Insertion number variation", description: "Variation in the number of transposable element insertions among individuals, often used as a proxy for recent TE activity."},
  {name: "Insertion of DNA segments", description: "Insertion of DNA segments refers to the integration of genetic material, such as more recent repeats, into a genomic sequence."},
  {name: "Insertion of filler DNA", description: "Insertion of filler DNA refers to the incorporation of non-templated DNA sequences during DNA repair or recombination events."},
  {name: "insertion of LINE-1", description: "The insertion of LINE-1 refers to the integration of a newly produced LINE-1 DNA copy into a new location in the genome."},
  {name: "Insertion of mobile elements", description: "The process by which transposable elements integrate into new genomic locations."},
  {name: "Insertion of new L1 retrotransposons into the genome", description: "The integration of newly reverse-transcribed LINE-1 cDNA copies into the host genome, which can lead to insertional mutations."},
  {name: "Insertion pattern", description: "Insertion pattern refers to the distribution and frequency of transposable element insertions within the genome."},
  {name: "Insertion polymorphism", description: "Insertion polymorphism refers to the presence or absence of a genetic element, such as a transposon, at a specific genomic location within a population."},
  {name: "Insertion polymorphism (RIP)", description: "Retrotransposon insertion polymorphism (RIP) refers to the presence or absence of a transposon insertion at a specific genomic locus, creating genetic variation within a population."},
  {name: "Insertion process", description: "The insertion process is a key step in retrotransposition where the newly synthesized cDNA copy of the retrotransposon integrates into a new genomic location."},
  {name: "Insertion site characterization", description: "Insertion site characterization refers to methods used to identify and analyze the genomic location of new transposon insertions."},
  {name: "Insertion site polymorphism", description: "The presence of genetic variation among individuals due to differences in the genomic locations where transposons have inserted."},
  {name: "Insertion site selection", description: "Insertion site selection refers to the non-random genomic integration preferences of integrating genetic elements."},
  {name: "insertion time estimation", description: "Insertion time estimation is a method to infer the age of a retrotransposon insertion based on the sequence divergence between its two LTRs."},
  {name: "Insertion-associated deletion", description: "Insertion-associated deletion is a mutational mechanism where the insertion of a retrotransposon is accompanied by a large genomic deletion at the insertion site."},
  {name: "insertion-based mutagenesis", description: "Insertion-based mutagenesis is a process where transposon insertion directly disrupts genomic sequence and function."},
  {name: "Insertion-induced transcriptional modification", description: "The alteration of existing transcripts through the insertion of genetic material, such as providing new exons or promoters."},
  {name: "Insertion-mediated deletion", description: "Insertion-mediated deletion is a genomic structural variation where the insertion of a transposon leads to the deletion of surrounding genomic sequence."},
  {name: "insertion-mediated genomic deletion", description: "Insertion-mediated genomic deletion is a mechanism where the insertion of a transposable element leads to the deletion of genomic sequences."},
  {name: "Insertion/deletion", description: "Insertion/deletion refers to the gain or loss of DNA sequence in the genome."},
  {name: "Insertion/deletion mutations", description: "Insertion/deletion mutations are genetic alterations caused by the insertion or deletion of nucleotides, which can be generated by L1 retrotransposition."},
  {name: "Insertional activity", description: "Insertional activity refers to the process by which transposable elements insert into new genomic locations."},
  {name: "Insertional bias", description: "Insertional bias refers to the non-random preference of transposons for inserting into specific genomic regions."},
  {name: "Insertional genomic injury", description: "Genomic damage resulting from the insertion of a retroelement into the genome."},
  {name: "Insertional history", description: "Insertional history refers to the record of past insertion events of a transposon family within a genome or population."},
  {name: "insertional mechanism", description: "Insertional mechanism refers to the process by which a transposon integrates into a new genomic location, potentially disrupting gene function."},
  {name: "insertional mutagenesis", description: "Insertional mutagenesis is a mechanism of genetic disease where the insertion of a transposable element disrupts or inactivates a gene."},
  {name: "insertional mutation", description: "A mutation caused by the insertion of a DNA sequence, such as a transposon, into a gene or regulatory region."},
  {name: "Insertional polymorphism", description: "Insertional polymorphism refers to genetic variation among individuals caused by the presence or absence of specific transposable element insertions."},
  {name: "insertions", description: "Insertions refer to the integration of retrotransposon sequences into new genomic locations."},
  {name: "insertions of Alu elements", description: "Insertions of Alu elements refer to the integration of Alu retrotransposons into new genomic locations, potentially disrupting gene function."},
  {name: "Insulin signaling pathway", description: "The insulin signaling pathway is a cellular mechanism through which insulin regulates processes like glucose uptake and gene expression."},
  {name: "Integration", description: "Integration is a rapid step in the transposition reaction of Hsmar1."},
  {name: "Integration into A-rich sequences", description: "Integration into A-rich sequences is a characteristic feature of LINE-mediated retrotransposition events."},
  {name: "integration into active chromatin", description: "The process where SVA retrotransposons preferentially insert into regions of open, transcriptionally active chromatin."},
  {name: "integration into genes", description: "The process by which transposons insert themselves into gene sequences."},
  {name: "Integration into hotspots", description: "Integration into hotspots refers to the preferential insertion of transposable elements into specific nucleotide positions within targeted TEs."},
  {name: "Integration into replicating DNA", description: "Integration into replicating DNA refers to the process where L1 retrotransposons preferentially insert into DNA undergoing replication."},
  {name: "integration into the genome", description: "The stage of retrotransposition where LINE-1 elements insert into the host genome."},
  {name: "Integration of mammalian retroposons", description: "The process by which reverse-transcribed cellular RNA molecules (retroposons) insert into mammalian chromosomes."},
  {name: "Integration of RNA molecules into the human genome", description: "The process by which RNA molecules are inserted into the human genome."},
  {name: "Integration pattern", description: "Integration pattern refers to the distribution and orientation of transposable element insertions within a genome."},
  {name: "Integration site selection", description: "Integration site selection is the process determining where a retrotransposon integrates into the genome, with L1 endonuclease nicking specificity being a major determinant."},
  {name: "Integration targeting", description: "Integration targeting refers to the non-random selection of specific genomic sites for the insertion of mobile DNA elements."},
  {name: "Inter-chromosomal duplication", description: "Inter-chromosomal duplication refers to the duplication of DNA sequences from one chromosome to another."},
  {name: "inter-chromosomal translocation", description: "Interchromosomal translocation is a genomic rearrangement involving the exchange of genetic material between non-homologous chromosomes."},
  {name: "inter-element recombination", description: "Recombination events occurring between two separate transposon copies."},
  {name: "interaction between retrotransposition complex and cellular partners", description: "This involves the validation of associations between LINE-1 retrotransposition complex components and potential host cellular factors involved in L1 replication."},
  {name: "Interaction with AGO proteins", description: "The molecular mechanism where miRNAs associate with Argonaute (AGO) proteins, such as AGO1, AGO2, and AGO3, to form the RNA-induced silencing complex (RISC)."},
  {name: "Interaction with HBV polymerase", description: "HBV polymerase interacts with the L1 ORF1p protein, hijacking it from P-bodies."},
  {name: "Interaction with KRAB-ZNF genes", description: "Interaction with KRAB-ZNF genes refers to the regulatory relationships between transposable elements and KRAB-ZNF genes."},
  {name: "Interaction with Pin1", description: "Phosphorylated PDPK sites in ORF1p are required for an interaction with the peptidyl prolyl isomerase 1 (Pin1), a critical component of PDPK-mediated regulation."},
  {name: "Intercellular regulation of gene expression", description: "Intercellular regulation of gene expression involves the modulation of gene activity in recipient cells through signals or molecules received from other cells."},
  {name: "interference with normal gene expression", description: "Active L1Hs antisense promoters are capable of interfering with the normal expression patterns of cellular genes."},
  {name: "Interferon (IFN) production", description: "Interferon production is the synthesis and release of signaling proteins (interferons) that mediate antiviral and immune responses."},
  {name: "Interferon response", description: "A cellular immune signaling pathway triggered by dsRNAs."},
  {name: "Interferon-inducible expression", description: "Interferon-inducible expression refers to the upregulation of gene transcription in response to interferon signaling."},
  {name: "Interferon-like response", description: "Interferon-like response is an innate immune response characterized by the expression of interferon-stimulated genes, often triggered by viral or retroelement activity."},
  {name: "Interindividual genetic variation", description: "Genetic differences between individuals, which in this context can be contributed to by the retrotransposition of chimeric RNAs."},
  {name: "Interindividual genomic variation", description: "Genetic differences between individuals, which can be generated by retrotransposition events."},
  {name: "Internal priming", description: "Internal priming is an alternative mechanism for retrotransposon integration where reverse transcription initiates upstream of the 3' poly-A tail."},
  {name: "internal promoter activity", description: "The function of the L1 5' UTR to initiate transcription of the element."},
  {name: "Internal rearrangement", description: "Internal rearrangement refers to structural modifications within a transposon element during its mobilization."},
  {name: "Internal RNA polymerase II promoter", description: "An unusual promoter within the 5'UTR of LINE-1 that drives its transcription, making new insertions less dependent on flanking sequences."},
  {name: "interpersonal insertion polymorphism", description: "Interpersonal insertion polymorphism refers to the presence or absence of a specific transposon insertion that varies among individuals."},
  {name: "Interplasmid transposition", description: "Interplasmid transposition is an assay used to demonstrate transposon mobility by movement between plasmids."},
  {name: "Interruption analysis", description: "Interruption analysis is a method to test the selective neutrality of transposable elements by analyzing the frequency with which they are interrupted by other elements."},
  {name: "Intra-chromosomal distribution", description: "Intra-chromosomal distribution describes the pattern of how transposon insertions are spread within a single chromosome."},
  {name: "intra-element recombination", description: "Recombination events occurring within a single transposon copy."},
  {name: "Intra-L1 rearrangement", description: "A form of genetic instability resulting from the resolution of L1 cDNA retrotransposition intermediates."},
  {name: "Intrachromosomal deletion", description: "A form of genetic instability resulting from the resolution of L1 cDNA retrotransposition intermediates."},
  {name: "Intrachromosomal duplication", description: "A form of genetic instability resulting from the resolution of L1 cDNA retrotransposition intermediates."},
  {name: "Intrachromosomal recombination", description: "Intrachromosomal recombination is a genetic event involving the exchange of genetic material between two regions on the same chromosome."},
  {name: "intragenic deletion", description: "Intragenic deletion is a type of mutation where a segment of DNA is lost from within a gene."},
  {name: "intragenic insertion", description: "Intragenic insertion is the insertion of a transposon into the coding or regulatory region of a gene."},
  {name: "intragenic L1 hypomethylation", description: "Reduced methylation of LINE-1 retrotransposons located within gene introns."},
  {name: "intragenic L1 insertion", description: "Intragenic L1 insertion refers to the insertion of a LINE-1 retrotransposon within the boundaries of a gene."},
  {name: "intragenomic conflict", description: "Intragenomic conflict refers to the evolutionary battle between selfish DNA (like L1) and host containment systems."},
  {name: "intraspecific chromosome rearrangement", description: "Intraspecific chromosome rearrangement refers to structural changes in chromosomes within a species."},
  {name: "Intrastrand tetraplex formation", description: "Intrastrand tetraplex formation is a structural feature involving G-rich polypurine tracts that can fold into specific four-stranded DNA structures."},
  {name: "Intrinsic immunity", description: "Intrinsic immunity refers to the cellular defense mechanisms, such as those mediated by APOBEC proteins, that have evolved to restrict the replication of endogenous retroelements and exogenous retroviruses."},
  {name: "Introduce structural variation", description: "SINEs contribute to genomic structural changes and variation."},
  {name: "introduction of new splice sites", description: "Introduction of new splice sites refers to the creation of novel donor or acceptor splice sites within a gene sequence."},
  {name: "Introduction of premature termination codons (PTCs)", description: "Introduction of premature termination codons (PTCs) is a mechanism that can lead to nonsense-mediated mRNA decay and altered gene function."},
  {name: "intron creation", description: "Intron creation is the process by which new introns are formed within a gene."},
  {name: "Intron expansion", description: "Intron expansion refers to the increase in size of an intron over evolutionary time."},
  {name: "Intron retention", description: "Intron retention is a form of alternative splicing where an intron is not removed from the mature mRNA transcript."},
  {name: "Intron size increase", description: "Intron size increase refers to the evolutionary process of introns becoming larger, potentially influenced by various mechanisms."},
  {name: "intronic enhancer", description: "An enhancer element located within an intron of a gene."},
  {name: "intronic insertion", description: "Intronic insertion refers to the insertion of a DNA sequence into an intron of a gene."},
  {name: "Inversion", description: "Inversion is a chromosomal rearrangement where a segment of a chromosome is reversed end to end."},
  {name: "Inversion of exonic regions", description: "Inversion of exonic regions refers to the chromosomal rearrangement that reverses the orientation of exon-containing segments within genes."},
  {name: "IRES-mediated translation", description: "Internal ribosome entry site (IRES)-mediated translation is a cap-independent mechanism of translation initiation."},
  {name: "KAP1 repression", description: "KAP1 represses the expression of endogenous retroviruses (ERVs) and ZNF genes."},
  {name: "KAP1-mediated repression", description: "A repression mechanism where KAP1, the master cofactor of KRAB-ZFPs, silences the expression of specific transposon lineages."},
  {name: "KRAB/KAP1-induced repression", description: "KRAB/KAP1-induced repression is a transcriptional repression system mediated by KRAB-containing zinc finger proteins and their cofactor KAP1."},
  {name: "L1 5'-UTR internal promoter activity", description: "The transcriptional activity driven by the internal promoter located within the long 5'-untranslated region (5'-UTR) of the human LINE-1 retrotransposon."},
  {name: "L1 activation", description: "L1 activation refers to the process that enables LINE-1 retrotransposons to become transcriptionally active and capable of retrotransposition."},
  {name: "L1 activity", description: "L1 activity encompasses the processes involved in LINE-1 retrotransposition, including transcription, translation, and the formation of ribonucleoprotein complexes."},
  {name: "L1 activity regulation", description: "L1 activity regulation refers to the mechanisms by which humans have evolved to limit the activity of LINE-1 elements."},
  {name: "L1 antisense promoter (ASP) activity", description: "The L1 antisense promoter drives transcription into adjacent host genes, producing chimeric transcripts."},
  {name: "L1 antisense promoter (ASP) transcriptional activity", description: "The antisense promoter (ASP) of L1 elements transcribes L1-gene chimeric RNAs that include neighboring exon sequences."},
  {name: "L1 antisense promoter activation", description: "L1 antisense promoter (L1-ASP) activation refers to the initiation of transcription from the antisense promoter within the LINE-1 5' UTR."},
  {name: "L1 antisense promoter activity", description: "The L1 antisense promoter drives transcription of chimeric transcripts, which are 5' L1 antisense sequences spliced to the exons of neighboring genes."},
  {name: "L1 antisense RNA expression", description: "Transcription from the antisense strand of an L1 retrotransposon."},
  {name: "L1 cDNA synthesis", description: "L1 cDNA synthesis is the reverse transcription of LINE-1 RNA into complementary DNA, a key step in retrotransposition."},
  {name: "L1 chimeric transcript (LCT) expression", description: "L1 chimeric transcript expression involves the production of transcripts composed of the L1 5' UTR followed by adjacent genomic sequence, initiated by the L1 antisense promoter."},
  {name: "L1 chimeric transcript formation", description: "L1 chimeric transcript formation refers to the generation of fusion transcripts between LINE-1 sequences and host or viral genes."},
  {name: "L1 chimeric transcription", description: "The process by which L1 elements express chimeric transcripts."},
  {name: "L1 derepression", description: "L1 derepression refers to the loss of transcriptional silencing of LINE-1 elements, which can occur under conditions such as DNA hypomethylation."},
  {name: "L1 dysregulation", description: "L1 dysregulation refers to the abnormal activity or expression of LINE-1 elements."},
  {name: "L1 element inversion", description: "L1 element inversion is a structural alteration where a segment of the L1 element is inserted in the opposite orientation."},
  {name: "L1 element-dependent retrotransposition", description: "A process of genomic insertion mediated by the reverse transcription and integration of LINE-1 elements."},
  {name: "L1 endonuclease (L1 EN) activity", description: "L1 endonuclease activity is the function of the ORF2 protein that nicks target DNA to initiate reverse transcription."},
  {name: "L1 endonuclease activity", description: "L1 endonuclease activity refers to the enzymatic function of the L1 ORF2 protein that cleaves DNA to initiate target-primed reverse transcription (TPRT)."},
  {name: "L1 endonuclease cleavage", description: "L1 endonuclease cleavage is the process where the L1-encoded endonuclease nicks the target DNA to initiate retrotransposition."},
  {name: "L1 endonuclease cutting activity", description: "L1 endonuclease cutting activity refers to the enzymatic function of the L1-encoded protein that cleaves DNA to initiate target-primed reverse transcription (TPRT) or other DNA rearrangements."},
  {name: "L1 endonuclease nicking", description: "The process by which the L1 endonuclease cleaves genomic DNA, an important initial step in the L1 transposition reaction."},
  {name: "L1 endonuclease-dependent integration", description: "An integration mechanism for retrotransposition that depends on the L1 endonuclease activity."},
  {name: "L1 endonuclease-mediated de novo insertion", description: "A specific mechanism of retrotransposon insertion into the genome that is dependent on the L1 endonuclease activity."},
  {name: "L1 endonuclease-mediated retrotransposition", description: "The process by which LINE-1 elements, utilizing their encoded endonuclease, insert new copies into the genome."},
  {name: "L1 expansion", description: "L1 expansion refers to periods of increased activity and genomic insertion of LINE-1 elements."},
  {name: "L1 expression", description: "L1 expression refers to the transcription of LINE-1 elements into RNA."},
  {name: "L1 expression during neurogenesis", description: "The transcriptional activation of LINE-1 elements, which mimics NeuroD1 gene activation, suggesting a role in neurogenesis."},
  {name: "L1 hypomethylation", description: "L1 hypomethylation refers to the reduced methylation of LINE-1 elements, often associated with their transcriptional activation."},
  {name: "L1 inhibition", description: "L1 inhibition refers to the cellular mechanisms that decrease the rate of L1 retrotransposition."},
  {name: "L1 insert generation", description: "The process resulting in the creation of new LINE-1 insertions in the genome."},
  {name: "L1 insertion", description: "L1 insertion is the process by which a newly synthesized LINE-1 copy integrates into the host genome."},
  {name: "L1 insertion polymorphism (LIP)", description: "L1 insertion polymorphism refers to the presence or absence of specific L1 retrotransposon insertions in the genome, which varies among individuals."},
  {name: "L1 integration", description: "The process of L1 retrotransposon insertion into the genome at specific sites."},
  {name: "L1 integration machinery", description: "The molecular machinery of LINE-1 retrotransposons used for creating new genomic integrations."},
  {name: "L1 inversion", description: "L1 inversion refers to the creation of inverted and truncated L1 insertions at the 5' end of the element."},
  {name: "L1 life cycle", description: "The L1 life cycle involves the dynamics of L1 proteins and mRNA localization and function during different stages of the host cell cycle."},
  {name: "L1 life cycle regulation", description: "L1 life cycle regulation refers to the cellular processes that control the replication and mobilization of LINE-1 retrotransposons."},
  {name: "L1 methylation", description: "L1 methylation refers to the DNA methylation status of the LINE-1 element, particularly in its 5' untranslated region."},
  {name: "L1 mobility", description: "L1 mobility refers to the activity and frequency of LINE-1 retrotransposition events."},
  {name: "L1 mobilization", description: "L1 mobilization refers to the process of LINE-1 retrotransposition and insertion into new genomic locations."},
  {name: "L1 mRNA 3' end dynamics", description: "L1 mRNA 3' end dynamics refer to the processes affecting the non-templated 3' ends of L1 mRNA, including poly(A) tail length and uridylation, which shape L1 biology and retrotransposition potential."},
  {name: "L1 mRNA degradation via autophagy", description: "The degradation of LINE-1 RNA transcripts through the cellular autophagy pathway, which is mediated by the m6A reader YTHDF2."},
  {name: "L1 mRNA expression", description: "L1 mRNA expression is the transcription of LINE-1 elements, which is the first step in retrotransposition."},
  {name: "L1 mRNA processing", description: "L1 mRNA processing involves modifications to the primary LINE-1 transcript, such as splicing."},
  {name: "L1 mutagenesis", description: "L1 mutagenesis refers to mutations caused by the activity of LINE-1 retrotransposons, such as insertional mutagenesis."},
  {name: "L1 ORF1p protein expression", description: "L1 ORF1p protein expression is the production of the ORF1 protein from LINE-1 transcripts, commonly detected in human cancers."},
  {name: "L1 ORF2 protein translation", description: "L1 ORF2 protein translation is the process of synthesizing the ORF2 protein from L1 mRNA, which is essential for L1 retrotransposition."},
  {name: "L1 ORF2 protein-dependent retrotransposition", description: "The retrotransposition of non-autonomous elements like Alu depends on the protein machinery (ORF2p) provided by the autonomous LINE-1 element."},
  {name: "L1 ORF2p pausing", description: "L1 ORF2p pausing is a molecular mechanism where the L1 ORF2 protein pauses during reverse transcription, potentially leading to truncated insertions of non-autonomous elements like Alu."},
  {name: "L1 overexpression", description: "An elevated level of L1 mRNA expression compared to normal levels."},
  {name: "L1 population dynamics", description: "L1 population dynamics refers to the changes in the number and activity of LINE-1 elements within the human population over evolutionary time."},
  {name: "L1 proliferation", description: "L1 proliferation refers to the replication and spread of LINE-1 elements within the genome."},
  {name: "L1 promoter activity", description: "L1 promoter activity refers to the transcriptional regulation of the LINE-1 element, which can be induced by various stresses and compounds."},
  {name: "L1 promoter demethylation", description: "L1 promoter demethylation is the loss of DNA methylation at the promoter region of LINE-1 elements, which can lead to their transcriptional reactivation."},
  {name: "L1 promoter hypomethylation", description: "Reduced methylation of the L1 promoter, which correlates with increased L1 activity."},
  {name: "L1 promoter repression", description: "L1 promoter repression is the silencing of the promoter region of LINE-1 elements to prevent their transcription and mobilization."},
  {name: "L1 protein expression", description: "The production of proteins encoded by the LINE-1 element, which are essential for its retrotransposition activity."},
  {name: "L1 protein nuclear entry", description: "L1 protein nuclear entry is the process by which L1 proteins enter the nucleus, a necessary step for L1 proliferation."},
  {name: "L1 quiescence", description: "L1 quiescence refers to periods of low or no activity of LINE-1 elements."},
  {name: "L1 reactivation", description: "L1 reactivation refers to the re-initiation of LINE-1 retrotransposition activity, often occurring in hypomethylated cells like cancer cells and iPSCs."},
  {name: "L1 regulation", description: "L1 regulation involves the cellular mechanisms that control the activity and expression of LINE-1 elements."},
  {name: "L1 replication", description: "L1 replication is the process of self-replication of LINE-1 elements, requiring the proteins ORF1 and ORF2."},
  {name: "L1 replication cycle", description: "The L1 replication cycle refers to the complete mechanistic process by which LINE-1 elements replicate and mobilize within the genome."},
  {name: "L1 repression", description: "L1 repression refers to the molecular mechanisms that suppress the transcriptional activity and retrotransposition of LINE-1 elements."},
  {name: "L1 restriction", description: "L1 restriction refers to the process by which host factors, such as APOBEC3 proteins, inhibit the replication of LINE-1 retroelements."},
  {name: "L1 retrotransposition activity", description: "L1 retrotransposition activity refers to the rate at which LINE-1 elements successfully copy and insert themselves into new genomic locations."},
  {name: "L1 retrotransposition assay", description: "The L1 retrotransposition assay is an exogenous cell culture assay used to study the mobilization of LINE-1 elements."},
  {name: "L1 retrotransposition-induced mutagenesis", description: "L1-retrotransposition-induced mutagenesis refers to the generation of mutations caused by the insertion of LINE-1 elements into new genomic locations."},
  {name: "L1 retrotransposon activity", description: "L1 retrotransposon activity refers to the process of LINE-1 elements mobilizing within the genome via retrotransposition."},
  {name: "L1 retrotransposon expression", description: "L1 retrotransposon expression refers to the transcription and translation of L1 elements, particularly its open reading frames (ORFs)."},
  {name: "L1 retrotransposon insertion", description: "L1 retrotransposon insertion refers to the integration of an L1 element into a new genomic location via retrotransposition."},
  {name: "L1 retrotransposon-induced DNA damage response", description: "The cellular response triggered by DNA damage caused by L1 retrotransposition activity."},
  {name: "L1 reverse transcriptase (RT) activity", description: "L1 reverse transcriptase (RT) activity refers to the enzymatic function of the L1 ORF2p protein to reverse transcribe L1 RNA into cDNA."},
  {name: "L1 reverse transcriptase activity", description: "The enzymatic activity of the LINE-1 ORF2 protein that converts L1 RNA into cDNA during retrotransposition."},
  {name: "L1 reverse transcription", description: "L1 reverse transcription is the process by which the L1 ORF2 protein converts L1 RNA into cDNA."},
  {name: "L1 ribonucleoprotein (RNP) complex formation", description: "L1 ribonucleoprotein (RNP) complex formation is a step in the retrotransposition process, where the L1 RNA and its encoded proteins assemble into a complex."},
  {name: "L1 ribonucleoprotein (RNP) formation", description: "L1 ribonucleoprotein formation involves the binding of LINE-1-encoded proteins to their encoding transcript, mediating retrotransposition."},
  {name: "L1 ribonucleoprotein complex integrity", description: "The L1 ribonucleoprotein complex is a structure containing L1 RNA and associated proteins, essential for the retrotransposition process."},
  {name: "L1 ribonucleoprotein formation", description: "The assembly of L1 RNA with proteins, including ORF1p, which is essential for retrotransposition."},
  {name: "L1 ribonucleoprotein particle (L1-RNP) expression", description: "L1-RNP refers to the ribonucleoprotein complex formed by LINE-1 RNA and associated proteins, which is essential for its retrotransposition."},
  {name: "L1 RNA degradation", description: "L1 RNA degradation refers to the cellular process of breaking down LINE-1 RNA, which can inhibit retrotransposition."},
  {name: "L1 RNA up-regulation", description: "L1 RNA up-regulation refers to an increase in the transcription or abundance of LINE-1 RNA."},
  {name: "L1 RNA/protein activity", description: "Activities of L1 si/piRNAs, mRNAs, and ORF1 and ORF2 proteins, independent of retrotransposition."},
  {name: "L1 RNP complex assembly", description: "L1 RNP complex assembly is the process where L1 ORF1p and ORF2p proteins bind L1 RNA to form a ribonucleoprotein complex."},
  {name: "L1 RNP complex formation", description: "The formation of the L1 ribonucleoprotein (RNP) complex, involving ORF1p and ORF2p proteins bound to L1 RNA, is essential for retrotransposition."},
  {name: "L1 RNP formation", description: "L1 RNP formation is the assembly of LINE-1 RNA and proteins into a ribonucleoprotein complex, which is an essential intermediate for retrotransposition."},
  {name: "L1 RNP trafficking", description: "L1 RNP trafficking refers to the movement of the LINE-1 ribonucleoprotein particle within the cell, particularly towards the nucleus where reverse transcription occurs."},
  {name: "L1 RNP translocation", description: "L1 RNP translocation refers to the movement of LINE-1 ribonucleoprotein complexes within the host cell."},
  {name: "L1 RT activity", description: "L1 reverse transcriptase (RT) activity is the enzymatic function required for the reverse transcription step during LINE-1 retrotransposition."},
  {name: "L1 silencing", description: "L1 silencing refers to the epigenetic repression of LINE-1 retrotransposon expression and activity."},
  {name: "L1 structure", description: "L1 structure refers to the genomic organization and sequence features of the LINE-1 element."},
  {name: "L1 suppression", description: "L1 suppression refers to host mechanisms that inhibit or reduce the activity and retrotransposition of LINE-1 elements."},
  {name: "L1 trans-driven Alu retrotransposition", description: "L1 trans-driven Alu retrotransposition is the process by which Alu elements are mobilized in trans by the LINE-1 retrotransposition machinery."},
  {name: "L1 trans-driven retrotransposition", description: "The process where non-autonomous elements (Alu, SVA) are mobilized by the LINE-1 protein machinery in trans."},
  {name: "L1 trans-driven SVA retrotransposition", description: "L1 trans-driven SVA retrotransposition is the process by which SVA elements are mobilized in trans by the LINE-1 retrotransposition machinery."},
  {name: "L1 transcription", description: "The process of transcribing the human LINE-1 (L1) retrotransposon sequence into RNA."},
  {name: "L1 transcription factor binding", description: "The binding of various transcription factors to specific sites within the internal region of the LINE-1 5'-UTR, which is crucial for effective transcription."},
  {name: "L1 transcription repression by DNA methylation", description: "A mechanism involving methylation of specific CpG sites in the L1 promoter to inhibit its transcriptional activity."},
  {name: "L1 transcriptional activation", description: "The process of initiating transcription of LINE-1 elements, which is governed by individual-, locus-, and cell-type-specific determinants."},
  {name: "L1 transcriptional activity", description: "L1 transcriptional activity refers to the process of transcribing LINE-1 retrotransposons into RNA."},
  {name: "L1 transcriptional regulation", description: "The mechanisms controlling the transcription of the human LINE-1 retrotransposon, involving specific regions within its 5'-UTR."},
  {name: "L1 transcriptional repression", description: "L1 transcriptional repression refers to the downregulation of LINE-1 RNA expression."},
  {name: "L1 translation", description: "The process of synthesizing L1-encoded proteins (ORF1p and ORF2p) from its mRNA."},
  {name: "L1 transposition", description: "The process by which LINE-1 elements move within the genome, which can cause genetic defects."},
  {name: "L1 transposon activity", description: "L1 transposon activity refers to the process of retrotransposition and other functional states of LINE-1 elements within the genome."},
  {name: "L1 transposon insertion", description: "L1 transposon insertion refers to the integration of an L1 element into a new genomic site, which can disrupt gene function or regulation."},
  {name: "L1 upregulation", description: "Increased expression levels of LINE-1 retrotransposons."},
  {name: "L1-derived chimeric transcript formation", description: "The generation of hybrid RNA molecules that contain sequences from both an L1 retrotransposon and a host gene."},
  {name: "L1-gene chimeric RNA transcription", description: "The L1 antisense promoter (ASP) transcribes L1-gene chimeric RNAs that include neighboring exon sequences."},
  {name: "L1-gene chimeric transcript formation", description: "L1-gene chimeric transcript (LCT) formation involves the creation of fusion transcripts between LINE-1 and host genes."},
  {name: "L1-host interactions", description: "L1-host interactions refer to the molecular interplay between the LINE-1 retrotransposon and host cellular factors that regulate its activity."},
  {name: "L1-induced DNA damage", description: "L1-induced DNA damage refers to genomic damage caused by the activity of the LINE-1 retrotransposon."},
  {name: "L1-induced mutagenesis", description: "L1-induced mutagenesis refers to the process where L1 retrotransposition causes mutations in the genome."},
  {name: "L1-initiated mutagenesis", description: "L1-initiated mutagenesis refers to the process where LINE-1 retrotransposition causes genetic mutations."},
  {name: "L1-mediated 3' transduction", description: "L1-mediated 3' transduction is a pathway for exon shuffling where L1 associates 3' flanking DNA in cis and carries it to a new genomic location."},
  {name: "L1-mediated Alu retrotransposition", description: "L1-mediated Alu retrotransposition is the process by which Alu elements mobilize using the LINE-1 enzymatic machinery."},
  {name: "L1-mediated gene disruption", description: "L1-mediated gene disruption refers to the molecular mechanisms by which LINE-1 retrotransposition events cause damage to or alter gene function."},
  {name: "L1-mediated mutation", description: "L1-mediated mutation refers to the acquisition of new mutations caused by LINE-1 retrotransposition activity."},
  {name: "L1-mediated nicking of genomic DNA", description: "The process by which L1 retrotransposition machinery introduces nicks or breaks in genomic DNA."},
  {name: "L1-mediated transduction", description: "L1-mediated transduction is the process by which active LINE-1 elements mobilize and insert non-L1 DNA sequences flanking their 3' ends into new genomic locations."},
  {name: "L1-mediated tumorigenesis", description: "L1-mediated tumorigenesis refers to the oncogenic processes that can be affected by L1 retrotransposons."},
  {name: "L1-MET chimera expression", description: "The production of a chimeric transcript resulting from the fusion of LINE-1 and the MET gene."},
  {name: "L1-NXF1 binding element (L1-NBE) function", description: "A sequence in the 3' UTR of LINE-1 mRNA that binds NXF1 and can mediate nuclear export of RNA."},
  {name: "L1-ORF1p activity", description: "L1-ORF1p activity refers to the function of the ORF1 protein encoded by LINE-1, which is essential for retrotransposition."},
  {name: "L1-ORF1p expression", description: "L1-ORF1p expression refers to the production of the ORF1 protein encoded by LINE-1 elements, indicative of L1 activity."},
  {name: "L1-ORF2 expression", description: "L1-ORF2 expression refers to the transcription of the open reading frame 2 of the LINE-1 element, which encodes proteins with endonuclease and reverse transcriptase activities."},
  {name: "L1-ORF2p overexpression", description: "Enhanced expression of the ORF2 protein encoded by LINE-1 retrotransposons."},
  {name: "L1-reinforced inflammation", description: "L1-reinforced inflammation is inflammation triggered or exacerbated by the activity of the LINE-1 retrotransposon."},
  {name: "L1-ribonucleoprotein particle formation", description: "An active L1 encodes two proteins (ORF1p and ORF2p) that bind with L1 RNA and form L1-ribonucleoprotein particles (RNPs)."},
  {name: "L1Hs expression", description: "The production of a protein encoded by the L1Hs element."},
  {name: "L1Hs retrotransposition", description: "The process by which L1Hs elements move within the genome through a 'copy-and-paste' mechanism involving reverse transcription."},
  {name: "L1Hs transcription", description: "The process of transcribing the L1Hs retrotransposon from its internal promoter in the 5' untranslated region (5'UTR)."},
  {name: "L1ORF1p trimerization", description: "L1ORF1p trimerizes via a coiled coil domain, which is essential for its function in retrotransposition."},
  {name: "L1RNA packaging", description: "L1ORF1p packages L1RNA into large assemblies, a step required for retrotransposition."},
  {name: "Large genomic copy number change", description: "Large genomic copy number change refers to alterations in the genome involving the gain or loss of hundreds of kilobases to megabases of DNA."},
  {name: "Large genomic deletion", description: "Large genomic deletion refers to the loss of a significant segment of DNA from the genome."},
  {name: "Large genomic deletions", description: "Large genomic deletions are a type of structural variation involving the loss of a significant segment of DNA."},
  {name: "Large genomic deletions upon insertion", description: "Large genomic deletions can be generated as a consequence of LINE-1 insertion events."},
  {name: "large genomic duplications", description: "Large genomic duplications are potentially mutagenic events that can occur at the site of retrotransposon insertion."},
  {name: "Large-scale concerted regulatory activities", description: "Coordinated regulatory events affecting many genomic loci, potentially driven by transposons."},
  {name: "large-scale duplication", description: "Large-scale duplication is a genomic alteration resulting in the amplification of a large chromosomal region."},
  {name: "Large-scale epigenetic reprogramming", description: "A genome-wide resetting of epigenetic marks, such as DNA methylation and histone modifications."},
  {name: "Lateral transmission", description: "Lateral transmission refers to the horizontal transfer of genetic material, such as transposable elements, between species."},
  {name: "lentiviral system", description: "A lentiviral system is a gene delivery method based on modified lentiviruses, capable of integrating genetic material into the genome of dividing and non-dividing mammalian cells."},
  {name: "Leucine zipper motif", description: "A leucine zipper is a structural motif in proteins that facilitates dimerization and may be involved in DNA binding or protein-protein interactions."},
  {name: "LINC01446 transcription", description: "The process of transcribing the long non-coding RNA LINC01446 from its genomic locus."},
  {name: "LINE expression", description: "LINE expression refers to the transcription of LINE elements and their potential incorporation into gene transcripts."},
  {name: "LINE expression suppression in S phase", description: "Suppression of LINE retrotransposon expression during the S phase of the cell cycle."},
  {name: "LINE insertion", description: "LINE insertion refers to the process by which LINE retrotransposons integrate into new genomic locations."},
  {name: "LINE integration", description: "LINE integration refers to the insertion of a LINE element into a new genomic location, often generating target-site duplications."},
  {name: "LINE reverse transcription", description: "The process by which LINE RNA is reverse transcribed into cDNA by its own encoded reverse transcriptase."},
  {name: "LINE transposition", description: "LINE transposition is the process by which LINE elements mobilize within the genome via retrotransposition."},
  {name: "LINE-1 activation", description: "LINE-1 activation refers to the increased transcriptional or retrotranspositional activity of LINE-1 elements."},
  {name: "LINE-1 activity", description: "LINE-1 activity refers to the functional capability of LINE-1 elements, including retrotransposition and the expression of its encoded proteins ORF1p and ORF2p."},
  {name: "LINE-1 activity-dependent lethality", description: "LINE-1 activity-dependent lethality refers to reduced cell viability that is contingent upon the functional activity of LINE-1 elements."},
  {name: "LINE-1 amplification", description: "LINE-1 amplification refers to the process of increasing the copy number of LINE-1 elements in the genome through retrotransposition."},
  {name: "LINE-1 chimeric transcript (LCT) generation", description: "The production of transcripts initiated from LINE-1 promoters that extend into flanking unique genomic sequences."},
  {name: "LINE-1 derepression", description: "The process by which LINE-1 elements are released from transcriptional silencing, often due to heterochromatin disruption."},
  {name: "LINE-1 dysregulation", description: "LINE-1 dysregulation refers to the abnormal expression or activity of LINE-1 elements, which is a feature observed in cancer cells."},
  {name: "LINE-1 evolution", description: "The process of change and diversification in LINE-1 sequences and lineages over time."},
  {name: "LINE-1 expression", description: "LINE1 expression refers to the transcription and potential activity of LINE-1 elements."},
  {name: "LINE-1 hypomethylation", description: "LINE1 hypomethylation refers to the reduced methylation level of LINE-1 elements."},
  {name: "LINE-1 induced DSB formation", description: "LINE-1 induced DSB formation refers to the generation of DNA double-strand breaks as a consequence of LINE-1 retrotransposition activity."},
  {name: "LINE-1 inhibition", description: "LINE-1 inhibition refers to the suppression of LINE-1 retrotransposition activity."},
  {name: "LINE-1 insertion", description: "The process by which LINE-1 retrotransposons insert into new genomic locations."},
  {name: "LINE-1 locus transcription", description: "The transcriptional activity originating from LINE-1 genomic loci."},
  {name: "LINE-1 methylation", description: "LINE-1 methylation refers to the level of 5'-methylcytosine modifications at CpG sites within LINE-1 elements, which is correlated with global DNA methylation."},
  {name: "LINE-1 methylation pattern", description: "LINE-1 methylation pattern refers to the specific distribution of methylated and unmethylated CpG sites within LINE-1 elements."},
  {name: "LINE-1 mobility", description: "LINE-1 mobility refers to the process of LINE-1 retrotransposition within the genome."},
  {name: "LINE-1 mobility enhancement", description: "The process of increasing the rate or efficiency of LINE-1 retrotransposition."},
  {name: "LINE-1 mobilization", description: "The process of LINE-1 retrotransposition, moving to new genomic locations."},
  {name: "LINE-1 mRNA host modification", description: "Host modification of LINE-1 mRNA is a central key intermediate component during the life cycle of LINE-1 retrotransposition."},
  {name: "LINE-1 overexpression", description: "LINE-1 overexpression is a hallmark of cancers."},
  {name: "LINE-1 polymorphisms", description: "LINE-1 polymorphisms are variations in LINE-1 sequences among individuals in a population."},
  {name: "LINE-1 promoter activity", description: "The transcriptional activity driven by the 5'-untranslated region (5'-UTR) of LINE-1 elements."},
  {name: "LINE-1 promoter hypomethylation", description: "Reduced methylation of the LINE-1 promoter region, which is associated with its transcriptional activation and overexpression."},
  {name: "LINE-1 promoter methylation", description: "LINE-1 promoter methylation is associated with decreased LINE-1 propagation."},
  {name: "LINE-1 reactivation", description: "The derepression and increased transcriptional activity of LINE1 elements."},
  {name: "LINE-1 replication", description: "LINE-1 replication is the process by which LINE-1 elements copy and insert themselves into new genomic locations."},
  {name: "LINE-1 replication cycle regulation", description: "The regulation of the whole LINE-1 replication cycle involves various molecular mechanisms."},
  {name: "LINE-1 repression", description: "The inhibition or downregulation of LINE-1 expression or activity."},
  {name: "LINE-1 restriction", description: "LINE-1 restriction refers to host mechanisms that curb or inhibit LINE-1 retrotransposition activity."},
  {name: "LINE-1 retrotransposition", description: "L1 retrotransposition is the process by which LINE-1 elements move within the genome through a 'copy-and-paste' mechanism."},
  {name: "LINE-1 retrotransposon expression", description: "LINE-1 retrotransposon expression refers to the transcriptional activation of LINE-1 elements, which is a prerequisite for their retrotransposition activity."},
  {name: "LINE-1 retrotransposon-mediated insertion", description: "A process where a LINE-1 retrotransposon mobilizes and inserts a cDNA copy of a gene into a new genomic location, often flanked by target site duplications."},
  {name: "LINE-1 reverse transcriptase activity", description: "LINE-1 reverse transcriptase activity is the enzymatic function of the LINE-1 ORF2 protein that converts LINE-1 RNA into cDNA during retrotransposition."},
  {name: "LINE-1 RNA degradation", description: "LINE-1 RNA degradation is the post-transcriptional reduction of LINE-1 RNA levels."},
  {name: "LINE-1 RNA transcription", description: "The process of synthesizing LINE-1 RNA from its genomic DNA template."},
  {name: "LINE-1 transcription", description: "LINE-1 transcription is the process of generating LINE-1 RNA from its genomic DNA."},
  {name: "LINE-1 transcription initiation", description: "LINE-1 transcription initiation is the process of starting RNA synthesis from the LINE-1 internal promoter, which is required for retrotransposition."},
  {name: "LINE-1 transcription regulation", description: "LINE-1 transcription regulation involves the control of LINE-1 gene expression by transcriptional regulators such as CTCF, YY1, and DUSP1."},
  {name: "LINE-1 transcription upregulation", description: "An increase in the transcriptional activity of LINE-1 retrotransposons."},
  {name: "LINE-1 transposition", description: "LINE-1 transposition is the movement of LINE-1 elements via retrotransposition."},
  {name: "LINE-1-centric chromatin interactions", description: "Chromatin interactions that are centered around or involve LINE-1 loci."},
  {name: "LINE-1-mediated cell toxicity", description: "Cellular damage or dysfunction caused by the activity or components of LINE-1 retrotransposons."},
  {name: "LINE-1-mediated insertion", description: "LINE-1-mediated insertion refers to the process where LINE-1 retrotransposition results in the integration of its own or other sequences into new genomic locations."},
  {name: "LINE-1-mediated retrotransposition", description: "LINE1 mediated retrotransposition is the process by which non-autonomous retrotransposons, such as SVA, are mobilized in the genome via the enzymatic machinery encoded by LINE1 elements."},
  {name: "LINE-mediated retrotransposition", description: "The process by which LINE retrotransposons facilitate the integration of non-autonomous sequences, such as retroviral mRNA, into the genome."},
  {name: "LINE1 suppression", description: "LINE1 suppression refers to the inhibition of LINE-1 retrotransposon activity or expression."},
  {name: "LINE1 transposition suppression", description: "LINE1 transposition suppression is the process of inhibiting the mobility of LINE-1 elements."},
  {name: "LINE1 upregulation", description: "LINE1 upregulation refers to the increased expression of LINE-1 elements."},
  {name: "LINE1-triggered immune activation", description: "LINE1-triggered immune activation refers to the process by which endogenous LINE1 components stimulate the innate immune system."},
  {name: "Lineage tracing", description: "Lineage tracing is a technique used to track the progeny of a single cell over time to understand cell fate and developmental trajectories."},
  {name: "Lineage-specific insertion", description: "The insertion of a genetic element, such as a retrotransposon, that is specific to a particular evolutionary lineage."},
  {name: "Lineage-specific protein birth", description: "The process by which LINE-1 elements contribute to the creation of lineage-specific proteins."},
  {name: "Linkage disequilibrium", description: "Linkage disequilibrium is the non-random association of alleles at different loci in a population."},
  {name: "Lipid droplet formation", description: "Lipid droplet formation is the process of creating intracellular organelles that store neutral lipids."},
  {name: "liquid droplet formation", description: "A biophysical process associated with phase separation, leading to the formation of membrane-less organelles or compartments."},
  {name: "Liquid-liquid phase separation", description: "Liquid-liquid phase separation (LLPS) is a biophysical process where biomolecules condense into membrane-less compartments to concentrate cellular components and regulate biological functions."},
  {name: "liquid-liquid phase separation (LLPS)", description: "Liquid-liquid phase separation (LLPS) is a biophysical process where biomolecules condense into membrane-less compartments, facilitating specific cellular functions."},
  {name: "lncRNA expression", description: "Expression of long non-coding RNAs (lncRNAs) derived from transposable elements."},
  {name: "lncRNA stabilization of p120-catenin", description: "LncMER52A, derived from a MER52A retrotransposon, stabilizes p120-catenin protein."},
  {name: "Local adaptation", description: "Local adaptation is the process by which populations evolve traits that are advantageous in their specific local environment."},
  {name: "local immune evasion", description: "Local immune evasion is a process by which tumor cells avoid detection and destruction by the immune system within the tumor microenvironment."},
  {name: "local regulation", description: "Local regulation refers to the control of gene or element expression by nearby sequence contexts or factors, as opposed to global regulation."},
  {name: "Locus protection from integration", description: "A mechanism or state where a specific genomic locus is shielded or resistant to the integration of transposons."},
  {name: "locus-specific transcriptional regulation", description: "Locus-specific transcriptional regulation refers to the precise control of gene or element expression at individual genomic locations."},
  {name: "long non-coding RNA (lncRNA) expression", description: "Long non-coding RNA expression refers to the transcription of RNA molecules longer than 200 nucleotides that do not code for proteins."},
  {name: "Long non-coding RNA (lncRNA) function", description: "Long non-coding RNA (lncRNA) function refers to the role of RNA molecules that do not code for proteins but have regulatory functions."},
  {name: "Long-range chromatin interaction", description: "A physical interaction between a retrotransposon and distant genomic regions, such as genes, facilitated by chromatin looping."},
  {name: "long-range enhancer-promoter chromatin interactions", description: "Long-range enhancer-promoter chromatin interactions are physical contacts between distal regulatory elements and gene promoters that regulate gene expression."},
  {name: "long-range gene activation", description: "The process of activating gene expression from a genomic location that is physically distant from the regulatory element."},
  {name: "long-range gene expression activation", description: "The process by which transcription of a genetic element activates the expression of genes located at a distance in the genome."},
  {name: "Long-range promoter-enhancer interaction", description: "Physical interactions between gene promoters and distal enhancer elements that regulate gene expression over large genomic distances."},
  {name: "Long-range transcriptional regulation", description: "A mechanism where a regulatory element influences gene expression from a distant genomic location."},
  {name: "Long-term accumulation", description: "Long-term accumulation refers to the process of Alu elements building up in GC-rich DNA over evolutionary time."},
  {name: "Long-term gene expression", description: "Long-term gene expression refers to the sustained production of a gene product over an extended period, often achieved through stable integration into the genome."},
  {name: "Loop formation", description: "Loop formation is a mechanism of chromatin organization where distant genomic regions are brought into close spatial proximity."},
  {name: "Loss of 5mC methylation", description: "Loss of 5mC methylation refers to the decrease in DNA methylation levels, which can lead to the de-repression of transposable elements."},
  {name: "Loss of DNA cytosine methylation", description: "Loss of DNA cytosine methylation refers to the reduction or removal of methyl groups from cytosine bases in DNA, often associated with gene activation."},
  {name: "Loss of efficient DNA repair", description: "Loss of efficient DNA repair is the diminished capacity of a cell to accurately mend DNA lesions."},
  {name: "loss of genome stability", description: "Loss of genome stability refers to the increased rate of genomic alterations, including mutations and chromosomal changes."},
  {name: "loss of heterochromatin", description: "Loss of heterochromatin is the reduction of tightly packed, transcriptionally silent chromatin regions."},
  {name: "loss of methylation", description: "Loss of methylation refers to the reduction or absence of DNA methylation, which can lead to the loss of epigenetic silencing."},
  {name: "Loss of methylation (LOM)", description: "Loss of methylation refers to the reduction or absence of DNA methylation at specific genomic regions, such as differentially methylated regions (DMRs), which can disrupt normal gene imprinting and expression."},
  {name: "LTR-driven gene expression", description: "LTR-driven gene expression refers to the ability of long terminal repeats (LTRs) to initiate transcription of a reporter gene in transient expression assays."},
  {name: "LTR-driven transcription", description: "LTRs can serve as regulatory sequences and drive transcription of tissue or cancer-specific transcripts."},
  {name: "LTR-mediated retroposition", description: "LTR-mediated retroposition is a mechanism of RNA-based duplication in metazoans, involving chimeric structures of retrocopies flanked by LTR retrotransposons."},
  {name: "Lysine methyltransferase activity", description: "Lysine methyltransferase activity is the enzymatic function of the SET domain within the SETMAR protein to methylate lysine residues on target proteins."},
  {name: "M1 macrophage polarization", description: "M1 macrophage polarization is the process by which macrophages are activated towards a pro-inflammatory, anti-tumor phenotype."},
  {name: "m6A methylation", description: "m6A methylation is a common RNA modification involving the methylation of adenine residues."},
  {name: "Maintaining genome integrity", description: "The process of preserving the stability and correct sequence of the genome."},
  {name: "maintaining memory function", description: "Maintaining memory function refers to preserving the ability of CAR-T cells to persist and respond effectively after administration."},
  {name: "maintaining pluripotency", description: "Maintaining pluripotency refers to the process of keeping embryonic stem cells in an undifferentiated state with the potential to develop into any cell type."},
  {name: "Maintaining trans-generational genome stability", description: "Maintaining trans-generational genome stability refers to the preservation of genomic integrity across generations."},
  {name: "Maintenance of H3K27me3 levels", description: "Maintenance of H3K27me3 levels refers to the process of sustaining repressive histone modifications, particularly at specific genomic loci."},
  {name: "Maintenance of neuronal progenitor cells", description: "Maintenance of neuronal progenitor cells refers to the biological processes that keep these stem-like cells in an undifferentiated, proliferative state."},
  {name: "Maintenance of retrotransposons", description: "Maintenance of retrotransposons refers to the processes that sustain the presence and activity of retrotransposons within a genome over evolutionary time."},
  {name: "malignant progression", description: "Malignant progression refers to the development of more aggressive and invasive cancer phenotypes."},
  {name: "malignant transformation", description: "Malignant transformation is the process by which normal cells acquire the properties of cancer cells."},
  {name: "Malignization", description: "Malignization is the process by which normal cells transform into malignant cancer cells."},
  {name: "Mammalian evolution", description: "The evolutionary process that gave rise to unique mammalian traits, such as viviparous reproduction and a developed central nervous system."},
  {name: "Mammalian-specific genomic functions", description: "A concept covering both mammalian-specific epigenetics and genetics, including processes like genomic imprinting and functions derived from LTR retrotransposons."},
  {name: "mcr restriction", description: "mcr restriction is a bacterial defense system that cleaves DNA containing methylated cytosine residues, particularly in CpG dinucleotides."},
  {name: "MDA5-MAVS pathway activation", description: "The activation of the innate immune signaling pathway involving the cytosolic RNA sensor MDA5 and its adaptor protein MAVS."},
  {name: "MDA5-mediated LINE-1 suppression", description: "MDA5-mediated LINE-1 suppression is the process by which the protein MDA5 inhibits LINE-1 activity."},
  {name: "Mechano-response enhancer element (MREE) activity", description: "The function of transposable elements to act as enhancers that respond to mechanical cues from the cellular microenvironment."},
  {name: "Mediating chromosome rearrangements", description: "Mediating chromosome rearrangements involves processes that lead to structural changes in chromosomes."},
  {name: "mediating epigenetic memory", description: "Mediating epigenetic memory is a function where retrotransposons can contribute to the maintenance of epigenetic states across cell divisions."},
  {name: "Mediating homeology-driven DNA recombination or repair", description: "A mechanism where transposable elements facilitate DNA recombination or repair based on homeologous (similar but not identical) sequences."},
  {name: "Mediating homology-driven DNA recombination or repair", description: "A mechanism where transposable elements facilitate DNA recombination or repair based on sequence homology."},
  {name: "Mediating microhomology-driven DNA recombination or repair", description: "A mechanism where transposable elements facilitate DNA recombination or repair based on short stretches of sequence similarity (microhomology)."},
  {name: "memory formation", description: "Memory formation is the biological process by which experiences are encoded, stored, and retrieved in the brain."},
  {name: "metabolic reprogramming", description: "Metabolic reprogramming is a hallmark of cancer where tumor cells alter their metabolism to support growth and proliferation."},
  {name: "metastasis", description: "Metastasis is the spread of cancer cells from the primary tumor to distant sites in the body."},
  {name: "methylation", description: "Methylation is an epigenetic modification involving the addition of a methyl group to DNA, often associated with gene silencing."},
  {name: "Methylation pattern analysis", description: "Methylation pattern analysis involves assessing the methylation status of cytosines on complementary DNA strands to understand epigenetic inheritance."},
  {name: "Methylation quantitative trait loci (mQTL)", description: "A methylation quantitative trait loci (mQTL) is a genomic locus where genetic variation is associated with variation in DNA methylation levels."},
  {name: "Methylation-induced silencing", description: "Methylation-induced silencing is a mechanism of gene repression mediated by DNA methylation."},
  {name: "microglial dysfunction", description: "Microglial dysfunction refers to the impaired function of microglia, including changes in morphology, cytokine secretion, and phagocytic ability."},
  {name: "Microhomology end-joining", description: "Microhomology end-joining is a DNA repair mechanism that uses short homologous sequences to join DNA ends."},
  {name: "Microhomology-driven single-strand annealing", description: "Microhomology-driven single-strand annealing is a process that resolves L1 inversion intermediates."},
  {name: "Microhomology-mediated end-joining", description: "A cellular DNA repair pathway that uses short patches of overlapping nucleotides to join DNA ends."},
  {name: "microhomology-mediated end-joining (MMEJ)", description: "Microhomology-mediated end-joining is an error-prone pathway for repairing DNA double-strand breaks."},
  {name: "microhomology-mediated mispairing", description: "Microhomology-mediated mispairing is a mechanism where short sequence homologies facilitate the annealing and integration of a nascent cDNA strand, potentially leading to truncated insertions."},
  {name: "Microhomology-mediated repair", description: "Microhomology-mediated repair is a DNA repair pathway that uses short homologous sequences (microhomologies) to join broken DNA ends, often resulting in deletions."},
  {name: "micronuclei formation", description: "Micronuclei formation is the generation of small, extranuclear bodies containing damaged chromosomes or chromosome fragments."},
  {name: "microRNA (miRNA) regulation", description: "MicroRNA regulation involves small non-coding RNAs that post-transcriptionally regulate gene expression by binding to target mRNAs."},
  {name: "microsatellite generation", description: "Microsatellite generation is the process by which new microsatellite repeats are formed in the genome."},
  {name: "microsatellite instability", description: "Microsatellite instability (MSI) is a condition of genetic hypermutability resulting from impaired DNA mismatch repair."},
  {name: "Minus-strand DNA synthesis", description: "Minus-strand DNA synthesis is a step during L1 reverse transcription, potentially facilitated by specific template structures like polypurine tracts and stem-loops."},
  {name: "miRNA biogenesis from transposable elements", description: "The process by which small RNA molecules (miRNAs) originate from transposable element sequences in the genome."},
  {name: "miRNA biogenesis modulation", description: "The process by which LINE-1-encoded RT modulates the production of miRNAs by governing the balance between regulatory double-stranded RNAs and RNA:DNA hybrids."},
  {name: "miRNA duplication", description: "miRNA duplication refers to the process by which miRNA genes are copied and expanded within the genome."},
  {name: "miRNA gene emergence", description: "miRNA gene emergence is the process by which new microRNA genes originate in the genome."},
  {name: "miRNA gene generation", description: "The process by which transposable elements, particularly MITEs, give rise to novel microRNA genes."},
  {name: "miRNA-based gene regulation", description: "miRNA-based gene regulation is a mechanism where microRNAs (miRNAs) bind to target mRNA sequences to inhibit translation or promote degradation."},
  {name: "miRNA-mediated gene regulation", description: "MicroRNAs (miRNAs) are non-coding RNA molecules that inhibit gene expression by binding to the 3' untranslated region (UTR) of target genes."},
  {name: "Mis-expression", description: "Mis-expression refers to the abnormal expression of a gene, such as in the wrong tissue, at the wrong time, or at abnormal levels."},
  {name: "mismatch repair", description: "Mismatch repair (MMR) is a DNA repair pathway that corrects base-base mismatches and insertion/deletion loops."},
  {name: "Misregulation of retrotransposons", description: "Misregulation of retrotransposons refers to abnormal expression or control of retrotransposon activity."},
  {name: "MITE mobilization", description: "MITE mobilization refers to the transposition of internally deleted transposon sequences (Miniature Inverted-repeat Transposable Elements)."},
  {name: "mitochondrial dysfunction", description: "Mitochondrial dysfunction refers to impaired function of mitochondria, which can lead to cellular energy deficits and contribute to disease."},
  {name: "Mitochondrial homeostasis", description: "Mitochondrial homeostasis involves the maintenance of mitochondrial number, structure, and function through processes like biogenesis and mitophagy."},
  {name: "Mitotic function of neocentromere", description: "Mitotic function of neocentromere refers to the role of a neocentromere in ensuring proper chromosome segregation during cell division."},
  {name: "Mitotic nuclear membrane breakdown", description: "Mitotic nuclear membrane breakdown is a stage in the cell cycle that LINE-1 ribonucleoproteins (RNPs) take advantage of to enter the nucleus."},
  {name: "Mitotic potential", description: "Mitotic potential refers to a cell's capacity to undergo cell division."},
  {name: "Mobile element insertion", description: "Mobile element insertion refers to the integration of transposable elements into new genomic locations."},
  {name: "Mobile element insertion (MEI)", description: "Mobile element insertion (MEI) refers to the integration of a transposable element into a new genomic location."},
  {name: "Mobile element transposition", description: "Mobile element transposition is the process by which mobile elements move and insert into new genomic locations."},
  {name: "Mobile element-associated deletion", description: "Mobile element-associated deletion refers to the removal of genomic sequence caused by or associated with transposable element activity."},
  {name: "mobile regulatory element", description: "A mobile regulatory element is a genetic element that can move within the genome and influence the expression of nearby genes."},
  {name: "mobility", description: "Mobility refers to the ability of transposable elements to change their genomic location through transposition."},
  {name: "Mobilization", description: "Mobilization is the process by which transposable elements move within the genome."},
  {name: "Mobilization efficiency determination", description: "Mobilization efficiency determination refers to the process by which specific domains of a retrotransposon influence its rate of successful retrotransposition."},
  {name: "Mobilization in cis", description: "Mobilization in cis refers to the process where an active LINE-1 element uses its own encoded enzymatic machinery to retrotranspose."},
  {name: "Mobilization in trans", description: "Mobilization in trans refers to the process where SINE elements utilize the enzymatic machinery encoded by active LINE-1 elements to retrotranspose."},
  {name: "Mobilization of cellular RNAs", description: "The process by which LINE-1 machinery contributes to the movement and amplification of other cellular RNAs, such as Alu, mRNAs, and snRNAs."},
  {name: "Mobilization of cellular transcripts", description: "The process by which HERVs can capture and mobilize portions of cellular mRNAs, such as TRPC6 mRNA, into the genome."},
  {name: "Mobilization of non-L1 RNAs", description: "The process by which LINE-1 retrotransposons facilitate the movement of non-L1 RNA sequences, such as pseudogenes, tRNAs, snRNAs, and SINEs, into new genomic locations."},
  {name: "Mobilization of other sequences", description: "Active retrotransposons can mobilize other sequences to generate retro-pseudogenes or amplify other repeated sequences."},
  {name: "Mobilization of transposable elements", description: "Mobilization of transposable elements refers to the activation and movement of transposons within the genome."},
  {name: "Mobilization of U6 snRNA", description: "The process by which the L1 retrotransposition machinery can move U6 small nuclear RNA to new genomic locations."},
  {name: "mobilization of unrelated sequences", description: "L1Hs elements can mobilize and insert non-autonomous sequences into existing genes."},
  {name: "Modeling genetic variations", description: "Modeling genetic variations involves creating cellular or animal models that carry specific genetic changes to study their biological consequences and relevance to disease."},
  {name: "Modification of chromatin structure and function", description: "Modification of chromatin structure and function involves changes to the organization and accessibility of DNA, which can affect gene activity."},
  {name: "modification of gene expression", description: "Modification of gene expression refers to changes in the level or timing of gene activity."},
  {name: "modification of transcribed coding sequence", description: "Modification of transcribed coding sequence refers to alterations in the coding region of a gene's mRNA, potentially affecting the protein product."},
  {name: "modifications in gene expression", description: "Modifications in gene expression refer to changes in the level or pattern of gene activity."},
  {name: "Modify gene regulatory networks", description: "SINEs can serve as building blocks that alter the networks controlling gene expression."},
  {name: "Modulating gene activity", description: "Modulating gene activity refers to the process of altering the expression or function of a gene."},
  {name: "Modulation of apoptotic responses", description: "Modulation of apoptotic responses refers to the regulation of programmed cell death pathways."},
  {name: "modulation of cellular plasticity", description: "Modulation of cellular plasticity refers to the influence on a cell's ability to change its phenotype or state."},
  {name: "Modulation of DNA methylation", description: "The process by which a retrotransposon may influence the methylation patterns in its local genomic region."},
  {name: "Modulation of gene expression", description: "Modulation of gene expression refers to the regulation of genes involved in processes such as proliferation, invasion, and metastasis."},
  {name: "modulation of gene expression patterns", description: "The process by which SVA retrotransposons can alter or influence the patterns of gene expression."},
  {name: "modulation of oncogenic signaling gene expression", description: "Modulation of oncogenic signaling gene expression refers to the alteration in the expression levels of genes involved in cancer-promoting signaling pathways."},
  {name: "Modulation of transcription factor occupancy", description: "The alteration of the binding levels or patterns of transcription factors at specific DNA sequences."},
  {name: "molecular mimicry", description: "Molecular mimicry is a mechanism where foreign antigens share structural similarities with self-antigens."},
  {name: "Molecular rearrangement", description: "Molecular rearrangement refers to structural changes in DNA, such as recombination or deletion, that alter the genomic sequence."},
  {name: "monitor epigenetic instability", description: "The proposed function of LINE-1 to sense and report widespread changes in the epigenetic landscape of the genome."},
  {name: "Monoallelic expression", description: "A gene expression pattern where only one of the two alleles is expressed, either randomly or in a parent-of-origin specific manner."},
  {name: "Mosaic evolution", description: "Mosaic evolution refers to the pattern where different lineages of a transposable element family evolve independently and coexist over extended periods."},
  {name: "Mosaic haplotype evolution", description: "Mosaic haplotype evolution is the process by which haplotypes are formed through the recombination of conserved genomic modules."},
  {name: "Mosaic recombination", description: "Mosaic recombination refers to the process of genetic recombination that results in a mosaic pattern of genetic material."},
  {name: "MOV10 granule formation", description: "MOV10 granule formation is a process involving MOV10's association with G3BP1, likely through liquid-liquid phase separation (LLPS)."},
  {name: "MOV10-mediated inhibition of LINE-1 retrotransposition", description: "MOV10-mediated inhibition of LINE-1 retrotransposition is a host restriction mechanism that suppresses LINE-1 mobilization."},
  {name: "MOV10/LINE-1 association", description: "MOV10/LINE-1 association refers to the direct interaction between the host protein MOV10 and LINE-1 elements."},
  {name: "mRNA degradation", description: "mRNA degradation is a cellular process that regulates gene expression by breaking down messenger RNA molecules."},
  {name: "mRNA destabilization", description: "mRNA destabilization is a process that reduces the stability and half-life of messenger RNA molecules."},
  {name: "mRNA expression", description: "The level of messenger RNA transcribed from a gene or transposon, indicative of its transcriptional activity."},
  {name: "mRNA integration into DNA", description: "The process by which mRNA sequences are reverse transcribed and inserted into the host genome."},
  {name: "mRNA mobilization in trans", description: "The ability of LINE-1 to mobilize mRNA sequences in trans, generating retrocopies."},
  {name: "mRNA polyadenylation", description: "mRNA polyadenylation is the addition of a polyadenylated (polyA) tail to mRNA, which regulates mRNA stability and translation."},
  {name: "mRNA quality control", description: "Cellular mechanisms, such as nonsense-mediated RNA decay (NMD), that monitor and degrade aberrant mRNAs."},
  {name: "mRNA retrotransposition", description: "The process by which messenger RNAs are reverse transcribed and integrated into the genome, generating processed pseudogenes."},
  {name: "mRNA splicing modulation", description: "mRNA splicing modulation refers to the process of altering the splicing patterns of mRNA transcripts."},
  {name: "mRNA stabilization", description: "mRNA stabilization refers to the regulation of mRNA half-life, often mediated by specific sequence motifs."},
  {name: "mRNA-like 3' end processing", description: "mRNA-like 3' end processing refers to the cleavage and polyadenylation of RNA transcripts, typically associated with RNA polymerase II transcripts, which can lead to RNA stabilization."},
  {name: "multiplex RNA interference", description: "Multiplex RNA interference is a technique that simultaneously knocks down the expression of multiple target genes using a single engineered transcript encoding multiple small interfering RNAs or microRNAs."},
  {name: "Multiplexed gRNA delivery", description: "Multiplexed gRNA delivery is the simultaneous introduction of multiple guide RNAs into a cell to target several genomic loci."},
  {name: "Mutagenesis", description: "Mutagenesis is the process by which genetic mutations are generated, with transposable elements being a major source."},
  {name: "Mutagenic events", description: "Mutagenic events are processes that cause changes in the DNA sequence."},
  {name: "mutagenic insertion", description: "Mutagenic insertion refers to the insertion of a transposable element into a genomic location, which can disrupt gene function or regulation and cause mutations."},
  {name: "Mutate genes", description: "SINEs have the potential to cause mutations in genes."},
  {name: "mutation", description: "A change in the DNA sequence, which in this context can be caused by retrotransposon integration."},
  {name: "mutation and rearrangement of host genomic DNA", description: "Mutation and rearrangement of host genomic DNA refers to alterations in the host's genome structure and sequence."},
  {name: "mutation generation", description: "Mutation generation is the process by which changes in the DNA sequence are created."},
  {name: "MxB-mediated inhibition of LINE-1", description: "MxB restricts LINE-1 mobilization by sequestering LINE-1 proteins within cytoplasmic stress granules, hindering their access to the nucleus."},
  {name: "myelopoiesis", description: "The process of producing myeloid lineage cells, including granulocytes, monocytes, and others."},
  {name: "myoblast proliferation", description: "Myoblast proliferation is the process by which muscle precursor cells divide and increase in number."},
  {name: "N6-adenosine methylation (m6A) modification", description: "N6-adenosine methylation (m6A) is the most abundant epigenetic modification on eukaryotic RNA and is dynamically reversible."},
  {name: "Natural mutagenesis", description: "Natural mutagenesis refers to the process of mutation generation in the genome under natural conditions."},
  {name: "naïve pluripotency gene expression", description: "Naïve pluripotency gene expression refers to the transcription of genes associated with the naïve state of pluripotency in stem cells."},
  {name: "ncRNA biogenesis", description: "The pathways involved in the synthesis and processing of noncoding RNAs."},
  {name: "neddylation", description: "Neddylation is a post-translational modification process involving the conjugation of NEDD8 to target proteins."},
  {name: "Negative feedback loop interruption", description: "Negative feedback loop interruption refers to the disruption of a regulatory mechanism that normally suppresses a process."},
  {name: "Negative feedback regulation of L1-5'UTR sense promoter", description: "A regulatory mechanism where L1-ORF1p and Ago2 act to suppress the activity of the L1-5'UTR sense promoter."},
  {name: "Negative selection", description: "Negative selection is an evolutionary process that removes deleterious genetic variants, such as harmful transposon insertions, from a population."},
  {name: "Neighboring gene expression inactivation", description: "Neighboring gene expression inactivation refers to the process by which the expression of a gene located near a transposon insertion is silenced."},
  {name: "Neocentromere formation", description: "Neocentromere formation is the epigenetic establishment of a functional centromere at a non-centromeric chromosomal site."},
  {name: "neoplastic progression", description: "Neoplastic progression is the multi-step process by which normal cells transform into malignant cancer cells."},
  {name: "nested insertion", description: "Nested insertion refers to a retrotransposon integrating into a pre-existing repetitive element in the genome."},
  {name: "Neural cell differentiation", description: "Neural cell differentiation is the process by which neural progenitor cells develop into specialized neural cell types."},
  {name: "Neural crest migration", description: "Neural crest migration is the process by which neural crest cells move from their site of origin to various locations in the embryo, contributing to the formation of diverse structures."},
  {name: "neural differentiation", description: "The process by which neural progenitor cells develop into specialized cells of the nervous system."},
  {name: "neural plasticity", description: "Neural plasticity is a biological process in which LINE-1 plays a crucial role."},
  {name: "Neuroaging", description: "Neuroaging refers to the biological processes associated with the aging of the nervous system."},
  {name: "Neurodevelopment", description: "Neurodevelopment refers to the complex process of nervous system formation and maturation."},
  {name: "Neurogenesis", description: "Neurogenesis is the process of generating new neurons from neural stem cells."},
  {name: "Neuroinflammation", description: "Neuroinflammation is an inflammatory response within the brain or spinal cord."},
  {name: "Neuronal development", description: "Neuronal development encompasses the processes involved in the generation, differentiation, and maturation of neurons."},
  {name: "Neuronal differentiation", description: "Neuronal differentiation is the process by which neural stem or progenitor cells develop into mature neurons."},
  {name: "neuronal diversity", description: "Neuronal diversity is a biological process in which LINE-1 plays a crucial role."},
  {name: "Neuronal L1 retrotransposition", description: "Neuronal L1 retrotransposition is the mobilization of LINE-1 elements specifically in neuronal cells or progenitors."},
  {name: "neuronal maturation", description: "Neuronal maturation is the process by which neurons develop their specialized structure and function."},
  {name: "Neuronal mosaicism", description: "Neuronal mosaicism refers to genetic differences between neurons in the brain, contributing to cellular diversity."},
  {name: "Neuronal somatic mosaicism", description: "Neuronal somatic mosaicism refers to genetic differences between neurons within an individual, potentially arising from somatic mutations."},
  {name: "Neuronal transcriptional expression impact", description: "The process by which LINE-1 insertions can dramatically alter the transcriptional output of individual neurons."},
  {name: "Neurotransmission", description: "Neurotransmission is the process by which signaling molecules (neurotransmitters) are released by neurons to communicate with target cells."},
  {name: "neutral base substitution rate", description: "The neutral base substitution rate is the rate of base changes in DNA sequences that are not under selective pressure."},
  {name: "Neutral evolution", description: "Neutral evolution refers to the pattern of molecular evolution driven by genetic drift rather than natural selection."},
  {name: "Neutral selection", description: "Neutral selection refers to genetic changes that have little to no effect on an organism's fitness and are not subject to significant selective pressure."},
  {name: "Neutrophil activation and death", description: "The process involving the activation and subsequent death of neutrophils, which can release cellular contents including transposon-encoded proteins."},
  {name: "New gene formation", description: "New gene formation refers to the evolutionary process by which novel genes originate and become functional."},
  {name: "New gene generation", description: "A potential mechanism for creating new genes, distinct from parental genes, through processes like mRNA retrotransposition coupled with 5' inversion."},
  {name: "NF-kappaB binding", description: "NF-kappaB binding is the process where NF-kappaB transcription factors attach to specific DNA sequences to regulate gene expression."},
  {name: "NF-kB binding", description: "NF-kB binding refers to the process where the NF-kB transcription factor complex attaches to specific DNA sequences to regulate gene expression."},
  {name: "NF-κB-mediated inflammatory response", description: "NF-κB-mediated inflammatory response is a signalling pathway that regulates genes involved in inflammation and immune responses."},
  {name: "Non-allelic homologous recombination", description: "Nonallelic homologous recombination is a mechanism of genetic disease involving recombination between similar sequences (e.g., Alu elements) at non-allelic positions, leading to deletions or rearrangements."},
  {name: "Non-allelic homologous recombination (NAHR)", description: "Nonallelic homologous recombination (NAHR) is a mechanism of genomic rearrangement that occurs between low-copy repeats with high sequence identity."},
  {name: "non-canonical NF-κB signaling activation", description: "Non-canonical NF-κB signaling activation is an alternative pathway involved in lymphoid organ development and immune responses."},
  {name: "non-canonical transcripts", description: "Non-canonical transcripts are RNA molecules produced from unconventional transcription."},
  {name: "non-canonical translation initiation", description: "Non-canonical translation initiation refers to mechanisms of protein synthesis that do not follow the standard scanning model for AUG codon recognition."},
  {name: "non-cell-autonomous effects mediated by extracellular vesicles", description: "Effects on neighboring or distant cells mediated by signaling molecules or nucleic acids packaged in extracellular vesicles."},
  {name: "Non-coding RNA expression", description: "Non-coding RNA expression refers to the transcription of RNA molecules that do not code for proteins but may have regulatory functions."},
  {name: "Non-CpG methylation", description: "Non-CpG methylation refers to the methylation of cytosine bases in contexts other than CpG dinucleotides."},
  {name: "non-CpG mutation", description: "Non-CpG mutation refers to base substitutions occurring in DNA sequences outside of CpG dinucleotides."},
  {name: "Non-homologous end joining (NHEJ)", description: "Non-homologous end joining (NHEJ) is a DNA repair pathway that directly ligates broken DNA ends."},
  {name: "non-homologous end-joining repair", description: "A major pathway for repairing DNA double-strand breaks by directly ligating the broken ends."},
  {name: "Non-homologous recombination", description: "Non-homologous recombination is a DNA repair mechanism that joins broken DNA ends without requiring extensive sequence homology."},
  {name: "non-insertional mechanism", description: "Non-insertional mechanism refers to the effects of a transposon that are independent of its physical integration into the genome, such as through transcriptional interference or epigenetic changes."},
  {name: "non-LTR retrotransposition", description: "Non-LTR retrotransposition is a process of genomic movement that generates a significant portion of the human genome sequence."},
  {name: "non-random integration site selectivity", description: "Non-random integration site selectivity describes the preference of a transposon for integrating into specific genomic regions."},
  {name: "Non-reference retrotransposon insertion polymorphism", description: "Non-reference retrotransposon insertion polymorphism (non-ref RIP) is a polymorphic insertion of a retrotransposon that is not present in the reference human genome."},
  {name: "Non-retrotransposition mechanism", description: "Non-retrotransposition mechanism refers to processes other than the canonical LINE-1-mediated retrotransposition that can lead to the generation or variation of transposable elements."},
  {name: "Non-specific binding", description: "Non-specific binding refers to the undesired interaction of a protein with DNA sequences other than its intended target."},
  {name: "non-templated base addition", description: "Non-templated base addition is the enzymatic addition of nucleotides to a DNA strand without a complementary template strand."},
  {name: "non-viral genetic engineering", description: "Non-viral genetic engineering refers to methods of introducing genetic material into cells without using viral vectors."},
  {name: "Nonautonomous retrotransposition", description: "Nonautonomous retrotransposition is a retrotransposition event that relies on the enzymatic machinery provided by autonomous elements."},
  {name: "Noncanonical mRNA splicing", description: "Noncanonical mRNA splicing involves the use of splice sites that deviate from the typical consensus sequences."},
  {name: "Noncoding RNA accumulation", description: "Noncoding RNA accumulation refers to the increased abundance of non-protein-coding RNA molecules within a cell."},
  {name: "Noncoding RNA production", description: "The generation of noncoding RNAs, such as lncRNAs, from sequences derived from or regulated by LTRs."},
  {name: "noncoding RNA regulation", description: "The process of controlling the expression or function of non-protein-coding RNA molecules."},
  {name: "Nonhomologous DNA end-joining", description: "A cellular DNA repair pathway that resolves DNA double-strand breaks without requiring sequence homology."},
  {name: "nonproductive splicing", description: "Nonproductive splicing is a mechanism where aberrant splicing leads to the production of non-functional or degraded transcripts."},
  {name: "nonsense-mediated decay", description: "An mRNA surveillance pathway that degrades transcripts containing premature termination codons."},
  {name: "Nonsense-mediated mRNA decay", description: "Nonsense-mediated mRNA decay (NMD) is a cellular surveillance pathway that degrades mRNA transcripts containing premature termination codons."},
  {name: "Nonsense-mediated RNA decay (NMD)", description: "An mRNA surveillance pathway that degrades transcripts containing premature termination codons."},
  {name: "Nonsense-mediated RNA decay (NMD) switch exon regulation", description: "NMD switch exons are regulatory elements that control gene expression by modulating nonsense-mediated RNA decay."},
  {name: "Nonviral gene delivery", description: "Nonviral gene delivery refers to methods of introducing genetic material into cells without using viral vectors."},
  {name: "Nonviral gene transfer", description: "Nonviral gene transfer is a method for introducing genetic material into cells without using viral vectors."},
  {name: "novel insertions into active genes", description: "The insertion of a retrotransposed element into an actively transcribed gene, which can disrupt its function."},
  {name: "novel L1 insertion", description: "Novel L1 insertion refers to a LINE-1 retrotransposition event not previously documented in reference genomes or databases."},
  {name: "Novel splice isoform production", description: "The process by which LINE-1 retrotransposons can generate new alternative splicing variants of transcripts."},
  {name: "novel TE insertions", description: "Novel TE insertions are transposable element insertions not previously documented in reference genomes or databases."},
  {name: "NSC aging", description: "Neural stem cell aging involves mechanisms such as changes in lineage fate, telomerase dysfunction, and failure of DNA repair."},
  {name: "Nuclear architecture", description: "Nuclear architecture refers to the three-dimensional organization of the nucleus and its components."},
  {name: "Nuclear compartmentalization", description: "Nuclear compartmentalization refers to the spatial organization of the nucleus into distinct functional regions."},
  {name: "Nuclear cytotoxicity", description: "Nuclear cytotoxicity refers to toxic effects that originate from or affect the cell nucleus, often due to genomic instability."},
  {name: "Nuclear division", description: "Nuclear division is the process by which a cell's nucleus divides, encompassing both mitosis and meiosis."},
  {name: "Nuclear entry", description: "The process by which LINE-1 RNP condensates gain access to the nucleus, facilitated by DNA binding during nuclear envelope breakdown in mitosis."},
  {name: "Nuclear export of mRNA", description: "The process by which mRNA molecules are transported from the nucleus to the cytoplasm."},
  {name: "Nuclear expression of ORF1p/ORF2p", description: "The localization of LINE-1 encoded ORF1p and ORF2p proteins within the cell nucleus."},
  {name: "Nuclear import of L1 RNP", description: "Nuclear import of L1 RNP is a required step for retrotransposition, presenting an opportunity for post-translational regulation."},
  {name: "Nuclear import of L1-ribonucleoprotein complex", description: "Nuclear import of the L1-ribonucleoprotein complex is a crucial step in the LINE-1 retrotransposition cycle, involving the transport of the complex into the nucleus."},
  {name: "nuclear lamin rupture", description: "Nuclear lamin rupture is the disruption of the nuclear lamina, a meshwork of proteins lining the inner nuclear membrane."},
  {name: "Nuclear lamina fragmentation", description: "Nuclear lamina fragmentation is the breakdown of the nuclear lamina, a dense fibrillar network inside the nucleus."},
  {name: "nuclear localization of L1-ORF1p", description: "Nuclear localization of L1-ORF1p refers to the presence of the LINE-1 ORF1 protein within the cell nucleus."},
  {name: "Nuclear localization of ORF1p", description: "Nuclear localization of ORF1p refers to the presence of the LINE-1 ORF1 protein within the nucleus of host cells."},
  {name: "nuclear protein binding", description: "The interaction between nuclear proteins and specific DNA sequences, such as cis-elements, to regulate gene expression."},
  {name: "nuclear retention of mRNA", description: "Nuclear retention of mRNA is a process where mRNA molecules are prevented from being exported from the nucleus to the cytoplasm, thereby inhibiting translation."},
  {name: "nuclear retention of TERRA", description: "The process of keeping telomeric repeat-containing RNA (TERRA) within the cell nucleus."},
  {name: "nuclear segregation", description: "The spatial separation of different genomic sequences or elements into distinct nuclear compartments."},
  {name: "nuclear siRNA mediated cis-regulation", description: "A regulatory mechanism where nuclear small interfering RNAs (siRNAs) act in cis to repress gene expression."},
  {name: "nuclear translocation of ORF1p", description: "The process by which the LINE-1 encoded ORF1 protein moves from the cytoplasm into the nucleus."},
  {name: "nucleating chromatin architecture", description: "The process of initiating or seeding the formation of specific three-dimensional chromatin structures."},
  {name: "nucleic acid binding", description: "The molecular mechanism by which ORF1p interacts with and binds to nucleic acids."},
  {name: "Nucleic acid chaperone activity", description: "Nucleic acid chaperone activity is exhibited by ORF1p, facilitating nucleic acid rearrangements."},
  {name: "Nucleic acid chaperone function", description: "Nucleic acid chaperone function involves proteins that facilitate the rearrangement of nucleic acid structures to achieve their functional conformations."},
  {name: "nucleic acid sensing", description: "Nucleic acid sensing is the process by which pattern recognition receptors detect foreign or aberrant self-nucleic acids, triggering an immune response."},
  {name: "nucleolar function", description: "The biological activities carried out by the nucleolus, primarily ribosome assembly."},
  {name: "Nucleolar localization", description: "Nucleolar localization refers to the targeting and accumulation of proteins within the nucleolus."},
  {name: "nucleolar organization", description: "Nucleolar organization refers to the structural and functional arrangement of the nucleolus, a nuclear subcompartment involved in ribosome biogenesis."},
  {name: "Nucleolar positioning", description: "The process by which specific genomic loci, such as distal junctions (DJs), are anchored or localized within the nucleolus."},
  {name: "Nucleolar structure maintenance", description: "The process required for maintaining the structural integrity and organization of the nucleolus."},
  {name: "Nucleolar transcriptional output", description: "The regulation of transcriptional activity within the nucleolus, which is the site of ribosomal DNA (rDNA) transcription."},
  {name: "Nucleosome positioning", description: "Nucleosome positioning is the arrangement of nucleosomes along DNA, which influences chromatin structure and gene accessibility."},
  {name: "Nucleosome preservation", description: "Nucleosome preservation refers to the retention of nucleosomes in sperm chromatin during the nucleosome-to-protamine exchange process."},
  {name: "nucleotide excision repair", description: "Nucleotide excision repair (NER) is a DNA repair pathway that removes bulky DNA lesions."},
  {name: "Nucleotidyl transfer", description: "The chemical reaction step in DNA elongation where a nucleotide is added to the growing DNA strand."},
  {name: "NXF1(TAP) binding", description: "The interaction between an RNA element and the cellular nuclear export factor 1 (NXF1/TAP)."},
  {name: "oligomerization", description: "Oligomerization refers to the assembly of multiple protein subunits into a complex, which is required for the inhibitory activity of APOBEC3G against retrotransposition."},
  {name: "onco-exaptation", description: "Onco-exaptation is a process where transposable elements become dysregulated in cancer cells and serve as alternate promoters to activate oncogenes."},
  {name: "oncogene amplification", description: "Oncogene amplification is the increase in the copy number of an oncogene, leading to its overexpression and contribution to cancer development."},
  {name: "oncogene amplifications", description: "Oncogene amplifications refer to the increase in copy number of genes that can promote cancer development when overexpressed."},
  {name: "Oncogene inactivation", description: "A process that reduces or eliminates the activity of genes that promote cancer development."},
  {name: "Oncogenesis", description: "Oncogenesis is the process through which normal cells transform into cancer cells."},
  {name: "oncogenic gene control", description: "The regulation of gene expression that contributes to cancer development."},
  {name: "Oncogenic pathway activation", description: "Oncogenic pathway activation refers to the process by which genetic alterations, such as transposon insertions, lead to the activation of signaling pathways that promote cancer development."},
  {name: "oncogenic pathways", description: "Oncogenic pathways are signaling pathways that, when dysregulated, can contribute to cancer development."},
  {name: "Oncogenic TE activation", description: "Oncogenic TE activation refers to the process where transposable elements are aberrantly activated, contributing to cancer development."},
  {name: "oncogenic transformation", description: "Oncogenic transformation is the process by which normal cells are converted into cancer cells, often involving genetic and epigenetic changes."},
  {name: "Oncogenic β-catenin/Wnt signaling", description: "Oncogenic β-catenin/Wnt signaling is a pathway that can be activated to promote tumorigenesis."},
  {name: "ongoing mobilization", description: "The continuous process of SVA retrotransposition generating genetic variation in the human population."},
  {name: "oocyte activation", description: "Oocyte activation is the process that initiates the resumption of meiosis and the completion of oocyte maturation, essential for fertilization."},
  {name: "Oocyte maturation", description: "Oocyte maturation refers to the final stages of development from the germinal vesicle stage to metaphase II, involving nuclear and cytoplasmic changes."},
  {name: "open and active chromatin formation", description: "The establishment of chromatin regions with reduced DNA methylation and increased enhancer-associated histone marks, facilitating gene expression."},
  {name: "Open reading frame (ORF)", description: "An open reading frame (ORF) is a sequence of DNA that has the potential to be translated into a protein."},
  {name: "orchestrating high-order chromatin assembly", description: "Orchestrating high-order chromatin assembly is a mechanism where retrotransposons can influence the three-dimensional structure of chromatin and gene regulation."},
  {name: "ORF0 expression", description: "ORF0 is a protein encoded by transcripts driven by the L1 antisense promoter (ASP)."},
  {name: "ORF0 translation", description: "The process of synthesizing the ORF0 protein from its mRNA."},
  {name: "ORF0-mediated fusion protein formation", description: "The process where ORF0, by virtue of containing two splice donor sites, can form fusion proteins with proximal exons."},
  {name: "ORF1 recruitment to chromatin", description: "Recruitment of the LINE-1 encoded open reading frame 1 (ORF1) protein to chromatin is a step in the retrotransposition process."},
  {name: "ORF1/p40-dependent transactivation", description: "A process of gene activation mediated by the L1 ORF1 protein (p40)."},
  {name: "ORF1p and ORF2p expression", description: "ORF1p and ORF2p expression refers to the production of the two proteins encoded by the LINE-1 element, which are essential for its retrotransposition activity."},
  {name: "ORF1p binding", description: "ORF1p binding refers to the interaction of the LINE-1 ORF1 protein with specific nucleic acid sequences."},
  {name: "ORF1p binding to single-stranded nucleic acid", description: "ORF1p, a major component of the LINE-1 ribonucleoprotein, binds single-stranded nucleic acid with high affinity."},
  {name: "ORF1p condensation", description: "Condensation of the ORF1p protein is critical for the formation of the L1 ribonucleoprotein (RNP) complex and for retrotransposition."},
  {name: "ORF1p cytoplasmic foci formation", description: "ORF1p cytoplasmic foci formation is the process by which the LINE-1 ORF1 protein aggregates into distinct cytoplasmic structures, which are thought to be sites of retrotransposition."},
  {name: "ORF1p degradation", description: "ORF1p degradation refers to the breakdown of the LINE-1 ORF1 protein, which is essential for retrotransposition."},
  {name: "ORF1p depletion", description: "The reduction or removal of the L1-encoded ORF1 protein, which is essential for retrotransposition."},
  {name: "ORF1p expression", description: "ORF1p expression refers to the production of the ORF1 protein encoded by the LINE-1 retrotransposon, which is critical for the retrotransposition process."},
  {name: "ORF1p function", description: "ORF1p is a protein encoded by LINE-1 elements, necessary for retrotransposition."},
  {name: "ORF1p nuclear localization", description: "ORF1p nuclear localization is the process by which the LINE-1 ORF1 protein is targeted to and accumulates in the cell nucleus, involving specific charged amino acids and interaction with KPNA proteins."},
  {name: "ORF1p oligomerization", description: "ORF1p oligomerization is the process by which the ORF1 protein forms multimeric complexes, which is a critical step for L1 retrotransposition."},
  {name: "ORF1p overexpression", description: "Increased expression of the LINE-1 ORF1p protein, often associated with tumorigenesis."},
  {name: "ORF1p self-interaction", description: "ORF1p self-interaction refers to the ability of the LINE-1 ORF1 protein to form multimers, such as trimers in vitro and heterodimers in trans within mammalian cells."},
  {name: "ORF1p-driven condensate formation", description: "The formation of cytoplasmic ribonucleoprotein condensates (L1 Bodies) driven by the LINE-1 ORF1 protein."},
  {name: "ORF1p-LINE-1 RNA interaction", description: "The essential interaction between the LINE-1 open reading frame 1 protein (ORF1p) and LINE-1 RNA, required for retrotransposition."},
  {name: "ORF1p-mediated increase in ORF2p-driven Alu retrotransposition", description: "ORF1p-mediated increase in ORF2p-driven Alu retrotransposition refers to the enhancement of Alu mobilization by the LINE-1 ORF1 protein."},
  {name: "ORF2 translation", description: "The process of synthesizing the ORF2 protein from the LINE-1 mRNA."},
  {name: "ORF2p association with Alu RNA poly(A) tract", description: "A critical step in Alu retrotransposition where the LINE-1 ORF2 protein binds to the poly(A) tail of the Alu RNA."},
  {name: "ORF2p binding to L1 RNA", description: "ORF2p binding to L1 RNA is a molecular interaction that facilitates the reverse transcription step of retrotransposition."},
  {name: "ORF2p expression", description: "The expression of the ORF2 protein encoded by LINE-1, which is essential for retrotransposition activity."},
  {name: "ORF2p function", description: "ORF2p is a protein encoded by LINE-1 elements, necessary for retrotransposition."},
  {name: "ORF2p hijacking", description: "7SL- and tRNA-derived SINEs use distinct strategies to 'hijack' the L1 ORF2p protein for their mobilization compared to other elements like SVA."},
  {name: "ORF2p RNA binding", description: "ORF2p RNA binding is the interaction between the LINE-1 ORF2 protein and RNA, which is required for retrotransposition."},
  {name: "ORF2p-driven Alu retrotransposition", description: "ORF2p-driven Alu retrotransposition is the process by which the LINE-1 ORF2 protein mobilizes Alu elements."},
  {name: "ORF2p-mediated LINE-1 RNP reverse transcription", description: "ORF2p-mediated LINE-1 RNP reverse transcription is a key step in the LINE-1 retrotransposition cycle involving the reverse transcription of LINE-1 RNA within a ribonucleoprotein complex."},
  {name: "orientation-dependent regulatory activity", description: "The phenomenon where the regulatory elements within an SVA retrotransposon exhibit different effects on gene expression depending on their orientation."},
  {name: "Origin of new transcripts/genes", description: "The process by which novel transcripts and genes are generated."},
  {name: "Overexpression", description: "Overexpression refers to the abnormally high level of expression of a gene or genetic element."},
  {name: "Overexpression of MET", description: "The process by which the MET gene is expressed at abnormally high levels."},
  {name: "overproduction inhibition", description: "Overproduction inhibition is a phenomenon where high levels of transposase protein inhibit transposition activity."},
  {name: "oxidative DNA damage", description: "Oxidative DNA damage is a type of DNA lesion caused by reactive oxygen species."},
  {name: "Oxidative stress", description: "Oxidative stress is an imbalance between the production of reactive oxygen species and the body's ability to detoxify them."},
  {name: "Oxidative stress-induced DNA strand breaks", description: "DNA strand breaks caused by oxidative stress, a state of imbalance between the production of reactive oxygen species and the body's ability to detoxify them."},
  {name: "p38delta MAP kinase induction", description: "The process of increasing the expression or activity of the p38delta mitogen-activated protein kinase."},
  {name: "p40 protein expression", description: "p40 protein expression refers to the production of the protein encoded by the first open reading frame of a LINE-1 element."},
  {name: "p40 protein multimerization", description: "p40 protein multimerization refers to the formation of complexes involving multiple p40 protein units, potentially mediated by a leucine zipper region."},
  {name: "p53 binding site", description: "A p53 binding site is a specific DNA sequence to which the transcription factor p53 can bind to regulate gene expression."},
  {name: "p53 binding site provision", description: "The act of providing a DNA sequence that the tumor suppressor protein p53 can bind to."},
  {name: "p53 occupancy", description: "p53 occupancy refers to the binding of the p53 protein to DNA response elements (REs)."},
  {name: "p53 transcriptional program", description: "The set of genes and regulatory elements that are controlled by the transcription factor p53."},
  {name: "p53-mediated apoptosis", description: "p53-mediated apoptosis is a programmed cell death pathway activated by the p53 tumor suppressor protein in response to cellular stress or damage."},
  {name: "p53-mediated regulation of L1 expression", description: "The p53 protein can directly bind to p53 responsive elements within the L1 promoter to increase L1 mRNA expression levels."},
  {name: "p53-mediated repression of LINE-1", description: "A tumor-suppressive mechanism where the p53 protein silences LINE-1 transposons in human somatic cells, preventing their reactivation and associated genomic instability."},
  {name: "Pachytene cluster piRNA targeting", description: "A mode of piRNA production at postnatal stages where piRNAs from pachytene clusters target older TEs."},
  {name: "packaging and transposition of RNA transcript", description: "The process by which the ORF1p protein packages its RNA transcript and facilitates its movement within the genome."},
  {name: "packaging into inactive chromatin", description: "The process of organizing DNA into a condensed chromatin structure that represses gene transcription."},
  {name: "Paired-ends complex assembly", description: "Paired-ends complex assembly is a step in transposition where the transposase brings the two ends of the transposon together."},
  {name: "paracrine senescence", description: "The process by which senescent cells induce senescence in neighboring cells via secreted factors."},
  {name: "Parallel evolution", description: "Parallel evolution refers to the independent emergence of similar non-canonical SVA structures in chimpanzees and humans."},
  {name: "parasitic strategy", description: "A strategy employed by SINE elements, such as Alu, to efficiently bypass the cis-preference of LINEs for their own retrotransposition."},
  {name: "partial deletion", description: "The loss of a portion of an inserted transposon sequence after integration."},
  {name: "Partial inclusion in mRNA", description: "Partial inclusion in mRNA refers to the aberrant splicing event where part of a transposon sequence is retained in the mature messenger RNA transcript."},
  {name: "Partial loss of gene function", description: "Partial loss of gene function refers to a reduction, but not complete absence, of a gene's normal activity."},
  {name: "Participating in evolutionary processes", description: "Participating in evolutionary processes refers to the role of genetic elements in driving or contributing to genomic changes over evolutionary time."},
  {name: "Passive co-transcription", description: "Passive co-transcription refers to the inclusion of LINE-1 sequences in transcripts originating from other genomic loci."},
  {name: "Paternal bias in retrotransposition", description: "Paternal bias in retrotransposition refers to the phenomenon where new retrotransposition events originate more frequently from the paternal germline."},
  {name: "Pathogenesis", description: "Pathogenesis refers to the process by which retrotransposon activity can lead to disease."},
  {name: "Pathological processes of neurological diseases", description: "Pathological processes refer to the molecular and cellular mechanisms underlying the development and progression of neurological disorders."},
  {name: "pattern recognition", description: "Pattern recognition is the process by which innate immune sensors detect pathogen-associated molecular patterns (PAMPs) or damage-associated molecular patterns (DAMPs)."},
  {name: "Pb(II) binding", description: "Pb(II) binding refers to the interaction between lead ions and specific protein domains, such as the tris-cysteine layers in the coiled-coil domain of ORF1p."},
  {name: "PCR inhibition detection", description: "PCR inhibition detection is the assessment for the presence of PCR inhibitors in a test sample."},
  {name: "PCR on LINE1 retrotransposons", description: "PCR on LINE1 retrotransposons is a molecular technique used to detect the presence of LINE-1 elements or their sequences in a DNA sample."},
  {name: "Peptide generation", description: "The production of protein fragments or peptides derived from sequences within RNA transcripts."},
  {name: "Pericentric inversion", description: "A pericentric inversion is a chromosomal rearrangement where a segment of a chromosome, containing the centromere, is reversed end to end."},
  {name: "Persistent DNA damage", description: "Persistent DNA damage refers to DNA lesions, such as double-strand breaks, that are not efficiently repaired and accumulate over time."},
  {name: "pervasive transcription", description: "Widespread, often non-functional, transcription of genomic regions, including repetitive elements like LINE-1."},
  {name: "phagocytosis of amyloid beta", description: "Phagocytosis of amyloid beta (Aβ) is the process by which microglia engulf and clear Aβ peptides, which accumulate in Alzheimer's disease."},
  {name: "Phase separation", description: "Phase separation is a biophysical process where biomolecules condense into distinct liquid-like compartments, as demonstrated for the ORF1 protein of LINE-1."},
  {name: "phase-separation mechanism", description: "A mechanism by which biomolecules demix into distinct liquid phases, driving the formation of cellular compartments without membranes."},
  {name: "phenotypic and functional variations modulation in tumor progression", description: "The reversible modulation of phenotypic and functional variations associated with the progression of tumors."},
  {name: "phenotypic dedifferentiation", description: "Phenotypic dedifferentiation is the loss of specialized cell characteristics."},
  {name: "phosphorylation of ORF1p", description: "Phosphorylation of the L1 protein ORF1p at specific motifs is a post-translational modification required for L1 retrotransposition activity."},
  {name: "Phosphorylation site homology", description: "The presence of similar amino acid sequences that can be phosphorylated by the same kinase in different proteins."},
  {name: "Photoaging", description: "Photoaging is the premature aging of the skin caused by repeated exposure to ultraviolet (UV) radiation."},
  {name: "Phylogenetic analysis", description: "Phylogenetic analysis is a method used to infer evolutionary relationships among biological entities based on sequence data."},
  {name: "Phylogenetic marker", description: "A phylogenetic marker is a genetic character used to infer evolutionary relationships among species or lineages."},
  {name: "Physical mapping", description: "Physical mapping is a technique used to determine the physical location of DNA sequences on chromosomes."},
  {name: "PI3K signaling pathway", description: "The PI3K signaling pathway is a key intracellular signaling cascade involved in cell growth, survival, and metabolism, often downstream of insulin."},
  {name: "piggyBac-mediated transposition", description: "piggyBac-mediated transposition is a genetic engineering technique that utilizes the piggyBac transposon system to stably integrate transgenes into the host genome."},
  {name: "PIN1 cytoplasmic localisation", description: "PIN1 cytoplasmic localisation refers to the increased presence of the prolyl isomerase PIN1 in the cytoplasm, which can modulate various signalling pathways."},
  {name: "piRNA biogenesis", description: "piRNA biogenesis is the process of producing PIWI-interacting RNAs, small regulatory RNAs critical for transposable element repression in germ cells."},
  {name: "piRNA depletion", description: "piRNA depletion refers to a reduction in the levels of piwi-interacting RNAs, small RNAs that facilitate the clearance of transposable element transcripts and maintain genomic stability."},
  {name: "piRNA pathway", description: "The piRNA pathway is a small RNA-based mechanism that represses transposable elements in germ cells."},
  {name: "piRNA-mediated repression", description: "piRNA-mediated repression is a mechanism by which piwi-interacting RNAs silence transposable elements in germ cells."},
  {name: "piRNA-mediated repression of transposons", description: "A process where piwi-interacting RNAs (piRNAs) repress the activity of mobile genetic elements, such as transposons."},
  {name: "piRNA-mediated retrotransposon expression", description: "piRNA-mediated retrotransposon expression refers to the potential regulation of retrotransposon activity by PIWI-interacting RNAs (piRNAs)."},
  {name: "piRNA-mediated TE control", description: "The process by which PIWI proteins and piRNAs suppress transposable element activity in the germline."},
  {name: "Pituitary GH gene regulation", description: "Pituitary GH gene regulation refers to the molecular mechanisms controlling the expression of the growth hormone gene in the pituitary gland."},
  {name: "Piwi pathway", description: "The Piwi pathway is a mechanism involving Piwi proteins and Piwi-interacting RNAs (piRNAs) that silences transposable elements in germ cells."},
  {name: "PIWI-piRNA pathway regulation", description: "A regulatory mechanism in which the PIWI-piRNA pathway controls the activity of specific transposons, such as L1Hs, in human embryonic stem cells."},
  {name: "PKR inhibition", description: "PKR inhibition is the suppression of the activity of the double-stranded RNA-activated protein kinase (PKR)."},
  {name: "Placental CRH expression", description: "The expression of corticotropin-releasing hormone (CRH) in the placenta, specifically in placental syncytiotrophoblasts."},
  {name: "Placental expression regulation", description: "The process by which the expression of genes, specifically the ERVWE1 locus encoding syncytin, is controlled in placental tissue."},
  {name: "Placental physiology", description: "Placental physiology refers to the biological processes and functions of the placenta."},
  {name: "Placentation", description: "Placentation is the process of forming the placenta, which is essential for pregnancy."},
  {name: "platelet hyperreactivity", description: "Platelet hyperreactivity is an increased tendency of platelets to become activated, which can contribute to thrombosis."},
  {name: "plectonemic intertwining", description: "Plectonemic intertwining is a right-handed supercoiling of DNA strands that brings specific sequences into close proximity."},
  {name: "Pluripotency", description: "Pluripotency is the state of a stem cell that has the potential to differentiate into any of the three germ layers."},
  {name: "Pluripotency factor expression", description: "Pluripotency factor expression refers to the transcriptional activity of genes like OCT4, SOX2, and NANOG, which maintain the pluripotent state of cells."},
  {name: "Pol II transcription", description: "Transcription by RNA polymerase II, which transcribes Alu RNAs embedded within coding or noncoding RNA transcripts."},
  {name: "Pol II transcription complex assembly", description: "The assembly of RNA polymerase II and associated factors at a promoter to initiate transcription."},
  {name: "Pol II-binding aptamer (RAP) activity", description: "Pol II-binding aptamer (RAP) activity refers to the ability of specific RNA sequences to bind RNA polymerase II."},
  {name: "Pol III transcription", description: "Transcription by RNA polymerase III, which transcribes free Alu RNAs."},
  {name: "Poly(A) binding protein (PABP) interaction", description: "The interaction between the A-rich region of SINE RNAs and the poly(A) binding protein (PABP)."},
  {name: "Poly(A) microsatellite formation", description: "Poly(A) microsatellite formation refers to the concurrent creation of a poly(A) DNA tract at the 3'-end of a retrotransposon insertion, which serves as the origin for a new microsatellite."},
  {name: "Poly(A) tail dynamics", description: "Poly(A) tail dynamics refer to the processes regulating the length and integrity of the polyadenylate tail at the 3' end of retrotransposon transcripts, which can influence their stability and retrotransposition efficiency."},
  {name: "Poly(A) tail length-dependent mobility", description: "The rate of Alu retrotransposition varies significantly depending on the length of its poly(A) tail."},
  {name: "Polyadenylation", description: "Polyadenylation is the addition of a poly(A) tail to the 3' end of an RNA transcript, often involved in its maturation and stability."},
  {name: "Polyadenylation at the 3' end", description: "A process involving conserved cis-acting elements (hexamer, cleavage site, GU-rich region) for adding a polyA tail to the 3' end of LINE-1 elements."},
  {name: "Polyadenylation bypass", description: "Polyadenylation bypass is a process where L1 mRNAs sometimes bypass their own polyadenylation signal and use fortuitous signals in flanking genomic DNA."},
  {name: "Polyadenylation function", description: "Polyadenylation function refers to the ability of a DNA sequence, such as an LTR, to signal the addition of a poly(A) tail to an RNA transcript."},
  {name: "Polymerization of ORF1p", description: "The process by which human L1 ORF1p forms polymers under low-salt conditions in the absence of nucleic acids."},
  {name: "polymorphic insertion", description: "Polymorphic insertion refers to the presence of a transposable element at a specific genomic location in some individuals but not others."},
  {name: "polymorphic mobile element insertion (pMEI)", description: "Polymorphic mobile element insertion (pMEI) is a type of genomic variation caused by the insertion of a mobile element that is not present in all individuals of a species."},
  {name: "Polymorphic SVA insertion", description: "Polymorphic SVA insertion refers to SVA insertions that vary between individuals, contributing to genomic variation."},
  {name: "Polymorphic TE insertion", description: "Polymorphic TE insertion refers to a transposable element insertion that is present in some individuals and absent in others, creating genetic variation."},
  {name: "polymorphic TE insertions", description: "Polymorphic TE insertions are transposable element insertions that vary among individuals in a population."},
  {name: "Polymorphic transposable element insertion", description: "Polymorphic transposable element insertion refers to the presence of a transposon at a specific genomic locus that varies among individuals in a population."},
  {name: "Polymorphism", description: "Polymorphism refers to the presence of multiple sequence variants at a specific genomic locus in a population."},
  {name: "Population evolution analysis", description: "Population evolution analysis is the study of genetic variation and changes in allele frequencies within and between populations over time."},
  {name: "Population genetic marker", description: "A population genetic marker is a genetic variant used to study the genetic structure, history, and diversity of populations."},
  {name: "Population subdivision", description: "Population subdivision refers to the division of a large population into smaller, reproductively isolated subpopulations (demes)."},
  {name: "Pose risk to genome integrity", description: "The potential of retrotransposons to cause harmful genomic instability through their activity."},
  {name: "positioning changes", description: "Positioning changes refer to alterations in the genomic location or nucleosome positioning of transposons over evolutionary time."},
  {name: "Positive feedback loop", description: "A positive feedback loop is a state where increased LINE-1 activity leads to exponential growth in cDNA copy number, as predicted by the computational model."},
  {name: "Positive selection", description: "Positive selection is a form of natural selection that increases the frequency of a beneficial allele in a population."},
  {name: "Post-insertion selection", description: "The process of natural selection acting on transposon copies after their integration into the genome."},
  {name: "post-insertion-based mutagenesis", description: "Post-insertion-based mutagenesis refers to genomic rearrangements caused by transposons after their initial insertion, such as through non-allelic homologous recombination."},
  {name: "Post-insertional genomic injury", description: "Genomic damage occurring after the insertion of a retroelement, potentially through mechanisms like ectopic recombination."},
  {name: "Post-transcriptional defense", description: "Post-transcriptional defense mechanisms suppress transposable element activity after transcription, such as through RNA interference."},
  {name: "Post-transcriptional gene regulation", description: "Post-transcriptional gene regulation refers to the control of gene expression after the RNA transcript has been made."},
  {name: "post-transcriptional modification", description: "Post-transcriptional modification refers to changes made to RNA molecules after transcription, which can be influenced by transposable element sequences."},
  {name: "Post-transcriptional regulation", description: "Post-transcriptional regulation involves processes that control RNA metabolism after transcription, such as modification, stability, and translation."},
  {name: "Post-transcriptional regulation of gene expression", description: "Post-transcriptional regulation of gene expression involves mechanisms that control gene expression after transcription has occurred."},
  {name: "post-transcriptional repression", description: "Post-transcriptional repression refers to the regulation of gene or transposon expression after transcription has occurred, often through RNA degradation or translational inhibition."},
  {name: "Post-translational regulation", description: "Post-translational regulation refers to the control of protein activity or stability after translation."},
  {name: "Post-translational regulation of L1 activity", description: "Post-translational regulation of L1 activity refers to the potential control of LINE-1 function through modifications after protein synthesis."},
  {name: "Post-translational regulation of retrotransposition", description: "Post-translational regulation of retrotransposition refers to cellular mechanisms that control L1 activity after the L1 proteins have been synthesized."},
  {name: "POU1F1-dependent activation", description: "POU1F1-dependent activation is the process by which the transcription factor POU1F1 (Pit-1) stimulates gene expression."},
  {name: "Precise deletion", description: "Precise deletion refers to the exact removal of a previously established retrotransposon insertion."},
  {name: "precise excision", description: "Precise excision refers to the removal of a transposon from its insertion site without leaving 'footprint' mutations."},
  {name: "Precise parallel insertion", description: "Precise parallel insertion refers to the independent insertion of apparently identical retrotransposons at orthologous positions in different lineages."},
  {name: "Precise transposon excision", description: "Precise transposon excision is the clean removal of a transposon from its original genomic location during transposition."},
  {name: "Predisposing to genomic instability", description: "The action of increasing the susceptibility of a genomic region to structural changes or mutations."},
  {name: "preimplantation development", description: "Preimplantation development refers to the early embryonic stages from fertilization to implantation."},
  {name: "Preimplantation embryo development", description: "Preimplantation embryo development refers to the early stages of embryonic development before implantation in the uterus."},
  {name: "Preintegration barrier", description: "A barrier that prevents L1 retrotransposition before its integration into the genome."},
  {name: "Premature insertion mechanism", description: "Premature insertion mechanism refers to the process where a transposon insertion event is terminated before completion, often resulting in truncated sequences."},
  {name: "premature polyadenylation", description: "Premature polyadenylation is a mechanism that down-regulates gene expression by adding a poly(A) tail early."},
  {name: "Premature stop codon creation", description: "Premature stop codon creation is a mutation that introduces a stop codon within the coding sequence, leading to truncated protein production."},
  {name: "Premature stop codon introduction", description: "Premature stop codon introduction is a molecular consequence where a mutation or aberrant splicing creates a stop codon earlier than the normal termination site, leading to a truncated protein."},
  {name: "Premature termination codon introduction", description: "Premature termination codon introduction is the creation of a stop codon within the coding sequence, leading to truncated protein products."},
  {name: "preservation of genome integrity", description: "This is a cellular function aimed at maintaining the stability and fidelity of the genome, preventing mutations and structural variations."},
  {name: "Preservation of naive pluripotency", description: "The maintenance of the earliest, most primitive state of pluripotency in stem cells."},
  {name: "Prevention of developmental reversion", description: "Prevention of developmental reversion refers to the mechanism that blocks the reversion of naive human embryonic stem cells to an earlier developmental state, such as 8-cell-like cells."},
  {name: "Primate identification", description: "The process of determining the primate species from which a DNA sample or tissue originated."},
  {name: "Pro-inflammatory cytokine production", description: "Pro-inflammatory cytokine production is the synthesis of signaling molecules that promote inflammation."},
  {name: "Pro-oncogenic perturbation", description: "Pro-oncogenic perturbation refers to genomic alterations that promote the initiation or progression of cancer."},
  {name: "pro-tumorigenic inflammation", description: "Pro-tumorigenic inflammation refers to chronic, tumor-promoting inflammatory responses within the tumor microenvironment."},
  {name: "processed pseudogene formation", description: "Processed pseudogene formation occurs when LINE-1 retrotransposes cellular mRNAs."},
  {name: "Processed pseudogene generation", description: "Processed pseudogene generation is a mechanism where host messenger RNA is reverse-transcribed and integrated into the genome, creating a non-functional copy of a gene."},
  {name: "Processed pseudogene genesis", description: "The process by which processed pseudogenes are generated through retrotransposition of mRNA transcripts."},
  {name: "processive DNA polymerization", description: "Processive DNA polymerization is the ability of a polymerase to add multiple nucleotides to a growing DNA chain without dissociating from the template."},
  {name: "Processive DNA synthesis", description: "Processive DNA synthesis describes the ability of a polymerase to incorporate many nucleotides without dissociating from the template; L1 RT is shown to be highly processive."},
  {name: "Programmed cell death", description: "Programmed cell death is a regulated process of cell suicide, often indicated by increased levels of cleaved caspase-3."},
  {name: "Promoter acquisition", description: "Promoter acquisition is the process by which a gene or retroelement gains regulatory sequences to enable its transcription."},
  {name: "promoter activity", description: "The function of a DNA sequence in initiating transcription of a particular gene."},
  {name: "Promoter activity in vivo", description: "L1 ASP can act as a promoter in living organisms."},
  {name: "Promoter activity modulation by flanking sequence", description: "The process by which upstream flanking cellular sequences strongly influence the L1 5'-UTR promoter activity, either repressing or enhancing it."},
  {name: "Promoter activity of LINE-1 5' UTR", description: "The promoter activity of the LINE-1 5' untranslated region (UTR) drives the transcription of LINE-1 RNA, which is the first step in the retrotransposition cycle."},
  {name: "Promoter activity regulation", description: "The process of controlling the level of transcription initiation from a gene promoter."},
  {name: "Promoter activity regulation of LINE-1 5'-UTR", description: "Promoter activity regulation of LINE-1 5'-UTR refers to the control of transcription initiation from the internal promoter located within the 5' untranslated region of LINE-1."},
  {name: "Promoter and first exon function", description: "The process by which a transposon element functions as the promoter and first exon of a protein-coding gene."},
  {name: "Promoter binding", description: "The process where a transcription factor binds to gene promoter regions to regulate transcription."},
  {name: "Promoter blocking", description: "Promoter blocking refers to the inhibition of transcriptional activity from a gene or element's promoter region."},
  {name: "Promoter capture", description: "Promoter capture is a mechanism by which transposable elements acquire and utilize host gene promoters to drive their own expression."},
  {name: "Promoter creation", description: "Promoter creation refers to the formation of novel transcriptional start sites."},
  {name: "Promoter divergence", description: "The process by which the regulatory regions of duplicate genes become functionally distinct."},
  {name: "promoter DNA demethylation", description: "Promoter DNA demethylation is the removal of methyl groups from cytosine residues in gene promoter regions, often associated with gene activation."},
  {name: "Promoter DNA methylation", description: "Promoter DNA methylation is an epigenetic modification that typically represses gene or transposon expression."},
  {name: "Promoter function", description: "Promoter function refers to the ability of a DNA sequence to initiate transcription of a gene."},
  {name: "promoter hypomethylation", description: "Promoter hypomethylation is a reduction in DNA methylation at promoter regions, often associated with increased gene expression."},
  {name: "promoter interaction", description: "Promoter interaction refers to the physical association between an enhancer and a gene promoter to regulate transcription."},
  {name: "Promoter methylation", description: "Promoter methylation is an epigenetic modification that typically leads to gene silencing by inhibiting transcription factor binding."},
  {name: "Promoter recruitment", description: "The process by which a transposable element is independently co-opted to serve as an alternative promoter for gene expression."},
  {name: "promoter/enhancer activity", description: "Promoter/enhancer activity refers to the ability of a DNA sequence to initiate or increase the transcription of a gene."},
  {name: "Promoting cancer cell invasion and metastasis", description: "The process by which cancer cells acquire the ability to invade surrounding tissues and spread to distant sites."},
  {name: "promoting cellular plasticity", description: "Enhancing a cell's ability to change its state, such as during differentiation or in response to environmental cues."},
  {name: "promoting cellular senescence", description: "A pleiotropic effect induced by L1 transposons."},
  {name: "promoting genome instability", description: "A pleiotropic effect induced by L1 transposons."},
  {name: "promoting inflammation", description: "A pleiotropic effect induced by L1 transposons."},
  {name: "promotion of cell proliferation", description: "Promotion of cell proliferation is a biological process where L1ORF1p overexpression enhances cell growth and colony formation."},
  {name: "Promotion of LINE-1 retrotransposition", description: "The process of increasing the rate or activity of LINE-1 retrotransposition."},
  {name: "propagation", description: "Propagation refers to the successful replication and spread of transposable elements within a genome."},
  {name: "protein aggregation", description: "Protein aggregation is the process where misfolded or unfolded proteins clump together, often leading to loss of function or toxicity."},
  {name: "Protein evolution", description: "Protein evolution refers to the process by which changes in protein structure or function arise, often through genetic alterations."},
  {name: "protein expression", description: "Protein expression refers to the production of proteins from their corresponding genes."},
  {name: "protein interaction", description: "Protein interaction refers to the physical or functional association between proteins."},
  {name: "Protein multimerization", description: "Protein multimerization is the process by which multiple protein subunits assemble into a larger complex."},
  {name: "protein synthesis stimulation", description: "Protein synthesis stimulation refers to the enhancement of the process by which cells build proteins."},
  {name: "Protein truncation", description: "Protein truncation is the production of a shortened, often non-functional, protein product."},
  {name: "Protein-coding gene evolution", description: "The process through which LTRs contribute to the creation of new protein-coding genes by providing regulatory and coding sequences."},
  {name: "Protein-coding region formation", description: "The process by which repeat sequences become functional elements, such as protein-coding regions."},
  {name: "Protein-protein interaction", description: "Protein-protein interaction is the physical association between two or more protein molecules."},
  {name: "Protein-protein interaction screening", description: "A method to systematically identify proteins that physically interact with a protein of interest."},
  {name: "Providing a fragile site for double-strand breaks", description: "Providing a fragile site for double-strand breaks refers to creating genomic locations that are prone to DNA double-strand breaks."},
  {name: "Providing accessible chromatin regions", description: "The function of contributing to genomic regions that are open and accessible for transcription factor binding and gene regulation."},
  {name: "providing alternative promoters", description: "Providing alternative promoters refers to a transposon insertion creating new transcription start sites for a gene."},
  {name: "Providing breakpoints", description: "Providing breakpoints refers to the role of a sequence in facilitating genomic rearrangements by serving as a site for DNA breakage and rejoining."},
  {name: "Providing complete exon cassettes", description: "The contribution of sequences that constitute entire, functional exons."},
  {name: "Providing novel promoters", description: "The process by which transposable elements supply new promoter regions to host genes upon integration."},
  {name: "Providing novel splicing sites", description: "The process by which transposable elements introduce new splice donor or acceptor sites into host genes upon integration."},
  {name: "providing polyadenylation signals", description: "Providing polyadenylation signals is a mechanism by which retroelements interfere with gene expression."},
  {name: "Providing promoters", description: "The contribution of regulatory sequences that initiate transcription of a gene."},
  {name: "providing regulatory modules", description: "Providing regulatory modules is a mechanism where retrotransposons can influence gene expression by supplying enhancers, silencers, or other regulatory elements."},
  {name: "Providing splice donors and acceptors", description: "The contribution of sequences that define the boundaries of introns for splicing."},
  {name: "Providing stop codon and polyadenylation signal", description: "A process where a genetic element contributes sequences that signal the termination of translation (stop codon) and the addition of a poly(A) tail to mRNA (polyadenylation signal)."},
  {name: "Providing terminal exons", description: "The contribution of sequences that form the final exon of a transcript, often containing the stop codon and polyadenylation signal."},
  {name: "Providing transcription termination sites", description: "The act of supplying genomic sequences that serve as signals for the termination of transcription."},
  {name: "Proviral integration", description: "Proviral integration is the process by which a retroviral DNA copy is inserted into the host genome."},
  {name: "Provision of mRNA splicing signals", description: "Provision of mRNA splicing signals refers to the supply of sequences that guide the removal of introns and joining of exons in pre-mRNA."},
  {name: "Provision of promoters and regulatory sequences", description: "Provision of promoters and regulatory sequences refers to the contribution of genetic elements that control the initiation and regulation of gene transcription."},
  {name: "Provision of STOP codons", description: "Provision of STOP codons refers to the introduction of nucleotide triplets that signal the termination of protein synthesis."},
  {name: "Provision of transcription initiation signals", description: "Provision of transcription initiation signals refers to the supply of sequences that mark the start site for RNA synthesis."},
  {name: "Pseudoexon insertion", description: "Pseudoexon insertion is the incorporation of a cryptic or non-canonical exon into a mature mRNA transcript."},
  {name: "Pseudogene creation", description: "The generation of non-functional copies of genes through retrotransposition."},
  {name: "Pseudogene formation", description: "Pseudogene formation is a process where non-functional copies of genes are generated, in this case mediated by L1 reverse transcriptase activity."},
  {name: "Pseudogenization", description: "Pseudogenization is the process by which a functional gene loses its protein-coding ability, often due to mutations."},
  {name: "Purifying selection", description: "Purifying selection is a type of natural selection that acts to remove deleterious genetic variants from a population."},
  {name: "purinergic signaling", description: "Purinergic signaling involves the extracellular actions of purine nucleotides and nucleosides, such as ATP and adenosine, on cell surface receptors."},
  {name: "Purkinje cell degeneration", description: "Purkinje cell degeneration is the loss of Purkinje neurons in the cerebellum, a key pathological feature in several ataxias."},
  {name: "Quantification", description: "Quantification refers to the measurement of the amount or concentration of a specific target, such as human-derived cfDNA, in a biological sample."},
  {name: "R-loop formation", description: "The formation of RNA-DNA hybrids, which are key intermediates during LINE-1 retrotransposition, including cis L1 R-loops (L1 mRNA-genomic DNA) and trans L1 R-loops (L1 mRNA-complementary DNA)."},
  {name: "Random insertion", description: "Random insertion refers to the distribution pattern of recent L1 insertions in genomic DNA."},
  {name: "random reinsertion", description: "Random reinsertion refers to the process where retrotransposons insert into new genomic locations in a non-targeted manner."},
  {name: "Randomized mutagenesis", description: "Randomized mutagenesis is a technique for introducing random mutations at a specific genomic locus to study protein function, regulatory elements, or model genetic variations."},
  {name: "Rapid evolution", description: "A high rate of sequence change over evolutionary time, characteristic of certain genomic elements."},
  {name: "rapid folding", description: "Rapid folding is the process by which a protein quickly attains its native three-dimensional structure to avoid misfolding or aggregation."},
  {name: "RBP association", description: "The binding of RNA Binding Proteins to specific sequences within RNA transcripts, influencing their fate and function."},
  {name: "reactivation", description: "Reactivation refers to the process by which previously silenced genetic elements become transcriptionally active again."},
  {name: "Reactivation of embryonic transcription profiles", description: "Reactivation of embryonic transcription profiles refers to the re-expression of gene expression patterns characteristic of embryonic development."},
  {name: "reactivation of transposable elements", description: "Reactivation of transposable elements refers to the process where silenced transposable elements become transcriptionally active again."},
  {name: "readthrough transcription", description: "Transcription that continues beyond the normal termination signal of a gene, potentially producing a chimeric transcript."},
  {name: "Rearrangement", description: "Rearrangement refers to structural changes in the genome, such as deletions, duplications, inversions, or translocations."},
  {name: "recapture", description: "The process by which host defense proteins evolve to recognize and silence transposons that had previously evaded them."},
  {name: "Recent transposition", description: "Recent transposition refers to the movement of a transposable element within the genome that has occurred in the recent evolutionary past."},
  {name: "Receptor for insertion", description: "A receptor for insertion is a genomic site or sequence that serves as a target for the integration of other transposons."},
  {name: "Reciprocal regulation", description: "Reciprocal regulation describes a mutual regulatory relationship between two or more molecular entities, such as between LINE-1 and transcription factors."},
  {name: "Reciprocal regulatory influence", description: "The reciprocal regulatory influence refers to the bidirectional interaction between individual L1 copies and their genomic integration sites."},
  {name: "reciprocal translocations", description: "Reciprocal translocations are structural chromosomal rearrangements involving the exchange of segments between non-homologous chromosomes."},
  {name: "recombination", description: "Recombination is a mechanism of genome alteration created by retrotransposable elements."},
  {name: "recombination between retrotransposons", description: "Recombination between retrotransposons is an event where increased copy numbers provide more chances for recombination, potentially leading to chromosomal breaks."},
  {name: "Recombination cold spot", description: "A recombination cold spot is a genomic region where the frequency of meiotic recombination is significantly lower than the genome average."},
  {name: "recombination mechanisms", description: "Genetic processes that rearrange DNA sequences, related to mobile element activity."},
  {name: "recombination of L1 insertion intermediates", description: "Recombination of L1 insertion intermediates refers to the process where the DNA intermediates generated during LINE-1 retrotransposition interact with other DNA breaks or with each other to form new genomic junctions."},
  {name: "recombination-associated genomic deletion", description: "Recombination-associated genomic deletion is a mechanism where recombination events involving transposable elements result in the loss of genomic material."},
  {name: "recombination-based mechanisms", description: "Recombination-based mechanisms are processes that use DNA recombination to maintain or elongate telomeres, often as an alternative to telomerase."},
  {name: "Recombination-mediated integration", description: "Recombination-mediated integration is a mechanism for the insertion of genetic material, such as a circular intermediate, into the genome."},
  {name: "Recombinational editing", description: "A proposed mechanism for the nonrandom genomic distribution of transposons involving recombination events."},
  {name: "Recruitment of transcription factors", description: "The process by which retrotransposons bind and attract specific transcription factors."},
  {name: "Recruitment of transcriptional repressors", description: "The process by which retrotransposons bind and attract proteins that suppress gene transcription."},
  {name: "Reduced gene expression", description: "Reduced gene expression refers to a decrease in the level of transcription or translation of a specific gene."},
  {name: "Reduced primary transcript content", description: "Decreased content of the corresponding hnRNAs (heterogeneous nuclear RNAs) due to specific transposon insertions."},
  {name: "redundant silencing pathways", description: "Redundant silencing pathways are mechanisms that can repress L1 expression even in the absence of DNA methylation."},
  {name: "Regenerative therapy", description: "Regenerative therapy involves the use of cells, genes, or biomaterials to repair, replace, or regenerate damaged tissues or organs."},
  {name: "regional gene regulation", description: "The regulation of genes in a spatially defined manner within genomic regions such as TADs."},
  {name: "Regional mutation pressure", description: "Regional mutation pressure refers to the tendency for repetitive sequences to be subject to the same mutation pressure as their surrounding genomic regions, leading to similar GC content."},
  {name: "Regional silencing", description: "Regional silencing is a mechanism where gene or transposon repression occurs preferentially over a defined chromosomal region rather than genome-wide."},
  {name: "regulated transcriptional expression", description: "Regulated transcriptional expression refers to the controlled transcription of genetic elements."},
  {name: "regulating cell fate", description: "Regulating cell fate is a function where retrotransposons can influence the developmental potential or differentiation state of a cell."},
  {name: "Regulating cell interactions during inflammatory reaction", description: "A biological process involving the control of communication and responses between cells in the context of inflammation."},
  {name: "Regulating gene expression", description: "Regulating gene expression is the process of controlling the amount and timing of gene product production."},
  {name: "regulating gene expression posttranscriptionally", description: "Regulating gene expression posttranscriptionally is a function where retrotransposons can influence RNA processing, stability, or translation."},
  {name: "regulating nearby genes", description: "Regulating nearby genes is a function where retrotransposons can influence the expression of endogenous genes located in their vicinity."},
  {name: "regulation", description: "The activity of transposable elements is tightly regulated by genetic and epigenetic mechanisms."},
  {name: "Regulation by DNA methylation", description: "Regulation by DNA methylation refers to the control of gene or repeat expression through the addition of methyl groups to cytosine bases in DNA."},
  {name: "Regulation during early embryonic development", description: "Regulation during early embryonic development refers to the control of retrotransposon expression and activity in the context of early embryogenesis."},
  {name: "Regulation in inflammatory settings", description: "The control of LTR retrotransposon expression levels in the context of inflammation."},
  {name: "regulation of chromatin landscapes", description: "Regulation of chromatin landscapes refers to the control of chromatin structure and accessibility, which influences gene expression."},
  {name: "regulation of DNA transposon activity", description: "The process of controlling the mobilization and insertion frequency of DNA transposons."},
  {name: "Regulation of expression quantitative trait loci (eQTL)", description: "The process by which genetic variants influence the expression levels of genes or other transcripts."},
  {name: "Regulation of gene expression", description: "Regulation of gene expression is the process by which the amount or activity of a gene product is controlled."},
  {name: "Regulation of gene expression in immune response", description: "The process by which gene expression is controlled during the immune response to infection."},
  {name: "regulation of genome structure", description: "The process of influencing the organization and architecture of the genome."},
  {name: "Regulation of human genes", description: "Regulation of human genes refers to the control of gene expression, which can be influenced by nearby genomic elements like ERVs/LRs."},
  {name: "regulation of immune-inflammatory responses", description: "The regulation of immune-inflammatory responses involves controlling the body's defense mechanisms against pathogens and tissue damage."},
  {name: "regulation of nephrogenesis", description: "Regulation of nephrogenesis involves the control of kidney development and the formation of nephrons."},
  {name: "Regulation of pluripotency states", description: "Regulation of pluripotency states refers to the molecular control of distinct pluripotent cell states."},
  {name: "Regulation of protein-coding gene expression", description: "The process by which SINE retrotransposons impact the expression of protein-coding genes."},
  {name: "Regulation of retrotransposable elements", description: "Regulation of retrotransposable elements refers to the cellular mechanisms that control the expression and activity of retrotransposons."},
  {name: "Regulation of retrotransposition", description: "Regulation of retrotransposition refers to the cellular mechanisms that control the frequency and activity of LINE-1 retrotransposition events."},
  {name: "Regulation of retrotransposons", description: "Regulation of retrotransposons involves cellular silencing mechanisms that restrict the expression and mobility of retrotransposable elements to prevent genomic damage."},
  {name: "Regulation of stochastic fluctuations", description: "Regulation of stochastic fluctuations refers to the control of random variations in the copy numbers of transposable elements."},
  {name: "regulation of target gene expression", description: "Regulation of target gene expression refers to the control of the level of gene product produced from a specific gene."},
  {name: "Regulation of target genes", description: "The process by which miRNAs affect the expression of various target genes in the genome."},
  {name: "Regulation of TE activity", description: "Mechanisms that control the expression and mobilization of transposable elements."},
  {name: "regulation of totipotency", description: "Regulation of totipotency involves the control of a cell's ability to give rise to all cell types of an organism."},
  {name: "Regulation of transcription", description: "The control of the rate at which genetic information is copied from DNA to RNA."},
  {name: "Regulation of transcription initiation", description: "The process by which the start of gene transcription is controlled, which can be influenced by genomic repeat elements."},
  {name: "Regulation of transposable element numbers", description: "Regulation of transposable element numbers is a proposed mechanism where nonautonomous elements control the copy numbers of autonomous elements."},
  {name: "Regulatory element", description: "A regulatory element is a DNA sequence that controls the transcription of one or more genes."},
  {name: "Regulatory element acquisition", description: "The process where LINE-1 loci with defunct promoters can acquire regulatory elements from nearby genes to restore retrotransposition activity."},
  {name: "Regulatory evolution", description: "The evolutionary changes in the genomic regulatory landscape, including promoters and enhancers, across species or tissues."},
  {name: "regulatory function", description: "Regulatory function refers to the role of elements in controlling gene expression."},
  {name: "regulatory innovation", description: "The evolutionary creation of new gene regulatory functions or networks."},
  {name: "Regulatory landscape remodeling", description: "The process by which the three-dimensional organization and regulatory interactions of a genomic region are altered."},
  {name: "Regulatory network assembly", description: "Regulatory network assembly refers to the process of integrating various DNA sequences, including transposon-derived sequences, into cellular gene regulatory circuits."},
  {name: "Regulatory protein encoding", description: "Regulatory protein encoding refers to the process where a transposon encodes a protein that can regulate biological processes."},
  {name: "regulatory rewiring", description: "Regulatory rewiring involves changes in gene regulatory networks."},
  {name: "Regulatory role", description: "A regulatory role refers to the function of a genomic element in controlling gene expression or other cellular processes."},
  {name: "Regulatory roles", description: "Regulatory roles refer to the functions of transposable elements in controlling gene expression or other genomic processes."},
  {name: "regulatory sequence turnover", description: "The evolutionary gain and loss of regulatory DNA sequences."},
  {name: "Regulatory signature switching", description: "The evolutionary process where a genomic region changes its primary regulatory function, such as switching between promoter and enhancer activity."},
  {name: "Reinfection", description: "Reinfection refers to the process by which exogenous retroviruses can integrate into the germline, contributing to the formation of HERVs."},
  {name: "Relative expression", description: "Relative expression refers to the quantification of gene or element expression levels compared to a reference or control group."},
  {name: "Repair of double-strand breaks", description: "Repair of double-strand breaks (DSBs) is a cellular process to fix DNA breaks, which can be mediated by reverse transcriptase."},
  {name: "Repeat element dysregulation", description: "Repeat element dysregulation refers to the abnormal expression or suppression of repetitive sequences, including transposons, in pathological states."},
  {name: "Repeat element expression", description: "Repeat element expression refers to the transcription of repetitive sequences, including transposons, in the genome."},
  {name: "repeat element representation altered by epigenetic states", description: "The representation of repeat elements in the genome can be altered by changes in DNA methylation, histone modifications, or other epigenetic marks."},
  {name: "repeat element representation altered by structural changes", description: "The representation of repeat elements in the genome can be altered by large-scale genomic rearrangements or structural variations."},
  {name: "Repeat enrichment in gene promoters", description: "Repeat enrichment in gene promoters refers to the overrepresentation of repetitive elements in the regulatory regions of genes."},
  {name: "Repeat expansion", description: "The pathological increase in the number of tandem repeat sequences, often associated with neurological diseases."},
  {name: "Repeat expression", description: "Repeat expression refers to the transcriptional activity of repetitive DNA elements, including transposons."},
  {name: "repeat length-dependent expansion", description: "Repeat length-dependent expansion describes the phenomenon where the propensity for a repeat tract to expand increases with its initial length."},
  {name: "Repeat-induced gene activation (RIGA)", description: "Repeat-induced gene activation is a process where repeated sequences enhance gene expression."},
  {name: "Repeat-induced gene silencing (RIGS)", description: "Repeat-induced gene silencing is a process where repeated sequences suppress gene expression."},
  {name: "Repetitive element transcript expression", description: "The transcription of repetitive element sequences into RNA."},
  {name: "replication", description: "Replication refers to the process by which transposable elements copy and insert themselves into new genomic locations."},
  {name: "Replication mechanism", description: "The process by which retroposons copy and insert themselves into new genomic locations."},
  {name: "Replication origin association", description: "Replication origin association refers to the localization of genomic elements within or near constitutive replication origins."},
  {name: "Replication regulation", description: "Replication regulation refers to the control of the replication process of genetic elements, such as retroelements."},
  {name: "replication stress", description: "Replication stress refers to the slowing or stalling of DNA replication forks, which can lead to genomic instability."},
  {name: "replication-coupled DNA-repair", description: "Replication-coupled DNA-repair refers to DNA repair pathways that are coordinated with the DNA replication machinery."},
  {name: "replication-fork restart", description: "Replication-fork restart is the process of resuming DNA synthesis after a stalled or collapsed replication fork."},
  {name: "replication-stress signaling", description: "Replication-stress signaling involves cellular pathways that detect and respond to obstacles or damage during DNA replication."},
  {name: "Replicative senescence", description: "A state of irreversible cell cycle arrest associated with aging and cellular stress."},
  {name: "replicative transposition (mobilization)", description: "Replicative transposition is the process by which active L1 elements copy and paste themselves into new genomic locations, driving genetic diversity."},
  {name: "repress transposable elements", description: "The process of inhibiting the activity or expression of transposable elements."},
  {name: "Repression", description: "Repression is a form of gene or transposon expression regulation that decreases or silences transcription."},
  {name: "Repression by DNA methylation", description: "The silencing of gene or transposon expression through the addition of methyl groups to cytosine bases in DNA."},
  {name: "Repression by KRAB-ZNF proteins", description: "Repression by KRAB-ZNF proteins is a key defense mechanism in mammals that silences transposable elements to offer genomic protection."},
  {name: "repression by KZNFs", description: "KRAB Zinc Finger Proteins (KZNFs) are a family of proteins that bind to and repress certain classes of repeat elements."},
  {name: "Repression of L1 5' UTR", description: "HBV polymerase represses the activity of the L1 5' untranslated region."},
  {name: "Repression of proximal genes", description: "The process of decreasing the transcription of genes located nearby."},
  {name: "repression of retrotransposition", description: "Repression of retrotransposition refers to cellular mechanisms that suppress the activity of retrotransposons."},
  {name: "Repression of retrotransposons", description: "Repression of retrotransposons is the silencing mechanism that controls their activity."},
  {name: "Repression of transposable elements", description: "Repression of transposable elements refers to the epigenetic silencing of transposons to prevent their aberrant activity."},
  {name: "repression of transposons", description: "Repression of transposons refers to the molecular mechanisms that inhibit the activity and mobility of transposable elements."},
  {name: "Reprogramming", description: "Reprogramming refers to the process of converting somatic cells into induced pluripotent stem cells (iPSCs) by expressing specific factors."},
  {name: "Reprogramming of gene expression", description: "Reprogramming of gene expression refers to the alteration of gene expression patterns."},
  {name: "Reprogramming transgene removal", description: "The process of excising transposon-delivered reprogramming transgenes from the genome of induced pluripotent stem cells."},
  {name: "Reprogramming vector removal", description: "Reprogramming vector removal is a technique to eliminate exogenous genetic material used to induce pluripotency, ensuring the safety of the resulting iPSCs."},
  {name: "Reshaping the genome", description: "The process by which retrotransposons alter the structure and composition of the genome."},
  {name: "restraining totipotency", description: "Restraining totipotency refers to the process of limiting the developmental potential of naive human embryonic stem cells to a totipotent-like state."},
  {name: "Restriction", description: "Restriction refers to the inhibition or limitation of the mobility or infectivity of retroelements and retroviruses."},
  {name: "restriction of retrotransposons", description: "Restriction of retrotransposons refers to the cellular mechanisms that inhibit or control the mobilization of retrotransposable elements to maintain genomic stability."},
  {name: "retention on the X chromosome", description: "The process of maintaining transposable elements, such as LINE-1, on the X chromosome, potentially through selection."},
  {name: "reteoelement expression", description: "Retroelement expression refers to the transcription and potential activity of retrotransposons such as LINE-1 and HERVs."},
  {name: "Retroduplication", description: "Retroduplication is the process involving reverse transcription of mRNAs and their insertion back into the genome."},
  {name: "retroelement activation", description: "Retroelement activation is the process by which retrotransposons become transcriptionally active."},
  {name: "retroelement amplification", description: "Retroelement amplification is the process by which retrotransposons increase their copy number in the genome."},
  {name: "retroelement derepression", description: "Retroelement derepression is the loss of repression leading to increased expression of retrotransposons."},
  {name: "retroelement integration", description: "Retroelement integration is the process by which retrotransposons insert into the genome."},
  {name: "Retroelement silencing", description: "Retroelement silencing refers to the epigenetic and transcriptional mechanisms that repress the activity of retrotransposable elements in the genome."},
  {name: "retroelement-induced mutagenesis", description: "Retroelement-induced mutagenesis refers to the molecular mechanisms by which retroelements cause human disease."},
  {name: "Retrogene formation", description: "Retrogene formation is the creation of new genes through the retroposition of processed mRNA."},
  {name: "retrohoming mechanism", description: "The mechanism by which mobile group II introns or related retrotransposons insert into a DNA target site via reverse splicing and reverse transcription."},
  {name: "Retroposition", description: "Retroposition is the process by which retrotransposons insert new copies into the genome via an RNA intermediate."},
  {name: "retroposon transposition", description: "Retroposon transposition is the process by which retroposons move and integrate into new genomic locations via reverse transcription of an RNA intermediate."},
  {name: "retrotranscriptome", description: "The complete set of transcripts derived from retrotransposons, including HERVs, within a cell or tissue."},
  {name: "Retrotransposable element (RTE) control", description: "Retrotransposable element control refers to the cellular mechanisms, such as siRNA silencing, that repress the activity of retrotransposons in somatic tissues."},
  {name: "retrotransposal integration", description: "The process by which retrotransposable elements insert copies of themselves into new genomic locations via an RNA intermediate."},
  {name: "retrotransposition", description: "Retrotransposition is the process by which LINE-1 elements move within the genome."},
  {name: "retrotransposition at dysfunctional telomeres", description: "The process of LINE-1 retrotransposition events targeted to dysfunctional telomeres via the ENi pathway."},
  {name: "Retrotransposition control", description: "Retrotransposition control refers to the host mechanisms that regulate or suppress the mobility of retrotransposable elements."},
  {name: "Retrotransposition in cis", description: "Retrotransposition in cis is the process by which LINE-1 preferentially mobilizes its own encoding RNA."},
  {name: "Retrotransposition in trans", description: "Retrotransposition in trans is the process by which LINE-1 proteins can mobilize non-self RNAs, such as Alu RNA or cellular mRNAs."},
  {name: "Retrotransposition of endogenous genes", description: "Retrotransposition of endogenous genes refers to the process where cellular protein-coding genes are reverse-transcribed and reinserted into the genome, creating processed pseudogenes."},
  {name: "Retrotransposition of processed pseudogenes", description: "The process by which cellular mRNAs are reverse transcribed and inserted into the nuclear genome by L1 machinery, creating processed pseudogenes."},
  {name: "retrotransposition-dependent DNA mobilization", description: "Retrotransposition-dependent DNA mobilization is a mechanism by which retrotransposons move within the genome, leading to insertion mutations and DNA deletions."},
  {name: "retrotransposition-independent consequences", description: "Effects of LINE-1 activity that do not require the element to move to a new location."},
  {name: "retrotransposition-independent disruption of epithelial programming and differentiation", description: "Retrotransposition-independent disruption of epithelial programming and differentiation is a mechanism by which retrotransposons affect cellular processes without necessarily mobilizing."},
  {name: "retrotransposition-mediated deletion", description: "Retrotransposition-mediated deletion is a mechanism of genome alteration created by retrotransposable elements."},
  {name: "Retrotransposon abundance variation", description: "Retrotransposon abundance variation refers to differences in the copy number or genomic proportion of retrotransposons among individuals or populations."},
  {name: "retrotransposon activation", description: "Retrotransposon activation refers to the process by which retrotransposons become transcriptionally and/or transpositionally active."},
  {name: "Retrotransposon activity", description: "Retrotransposon activity refers to the transcription and mobilization of retrotransposons within the genome."},
  {name: "Retrotransposon amplification", description: "Retrotransposon amplification refers to the process of increasing copy number through replication and insertion."},
  {name: "Retrotransposon control", description: "Retrotransposon control refers to the cellular mechanisms that regulate the activity and mobility of retrotransposons."},
  {name: "retrotransposon de-repression", description: "Retrotransposon de-repression refers to the loss of transcriptional silencing of retrotransposons, leading to their aberrant expression."},
  {name: "retrotransposon derepression", description: "Retrotransposon derepression refers to the loss of transcriptional silencing or repression of retrotransposons, leading to their increased expression."},
  {name: "Retrotransposon diversification", description: "The evolutionary process leading to the emergence of distinct retrotransposon lineages or families."},
  {name: "Retrotransposon evolution", description: "Retrotransposon evolution refers to the process of change and diversification of retrotransposon families and subfamilies over time."},
  {name: "retrotransposon expression", description: "The production of RNA transcripts from retrotransposon sequences."},
  {name: "Retrotransposon expression upregulation", description: "An increase in the expression levels of retrotransposons."},
  {name: "Retrotransposon extinction", description: "The loss of active retrotransposon lineages from a genome."},
  {name: "retrotransposon hypomethylation", description: "Retrotransposon hypomethylation refers to a decrease in the methylation level of retrotransposon sequences, which can lead to their increased activity or expression."},
  {name: "Retrotransposon insertion", description: "Retrotransposon insertion refers to the genomic integration event of a retrotransposon into a new location in the genome."},
  {name: "Retrotransposon insertion polymorphism", description: "Retrotransposon insertion polymorphism refers to the presence or absence of non-reference transposable element variants in an individual's genome."},
  {name: "Retrotransposon Insertion Polymorphism (RIP)", description: "Retrotransposon Insertion Polymorphism (RIP) is defined as the presence or absence of a retrotransposon insertion among human populations at a specific genomic location."},
  {name: "Retrotransposon mobilization", description: "Retrotransposon mobilization is the process by which retrotransposons move to new genomic locations."},
  {name: "Retrotransposon proliferation", description: "The process by which retrotransposons increase their copy number within the host genome, creating a tension with host survival."},
  {name: "Retrotransposon propagation", description: "Retrotransposon propagation refers to the process by which retrotransposons, such as LINE-1, replicate and increase their copy number within the genome through a copy-and-paste mechanism."},
  {name: "retrotransposon reactivation", description: "Retrotransposon reactivation refers to the process where normally silenced retrotransposons become transcriptionally active again."},
  {name: "Retrotransposon recombination-mediated inversion (RRMI)", description: "Retrotransposon recombination-mediated inversion is a mechanism that causes chromosomal inversions without altering the amount of genomic material."},
  {name: "retrotransposon regulation", description: "Retrotransposon regulation involves the control of retrotransposon activity and expression."},
  {name: "retrotransposon repression", description: "Retrotransposon repression is the process of inhibiting the transcription or activity of retrotransposons."},
  {name: "retrotransposon RNA expression", description: "Retrotransposon RNA expression refers to the transcription of retrotransposon elements into RNA."},
  {name: "Retrotransposon RNA stability regulation", description: "Retrotransposon RNA stability regulation is the process by which the stability of retrotransposon RNA transcripts is controlled, affecting their potential for retrotransposition."},
  {name: "Retrotransposon silencing", description: "Retrotransposon silencing refers to the cellular mechanisms that restrict the mobility and expression of retrotransposons."},
  {name: "Retrotransposon transcription", description: "Retrotransposon transcription is the process of generating RNA transcripts from retrotransposon sequences."},
  {name: "Retrotransposon transcription regulation", description: "Retrotransposon transcription regulation involves the control of the initiation and rate of transcription of retrotransposon elements from genomic DNA into RNA."},
  {name: "Retrotransposon transcriptional silencing", description: "A host defense mechanism to repress retrotransposon transcription and prevent further insertions."},
  {name: "Retrotransposon-mediated sequence transduction", description: "Retrotransposon-mediated sequence transduction is the process by which a retrotransposon carries flanking sequence during its mobilization, proposed as a gene duplication mechanism."},
  {name: "retrotransposons activation", description: "Retrotransposons activation refers to the increased transcriptional and/or transpositional activity of retrotransposons."},
  {name: "Retroviral deletion", description: "Retroviral deletion refers to the loss of endogenous retroviral sequences from the genome, which can occur over evolutionary time."},
  {name: "Retroviral insertion", description: "Retroviral insertion is the process by which a retrovirus integrates its genetic material into the host genome."},
  {name: "Retroviral insertion mutagenesis", description: "A process where the integration of a retroviral genome into the host DNA disrupts gene function or regulation, leading to mutations."},
  {name: "Retroviral integration", description: "Retroviral integration is the process by which a retrovirus inserts its DNA copy into the host genome."},
  {name: "Retroviral primer-binding site hybridization", description: "A method using synthetic oligonucleotides complementary to putative retroviral primer-binding sites as hybridization probes to detect novel retrovirus-like sequences."},
  {name: "Retroviral provirus structure", description: "A genomic element with structural features characteristic of a retroviral provirus, including long terminal repeats and a pol gene."},
  {name: "Retroviral transposition", description: "Retroviral transposition is a process by which retroviral-like elements move and insert into new genomic locations."},
  {name: "reverse transcriptase (RT) enzyme expression", description: "The expression of the reverse transcriptase enzyme encoded by retrotransposons."},
  {name: "Reverse transcriptase activity", description: "Reverse-transcriptase activity is the enzymatic function of converting RNA into DNA, which is utilized by retrotransposons."},
  {name: "Reverse transcriptase expression", description: "Reverse transcriptase expression refers to the production of the enzyme that catalyzes the reverse transcription of RNA into DNA."},
  {name: "reverse transcriptase inhibition", description: "The process of inhibiting the activity of reverse transcriptase (RT) enzymes."},
  {name: "Reverse transcriptase-mediated DNA damage response", description: "Reverse transcriptase-mediated DNA damage response is a cellular response triggered by the reverse transcriptase activity of LINE-1 ORF2p, independent of its endonuclease activity."},
  {name: "Reverse transcription", description: "The enzymatic process of synthesizing DNA from an RNA template, utilized by retrotransposons."},
  {name: "Reverse transcription and integration", description: "Reverse transcription and integration is the process by which RNA is reverse transcribed into DNA and then inserted into a new genomic location."},
  {name: "Reverse transcription by ORF2p", description: "ORF2p possesses reverse transcriptase activity and can use recruited cellular RNAs as templates."},
  {name: "Reverse transcription of L1 RNA 5'-CAP", description: "A process that explains the higher frequency of G nucleotides observed upstream from the L1, likely involving the incorporation of the RNA cap during reverse transcription."},
  {name: "reverse transcription priming", description: "Reverse transcription priming is the process where the nicked poly-T DNA strand generated by LINE-1 endonuclease serves as a primer for the reverse transcription of LINE-1 RNA."},
  {name: "reverse transcriptional transposition", description: "Reverse transcriptional transposition is the process by which LINE-1 replicates and inserts itself into new gene sites through reverse transcription."},
  {name: "reversible immortalization", description: "Reversible immortalization is a technique to enable continuous cell growth without senescence, which can later be reversed."},
  {name: "Ribonuclease sensitivity", description: "The property of a complex being disrupted or dissociated upon treatment with ribonuclease."},
  {name: "Ribonucleoprotein (RNP) complex formation", description: "The process where L1-encoded proteins ORF1p and ORF2p bind to L1 RNA in cis to form a ribonucleoprotein complex essential for retrotransposition."},
  {name: "Ribonucleoprotein (RNP) condensate formation", description: "Many copies of the ORF1p protein assemble onto the LINE-1 RNA to form a ribonucleoprotein (RNP) condensate."},
  {name: "Ribonucleoprotein (RNP) formation", description: "Ribonucleoprotein (RNP) formation is the process where the full-length LINE-1 transcript assembles in cis with its encoded proteins ORF1p and ORF2p."},
  {name: "Ribonucleoprotein (RNP) particle formation", description: "The process of forming complexes containing retrotransposon RNA and proteins, such as ORF1p and ORF2p, which are essential for retrotransposition."},
  {name: "Ribonucleoprotein complex formation", description: "Ribonucleoprotein complex formation is the process by which RNA and proteins assemble into a functional complex."},
  {name: "ribonucleoprotein particle (RNP) disruption", description: "Ribonucleoprotein particle (RNP) disruption refers to the impairment of the functional complex formed by LINE-1 RNA and proteins (ORF1p, ORF2p), which is essential for retrotransposition."},
  {name: "Ribonucleoprotein particle (RNP) formation", description: "The process where L1-encoded proteins (ORF1p and ORF2p) preferentially associate with their encoding transcript to form a proposed retrotransposition intermediate."},
  {name: "ribonucleoprotein particle assembly", description: "Ribonucleoprotein particle assembly is the formation of a complex containing L1 RNA, ORF1p, and ORF2p, which is the core of the LINE-1 retrotransposition machinery."},
  {name: "ribonucleoprotein particle formation", description: "Ribonucleoprotein particle formation is the assembly of RNA and proteins, which is a step in the retrotransposition cycle of LINE-1."},
  {name: "Ribonucleoprotein particle transport", description: "Ribonucleoprotein particle transport is the movement of ribonucleoprotein complexes within the cell."},
  {name: "Ribonucleotide Excision Repair (RER)", description: "Ribonucleotide Excision Repair (RER) is a pathway that completes the removal of ribonucleoside monophosphates (rNMPs) from DNA after incision by RNase H2."},
  {name: "Ribosomal association", description: "Ribosomal association is the process by which Alu RNA interacts with ribosomes."},
  {name: "Ribosome stalling", description: "Ribosome stalling is a condition where the ribosome pauses during translation elongation, which is recognized by the Alu ribonucleoprotein particle."},
  {name: "RIG-I-like receptor (RLR)-associated type-I interferon signaling", description: "RIG-I-like receptor (RLR)-associated type-I interferon signaling is an innate immune pathway triggered by detection of viral or endogenous dsRNA."},
  {name: "RNA 3'-end polyadenylation", description: "RNA 3'-end polyadenylation is the addition of a poly(A) tail to the 3' end of an RNA molecule."},
  {name: "RNA 3'-end uridylation", description: "RNA 3'-end uridylation is the addition of uridine residues to the 3' end of an RNA molecule."},
  {name: "RNA binding", description: "LINE-1 ORF1 protein (ORF1p) is an RNA-binding protein that binds to L1 RNA."},
  {name: "RNA chaperone activity", description: "LINE-1 ORF1 protein (ORF1p) acts as an RNA chaperone, which is required for retrotransposition."},
  {name: "RNA circularization", description: "RNA circularization is a process where the ends of an RNA molecule are joined to form a circle."},
  {name: "RNA circularization via Alu/Alu base-pairing", description: "A process where Alu sequences located in flanking introns base-pair with each other, facilitating the formation of circular RNA molecules from exons."},
  {name: "RNA decay", description: "RNA decay is the process of RNA degradation."},
  {name: "RNA degradation", description: "RNA degradation is a cellular pathway that breaks down RNA molecules, serving as a regulatory mechanism to control the expression of retrotransposons."},
  {name: "RNA duplex formation", description: "RNA duplex formation is the process where complementary RNA strands base-pair to form a double-stranded structure."},
  {name: "RNA expression", description: "The process of transcribing DNA sequences into RNA molecules."},
  {name: "RNA interference (RNAi)", description: "RNA interference is a mechanism of gene silencing triggered by small interfering RNAs."},
  {name: "RNA interference (RNAi) by antisense ORF0 RNA", description: "RNA interference by antisense ORF0 RNA is a potential regulatory mechanism targeting LINE-1 RNA."},
  {name: "RNA ligation", description: "A known mechanism potentially involved in the formation of LINE-1 chimeric insertions."},
  {name: "RNA m6A modification", description: "A common post-transcriptional RNA modification, involving methylation at the N6 position of adenosine."},
  {name: "RNA metabolism", description: "A recurring theme for retrotransposons is their tie-in to RNA metabolism, as they mobilize via RNA intermediates."},
  {name: "RNA methylation", description: "RNA methylation is a chemical modification of RNA molecules, such as N6-methyladenosine (m6A)."},
  {name: "RNA packaging", description: "RNA packaging is a function performed by the L1ORF1 protein during LINE-1 retrotransposition."},
  {name: "RNA polymerase II activity", description: "The transcriptional activity of RNA polymerase II, the enzyme responsible for synthesizing mRNA and other non-coding RNAs."},
  {name: "RNA polymerase II enrichment", description: "The accumulation of RNA polymerase II at specific genomic loci."},
  {name: "RNA polymerase II transcription", description: "A transcription process regulated by motifs such as CCAAT, TATA, and ATTAAA found in long terminal repeats."},
  {name: "RNA polymerase II-driven transcription", description: "Transcription of LINE-1 elements is driven by an internal RNA polymerase II promoter."},
  {name: "RNA polymerase III transcription", description: "RNA polymerase III transcription is the process by which RNA polymerase III synthesizes small, non-coding RNAs, including some from transposable elements."},
  {name: "RNA polymerase III-dependent transcription", description: "A transcription process mediated by RNA polymerase III, which is sensitive to the inhibitor tagetitoxin."},
  {name: "RNA polymerase III-driven transcription", description: "Transcription of SINE elements like Alu is driven by an internal RNA polymerase III promoter."},
  {name: "RNA processing", description: "RNA processing encompasses the modifications an RNA molecule undergoes after transcription, such as splicing, editing, and polyadenylation."},
  {name: "RNA quality control", description: "RNA quality control refers to cellular mechanisms that ensure the fidelity and proper processing of RNA molecules."},
  {name: "RNA recognition by LINE-1 reverse transcriptase", description: "The mechanism by which the LINE-1-encoded reverse transcriptase (RT) specifically recognizes its own RNA and Alu RNA for retrotransposition."},
  {name: "RNA recombination", description: "RNA recombination is a process involving the exchange of genetic material between RNA molecules."},
  {name: "RNA recruitment to L1-RNP", description: "The RNA-binding property of ORF1p is critical to recruit other mobile RNAs to the L1-ribonucleoprotein particle."},
  {name: "RNA secondary structure disruption", description: "RNA secondary structure disruption refers to the alteration of the base-pairing patterns within an RNA molecule, which can affect its function and interactions."},
  {name: "RNA sensing pathways", description: "RNA sensing pathways are innate immune signaling cascades that detect foreign or aberrant RNA, such as those mediated by RIG-I and MDA5."},
  {name: "RNA splicing", description: "RNA splicing is the process of removing introns from a pre-mRNA transcript and joining exons together."},
  {name: "RNA stability", description: "The resistance of an RNA molecule to degradation, influencing its availability for processes like retrotransposition."},
  {name: "RNA stability regulation", description: "RNA stability regulation refers to the processes that control the degradation or stabilization of RNA molecules, influencing their half-life and abundance."},
  {name: "RNA surveillance", description: "RNA surveillance refers to cellular mechanisms that monitor and degrade aberrant or nonsense RNAs."},
  {name: "RNA targeting", description: "RNA targeting refers to the process of directing or localizing RNA molecules to specific cellular locations or complexes."},
  {name: "RNA template switching", description: "A process during reverse transcription where the reverse transcriptase switches from one RNA template to another, leading to the formation of chimeric cDNA."},
  {name: "RNA transcript production", description: "RNA transcript production is the generation of RNA molecules from a DNA sequence, which is a key step in gene expression."},
  {name: "RNA truncation", description: "RNA truncation refers to the generation of shortened RNA transcripts, often due to premature termination of transcription."},
  {name: "RNA-chromatin crosstalk", description: "RNA-chromatin crosstalk describes the interaction and mutual regulation between RNA molecules and chromatin structure during cell fate transitions."},
  {name: "RNA-DNA hybrid formation", description: "RNA-DNA hybrid formation is the generation of structures where an RNA strand is base-paired with a complementary DNA strand."},
  {name: "RNA-guided transposition", description: "RNA-guided transposition is a process where transposase activity is directed to specific genomic sequences using guide RNAs."},
  {name: "RNA-mediated DNA repair", description: "A proposed ancestral mechanism associated with non-LTR retrotransposons that may have been used before the acquisition of an endonuclease domain."},
  {name: "RNA-mediated gene insertion", description: "RNA-mediated gene insertion is a process where genetic material is delivered and integrated into the genome via an RNA intermediate."},
  {name: "RNA-mediated genomic invasion", description: "The process by which retrotransposon RNAs and cellular mRNAs are reverse transcribed and integrated into genomic DNA."},
  {name: "RNA-protein complex formation", description: "The process where SINE-derived RNAs interact with cellular proteins to form ribonucleoprotein (RNP) complexes."},
  {name: "RNA-RNA interaction", description: "RNA-RNA interaction refers to the direct physical association between different RNA molecules."},
  {name: "RNA-RNA recombination", description: "RNA-RNA recombination is a process that occurs during L1 reverse transcription, leading to the formation of chimeric retrotranscripts."},
  {name: "RNA-sensing response", description: "An innate immune response triggered by sensing of RNA, mediated through MAVS signaling."},
  {name: "RNA-seq analysis", description: "A method using next-generation sequencing to measure RNA expression levels."},
  {name: "RNA/DNA hybrid processing", description: "RNA/DNA hybrid processing refers to the cleavage of the RNA strand in RNA/DNA hybrids, a function shared by RNase H1 and RNase H2."},
  {name: "RNA:DNA heteroduplex formation", description: "RNA:DNA heteroduplex formation is the process where an RNA strand base-pairs with a complementary DNA strand."},
  {name: "RNA:DNA hybrid formation", description: "RNA:DNA hybrid formation is the generation of duplex structures composed of one RNA strand and one DNA strand."},
  {name: "RNase H activity", description: "A putative function associated with the 3'-end domain of the LINE ORF2 protein, dispensable for reverse transcription in this assay."},
  {name: "RNP complex assembly", description: "RNP complex assembly refers to the formation of ribonucleoprotein particles containing L1 RNA and the encoded proteins ORF1p and ORF2p."},
  {name: "RNP complex formation", description: "ORF1p packages its transcript into an ORF2p-containing ribonucleoprotein (RNP) complex, which is the retrotransposition intermediate."},
  {name: "RNP formation", description: "RNP (ribonucleoprotein) formation is the assembly of LINE-1 RNA with its encoded proteins, which is a critical step in the retrotransposition cycle."},
  {name: "RNP sequestration in cytoplasmic bodies", description: "RNP sequestration in cytoplasmic bodies involves the compartmentalization of ribonucleoprotein complexes, potentially to limit their activity."},
  {name: "RT-dependent mechanism in tumorigenesis", description: "A mechanism that operates in tumorigenesis and is dependent on reverse transcriptase activity."},
  {name: "RT-dependent regulatory mechanism", description: "A regulatory mechanism that operates during preimplantation development, is repressed in normal tissues, and when reactivated, promotes cell transformation and cancer progression."},
  {name: "RT-mediated somatic gene recombination/retroinsertion", description: "RT-mediated somatic gene recombination/retroinsertion is a process where reverse transcriptase activity facilitates the insertion or recombination of genetic material in somatic cells."},
  {name: "RTE de-repression", description: "RTE de-repression is the loss of normal silencing mechanisms, leading to increased activity of retrotransposable elements."},
  {name: "S phase", description: "S phase is the stage of the cell cycle when DNA replication occurs and when LINE-1 retrotransposition peaks."},
  {name: "S-phase insertion", description: "A proposed mechanism for the nonrandom genomic distribution of transposons based on insertion timing during DNA replication."},
  {name: "S/G2 phase DNA repair", description: "S/G2 phase DNA repair refers to DNA repair mechanisms that are active during the S and G2 phases of the cell cycle."},
  {name: "Seamless genome editing", description: "Seamless genome editing is a technique for introducing precise genetic modifications, such as point mutations, without leaving exogenous DNA sequences like selection markers at the target locus."},
  {name: "seamless removal of selection markers", description: "The process of excising genetic selection markers from the genome without leaving behind unwanted sequences."},
  {name: "Second-strand cleavage", description: "Second-strand cleavage is the rate-limiting catalytic step in the transposition reaction of Hsmar1."},
  {name: "second-strand DNA synthesis", description: "The synthesis of the complementary DNA strand following reverse transcription to generate a double-stranded DNA copy."},
  {name: "Segmental duplication", description: "Segmental duplication is a genomic event involving the copying and insertion of a large DNA segment, often containing genes and repeats."},
  {name: "Segmental duplication (SD) mobilization", description: "Segmental duplication mobilization is the process by which large, duplicated genomic segments are propagated and rearranged."},
  {name: "Segmental genomic duplication", description: "A process involving the duplication of large genomic regions, which can confound the identification of unique L1 insertion events."},
  {name: "Selection", description: "Selection is a process in genetic engineering where cells that have successfully incorporated a desired genetic construct (e.g., a resistance gene) are isolated and propagated."},
  {name: "selection system", description: "A system, such as one based on the piggyBac transposon, used to select for genetically modified cells."},
  {name: "Selective isolation of recent L1 sequences", description: "A novel method developed to isolate human L1 sequences that transposed in the relatively recent past, based on features like high CpG content and rare cutter sites."},
  {name: "selective repression", description: "Selective repression is the targeted inhibition of specific genes or elements, such as certain TE families."},
  {name: "self-priming of Alu RNA", description: "A mechanism by which Alu RNA can initiate its own reverse transcription in the cytoplasm without requiring a separate primer."},
  {name: "self-propagation", description: "Self-propagation refers to the autonomous ability of LINE-1 to copy and insert itself into new genomic locations."},
  {name: "Self-renewal", description: "Self-renewal is the ability of a stem cell to divide and produce at least one daughter cell that retains its stem cell properties."},
  {name: "Self-renewal maintenance", description: "The process by which cells, such as human embryonic stem cells (hESCs), maintain their ability to divide and produce identical daughter cells."},
  {name: "self-replication", description: "Self-replication is the process by which retrotransposons copy and reinsert themselves into the genome."},
  {name: "senescence", description: "Senescence is a state of permanent cell cycle arrest, often triggered by stress or damage."},
  {name: "Senescence-associated chromatin rewiring", description: "Extensive remodeling of 3D chromatin architecture during cellular senescence, including compartment switching and increased chromatin loops."},
  {name: "Senescence-associated secretory phenotype", description: "Senescence-associated secretory phenotype (SASP) is a pro-inflammatory secretome produced by senescent cells, including factors like IL-6 and IL-8."},
  {name: "senescence-associated secretory phenotype (SASP)", description: "SASP is a pro-inflammatory and tissue-disruptive secretome produced by senescent cells."},
  {name: "senescence-like phenotype", description: "A senescence-like phenotype is a state of irreversible cell cycle arrest, often triggered by stress such as DNA damage."},
  {name: "sense transcription", description: "Sense transcription refers to the production of RNA from the coding strand of a DNA sequence, typically producing a functional transcript."},
  {name: "Sequence amplification", description: "Sequence amplification refers to the process of generating multiple copies of a DNA segment within the genome."},
  {name: "Sequence diversification", description: "Sequence diversification refers to the process of generating genetic variation within a gene family, such as through gene conversion."},
  {name: "sequence diversity accumulation", description: "The process of accumulating mutations in the L1 5' UTR at a faster rate than other components."},
  {name: "Sequence homology", description: "Sequence homology refers to the similarity in the nucleotide or amino acid sequences of different genes or proteins, suggesting a common evolutionary origin."},
  {name: "Sequence transduction", description: "Sequence transduction is a process where a mobile element, such as an L1, carries flanking genomic sequences to a new insertion site during retrotransposition."},
  {name: "Sequence-specific DNA binding", description: "Sequence-specific DNA binding is the ability of a protein to recognize and bind to a particular DNA sequence motif."},
  {name: "Sequence-specific insertion", description: "A proposed mechanism for the nonrandom genomic distribution of transposons based on insertion site preference."},
  {name: "Sequence-specific mRNA degradation", description: "Sequence-specific mRNA degradation is the targeted breakdown of messenger RNA molecules, a key outcome of the RNAi mechanism."},
  {name: "sequence-specific nicking", description: "Sequence-specific nicking is the enzymatic cleavage of a DNA strand at a specific consensus sequence, such as 5'-TTTTT/AA-3' for LINE-1 endonuclease."},
  {name: "Sequence-specific single-strand RNA binding", description: "Sequence-specific single-strand RNA binding is a specific type of RNA binding where a protein recognizes and binds to particular sequences in single-stranded RNA molecules."},
  {name: "sequestering oncosuppressors", description: "Sequestering oncosuppressors involves binding and inactivating tumor suppressor proteins."},
  {name: "Sequestration into stress granules and multivesicular structures", description: "Sequestration involves the compartmentalization of LINE-1 products into stress granules and multivesicular bodies, potentially limiting their activity."},
  {name: "Sequestration of L1ORF1p", description: "Sequestration of L1ORF1p refers to the trapping or confinement of the LINE-1 ORF1 protein within specific cellular compartments."},
  {name: "Sequestration of LINE-1 RNP in stress granules", description: "Sequestration of LINE-1 RNP in stress granules refers to the confinement of LINE-1 ribonucleoprotein particles within stress granules, limiting their mobility and activity."},
  {name: "Shape genomic variation in somatic cells", description: "Retrotransposed LINE-1 elements contribute to genomic variation in somatic cells."},
  {name: "shaping non-coding RNA transcriptomic profile", description: "Shaping the non-coding RNA transcriptomic profile refers to the process of influencing the global expression patterns of non-coding RNAs."},
  {name: "Shaping the human genome", description: "Retrotransposons have played a role in shaping the structure and evolution of the human genome."},
  {name: "signaling events in the early embryo", description: "Signaling events in the early embryo are molecular communication processes crucial for embryonic development."},
  {name: "Signaling modulation", description: "SINE ncRNAs can modulate signaling events."},
  {name: "silencing", description: "Silencing refers to the epigenetic repression of gene or transposon expression."},
  {name: "silencing by KZNF proteins", description: "Transposable elements are often silenced by KRAB zinc finger (KZNF) proteins which recruit corepressor proteins to establish a repressive chromatin state."},
  {name: "Silencing of transposable elements", description: "Silencing of transposable elements refers to the complex regulatory mechanisms that suppress the activity of transposons in mammalian cells."},
  {name: "SINE activation", description: "SINE activation refers to the upregulation of SINE transcript levels and retrotransposition following cellular stress."},
  {name: "SINE induction", description: "SINE induction is the transcriptional upregulation of SINE elements triggered by specific stimuli."},
  {name: "SINE retrotransposition", description: "SINE retrotransposition is the process by which SINE elements move within the genome through an RNA intermediate."},
  {name: "SINE retrotransposition assay", description: "An experimental method developed to monitor the activity and insertion of SINE retrotransposons in cell culture."},
  {name: "SINE RNA mobilization", description: "The process by which non-autonomous SINE RNAs, such as those derived from 7SL RNA or tRNA, hijack the LINE-1 ORF2 protein machinery to achieve their own retrotransposition."},
  {name: "SINE transcription", description: "SINE transcription by RNA polymerase III is a process required for retrotransposition."},
  {name: "SINE transcription induction", description: "The dramatic increase in the transcription of SINE elements, observed in response to DNA-damaging agents."},
  {name: "SINE-SINE recombination", description: "SINE-SINE recombination refers to chromosomal rearrangements caused by homologous recombination between SINE elements, potentially stimulated by DNA breaks at integration sites."},
  {name: "Single-strand DNA break induction", description: "The process of creating breaks in single-stranded DNA, which is a step in LINE-1 integration."},
  {name: "Single-strand hairpin formation", description: "Single-strand hairpin formation is a secondary structure that can make introns unstable and facilitate exon deletion."},
  {name: "single-strand nicking", description: "The introduction of a single-strand break (nick) in a DNA molecule."},
  {name: "Single-stranded nucleic acid complex formation", description: "The formation of distinct complexes with single-stranded nucleic acids."},
  {name: "Single-stranded RNA binding", description: "Single-stranded RNA binding is a specific activity of the L1ORF1 protein."},
  {name: "siRNA delivery", description: "siRNA delivery is the process of introducing small interfering RNA into cells to induce RNA interference."},
  {name: "site-directed genomic integration", description: "The process of directing gene integration to a user-defined chromosomal location."},
  {name: "Site-specific DNA binding", description: "Site-specific DNA binding is the ability of a protein to recognize and bind to a specific DNA sequence."},
  {name: "Site-specific endonuclease activity", description: "Site-specific endonuclease activity refers to the enzymatic function that cleaves DNA at specific nucleotide sequences."},
  {name: "Site-specific gene targeting", description: "Site-specific gene targeting refers to the precise insertion of a therapeutic gene into a predetermined genomic location."},
  {name: "site-specific insertion", description: "Site-specific insertion refers to the integration of a genetic element into a particular location in the genome, potentially with regulatory effects."},
  {name: "Site-specific insertion of large genetic constructs", description: "Site-specific insertion of large genetic constructs is a genome editing goal involving the precise integration of substantial DNA sequences into a targeted genomic location."},
  {name: "Site-specific single-nucleotide substitution", description: "Site-specific single-nucleotide substitution is a precise genome editing technique aimed at changing a single nucleotide at a defined location in the genome."},
  {name: "Skeletal muscle development", description: "Skeletal muscle development is the process of formation and maturation of skeletal muscle tissue."},
  {name: "Sloping shores", description: "A graded influence of a hypomethylated CpG island on the DNA methylation status of flanking CpG sites."},
  {name: "Smad4 sequestration", description: "Smad4 sequestration is a molecular mechanism where L1ORF1p interacts with Smad4 and retains it in the cytoplasm."},
  {name: "Smad4-signaling regulation", description: "Smad4-signaling regulation is a pathway involved in tumorigenesis, which L1ORF1p participates in by sequestering Smad4."},
  {name: "Small interfering RNAs (siRNAs)", description: "Small interfering RNAs are short RNA molecules that can trigger RNA interference to suppress gene expression."},
  {name: "small regulatory RNA production", description: "Small regulatory RNA production refers to the generation of small RNAs, such as miRNAs, that regulate gene expression."},
  {name: "small RNA expression", description: "Small RNA expression refers to the production of short non-coding RNAs, such as miRNAs and piRNAs, which regulate gene expression."},
  {name: "Soma to germline inheritance of extrachromosomal genetic information", description: "A proposed model where genetic information from somatic cells can be transferred to and inherited via germ cells (sperm)."},
  {name: "Somatic and germ-line mosaicism", description: "Somatic and germ-line mosaicism refers to the presence of genetically distinct cell populations within an individual, arising from a mutation during early embryonic development."},
  {name: "Somatic copy number variant (CNV)", description: "Somatic copy number variant is a change in the number of copies of a specific genomic region that occurs in somatic cells."},
  {name: "Somatic deletion", description: "Somatic deletion is a type of structural variation where a segment of DNA is lost in somatic cells."},
  {name: "Somatic DNA alteration", description: "Somatic DNA alteration refers to changes in DNA nucleotide sequences that occur in somatic cells, distinct from the germline."},
  {name: "Somatic expression", description: "Somatic expression refers to the transcription of genes or transposable elements in somatic cells, as opposed to germline cells."},
  {name: "Somatic genome alteration", description: "Somatic genome alteration refers to changes in the DNA sequence of somatic cells, which can affect cell physiology and contribute to diseases like cancer."},
  {name: "Somatic genome mosaicism", description: "Somatic genome mosaicism refers to the presence of genetically distinct cell populations within an individual, which can be caused by somatic retrotransposition events."},
  {name: "somatic genome variation", description: "Somatic genome variation refers to genetic differences that arise in somatic cells during an organism's lifetime, distinct from the germline genome."},
  {name: "Somatic genomic mosaicism", description: "Somatic genomic mosaicism refers to the presence of genetically distinct cell populations within an individual, arising from post-zygotic mutations such as retrotransposition events."},
  {name: "somatic genomic variation", description: "Somatic genomic variation refers to genetic alterations that occur in somatic cells and are not inherited."},
  {name: "somatic insertion", description: "Somatic insertion refers to the acquisition of new transposon insertions in the genome of somatic cells, such as in cancer."},
  {name: "Somatic insertions", description: "Somatic insertions refer to the integration of transposable elements into the genome of somatic cells."},
  {name: "somatic instability", description: "Somatic instability refers to changes in repeat length that occur in somatic cells, distinct from the germline."},
  {name: "Somatic L1 insertion", description: "Somatic L1 insertion refers to the integration event of a LINE-1 element into the genome of a somatic cell."},
  {name: "Somatic L1 retrotransposition", description: "Somatic L1 retrotransposition is the process by which LINE-1 elements move within the genome of somatic cells through a 'copy-and-paste' mechanism."},
  {name: "somatic mobilization", description: "Somatic mobilization refers to the activation and movement of transposable elements in non-germline cells."},
  {name: "Somatic mosaicism", description: "Somatic mosaicism refers to the presence of genetically distinct cell populations within an individual, arising from post-zygotic mutations."},
  {name: "Somatic mutagenesis", description: "Somatic mutagenesis refers to the generation of mutations in somatic cells, which can be caused by LINE-1 retrotransposition."},
  {name: "somatic mutation", description: "Somatic mutations are genetic alterations that occur in non-germline cells and are not inherited by offspring."},
  {name: "somatic repression evasion", description: "Somatic repression evasion refers to the process by which a transposon escapes the silencing mechanisms active in somatic cells."},
  {name: "Somatic retroinsertion", description: "Somatic retroinsertion refers to the insertion of retrotransposon sequences into the genome of somatic cells, contributing to genomic mosaicism."},
  {name: "somatic retroposition", description: "Somatic retroposition is the process of retroelement insertion occurring in somatic cells, leading to somatic mosaicism."},
  {name: "somatic retrotransposition", description: "Somatic retrotransposition refers to retrotransposition events that occur in somatic cells, not inherited through the germline."},
  {name: "Somatic retrotransposon insertion", description: "Somatic retrotransposon insertion refers to the acquisition of new mobile element insertions in somatic cells, contributing to genetic variation."},
  {name: "somatic structural variation", description: "Somatic structural variation refers to large-scale genomic alterations (e.g., deletions, duplications, translocations) that occur in somatic cells."},
  {name: "Somatic SVA retrotransposition", description: "Somatic SVA retrotransposition refers to SVA insertion events occurring in somatic cells, potentially during different tissues or developmental stages."},
  {name: "somatic TE activity", description: "Somatic TE activity refers to the expression and mobilization of transposable elements in non-germline tissues."},
  {name: "Somatic TE insertion", description: "Somatic TE insertion refers to a transposable element insertion that occurs in somatic cells and is not inherited."},
  {name: "somatic TE mobilization", description: "Somatic TE mobilization refers to the movement or retrotransposition of transposable elements that occurs in somatic cells, potentially leading to genetic alterations."},
  {name: "Somatic transposition", description: "Somatic transposition refers to the movement of transposable elements within the genome of somatic cells, often observed in tumors."},
  {name: "source of de novo mutations", description: "A mechanism that generates new mutations in the genome."},
  {name: "source of intrapopulation variability", description: "A mechanism that contributes to genetic variation within a population."},
  {name: "Source-tracing", description: "Source-tracing is a strategy to identify the specific genomic source element responsible for a new insertion event."},
  {name: "Sp1-dependent gene expression", description: "Sp1-dependent gene expression refers to transcriptional activation driven by the host transcription factor Sp1."},
  {name: "Speciation", description: "Speciation is the evolutionary process by which populations evolve to become distinct species."},
  {name: "Species-specific changes in gene expression", description: "Alterations in gene expression patterns that are unique to a particular species, which can be associated with species-specific transposable element insertions."},
  {name: "Species-specific differential methylation", description: "Species-specific differential methylation refers to differences in DNA methylation patterns between species, often associated with sequence changes."},
  {name: "Species-specific domain boundary introduction", description: "The evolutionary process where L1 insertions create domain boundaries unique to a species."},
  {name: "species-specific gene expression", description: "Gene expression patterns that are unique to a particular species."},
  {name: "Species-specific regulatory phenotypes", description: "Regulatory characteristics, such as gene expression patterns, that are unique to a particular species lineage."},
  {name: "spermatogenesis", description: "Spermatogenesis is the process of sperm cell development."},
  {name: "spermiogenesis arrest", description: "Spermiogenesis arrest is a developmental block during the final stages of spermatogenesis, preventing the formation of mature spermatozoa."},
  {name: "spliceosome interaction", description: "Spliceosome interaction refers to the binding and recognition of splice sites by the spliceosome complex during pre-mRNA splicing."},
  {name: "splicing", description: "Splicing is the process of removing introns from pre-mRNA and joining exons together."},
  {name: "splicing aberrations", description: "Splicing aberrations refer to abnormalities in the process of RNA splicing, which can lead to non-functional or altered protein products."},
  {name: "Splicing alteration", description: "Splicing alteration is a change in the normal pattern of pre-mRNA splicing, which can lead to aberrant gene products."},
  {name: "Splicing disorder", description: "Splicing disorder refers to a disease state caused by abnormal RNA splicing, often due to mutations in splice sites or regulatory elements."},
  {name: "splicing modulation therapy", description: "Splicing modulation therapy involves the use of agents like antisense oligonucleotides to correct abnormal splicing events in genetic diseases."},
  {name: "splicing of L1Hs 5'UTR to gene sequences", description: "L1Hs 5' untranslated regions can be spliced to sequences of known genes or non-protein-coding sequences, forming chimeric transcripts."},
  {name: "Splicing regulation", description: "Splicing regulation refers to the control of the process by which introns are removed from pre-mRNA and exons are joined together."},
  {name: "Splicing suppression", description: "Splicing suppression refers to the cellular mechanisms that prevent the inclusion of transposable element sequences into mature mRNA transcripts."},
  {name: "Spontaneous insertion", description: "Spontaneous insertion refers to the de novo integration of a transposon into the genome, which can occur in germ cells, somatic tissues, and cancer cells."},
  {name: "SRP9/14 binding", description: "SRP9/14 binding refers to the interaction between the Alu RNA and the SRP9/14 protein heterodimer."},
  {name: "SRPK2/SRSF1/VEGFA165 axis activation", description: "The molecular mechanism involving the activation of serine/arginine protein kinase 2 (SRPK2), leading to the activation of serine/arginine splicing factor 1 (SRSF1), which subsequently increases the splicing and expression of the VEGF isoform A165 (VEGFA165)."},
  {name: "Stabilizing p120-catenin", description: "The process of increasing the stability and preventing the degradation of the p120-catenin protein."},
  {name: "stable cell line engineering", description: "Stable cell line engineering involves the integration of a transgene into the host genome to create a cell line that constitutively expresses the gene of interest."},
  {name: "Stable coexistence", description: "Stable coexistence describes a state where autonomous and nonautonomous retrotransposons can persist together in a genome over long periods."},
  {name: "stable expression", description: "Stable expression refers to the long-term, persistent expression of a gene or genetic component integrated into the host genome."},
  {name: "stable gene expression", description: "Stable gene expression refers to the long-term, heritable expression of a transgene integrated into the host genome."},
  {name: "Stable gene silencing", description: "Stable gene silencing refers to the long-term suppression of gene expression."},
  {name: "Stable genomic integration", description: "Stable genomic integration is the process by which a DNA sequence, such as a retrotransposed element, is permanently inserted into the host genome."},
  {name: "Stable integration", description: "Stable integration refers to the permanent insertion of a transgene into the host chromosome, allowing for long-term maintenance."},
  {name: "stable nonviral gene marking", description: "A method for introducing a genetic marker into cells without using viral vectors, allowing for long-term tracking of the cells."},
  {name: "Stable protein expression", description: "Stable protein expression refers to the sustained production of a protein in a cell line over multiple generations."},
  {name: "Stable transfection", description: "Stable transfection is a process that results in the long-term integration and expression of foreign genetic material into the host cell genome."},
  {name: "Stable transgene expression", description: "Stable transgene expression refers to the long-term, sustained expression of an introduced gene in a cell line or organism."},
  {name: "Staggered DNA double-strand break repair", description: "Staggered DNA double-strand break repair is a DNA repair pathway that may be involved in the integration of retrotransposons via alternative mechanisms."},
  {name: "Staggered nicking", description: "A mechanism involving two nicks at specific, non-random sequences in the target DNA to facilitate integration."},
  {name: "sterile inflammation", description: "Inflammation that occurs in the absence of pathogens, often associated with aging and cellular damage."},
  {name: "Stimulation of innate immunity", description: "Retrotransposon expression can stimulate cellular innate immune responses through endogenous nucleic acid patterns."},
  {name: "STING-mediated ORF1p degradation", description: "STING interacts with LINE-1 ORF1p, sorts it to lysosomes via the ERGIC and Golgi, leading to its degradation."},
  {name: "Strand asymmetry", description: "Strand asymmetry refers to the unequal distribution of transposable elements, such as LINE-1, between the two DNA strands of a genomic region."},
  {name: "Stress granule assembly", description: "Stress granule assembly is a cellular process where RNA-protein complexes aggregate in response to various stresses."},
  {name: "Stress granule formation", description: "Stress granule formation is the process of assembling dense cytoplasmic aggregations of proteins and RNAs containing stalled translation pre-initiation complexes when the cell is under stress."},
  {name: "Stress granule localization", description: "The process by which the LINE-1 ORF1 protein localizes to cytoplasmic stress granules."},
  {name: "stress granule pathway inhibition", description: "Stress granule pathway inhibition is a cellular mechanism that sequesters the LINE-1 RNA-protein complex, inhibiting its nuclear import and retrotransposition."},
  {name: "Stress response", description: "Stress response is a cellular process activated under various stress conditions to maintain homeostasis."},
  {name: "stress-dependent transition to a highly malignant growth phenotype", description: "A transition of cancer cells from a non-aggressive to a highly malignant growth phenotype induced by stress."},
  {name: "stress-induced expression", description: "Stress-induced expression refers to the increased transcription of genes or elements in response to cellular stress."},
  {name: "Stress-induced L1 reactivation", description: "Stress-induced L1 reactivation refers to the process where cellular stress leads to the increased activity of LINE-1 elements."},
  {name: "Stringent-type retrotransposition", description: "A type of LINE retrotransposition characterized by the recognition of the 3' tail of its own RNA by reverse transcriptase (RT)."},
  {name: "structural disorder", description: "Structural disorder refers to protein regions that lack a fixed three-dimensional structure under physiological conditions."},
  {name: "Structural element in genome", description: "LINE-1 elements can function as structural components within the genome."},
  {name: "structural genomic variations", description: "Structural genomic variations are alterations in the structure of chromosomes, which can be induced by transposable elements like Alu and SVA via LINE-1 machinery."},
  {name: "structural modification of endogenous genes", description: "Structural modification of endogenous genes refers to the potential alteration of gene structure, such as through insertions, over evolutionary time."},
  {name: "Structural rearrangement", description: "Structural rearrangement refers to changes in the structure of chromosomes, such as deletions, duplications, inversions, or translocations."},
  {name: "structural variant", description: "Structural variants are large-scale alterations in the genome, such as deletions, duplications, inversions, and translocations."},
  {name: "Structural variant formation", description: "Structural variant formation refers to the processes that generate large-scale genomic rearrangements such as deletions, duplications, insertions, and inversions."},
  {name: "Structural variant generation", description: "Structural variant generation refers to the creation of genomic rearrangements, such as insertions, deletions, or duplications."},
  {name: "Structural variation", description: "Structural variation refers to large-scale differences in the genomic architecture of individuals, such as deletions, duplications, and inversions."},
  {name: "Structural variation generation", description: "Structural variation generation is the process leading to genomic rearrangements such as insertions, deletions, and duplications."},
  {name: "Structure-dependent endonuclease activity", description: "Structure-dependent endonuclease activity refers to the enzymatic function of ORF2p that recognizes and cleaves DNA based on specific structural features, such as forked or flap structures."},
  {name: "Sub-cellular localization", description: "Sub-cellular localization is the specific location of a protein or other molecule within a cell."},
  {name: "Subcellular distribution", description: "The localization of RNA transcripts within specific compartments of the cell, such as the nucleus or cytoplasm."},
  {name: "subcellular localization of retrotransposition intermediates", description: "This refers to the detection of ORF1p, ORF2p, and L1 mRNA within specific compartments of the cell during the retrotransposition process."},
  {name: "Subcellular RNA localization", description: "The specific distribution and targeting of retrotransposon RNA to distinct compartments within the cell, such as cytoplasmic foci or nuclear aggregates."},
  {name: "subclinical inflammation", description: "Subclinical inflammation refers to a low-grade, chronic inflammatory state that does not produce overt clinical symptoms."},
  {name: "subfamily amplification", description: "Subfamily amplification refers to the expansion of a specific lineage of transposable elements within a genome over evolutionary time."},
  {name: "Substrate preference", description: "Substrate preference refers to the specificity or selectivity of a protein (e.g., LINE-1 ORF1p) for mobilizing one type of non-autonomous element over another."},
  {name: "Sumoylation", description: "Sumoylation is a post-translational modification that controls protein-protein interactions and subcellular localization."},
  {name: "Super-enhancer assembly", description: "Super-enhancer assembly is the formation of large clusters of enhancers that drive high-level expression of key genes."},
  {name: "superantigen activity", description: "Superantigen activity refers to the ability of certain molecules to non-specifically activate a large number of T-cells."},
  {name: "suppressing immune exhaustion", description: "Suppressing immune exhaustion involves preventing the state of T cell dysfunction that occurs during chronic antigen exposure."},
  {name: "suppressing the mobility of endogenous retrotransposons", description: "This is a function that maintains genomic stability by inhibiting the replicative transposition of elements like LINE-1."},
  {name: "Suppression of homologous recombination", description: "Suppression of homologous recombination is a process that prevents the exchange of genetic material between homologous chromosomes."},
  {name: "suppression of L1 retrotransposition", description: "This refers to the cellular processes that inhibit or repress the mobilization of LINE-1 elements to preserve genome integrity."},
  {name: "Suppression of primary cilia formation", description: "Suppression of primary cilia formation is the inhibition of the assembly of non-motile sensory organelles that project from the surface of most vertebrate cells."},
  {name: "suppression of transposable elements", description: "The process of inhibiting the activity or expression of transposable elements."},
  {name: "Suppressive mechanisms", description: "Suppressive mechanisms are cellular processes that generally inhibit LINE-1 retrotransposition."},
  {name: "Suppressor gene activation", description: "A process that increases the activity of genes that inhibit cancer development."},
  {name: "Sustained expression", description: "Sustained expression refers to the prolonged and stable production of a gene product, such as a prime-editor, within a cell."},
  {name: "SVA integration", description: "SVA integration refers to the insertion of SVA retrotransposons into new genomic locations, potentially causing structural variants."},
  {name: "SVA trans-mobilization", description: "SVA trans-mobilization is the process by which noncoding SVA elements are mobilized in trans by the protein machinery encoded by autonomous LINE-1 retrotransposons."},
  {name: "SVA-mediated 3' flanking sequence transduction", description: "SVA-mediated 3' flanking sequence transduction is the process by which SVA elements duplicate and mobilize 3' flanking genomic sequences during retrotransposition."},
  {name: "synapse formation", description: "Synapse formation is a biological process in which LINE-1 plays a role."},
  {name: "synapsis of transposon ends", description: "Synapsis of transposon ends is the pairing and physical association of two transposon ends within the transpososome complex."},
  {name: "Synaptic complex formation", description: "Synaptic complex formation is the process of assembling a protein-DNA complex that brings together transposon ends for catalysis."},
  {name: "Syncytin function", description: "Syncytin function refers to the role of syncytin proteins, encoded by certain HERVs, in placental development and cell fusion."},
  {name: "Syncytiotrophoblast formation", description: "Syncytiotrophoblast formation is the process of creating the outer layer of the placenta, essential for nutrient and gas exchange."},
  {name: "Syncytium formation", description: "The process of cell fusion to form a multinucleated structure, specifically in placental trophoblasts."},
  {name: "T cell activation", description: "T cell activation is the process by which T cells are stimulated to proliferate and differentiate into effector cells."},
  {name: "T cell engineering", description: "T cell engineering is the process of modifying T cells, often to express chimeric antigen receptors (CARs), for therapeutic purposes."},
  {name: "T cell migration", description: "T cell migration is the directed movement of T cells towards sites of inflammation or infection."},
  {name: "T-cell activity", description: "T-cell activity refers to the functions of T lymphocytes, which are central to adaptive immunity."},
  {name: "TAD boundary formation", description: "TAD (topologically associating domain) boundary formation refers to the establishment of genomic regions that restrict interactions between adjacent chromatin domains."},
  {name: "TAD hierarchy disruption", description: "TAD hierarchy disruption refers to the perturbation of the hierarchical organization of topologically associating domains (TADs) in the 3D genome architecture."},
  {name: "Tailless retropseudogene formation", description: "The formation of retropseudogenes that lack the characteristic oligo(A) tail, often resulting from LINE-1-mediated retrotransposition."},
  {name: "tandem insertion", description: "Tandem insertion refers to the insertion of multiple genetic elements in a sequential or adjacent manner."},
  {name: "target DNA cleavage", description: "Target DNA cleavage is the endonucleolytic cleavage of genomic DNA by ORF2p to create a nick for LINE-1 insertion."},
  {name: "target gene disruption", description: "The functional impairment of a gene caused by an insertion event, such as from a retrotransposon."},
  {name: "target locus deletion", description: "The deletion of genomic sequence at the site of transposon insertion."},
  {name: "Target site cleavage", description: "The process of cleaving the genomic DNA at the target site for L1 insertion."},
  {name: "Target site duplication (TSD)", description: "Target site duplication is a short, direct repeat of genomic DNA flanking a newly inserted transposable element, generated during the integration process."},
  {name: "Target site recognition and cleavage", description: "The process by which L1-Endonuclease specifically recognizes and cleaves the TA junction DNA sequence (5'-TTTT/AA-3') to initiate integration during retrotransposition."},
  {name: "Target site selection", description: "Target site selection refers to the process by which a transposon's endonuclease domain recognizes and cleaves specific DNA sequences for insertion."},
  {name: "Target-primed retrotransposition", description: "Target-primed retrotransposition is the replication mechanism of non-LTR retrotransposons, such as LINE-1, involving reverse transcription at the site of insertion."},
  {name: "Target-primed reverse transcription (TPRT)", description: "Target-site primed reverse transcription (TPRT) is the mechanism by which non-LTR retrotransposons like LINE-1 insert into chromosomal DNA."},
  {name: "target-site DNA nicking", description: "Target-site DNA nicking is the process where L1 ORF2p cleaves the longer strand of target DNA, generating a staggered break to initiate reverse transcription."},
  {name: "Target-site duplication (TSD) generation", description: "The creation of short direct repeats flanking a newly inserted transposon, resulting from staggered cuts at the target site."},
  {name: "Target-site preference", description: "Mammalian L1s show target preference for the sequence 5'-TTAAAA-3'."},
  {name: "Target-site primed reverse transcription", description: "Target site-primed reverse transcription is the mechanism by which L1 and its non-autonomous partners like Alu initiate reverse transcription at the genomic insertion site."},
  {name: "Targeted DNA cleavage", description: "Targeted DNA cleavage is a coordinated reaction involved in the retrotransposition pathway of NLRs."},
  {name: "Targeted DNA integration", description: "The process of integrating DNA into a specific genomic locus, which is needed for improved safety in gene delivery applications."},
  {name: "Targeted DNA methylation", description: "Targeted DNA methylation is an epigenetic modification technique that specifically adds methyl groups to cytosine bases in defined genomic regions."},
  {name: "Targeted gene addition", description: "Targeted gene addition is a method for inserting therapeutic genes into specific genomic locations."},
  {name: "Targeted insertion", description: "Targeted insertion refers to the process of directing a genetic element to integrate at a specific genomic sequence."},
  {name: "Targeted integration", description: "The directed insertion of DNA, such as retrotransposons, into specific genomic locations, influenced by factors beyond just endonuclease specificity."},
  {name: "Targeted mRNA decay via short imperfect base-pairing", description: "A post-transcriptional regulatory mechanism where RNA molecules with imperfect complementarity bind to target mRNAs, leading to their degradation."},
  {name: "Targeted transgene integration", description: "Targeted transgene integration is a genome engineering technique for inserting specific DNA sequences into precise genomic locations."},
  {name: "Targeted transposition", description: "Targeted transposition is the process of directing transposon integration to specific, user-defined genomic locations."},
  {name: "Targeting", description: "Targeting refers to the directed localization of a protein or complex to specific genomic sites."},
  {name: "Targeting gene-poor regions", description: "A strong preference for LINE-1 retrotransposition to insert into gene-poor regions of the genome, such as those on chromosome 13."},
  {name: "Targeting of Alu repeats by microRNAs", description: "A process where microRNAs bind to complementary sequences within Alu repeats integrated in mRNAs, potentially regulating gene expression."},
  {name: "Targeting of retrotransposon integration", description: "The process by which the integration of retrotransposons is directed to specific genomic regions."},
  {name: "TE activation", description: "TE activation refers to the increased expression or mobilization of transposable elements."},
  {name: "TE amplification", description: "The process by which transposable elements increase their copy number within a genome."},
  {name: "TE dysregulation", description: "TE dysregulation refers to the abnormal expression or activity of transposable elements."},
  {name: "TE exaptation", description: "TE exaptation refers to the process by which transposable elements are co-opted by the host genome for new functions."},
  {name: "TE expression", description: "TE expression refers to the transcription of transposable elements into RNA."},
  {name: "TE expression QTL (teQTL)", description: "TE expression QTL (teQTL) refers to genetic loci that influence the expression levels of transposable elements."},
  {name: "TE genotyping", description: "TE genotyping is the process of determining the allelic status of transposable element insertions in an individual's genome."},
  {name: "TE insertion", description: "TE insertion refers to the integration of a transposable element into a new genomic location."},
  {name: "TE insertion mutation", description: "TE insertion mutation refers to a mutation caused by the insertion of a transposable element into a genomic locus."},
  {name: "TE insertional activity", description: "TE insertional activity refers to the somatic insertion of transposable elements into new genomic locations."},
  {name: "TE insertions", description: "TE insertions refer to the integration of transposable element sequences into new genomic locations."},
  {name: "TE mobilization", description: "Transposable element mobilization is the process by which TEs move or copy themselves to new genomic locations."},
  {name: "TE nesting", description: "TE nesting refers to the insertion of transposable elements (TEs) into existing TEs in the genome."},
  {name: "TE proliferation", description: "TE proliferation refers to the replication and increase in copy number of transposable elements within a genome."},
  {name: "TE repression", description: "TE repression is the process of silencing transposable elements to prevent their activity and potential genomic damage."},
  {name: "TE silencing", description: "TE silencing refers to the molecular mechanisms that repress the expression and activity of transposable elements."},
  {name: "TE transcriptional activation", description: "Transposable element transcriptional activation refers to the increased expression of transposable elements."},
  {name: "TE transcriptional network co-expression regulation", description: "The coordinated regulation of transposable element expression networks, often involving transcription factors."},
  {name: "TE variant detection", description: "TE variant detection is the process of identifying the presence or absence of transposable element sequences in genomic data."},
  {name: "TE-derived promoter activity", description: "TE-derived promoter activity refers to the ability of transposable element sequences to initiate transcription of downstream genes."},
  {name: "TE-mediated damage", description: "TE-mediated damage refers to genomic damage caused by the activity of transposable elements."},
  {name: "TE-mediated deletion", description: "TE-mediated deletion is a structural variation event where the presence or activity of a transposable element leads to the removal of a genomic segment."},
  {name: "telomerase activation", description: "Telomerase activation is the process of activating the enzyme telomerase, which is critical for maintaining telomere length."},
  {name: "Telomere dysfunction", description: "Telomere dysfunction refers to the loss of protective function at chromosome ends, leading to genomic instability."},
  {name: "Telomere homeostasis", description: "Telomere homeostasis refers to the maintenance of proper telomere length and stability."},
  {name: "telomere maintenance", description: "Telomere maintenance is the process that preserves the length and integrity of telomeres, the protective ends of chromosomes."},
  {name: "telomere maintenance regulation", description: "Telomere maintenance regulation involves the processes that control the length and integrity of telomeres, the protective ends of chromosomes."},
  {name: "telomere maintenance via alternative lengthening of telomeres (ALT)", description: "A telomerase-independent mechanism used by some cancer cells to maintain telomere length."},
  {name: "telomere regulation", description: "Telomere regulation refers to the processes that control the length and structure of telomeres, the ends of chromosomes."},
  {name: "telomere stabilization", description: "The process of maintaining telomere structure and function to prevent genomic instability."},
  {name: "telomeric DNA damage", description: "Damage occurring specifically at telomeric DNA sequences."},
  {name: "telomeric integrity", description: "The maintenance of structural and functional stability at telomeres."},
  {name: "telomeric integrity support", description: "Telomeric integrity support refers to the role of L1-RNPs in maintaining the structure and function of telomeres, particularly in ALT-dependent cells."},
  {name: "telomeric repeat containing RNA (TERRA) binding", description: "TERRA binding refers to the interaction between L1-RNP and telomeric repeat-containing RNA, which is involved in telomere stabilization."},
  {name: "template choice mechanism", description: "A mechanism for the trans-mediated mobilization of non-L1 RNAs by the LINE-1 reverse transcriptase."},
  {name: "template RNA recognition", description: "Template RNA recognition is the sequence-specific binding of the polyadenosine tract in template RNA by distinct domains of the L1 ORF2p enzyme."},
  {name: "template switching", description: "Template switching is a mechanism where a polymerase jumps from one nucleic acid template to another during synthesis."},
  {name: "template switching during reverse transcription", description: "Template switching during reverse transcription is a mechanism where the reverse transcriptase switches between different RNA templates during cDNA synthesis, leading to the formation of chimeric sequences."},
  {name: "Template-jumping", description: "Template-jumping is a proposed mechanism by which the L1-encoded reverse transcriptase switches templates during reverse transcription, potentially leading to extra nucleotide additions."},
  {name: "template-switching mechanism", description: "A mechanism for the trans-mediated mobilization of non-L1 RNAs by the LINE-1 reverse transcriptase."},
  {name: "Templated Sequence Insertion Polymorphism (TSIP)", description: "TSIP is a form of polymorphism where a sequence templated from a distant genomic region is inserted into the genome."},
  {name: "Tethering mechanism", description: "Tethering mechanism is a process that directs integrating genetic elements into specific genomic regions, such as transcriptional start sites."},
  {name: "Tetraploidy", description: "Tetraploidy refers to the state of having four copies of a genomic segment or chromosome."},
  {name: "TF binding site contribution", description: "The process by which transposable elements provide functional binding sites for transcription factors."},
  {name: "TGF-β1 signaling pathway", description: "TGF-β1 signaling pathway is a canonical signaling pathway involved in various cellular processes."},
  {name: "TGF-β1/Smad pathway", description: "The TGF-β1/Smad pathway is a signaling cascade that can be involved in regulating gene expression and cellular processes."},
  {name: "TGFβ-signalling activation", description: "TGFβ-signalling activation is a key oncogenic pathway involved in cell growth, differentiation, and apoptosis, often dysregulated in cancer."},
  {name: "THE1B fusion transcript expression", description: "THE1B fusion transcript expression refers to the transcription of chimeric RNA molecules containing THE1B sequences."},
  {name: "Three-dimensional genome changes", description: "Alterations in the spatial organization and folding of chromatin within the nucleus."},
  {name: "thrombosis", description: "Thrombosis is the formation of a blood clot inside a blood vessel, obstructing the flow of blood."},
  {name: "TIR-DNA-binding", description: "TIR-DNA-binding is the activity of the Hsmar1 transposase domain within SETMAR to specifically recognize and bind to terminal inverted repeat (TIR) sequences."},
  {name: "TIR-specific DNA-binding activity", description: "TIR-specific DNA-binding activity is the ability to bind specifically to Terminal Inverted Repeat sequences of transposons."},
  {name: "Tissue adaptation", description: "Tissue adaptation is the process by which immune cells acquire specialized functions to reside and operate within specific organs."},
  {name: "Tissue-shared regulatory region formation", description: "The process by which specific genomic regions acquire regulatory activity (e.g., promoter or enhancer function) that is conserved across multiple tissues."},
  {name: "tissue-specific active chromatin", description: "Genomic regions with an open chromatin structure that are active in a specific tissue."},
  {name: "tissue-specific active regulatory region", description: "A regulatory genomic region, such as an enhancer, that is active in a specific tissue."},
  {name: "tissue-specific enhancer activity", description: "Tissue-specific enhancer activity refers to the ability of a genomic element to regulate gene expression in a specific tissue or cell type."},
  {name: "tissue-specific expression", description: "Tissue-specific expression refers to the pattern of gene expression that is restricted to particular tissues or cell types."},
  {name: "tissue-specific gene expression variation", description: "Differences in the expression level of a gene across different tissues."},
  {name: "Tissue-specific gene regulation", description: "The process by which gene expression is controlled in a manner specific to particular tissues or cell types."},
  {name: "Tissue-specific promoter activity", description: "Tissue-specific promoter activity refers to the initiation of gene transcription primarily in specific tissues or cell types."},
  {name: "Tissue-specific regulation", description: "Tissue-specific regulation refers to the modulation of gene expression that occurs in a particular tissue type."},
  {name: "Tissue-specific regulatory region formation", description: "The process by which specific genomic regions acquire regulatory activity (e.g., promoter or enhancer function) in a tissue-specific manner."},
  {name: "tissue-specific repressed chromatin", description: "Genomic regions with a closed chromatin structure that are repressed in a specific tissue."},
  {name: "Tissue-specific splicing", description: "Tissue-specific splicing refers to exons whose inclusion in the mature mRNA transcript varies depending on the tissue type."},
  {name: "tissue-specific targeting", description: "The process of directing a molecule or therapy specifically to a particular tissue type."},
  {name: "Tissue-specific transcription", description: "The activity of L1 ASP is tissue-specific, potentially expanding the expression pattern of adjacent host genes."},
  {name: "TNF-induced gene expression", description: "TNF-induced gene expression is the activation of specific genes in response to stimulation by the proinflammatory cytokine Tumor Necrosis Factor (TNF)."},
  {name: "totipotency establishment", description: "Totipotency establishment is the process by which blastomeres gain the ability to give rise to all cell types and a complete organism."},
  {name: "toxicity", description: "Toxicity in this context refers to cellular damage or death induced by the endonuclease activity of the LINE-1 ORF2 protein."},
  {name: "TP53-mediated TE regulation", description: "TP53-mediated TE regulation refers to the process by which the TP53 tumor suppressor protein directly or indirectly controls the expression of transposable elements."},
  {name: "trans complementation", description: "trans complementation refers to the mechanism where L1-encoded proteins can act in trans to promote retrotransposition of other RNAs."},
  {name: "trans mobilization of genomic DNA", description: "Trans mobilization of genomic DNA is an alternative mechanism for retrotransposon-mediated exon shuffling, where genomic DNA distant from L1 is mobilized."},
  {name: "trans retrotransposition", description: "Trans retrotransposition is the process where LINE-1 retrotransposes other RNAs (e.g., Alu, SVA, U6) to new genomic locations."},
  {name: "trans-mediated mobilization of non-L1 RNAs", description: "The process by which LINE-1-encoded proteins mobilize other cellular RNAs (e.g., Alu, SVA, U6 snRNA)."},
  {name: "Trans-mobilization", description: "Trans-mobilization is the process where autonomous retrotransposons (like LINE-1) mobilize non-autonomous elements (like SINEs and processed pseudogenes)."},
  {name: "Trans-regulation", description: "Trans-regulation refers to the regulation of gene expression by a genetic element located on a different chromosome."},
  {name: "trans-silencing of LTRs", description: "Trans-silencing of LTRs refers to the mechanism by which non-LTR retrotransposons regulate the activity of LTR retrotransposons."},
  {name: "trans-splicing", description: "Trans-splicing is a form of RNA processing where exons from two different primary RNA transcripts are joined together."},
  {name: "Transcript co-option", description: "L1-derived transcripts are co-opted as chimeric transcripts or regulatory RNAs."},
  {name: "Transcript generation", description: "L1s generate hundreds of developmentally regulated and cell type-specific transcripts."},
  {name: "Transcript half-life regulation", description: "Control of the stability or degradation rate of RNA transcripts, affecting their persistence in the cell."},
  {name: "Transcript incorporation", description: "The process by which transposable element-derived sequences become part of coding or noncoding RNA transcripts."},
  {name: "Transcript isoform usage", description: "Transcript isoform usage refers to the relative abundance or selection of different mRNA splice variants produced from a single gene."},
  {name: "Transcript splitting", description: "The process where a single gene transcript is divided into two separate transcripts due to the insertion of an L1 element."},
  {name: "transcript stability regulation", description: "Transcript stability regulation refers to the control of mRNA half-life and degradation."},
  {name: "Transcript steady-state level regulation", description: "Control of the abundance of RNA transcripts within the cell under equilibrium conditions."},
  {name: "Transcript structure modulation", description: "Alteration of the architecture or composition of RNA transcripts, which can affect their stability, localization, or function."},
  {name: "Transcription", description: "The process of synthesizing RNA from a DNA template."},
  {name: "transcription activation", description: "Transcription activation is the process of initiating and increasing the transcription of genetic sequences."},
  {name: "transcription activation in cancer", description: "Transcription activation in cancer refers to the process where transposable elements become actively transcribed in various cancer tissues."},
  {name: "Transcription by RNA polymerase III", description: "SINEs are transcribed by RNA polymerase III, generating noncoding RNA."},
  {name: "Transcription disruption", description: "Transcription disruption refers to the interference with normal gene transcription processes."},
  {name: "transcription driven from adjacent gene promoters", description: "L1Hs transcription can also be initiated from the promoters of neighboring cellular genes."},
  {name: "Transcription dysregulation", description: "Transcription dysregulation refers to the abnormal control of gene transcription, which can be caused by various mechanisms including retrotransposon insertions."},
  {name: "Transcription elongation", description: "Transcription elongation is the process of synthesizing RNA from a DNA template, which can be defective in native L1 elements due to high adenosine content."},
  {name: "transcription factor binding", description: "The process where transcription factors bind to specific DNA sequences to regulate gene expression."},
  {name: "transcription factor binding site", description: "A specific DNA sequence where a transcription factor binds to regulate gene expression."},
  {name: "Transcription factor binding site (TFBS) derivation", description: "The process by which repetitive DNA sequences, including transposable elements, serve as origins for functional transcription factor binding sites."},
  {name: "transcription factor binding site spreading", description: "The dissemination of specific DNA motifs recognized by transcription factors across the genome, often mediated by mobile genetic elements."},
  {name: "transcription factor-binding site creation", description: "The emergence of novel DNA sequences capable of binding specific transcription factors."},
  {name: "Transcription from core promoter", description: "The initiation of RNA synthesis from a gene's core promoter region."},
  {name: "Transcription from repetitive sequences", description: "The process of generating RNA transcripts from repetitive DNA sequences in the genome."},
  {name: "Transcription initiation", description: "Transcription initiation is the process of beginning RNA synthesis from a DNA template."},
  {name: "transcription initiation from internal promoter", description: "L1Hs transcription is initiated from its own internal promoter."},
  {name: "transcription of chimeric transcripts", description: "The L1 antisense promoter drives the production of chimeric transcripts, which are sense-oriented alternative genic transcripts."},
  {name: "Transcription of intergenic RNAs", description: "The process of synthesizing RNA molecules from intergenic regions of the genome."},
  {name: "transcription of transposable elements", description: "The process of transcribing transposable element DNA into RNA."},
  {name: "Transcription regulation", description: "Transcription regulation refers to the control of gene or element expression at the transcriptional level."},
  {name: "Transcription termination", description: "Transcription termination is the process of ending RNA synthesis at specific genomic sites."},
  {name: "Transcription-coupled DNA repair (TCR)", description: "Transcription-coupled DNA repair (TCR) is a DNA repair pathway that preferentially removes lesions from the transcribed strand of active genes."},
  {name: "Transcription-coupled nucleotide excision repair", description: "A sub-pathway of nucleotide excision repair that preferentially repairs lesions in the transcribed strand of active genes."},
  {name: "transcription-dependent de novo chromatin interactions", description: "The formation of new chromatin interactions that requires transcriptional activity."},
  {name: "transcriptional activation", description: "Transcriptional activation is the process of increasing the rate of gene transcription."},
  {name: "Transcriptional activity", description: "Transcriptional activity refers to the process of transcribing DNA into RNA, indicating gene or element expression."},
  {name: "Transcriptional activity of transposable elements", description: "The process of transcribing transposable element sequences into RNA, which is often linked to cancer development when epigenetic repression is lifted."},
  {name: "Transcriptional alteration", description: "Transcriptional alteration refers to changes in gene expression levels or patterns, including changes in splicing."},
  {name: "transcriptional control", description: "Transcriptional control is the regulation of gene or transposon expression at the level of transcription initiation, elongation, or termination."},
  {name: "Transcriptional control by external promoters", description: "Transcriptional control by external promoters is a mechanism where SVA source elements are regulated by a multitude of cellular promoters in germ cells."},
  {name: "Transcriptional control via LINE-1 ASP", description: "The regulation of gene expression by the LINE-1 antisense promoter (ASP)."},
  {name: "Transcriptional de-repression", description: "Transcriptional de-repression refers to the release of transcriptional silencing, often associated with epigenetic changes like DNA demethylation."},
  {name: "Transcriptional defect", description: "Transcriptional defect refers to an abnormality in the process of gene transcription, leading to reduced or aberrant mRNA production."},
  {name: "Transcriptional defense", description: "Transcriptional defense mechanisms suppress transposable element activity at the level of transcription."},
  {name: "transcriptional deregulation", description: "Transcriptional deregulation refers to the abnormal control of gene expression at the transcriptional level."},
  {name: "transcriptional disruption", description: "Transcriptional disruption refers to the perturbation of normal gene transcription processes."},
  {name: "Transcriptional downregulation", description: "A decrease in the level of transcription of specific genetic elements."},
  {name: "Transcriptional dysregulation", description: "Transcriptional dysregulation refers to the abnormal or disrupted control of gene expression at the transcriptional level."},
  {name: "transcriptional economy", description: "Transcriptional economy refers to the selective pressure for efficient transcription, favoring compact gene structures."},
  {name: "Transcriptional elongation defect", description: "A transcriptional elongation defect in LINE-1 open reading frames inhibits the robust expression of L1 RNA and proteins."},
  {name: "transcriptional elongation inhibition", description: "A mechanism where L1 sequences cause inadequate transcriptional elongation, leading to decreased RNA concentration."},
  {name: "Transcriptional enhancement", description: "Transcriptional enhancement is the process of increasing or promoting gene transcription."},
  {name: "Transcriptional enhancer activity", description: "The ability of a DNA sequence to increase the transcription of cis-linked genes."},
  {name: "transcriptional expression", description: "Transcriptional expression refers to the process of transcribing DNA into RNA."},
  {name: "Transcriptional flexibility", description: "L1 ASP-driven transcription may increase the transcriptional flexibility of several human genes."},
  {name: "Transcriptional gene silencing", description: "Transcriptional gene silencing is an epigenetic mechanism that represses gene expression at the transcriptional level."},
  {name: "Transcriptional inactivation", description: "Transcriptional inactivation refers to the silencing of gene or transposon expression."},
  {name: "Transcriptional induction", description: "Transcriptional induction is the process of increasing the rate of transcription of a specific genetic element."},
  {name: "Transcriptional inhibition in cis", description: "Transcriptional inhibition in cis refers to the silencing of gene expression by a regulatory element located on the same DNA molecule."},
  {name: "Transcriptional interference", description: "Transcriptional interference refers to the inadvertent transcriptional activity of retroelements that may affect the expression of neighboring genes."},
  {name: "transcriptional modulation", description: "Transcriptional modulation involves the alteration of gene expression levels through the regulation of transcription."},
  {name: "transcriptional network incorporation", description: "Transcriptional network incorporation is the process by which genomic elements become integrated into regulatory circuits controlling gene expression."},
  {name: "transcriptional network regulation", description: "Transcriptional network regulation refers to the control of gene expression patterns through complex interactions of transcription factors and regulatory elements."},
  {name: "transcriptional noise suppression", description: "Transcriptional noise suppression is the reduction of spurious or low-level background transcription."},
  {name: "Transcriptional program activation", description: "Transcriptional program activation refers to the induction of a specific set of genes by a transcription factor."},
  {name: "Transcriptional reactivation", description: "Transcriptional reactivation refers to the process where previously silenced genes or elements become transcriptionally active again."},
  {name: "Transcriptional regulation", description: "Transcriptional regulation is the control of gene expression at the level of transcription."},
  {name: "Transcriptional regulation of trophoblast syncytialization", description: "The process of controlling gene expression during the fusion of trophoblast cells to form multinucleated syncytiotrophoblasts."},
  {name: "Transcriptional regulation via DLX3", description: "The mechanism by which the transcription factor distal-less homeobox 3 (DLX3) interacts with a genomic site to regulate gene expression."},
  {name: "Transcriptional regulator binding site formation", description: "The process by which repeat sequences become functional elements, such as binding sites for transcriptional regulators."},
  {name: "Transcriptional repression", description: "Transcriptional repression is a process that decreases the rate of gene transcription, often involving histone modifications and heterochromatin formation."},
  {name: "Transcriptional reprogramming", description: "A global change in gene expression profiles."},
  {name: "transcriptional roadblock", description: "A transcriptional roadblock is a mechanism where an element impedes or slows down the transcription of a host gene."},
  {name: "Transcriptional silencing", description: "Transcriptional silencing refers to the repression of gene expression, which can be mediated by promoter methylation or other epigenetic mechanisms."},
  {name: "Transcriptional suppression", description: "Transcriptional suppression refers to the inhibition of gene or transposon expression at the transcriptional level."},
  {name: "Transcriptome alteration", description: "Transcriptome alteration refers to changes in the expression pattern of genes, which can be caused by nearby transposon insertions."},
  {name: "Transcriptome complexity", description: "L1-derived transcripts provide a layer of primate- and human-specific transcriptome complexity."},
  {name: "transcriptome imbalance", description: "An abnormal state of the transcriptome, characterized by unregulated expression of coding and non-coding RNAs, which can be caused by high RT activity in cancer cells."},
  {name: "Transcriptome influence", description: "Transcriptome influence refers to the effect of a genetic variant, such as a transposon insertion, on the complete set of RNA transcripts in a cell."},
  {name: "transcriptome plasticity", description: "Transcriptome plasticity refers to the ability of the transcriptome to change in response to various factors, including transposable element activity."},
  {name: "transcriptomic alterations", description: "Transcriptomic alterations refer to changes in the transcriptome, such as gene expression levels or RNA processing."},
  {name: "Transcriptomic changes", description: "Changes in the complete set of RNA transcripts produced by the genome in response to stimuli."},
  {name: "Transcriptomic regulation", description: "The regulation of gene expression programs, which can be affected by transposon activity."},
  {name: "Transfection", description: "Transfection is the process of deliberately introducing nucleic acids into eukaryotic cells, often using vectors or physical methods."},
  {name: "Transfer of non-L1 DNA", description: "A mechanism where LINE-1 retrotransposition transfers flanking non-L1 DNA sequences to new genomic locations."},
  {name: "Transgene excision", description: "Transgene excision is the process of removing an introduced gene from the genome, often leaving no residual sequence (scarless)."},
  {name: "Transgene expression", description: "Transgene expression is the process by which a gene that has been introduced into an organism is transcribed and translated to produce a functional protein."},
  {name: "Transgene reactivation", description: "The re-expression of residual reprogramming transgenes upon induction of cell differentiation."},
  {name: "Transgene removal", description: "Transgene removal is the process of excising exogenous genetic material after it has served its purpose in reprogramming."},
  {name: "transgene repression", description: "Transgene repression is the silencing of introduced or foreign genetic sequences."},
  {name: "transgenerational inheritance", description: "Transgenerational inheritance refers to the transmission of phenotypic traits across generations via non-genetic mechanisms."},
  {name: "Transgenesis", description: "Transgenesis is the introduction of foreign DNA into a genome, facilitated by transposon systems."},
  {name: "Transient hyperactivation", description: "Transient hyperactivation is a temporary, high-level increase in the activity of a genetic element."},
  {name: "transition into open chromatin", description: "A change in chromatin structure from a condensed, inactive state to a more accessible, active state."},
  {name: "Translation", description: "Translation is the cellular process of synthesizing proteins from messenger RNA (mRNA)."},
  {name: "Translation enhancement", description: "Translation enhancement is the process of increasing the efficiency of protein synthesis from an mRNA molecule."},
  {name: "translation initiation", description: "Translation initiation is the process by which ribosomes assemble on mRNA and begin protein synthesis."},
  {name: "Translation on free cytoplasmic ribosomes", description: "Protein synthesis occurring on ribosomes not associated with the endoplasmic reticulum, typically for soluble proteins."},
  {name: "Translation regulation", description: "Translation regulation controls the efficiency of protein synthesis from mRNA."},
  {name: "Translation reinitiation", description: "Translation reinitiation is a process where a ribosome that has terminated translation at one stop codon can initiate translation at a downstream start codon."},
  {name: "Translational regulation", description: "Translational regulation refers to the control of protein synthesis at the level of mRNA translation."},
  {name: "translational repression", description: "Translational repression is a mechanism that inhibits the process of protein synthesis from mRNA."},
  {name: "Translocation", description: "Translocation refers to the movement of a genomic segment from one location to another, which can involve transposons."},
  {name: "translocation breakpoint formation", description: "Translocation breakpoint formation is a type of genomic rearrangement where chromosome segments are exchanged."},
  {name: "translocations", description: "Translocations are a type of chromosomal rearrangement where segments of chromosomes are exchanged."},
  {name: "transposable element dysregulation", description: "Transposable element dysregulation refers to the abnormal expression or activity of transposable elements."},
  {name: "transposable element expression", description: "Transposable element expression refers to the transcription of transposable element sequences into RNA."},
  {name: "transposable element repression", description: "Transposable element repression is a biological process that silences the activity of transposable elements to maintain genomic stability."},
  {name: "transposable element transcription", description: "The process of transcribing transposable element sequences into RNA."},
  {name: "transposable elements reactivation", description: "Transposable elements reactivation refers to the process where normally silenced transposons become transcriptionally and/or transpositionally active."},
  {name: "Transposase activity", description: "Transposase activity refers to the enzymatic function that catalyzes the movement of transposable elements within the genome."},
  {name: "transposase binding to inverted-repeat sequences", description: "The specific interaction between a transposase protein and the inverted repeat sequences at the ends of a transposon."},
  {name: "Transposase functionality", description: "Transposase functionality refers to the enzymatic activity associated with transposable elements that can mediate their movement and potentially influence genomic stability."},
  {name: "Transposase gene splicing", description: "Transposase gene splicing is the process where the transposase gene of a transposon is spliced to a host cellular gene, potentially affecting its expression or function."},
  {name: "Transposase overproduction inhibition", description: "Transposase overproduction inhibition is a mechanism where high concentrations of transposase protein inhibit further transposition activity."},
  {name: "Transposase rodlet formation", description: "Transposase rodlet formation is the process by which transposase proteins assemble into filamentous structures, which is associated with the cessation of transposition activity."},
  {name: "transposition", description: "Transposition is the process by which transposable elements move within the genome."},
  {name: "Transposition activity", description: "Transposition activity refers to the ability of transposable elements to move and replicate within genomes over evolutionary time."},
  {name: "Transposition burst", description: "A transposition burst refers to a period of high activity and increased copy number of transposable elements in a genome."},
  {name: "Transposition into and fragmentation of other TEs", description: "The process where a transposable element inserts into and fragments another, older transposable element already present in the genome."},
  {name: "Transposition repression", description: "Transposition repression refers to the mechanisms that inhibit the movement or 'jumping' of transposable elements within the genome."},
  {name: "Transposition restriction", description: "Transposition restriction refers to the cellular mechanisms that suppress or inhibit the uncontrolled movement of transposable elements like LINE-1."},
  {name: "transpositional activity", description: "The ability of a transposable element to move or copy itself to new positions within a genome."},
  {name: "transposon cleavage", description: "The enzymatic process of cutting DNA at the ends of a transposon, initiating its excision or integration."},
  {name: "transposon control", description: "Transposon control refers to the molecular mechanisms that suppress the expression and mobility of transposable elements."},
  {name: "Transposon de-silencing", description: "Transposon de-silencing refers to the loss of repression, leading to increased transposon expression and potential activity."},
  {name: "transposon demethylation", description: "Transposon demethylation is the loss of DNA methylation specifically at transposable element sequences."},
  {name: "transposon derepression", description: "Transposon derepression refers to the loss of silencing mechanisms that normally keep transposable elements inactive."},
  {name: "Transposon dispersal", description: "Transposon dispersal is the process by which transposable elements spread to new genomic locations."},
  {name: "Transposon expression", description: "Transposon expression refers to the transcription and potential translation of transposable element sequences."},
  {name: "Transposon insertion", description: "Transposon insertion is the process by which transposons relocate and integrate into new genomic locations."},
  {name: "transposon insertion mapping", description: "A high-throughput technique for identifying and locating all transposon insertions present in a genomic sample."},
  {name: "Transposon insertion polymorphism", description: "Transposon insertion polymorphism refers to genetic variation in a population caused by the presence or absence of a transposon insertion at a specific genomic locus."},
  {name: "Transposon integration", description: "Transposon integration refers to the insertion of a transposon into the host genome."},
  {name: "transposon mobility", description: "Transposon mobility refers to the ability of transposable elements to move or transpose within the genome."},
  {name: "Transposon mutagenesis", description: "Transposon mutagenesis is a technique that uses transposable elements to create insertional mutations in the genome."},
  {name: "Transposon proliferation", description: "Transposon proliferation is an evolutionary mechanism that increases genome complexity."},
  {name: "Transposon regulation", description: "Transposon regulation encompasses the cellular mechanisms that control the activity and expression of transposable elements."},
  {name: "transposon removal", description: "Transposon removal refers to the excision of a transposon from the genome, often mediated by transposase."},
  {name: "transposon repression", description: "Transposon repression is the process of silencing transposable elements to maintain genomic stability."},
  {name: "Transposon silencing", description: "Transposon silencing is the process of repressing transposon activity and expression to maintain genomic stability."},
  {name: "Transposon suppression system", description: "A proposed system to explain why transposon-derived repeats seldom cause mutations in humans."},
  {name: "transposon-derived promoter activation", description: "Transposon-derived promoter activation refers to the process where promoter sequences originating from transposons become transcriptionally active."},
  {name: "Transposon-mediated gene delivery", description: "Transposon-mediated gene delivery is a technique that utilizes transposon systems to stably integrate genetic material into a host cell's genome."},
  {name: "Transposon-mediated gene transfer", description: "Transposon-mediated gene transfer is a method for introducing genetic material into cells using transposon systems as vectors."},
  {name: "Transposon-mediated indels", description: "Insertions and deletions in the genome that are mediated by the activity of transposable elements."},
  {name: "transposon-mediated mutagenesis", description: "Transposon-mediated mutagenesis is the process by which transposons cause mutations in the genome."},
  {name: "transpososome assembly", description: "Transpososome assembly is the process of forming a higher-order protein-DNA complex required for DNA transposition."},
  {name: "trigger p53 response", description: "The activation of the p53 tumor suppressor pathway in response to cellular stress or damage."},
  {name: "trigger type I interferon (IFN-1) response", description: "The activation of the innate immune system's type I interferon pathway, often in response to viral or endogenous nucleic acids."},
  {name: "TRIM41-mediated ORF2p ubiquitination and degradation", description: "This is a mechanism where the E3 ligase TRIM41 ubiquitinates the L1-encoded ORF2p protein, targeting it for proteasomal degradation."},
  {name: "TRIM5α-induced innate immune signaling", description: "TRIM5α acts as a pattern recognition receptor and induces innate immune signaling upon interaction with LINE-1 ribonucleoprotein complexes."},
  {name: "TRIM5α-mediated restriction of LINE-1", description: "The intrinsic immune factor TRIM5α senses and restricts LINE-1 retroelements by interacting with LINE-1 ribonucleoprotein complexes in the cytoplasm."},
  {name: "Trimerization", description: "Trimerization is the process of forming a complex consisting of three identical or similar subunits."},
  {name: "trophoblast differentiation", description: "Trophoblast differentiation is a critical process in placental development where cytotrophoblast cells fuse to form the syncytiotrophoblast."},
  {name: "truncated retrotransposition", description: "Truncated retrotransposition is a process where a retrotransposon inserts into the genome but the insertion is incomplete or shortened."},
  {name: "TTAA target-site specific insertion", description: "TTAA target-site specific insertion is a characteristic insertion mechanism of the piggyBac transposon."},
  {name: "tumor development", description: "Tumor development is the process by which normal cells transform and proliferate to form tumors."},
  {name: "Tumor driver", description: "Tumor driver refers to a mechanism or factor, such as aberrant expression of satellite RNA, that promotes the initiation or progression of cancer."},
  {name: "tumor evolution", description: "Tumor evolution refers to the process by which tumors acquire new mutations and adapt over time."},
  {name: "tumor immune microenvironment modulation", description: "Tumor immune microenvironment (TIME) modulation involves changes in the cellular and molecular composition of the immune landscape within a tumor."},
  {name: "tumor immunity", description: "Tumor immunity refers to the immune system's response to recognize and eliminate cancer cells."},
  {name: "tumor initiation", description: "Tumor initiation is the first step in tumorigenesis, involving the acquisition of initial driver mutations."},
  {name: "Tumor invasion", description: "Tumor invasion is the process by which cancer cells spread into surrounding tissues."},
  {name: "tumor progression", description: "Tumor progression is the process by which a tumor develops and becomes more aggressive."},
  {name: "Tumor suppression", description: "A biological process that inhibits the formation or progression of tumors."},
  {name: "tumor vascularisation", description: "Tumor vascularisation is the formation of new blood vessels that supply nutrients and oxygen to a tumor."},
  {name: "Tumor-exclusive expression", description: "Expression of L1 retrotransposons that is detected only in tumor cells and is absent in normal cells and tissues."},
  {name: "tumor-promoting functions", description: "Tumor-promoting functions are activities that support or enhance tumor growth and progression."},
  {name: "Tumor-specific antigen generation", description: "Tumor-specific antigen generation is the process of creating peptides that are uniquely or predominantly presented by tumor cells, which can be recognized by the immune system."},
  {name: "tumor-specific antigens", description: "Tumor-specific antigens are molecules expressed specifically by tumor cells that can be recognized by the immune system."},
  {name: "tumor-specific changes in repeat elements", description: "Tumor-specific changes in repeat elements refer to alterations in the sequence, structure, or representation of repetitive elements that are specific to cancer cells."},
  {name: "tumor-suppressive mechanisms", description: "Tumor-suppressive mechanisms are processes that inhibit tumor formation or progression."},
  {name: "Tumorigenesis", description: "Tumorigenesis is the process of tumor formation and development."},
  {name: "tumorigenic mechanisms", description: "Tumorigenic mechanisms are processes that contribute to the initiation and development of tumors."},
  {name: "Twin priming", description: "Twin-priming is a mechanism during L1 retrotransposition that can lead to the formation of inversion polymorphisms."},
  {name: "Twin-priming mechanism", description: "Twin-priming is a mechanism that can lead to rearrangements during L1 retrotransposition."},
  {name: "Type I interferon response", description: "Type I interferon induction is the process of stimulating the production of type I interferons, which are signaling proteins involved in immune responses."},
  {name: "U6 snRNA retrotransposition", description: "The retrotransposition of U6 small nuclear RNA, which requires both LINE-1 ORF1p and ORF2p."},
  {name: "U6/L1 chimeric RNA formation", description: "The process of forming chimeric RNAs consisting of a copy of U6 small nuclear RNA (snRNA) conjoined to a variably 5'-truncated L1 RNA."},
  {name: "U6/L1 pseudogene formation", description: "The generation of processed pseudogenes resulting from the retrotransposition of U6/L1 chimeric RNAs."},
  {name: "Ubiquitin-proteasome system", description: "The ubiquitin-proteasome system is a major pathway for the degradation of intracellular proteins."},
  {name: "ubiquitination", description: "Ubiquitination is a post-translational modification involving the attachment of ubiquitin to proteins, often targeting them for degradation."},
  {name: "uncontrolled TE activity", description: "Uncontrolled transposable element activity refers to aberrant or deregulated transposition events."},
  {name: "unconventional translation", description: "An atypical mechanism of protein synthesis, such as termination/reinitiation, used by some mRNAs."},
  {name: "Underrepresentation in epigenetic studies", description: "The systematic omission of ambiguous sequencing reads leads to an incomplete and biased assessment of the epigenetic state of recently active transposable elements."},
  {name: "undesired immune responses", description: "Undesired immune responses are potentially harmful immune reactions."},
  {name: "unequal crossover", description: "Unequal crossover is a type of genetic recombination that occurs between misaligned homologous chromosomes, leading to duplications or deletions."},
  {name: "Unequal recombination", description: "Unequal recombination is a type of genetic recombination that can occur between misaligned repetitive sequences, such as transposons, leading to genomic rearrangements."},
  {name: "Unequal sister chromatid exchange", description: "Unequal sister chromatid exchange is a recombination event between non-allelic sequences on sister chromatids, leading to duplications and deletions."},
  {name: "unwanted immune activation", description: "The inappropriate or excessive activation of the immune system, which can lead to inflammation and disease."},
  {name: "upregulated expression", description: "Upregulated expression refers to an increase in the level of gene or element transcription."},
  {name: "Upregulation", description: "Upregulation refers to an increase in the expression or activity of a biological element."},
  {name: "Uridylation", description: "Uridylation is a post-transcriptional RNA modification involving the addition of uridine residues to the 3' end of RNA molecules."},
  {name: "Utilization of DNA repair machinery", description: "Retrotransposons can co-opt cellular DNA repair enzymes to complete their replication cycle."},
  {name: "Variable number of tandem repeat (VNTR) region", description: "A region within a transposon characterized by tandemly repeated sequences that vary in copy number."},
  {name: "Variable transcription initiation", description: "The phenomenon where transcription initiation sites for L1 are not restricted to a single nucleotide but vary considerably in both downstream and upstream directions."},
  {name: "Vasculogenesis", description: "Vasculogenesis is the de novo formation of blood vessels from endothelial progenitor cells."},
  {name: "Vector removal", description: "Vector removal is the process of excising or eliminating the delivery vehicle (e.g., transposon vector) from the host genome after it has served its purpose."},
  {name: "Ventricular enlargement", description: "An increase in the size of the heart's ventricles."},
  {name: "Viral DNA integration", description: "Viral DNA integration is the process by which viral genetic material inserts into the host genome."},
  {name: "viral DNA replication", description: "Viral DNA replication is the process by which a virus copies its genetic material within a host cell."},
  {name: "Viral genome integration", description: "Viral genome integration refers to the insertion of viral DNA into the host genome."},
  {name: "viral mimicry", description: "Viral mimicry is a phenomenon where endogenous cellular components, such as repetitive elements, mimic viral patterns and trigger innate immune responses."},
  {name: "Viral particle production", description: "Viral particle production is the assembly and release of complete viral particles."},
  {name: "Viral protein production", description: "Viral protein production is the synthesis of proteins encoded by viral elements."},
  {name: "Viral RNA integration", description: "Viral RNA integration refers to the process by which viral RNA sequences are reverse-transcribed and inserted into the host genome."},
  {name: "Viral sequence integration", description: "Viral sequence integration refers to the incorporation of viral genetic material into the host genome."},
  {name: "Viral-host chimeric transcription", description: "Viral-host chimeric transcription refers to the expression of transcripts containing sequences from both integrated viral DNA and the host genome."},
  {name: "Virus-host genomic integration", description: "Virus-host genomic integration refers to the process where viral DNA is inserted into the host genome."},
  {name: "VNTR activity repression", description: "The inhibition of the activity of variable number tandem repeats (VNTRs) in a gene's 3' UTR."},
  {name: "VNTR expansion/contraction", description: "VNTR expansion/contraction is a microhomology-driven mechanism that mediates changes in the length of the VNTR domain at the DNA level."},
  {name: "X chromosome inactivation", description: "X chromosome inactivation is the process by which one of the two X chromosomes in female mammals is transcriptionally silenced to achieve dosage compensation."},
  {name: "X inactivation", description: "X inactivation is the process by which one of the two X chromosomes in female mammals is transcriptionally silenced to achieve dosage compensation."},
  {name: "YY1-driven transcription from LTR promoter", description: "YY1 transcription factor binds to the cryptic MER52A LTR promoter and drives transcription of lncMER52A in hepatocellular carcinoma."},
  {name: "YY1-mediated transcription regulation", description: "Transcription regulation involving the nuclear factor YY1, which can function in both RNA polymerase II and III systems."},
  {name: "ZAP-mediated inhibition of retrotransposition", description: "Zinc-finger antiviral protein (ZAP) inhibits the retrotransposition of LINE and Alu elements by reducing the accumulation of full-length L1 RNA and L1-encoded proteins."},
  {name: "zygotic genome activation", description: "Zygotic genome activation is the process during early development when the embryonic genome begins widespread transcription."},
  {name: "zygotic genome activation (ZGA)", description: "Zygotic genome activation is the process of transcriptional activation in the early embryo."}
] AS row
MERGE (n:Function {name: row.name})
SET n.description = row.description, n.source_group = "functions";

