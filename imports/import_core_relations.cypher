  {source: "SVA_F", predicate: "leads to", target: "Occipital horn syndrome", pmids: ["38960580"]},
  {source: "SVA_F", predicate: "leads to", target: "X-linked dystonia parkinsonism (XDP)", pmids: ["41278988"]}
] AS row
MATCH (s:TE {name: row.source})
MATCH (t:Disease {name: row.target})
MERGE (s)-[r:BIO_RELATION {predicate: row.predicate}]->(t)
SET r.pmids = row.pmids, r.source_group = 'core_relation';
