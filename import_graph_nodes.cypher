  {name: "Tf_I", description: "Tf_I是近一百万年来在小鼠基因组中扩增的年轻LINE-1亚家族之一。"},
  {name: "Tf_II", description: "Tf_II是近一百万年来在小鼠基因组中扩增的年轻LINE-1亚家族之一。"},
  {name: "Tf_III", description: "Tf_III是本研究分析的LINE-1亚家族之一。"},
  {name: "TRAS1", description: "TRAS1是家蚕中一种靶向端粒重复序列的LINE-1类转座子。"},
  {name: "zebrafish LINE-2", description: "斑马鱼基因组中的LINE-2转座子。"},
  {name: "ZfL2-1", description: "斑马鱼的一种LINE转座子。"},
  {name: "ZfL2-2", description: "斑马鱼基因组中的一种长散布核元件。"},
  {name: "Zorro3", description: "Zorro3是来自白色念珠菌的LINE-1同源物，被重新设计用于在酿酒酵母中进行研究。"},
  {name: "非自主L1逆转录转座事件", description: "一种不依赖自身编码蛋白，但利用其他LINE-1元件提供的反式作用因子完成的逆转录转座过程。"}
] AS row
MERGE (n:TE {name: row.name})
ON CREATE SET n.description = row.description, n.source_group = "transposons";

