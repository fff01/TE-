UNWIND [
  {name: "A-type subfamily", description: "A型亚家族是小鼠基因组中一个活跃的LINE-1亚家族。"},
  {name: "A_I", description: "A_I是近一百万年来在小鼠基因组中扩增的年轻LINE-1亚家族之一。"},
  {name: "A_II", description: "A_II是本研究分析的LINE-1亚家族之一。"},
  {name: "aL1", description: "活跃的LINE-1重复序列亚家族。"},
  {name: "Alu", description: "一种非自主逆转录转座子，依赖LINE-1的逆转录活性进行转座。"},
  {name: "baboon-specific L1s", description: "狒狒特异性的全长LINE-1逆转录转座子，其编码的蛋白质可能诱导Alu元件的转座。"},
