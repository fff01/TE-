UNWIND [
  {name: "acquired immunodeficiency syndrome (AIDS)", description: "获得性免疫缺陷综合征，由人类免疫缺陷病毒（HIV）感染引起的疾病。"},
  {name: "age-related macular degeneration", description: "年龄相关性黄斑变性，是一种导致中心视力丧失的视网膜疾病。"},
  {name: "ageing", description: "衰老是生物体随时间推移功能逐渐衰退的过程。"},
  {name: "Aicardi-Goutières syndrome", description: "Aicardi-Goutières综合征是一种遗传性自身免疫性疾病，与干扰素信号通路异常相关。"},
  {name: "Aicardi-Goutières syndrome (AGS)", description: "一种由宿主免疫不当激活导致的自身免疫性疾病，与TREX1和ADAR1等蛋白的基因突变有关。"},
  {name: "AIDS", description: "获得性免疫缺陷综合征，由人类免疫缺陷病毒（HIV）感染引起。"},
