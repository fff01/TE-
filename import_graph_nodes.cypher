  {name: "疾病", description: "疾病是泛指影响机体正常结构和功能的异常状态。"},
  {name: "癌", description: "摘要中提到的与L1甲基化改变相关的疾病类别，特别是癌。"},
  {name: "癌症", description: "人类癌症，一种以细胞不受控制地生长和分裂为特征的疾病。"},
  {name: "皮肤肿瘤", description: "由7,12-二甲基苯并[a]蒽和12-O-十四烷酰佛波醇-13-乙酸酯诱导的多阶段致癌模型。"},
  {name: "着色性干皮病", description: "着色性干皮病是一种由DNA修复基因缺陷导致的遗传性疾病，患者对紫外线极度敏感，皮肤癌风险显著增加。"},
  {name: "神经发育障碍", description: "一类在神经系统发育过程中出现异常的疾病，常影响大脑功能和行为。"},
  {name: "神经母细胞瘤", description: "神经母细胞瘤是一种起源于未分化神经母细胞的儿童期常见实体肿瘤。"},
  {name: "神经管缺陷", description: "一种由胚胎发育早期神经管闭合失败引起的先天性出生缺陷。"},
  {name: "神经精神疾病", description: "摘要中提及的一类与LINE-1活性改变相关的疾病。"},
  {name: "神经系统疾病", description: "神经系统疾病是影响中枢或周围神经系统结构和功能的疾病。"},
  {name: "神经退行性疾病", description: "摘要中提到的与衰老相关的疾病类别。"},
  {name: "神经遗传性疾病", description: "摘要中提及的，可能与体细胞镶嵌现象相关的神经系统疾病。"},
  {name: "神经遗传疾病", description: "摘要中提到体细胞突变越来越多地被认为是神经遗传疾病的一个原因。"},
  {name: "类风湿关节炎", description: "一种自身免疫性疾病，其特征是关节滑膜炎症和关节破坏。"},
  {name: "精神分裂症", description: "一种严重的精神障碍，影响思维、感觉和行为。"},
  {name: "精神疾病", description: "摘要中提及的一类精神障碍，包括双相情感障碍等。"},
  {name: "糖尿病", description: "糖尿病是一种以高血糖为特征的代谢性疾病。"},
  {name: "结直肠癌", description: "结直肠癌是一种常见的消化道恶性肿瘤。"},
  {name: "结肠炎", description: "结肠的炎症性疾病，在本研究中由葡聚糖硫酸钠诱导。"},
  {name: "结肠炎相关癌症", description: "在慢性结肠炎背景下发生的结直肠癌。"},
  {name: "结肠癌", description: "一种发生在结肠的恶性肿瘤。"},
  {name: "肌萎缩侧索硬化", description: "一种进行性神经退行性疾病，影响运动神经元。"},
  {name: "肝内胆管癌", description: "一种起源于肝内胆管上皮的恶性肿瘤，在本研究中与LINE-1的体细胞插入相关。"},
  {name: "肝硬化", description: "肝硬化是一种慢性进行性肝病。"},
  {name: "肝细胞癌", description: "一种原发性肝癌，是本研究涉及的癌症类型。"},
  {name: "肺癌", description: "发生在肺部的恶性肿瘤，LINE-1插入活动相关的表达特征对其生存期有较小影响。"},
  {name: "肺腺癌", description: "一种常见的肺癌亚型，本研究中特指具有特定进化轨迹的肺腺癌。"},
  {name: "肿瘤", description: "肿瘤是机体细胞异常增生所形成的占位性病变，可分为良性和恶性。"},
  {name: "肿瘤发生", description: "肿瘤发生是指正常细胞转变为肿瘤细胞并最终形成肿瘤的过程。"},
  {name: "肿瘤疾病", description: "摘要中提及的与L1逆转录转座相关的疾病类别。"},
  {name: "胃癌", description: "发生在胃部的恶性肿瘤，LINE-1插入活动相关的表达特征对其生存期有较小影响。"},
  {name: "胃肠道癌症", description: "发生在胃、结直肠和食道等消化道的恶性肿瘤。"},
  {name: "胎盘功能障碍", description: "胎盘结构或功能异常，影响胚胎发育。"},
  {name: "胚胎性肿瘤", description: "胚胎性肿瘤是一组起源于胚胎或原始神经上皮细胞的中枢神经系统恶性肿瘤。"},
  {name: "胰腺导管腺癌", description: "一种胰腺癌，是摘要中研究的疾病模型。"},
  {name: "胰腺癌", description: "一种发生在胰腺的恶性肿瘤，与LINE-1插入活动相关的表达特征与患者较差的总生存期相关。"},
  {name: "胰腺神经内分泌肿瘤", description: "一种发生在胰腺的神经内分泌肿瘤。"},
  {name: "脑发育的体细胞突变疾病", description: "摘要中提到的已知的脑发育相关的体细胞突变疾病，其分布模式与研究中发现的克隆模式相似。"},
  {name: "脑癌", description: "起源于脑组织的癌症。"},
  {name: "膀胱癌", description: "发生在膀胱的恶性肿瘤，是尿路上皮癌的主要类型。"},
  {name: "自发遗传病", description: "由有害的逆转录转座事件诱发的遗传性疾病。"},
  {name: "自身免疫性疾病", description: "免疫系统攻击自身组织的一类疾病。"},
  {name: "自身免疫疾病", description: "免疫系统错误攻击自身健康组织的疾病。"},
  {name: "自闭症", description: "一种神经发育障碍，其特征包括社交互动和沟通困难以及重复性行为。"},
  {name: "自闭症谱系障碍", description: "一种神经发育障碍，其特征是社会交往和沟通困难以及重复性行为。"},
  {name: "血友病A", description: "血友病A是一种由F8基因突变导致凝血因子VIII缺乏的遗传性出血疾病。"},
  {name: "血友病B", description: "血友病B是一种因凝血因子IX缺乏或功能异常导致的遗传性出血性疾病。"},
  {name: "血癌", description: "起源于血液或造血组织的癌症。"},
  {name: "衰老", description: "一种与年龄相关的生理功能逐渐衰退的过程。"},
  {name: "认知任务表现受损", description: "由甲基苯丙胺滥用引起的、由纹状体介导的多种认知任务表现下降。"},
  {name: "遗传不稳定性", description: "由ERCC1或XPF基因缺陷个体表现出的基因组不稳定状态。"},
  {name: "遗传性疾病", description: "摘要中提及的与逆转录转座相关的多种遗传性疾病。"},
  {name: "遗传疾病", description: "由基因突变或异常引起的疾病。"},
  {name: "遗传病", description: "由基因突变引起的疾病。"},
  {name: "非小细胞肺癌", description: "全球最常见的肺癌形式，具有侵袭性，当前诊断方法成本高、易出现假阳性，且常出现治疗耐药性。"},
  {name: "面肩肱型肌营养不良症", description: "面肩肱型肌营养不良症是一种由DUX4基因在骨骼肌中异常表达引起的遗传性肌肉疾病。"},
  {name: "额颞叶变性", description: "一组以额叶和颞叶进行性萎缩为特征的神经退行性疾病。"},
  {name: "食管癌", description: "发生在食管部位的恶性肿瘤。"},
  {name: "食管腺癌", description: "一种发生在食管腺体组织的恶性肿瘤。"},
  {name: "食管鳞状细胞癌", description: "摘要中研究的癌症类型，是食管癌中最常见的形式，通常诊断时已到晚期。"},
  {name: "骨髓增生异常综合征", description: "一种骨髓造血功能异常的克隆性疾病，可进展为急性髓系白血病。"},
  {name: "髓系恶性肿瘤", description: "泛指起源于髓系造血细胞的一类恶性肿瘤，包括骨髓增生异常综合征和急性髓系白血病等。"},
  {name: "髓系白血病", description: "本文研究的白血病类型，文中描述了LINE-1在其中具有肿瘤抑制功能。"},
  {name: "高级别卵巢浆液性癌", description: "一种卵巢癌的亚型，本研究中检测到体细胞LINE-1逆转录转座事件。"},
  {name: "高级别浆液性卵巢癌", description: "一种常见且侵袭性强的卵巢癌亚型。"},
  {name: "高级别胶质瘤", description: "高级别胶质瘤是一类恶性程度高、预后较差的中枢神经系统胶质瘤。"}
] AS row
MERGE (n:Disease {name: row.name})
ON CREATE SET n.description = row.description, n.source_group = "diseases";

// Import functions
UNWIND [
  {name: "3' poly(A)尾依赖性", description: "LINE-1转座子及其反式动员的RNA的3'端需要一个多聚腺苷酸尾，该结构对于其逆转录转座活性至关重要。"},
  {name: "3' UTR依赖的逆转录转座", description: "某些LINE-1亚型（严格型）进行逆转录转座所必需的机制。"},
  {name: "3' UTR茎环结构", description: "在LINE-1和Alu转座子3'非翻译区发现的高度保守的RNA二级结构，可能被LINE-1逆转录酶识别，对逆转录转座至关重要。"},
  {name: "3' 转导", description: "L1机制偶尔动员邻近的非重复序列的过程。"},
  {name: "3'-末端茎环结构", description: "位于RNA或DNA序列3'末端的二级结构，由互补碱基配对形成的茎部和未配对的环部组成。"},
  {name: "3'-转导", description: "LINE-1逆转录转座时，将其3'侧翼基因组序列一同转导到新插入位点的现象。"},
  {name: "3'侧翼序列转导", description: "LINE-1逆转录转座过程中，将其3'端侧翼的非L1 DNA序列一同转座到新基因组位置的现象。"},
  {name: "3'末端添加额外胞嘧啶", description: "人类LINE-1逆转录酶在合成cDNA第一链的3'末端时，会添加一个额外的胞嘧啶（C）残基。"},
  {name: "3'端多聚腺苷酸化", description: "在LINE-1元件的3'末端添加多聚腺苷酸尾的过程，是其完成逆转录转座的关键步骤。"},
  {name: "3'端转导", description: "LINE-1逆转录转座时，有时会携带其下游的宿主基因组序列一同插入新位点的现象。"},
  {name: "3'转导", description: "3'转导是L1逆转录转座事件中，将供体位点下游的基因组序列一同携带并插入新位点的现象。"},
  {name: "3´ transduction", description: "3´端转导，是LINE-1移动其侧翼非重复区域的一种机制，可用于识别源自特定活跃LINE-1的新插入事件。"},
  {name: "5' and 3' transduction", description: "5'和3'转导是逆转录转座子移动时，将侧翼基因组序列一同转移，从而重排基因组区域的过程。"},
  {name: "5' truncation", description: "指转座子插入序列在5'端发生截断的现象，在AluYa5和AluYb8插入中观察到。"},
  {name: "5' UTR启动子活性", description: "LINE-1转座子5'非翻译区具有驱动自身转录的启动子功能。"},
  {name: "5' UTR活性", description: "LINE-1的5'非翻译区在基因表达调控中的作用。"},
  {name: "5'-截短插入", description: "指新插入的LINE-1转座子序列在其5'端发生缺失，导致插入片段变短。"},
  {name: "5'-末端连接通路", description: "LINE逆转录转座过程中，其5'端与宿主染色体DNA连接的不同分子机制，包括退火通路和直接通路。"},
  {name: "5'和3'转导", description: "LINE-1逆转录转座过程中，有时会捕获并携带其上游或下游的宿主基因组序列一同插入新位点。"},
  {name: "5'截断", description: "LINE-1在插入基因组过程中，其5'端序列发生不完整整合的现象。"},
  {name: "5'端倒位", description: "LINE转座子整合后，其5'端序列相对于原始方向发生反转的现象。"},
  {name: "5'端反向插入", description: "LINE-1插入的一种结构类型，其5'端序列发生倒置。"},
  {name: "5'端截断", description: "LINE-1在逆转录转座过程中，其5'端序列偶尔发生不完整复制。"},
  {name: "5'端截短", description: "LINE-1插入过程中的一种现象，约95%的插入事件会移除其大部分5'端序列。"},
  {name: "5'端截短插入", description: "LINE-1插入的一种结构类型，其5'端序列发生缺失。"},
  {name: "5'端整合", description: "LINE逆转录转座过程中，其5'端DNA整合到宿主基因组的分子机制。"},
  {name: "5'端连接", description: "LINE转座子整合过程中，其5'端与宿主DNA断裂末端连接的方式。"},
  {name: "5'端额外核苷酸生成", description: "在LINE整合过程中，其5'端产生来源于侧翼序列的额外核苷酸的现象。"},
  {name: "5‘截短", description: "LINE-1插入事件中，新生拷贝的5‘端发生截断的现象。"},
  {name: "5‘端附着", description: "LINE-1插入过程中，新生拷贝的5‘端连接到染色体DNA的后续步骤。"},
  {name: "A-tail扩展", description: "在插入过程中，由LINE-1 ORF2蛋白滑动导致的Alu元件A-tail序列长度增加。"},
  {name: "aberrant expression", description: "异常表达，指基因或转座子在不适当的时间或位置以不适当的水平进行表达。"},
  {name: "activities of L1 si/piRNAs, mRNAs, ORF1 and ORF2 proteins", description: "L1 si/piRNAs、mRNAs、ORF1和ORF2蛋白的活性，这些分子活动参与疾病的发生发展。"},
  {name: "ADAR1介导的RNA编辑", description: "ADAR1酶将RNA中的腺苷脱氨基为肌苷（A-to-I编辑）的过程。"},
  {name: "ADAR1抑制LINE-1逆转录转座", description: "ADAR1蛋白通过一种不依赖于其RNA编辑活性的机制，抑制LINE-1的逆转录转座活性。"},
  {name: "adjacent genes expression", description: "LINE-1插入位点附近基因的表达水平，受LINE-1活动的影响。"},
  {name: "AhR核转位蛋白-1 (ARNT1) 介导的细胞机制", description: "一种由ARNT1蛋白参与的细胞信号通路，能够介导LINE-1的逆转录转座活性。"},
  {name: "ALKBH5抑制L1逆转录转座", description: "m6A去甲基化酶ALKBH5通过去除L1 RNA的m6A修饰，从而抑制L1的逆转录转座活性。"},
  {name: "allele-specific methylation", description: "等位基因特异性甲基化，指转座子在不同等位基因上表现出不同的甲基化状态。"},
  {name: "altered chromatin landscapes", description: "改变的染色质景观是指基因组中染色质结构和修饰状态的变化。"},
  {name: "altered retrotransposon expression", description: "逆转录转座子表达改变，指转座子转录水平或活性发生异常变化。"},
  {name: "altering gene activity", description: "逆转录转座子插入到基因中，改变该基因的活性或功能。"},
  {name: "Alu RNA隔离", description: "高分子量APOBEC3G复合物通过将Alu RNA隔离在细胞质中，使其无法进入细胞核接触LINE-1的逆转录酶机制，从而抑制其逆转录转座。"},
  {name: "Alu SINE 逆转录转座", description: "非自主的Alu SINE元件依赖LINE-1编码的蛋白（特别是ORF2p）进行扩增的过程。"},
  {name: "Alu/L1逆转录转座", description: "Alu和LINE-1转座子通过逆转录机制在基因组中移动的过程。"},
  {name: "Alu/SVA retrotransposition", description: "Alu/SVA逆转录转座是依赖LINE-1编码的蛋白机器（反式作用）完成的非自主逆转录转座过程。"},
  {name: "Alu转座", description: "非自主的Alu元件依赖LINE-1 ORF2蛋白进行传播的过程。"},
  {name: "Alu转座动员", description: "LINE-1的ORF2蛋白能够反式辅助非自主的Alu逆转录转座子进行移动的过程。"},
  {name: "Alu转录", description: "Alu元件在特定条件下（如应激）被激活并产生RNA的过程。"},
  {name: "Alu逆转录转座", description: "由LINE-1蛋白反式介导的Alu元件的移动过程。"},
  {name: "AMPK激活", description: "AMPK是一种主代谢调节因子，可由ROS、Ca2+水平升高或AMP/ATP比率增加等细胞应激信号激活。"},
  {name: "aneuploidy generation", description: "非整倍体生成是指细胞染色体数目异常的过程。"},
  {name: "angiogenesis", description: "血管生成，是从现有血管形成新血管的过程。"},
  {name: "APOBEC3C介导的L1限制", description: "APOBEC3C蛋白通过非脱氨酶依赖的机制抑制LINE-1的逆转录转座活性。"},
  {name: "APOBEC3F介导的GA→AA突变", description: "APOBEC3F等蛋白在逆转录元件基因组中诱导的特定G到A突变模式。"},
  {name: "APOBEC3G介导的GG→AG突变", description: "APOBEC3G蛋白在逆转录元件基因组中诱导的特定G到A突变模式。"},
  {name: "APOBEC3酶催化胞嘧啶脱氨", description: "APOBEC3家族酶在单链DNA底物上催化胞嘧啶脱氨基形成尿嘧啶的生化反应。"},
  {name: "apoptosis", description: "细胞凋亡，一种程序性细胞死亡过程。"},
  {name: "ASP hypomethylation", description: "反义启动子低甲基化，LINE-1反义启动子区域甲基化水平降低，导致其活性增强。"},
  {name: "ATM-MRN-SMC S期检查点通路", description: "ATM-MRN-SMC S期检查点通路是DNA双链断裂诱导的、在S期激活的DNA损伤应答通路。"},
  {name: "ATM-signaling pathway activation", description: "ATM信号通路激活，由DNA双链断裂触发，参与调控LINE-1逆转录转座。"},
  {name: "ATM蛋白水平降低", description: "ATM是一种关键的DNA损伤应答激酶，其蛋白稳态水平被β-HPV E6蛋白下调。"},
  {name: "bHLH/PAS转录因子依赖的逆转录转座", description: "一种由bHLH/PAS家族转录因子介导的LINE-1逆转录转座模式。"},
  {name: "brain-specific insertion", description: "脑特异性插入，指转座子插入事件特异性地发生在脑组织中。"},
  {name: "burden", description: "负荷/负担，指个体携带特定遗传元件（如高活性RC-L1）的数量或组合。"},
  {name: "cAMP反应元件结合蛋白激活", description: "一种转录因子激活过程，在本研究中被证明是甲基苯丙胺或可卡因诱导L1逆转录转座所依赖的关键机制。"},
  {name: "cDNA synthesis", description: "cDNA合成，指LINE-1 ORF2p在逆转录过程中启动并进行的互补DNA链合成。"},
  {name: "cDNA合成", description: "由LINE-1编码的ORF2p蛋白介导的，将LINE-1 RNA逆转录为DNA的过程。"},
  {name: "cell cycle arrest", description: "细胞周期阻滞，逆转录酶抑制剂诱导癌细胞停止分裂的过程。"},
  {name: "cell cycle progression", description: "细胞周期进程，本文中观察到异常的G2/M期积累。"},
  {name: "cell non-autonomous effects", description: "细胞非自主效应，指一个细胞的表型或命运受到邻近其他细胞影响的现象。"},
  {name: "cell proliferation and invasion", description: "细胞增殖和侵袭，是肿瘤细胞恶性表型的核心特征。"},
  {name: "cellular self-renewal", description: "细胞的自我更新能力，受LINE-1活动的影响。"},
  {name: "cGAS-STING pathway activation", description: "cGAS-STING通路激活，由LINE-1来源的胞质DNA触发，促进p21依赖性细胞周期阻滞和细胞介导的免疫反应。"},
  {name: "cGAS-STING通路", description: "由cGAS感知胞质DNA并合成cGAMP，进而激活STING蛋白，最终诱导I型干扰素等免疫反应的信号通路。"},
  {name: "cGAS-STING通路激活", description: "由细胞质DNA感知触发的信号通路，导致干扰素等促炎因子表达。"},
  {name: "cGAS/STING-mediated DNA sensing", description: "一种DNA感应通路，在本研究中被证明不是LINE-1触发免疫激活所必需的。"},
  {name: "chimeric gene formation", description: "嵌合基因形成，由LINE-1插入基因序列并影响其转录调控而产生的基因。"},
  {name: "chromatin topology remodeling", description: "染色质拓扑结构重塑，涉及基因组三维结构的改变。"},
  {name: "chromosomal breaks", description: "染色体断裂是指染色体DNA双链发生断裂。"},
  {name: "chromosomal rearrangements", description: "染色体重排是指染色体片段发生位置或方向改变的结构变异。"},
  {name: "cis preference", description: "顺式偏好，指特定L1编码的蛋白质优先作用于其自身编码的RNA，而非其他L1 RNA。"},
  {name: "clonal amplification", description: "克隆扩增，指携带特定插入突变的细胞群体在组织中增殖扩大的过程。"},
  {name: "competition with double-strand break repair", description: "与双链断裂修复竞争是指LINE-1的活性可能干扰或占用细胞修复DNA双链断裂的机制。"},
  {name: "copy number variation", description: "拷贝数变异，指基因组中特定DNA片段拷贝数增加或减少的结构变异。"},
  {name: "CpG methylation-mediated repression", description: "CpG甲基化介导的抑制是通过DNA甲基化来沉默转座子等重复元件表达的表观遗传机制。"},
  {name: "cytoplasmic cDNA synthesis", description: "细胞质cDNA合成，指在细胞质中独立于基因组整合位点发生的逆转录过程。"},
  {name: "cytoplasmic RNA granule formation", description: "细胞质RNA颗粒形成，指RNA结合蛋白（如ORF1p）与RNA在细胞质中组装成颗粒状结构。"},
  {name: "de novo L1 insertion", description: "新发LINE-1插入，指在个体发育过程中新产生的、非遗传自亲本的LINE-1插入事件。"},
  {name: "de novo L1 insertions", description: "新的LINE-1插入，指在神经元前体细胞中发生的LINE-1逆转录转座事件，导致基因组中产生新的插入位点。"},
  {name: "de novo LINE-1 insertion", description: "LINE-1的新插入事件，可能驱动肿瘤发生。"},
  {name: "de novo somatic retrotransposition", description: "体细胞新生逆转录转座，指在个体发育过程中，体细胞内发生的新的转座子插入事件。"},
  {name: "de novo突变", description: "新发生的基因突变，包括由转座子插入引起的缺失、重复和重排。"},
  {name: "decreased copy number", description: "拷贝数减少，指基因组中特定DNA序列（如转座子）的数量减少。"},
  {name: "deleterious L1 insertions", description: "有害的LINE-1插入，指可能导致基因功能丧失或改变的LINE-1插入事件。"},
  {name: "deletions", description: "缺失是指基因组中DNA片段的丢失。"},
  {name: "demethylation", description: "去甲基化，指DNA上CpG位点甲基化修饰的丢失，在癌症中与年轻LINE-1的活性相关。"},
  {name: "dGTP依赖的SAMHD1四聚体形成", description: "SAMHD1蛋白在dGTP结合诱导下形成同源四聚体的过程。"},
  {name: "Dicer介导的RNAi沉默", description: "Dicer介导的RNAi沉默是一种通过Dicer酶产生小干扰RNA来抑制基因组寄生虫（如逆转录转座子）活性的防御机制。"},
  {name: "DICER依赖性mRNA降解", description: "细胞通过DICER依赖性途径破坏LINE-1 mRNA来下调其蛋白表达。"},
  {name: "differentiation potential", description: "细胞分化为特定类型细胞的能力，受LINE-1活动的影响。"},
  {name: "disruption of genetic loci at insertion sites", description: "在插入位点破坏基因位点，指逆转录转座的LINE-1序列插入导致基因功能受损。"},
  {name: "DNA break", description: "DNA断裂，由L1编码的内切酶在整合过程中产生。"},
  {name: "DNA damage response", description: "DNA损伤应答，是细胞感知和修复DNA损伤的机制。"},
  {name: "DNA deamination-independent inhibition", description: "APOBEC3B和APOBEC3F通过不依赖DNA脱氨的机制抑制LINE-1逆转录转座。"},
  {name: "DNA deletions", description: "DNA缺失，指转座子活动过程中或活动后导致的基因组DNA片段丢失。"},
  {name: "DNA double strand breaks (DNA DSBs)", description: "DNA双链断裂是DNA两条链同时断裂的严重损伤，可由LINE-1逆转录转座等活动引发。"},
  {name: "DNA double-strand breaks", description: "DNA双链断裂，由LINE-1内切酶活性在插入位点诱导产生。"},
  {name: "DNA IR损伤和ATR介导的细胞反应", description: "细胞对电离辐射（IR）引起的DNA损伤并通过ATR激酶通路作出反应的过程。"},
  {name: "DNA strand breaks with incomplete retrotransposition", description: "伴随不完全逆转录转座的DNA链断裂，逆转录酶抑制剂可能通过此机制诱导细胞周期阻滞和免疫反应。"},
  {name: "DNA-directed polymerization", description: "DNA指导的聚合是ORF2p以DNA为模板合成DNA的能力。"},
  {name: "DNA低甲基化", description: "DNA低甲基化是指基因组DNA上CpG位点甲基化水平降低的现象，常与基因异常激活相关。"},
  {name: "DNA修复", description: "细胞识别和修复DNA损伤的机制，ERCC1/XPF异二聚体是参与此过程的核酸内切酶。"},
  {name: "DNA修复抑制", description: "重金属通过置换细胞蛋白中的Mg和Zn，抑制DNA修复蛋白或其他酶的活性。"},
  {name: "DNA修复机制", description: "DNA修复机制参与处理DNA损伤，可能影响L1的移动。"},
  {name: "DNA修复活性降低", description: "细胞修复DNA损伤的能力减弱，可能影响逆转录转座的下游事件。"},
  {name: "DNA修复蛋白募集", description: "DNA损伤信号通路激活后，DNA修复蛋白被招募到损伤位点的过程。"},
  {name: "DNA去甲基化", description: "TET酶通过氧化5-甲基胞嘧啶介导的DNA主动去甲基化过程。"},
  {name: "DNA双链断裂", description: "DNA分子中两条互补链同时发生断裂的损伤类型。"},
  {name: "DNA双链断裂修复", description: "细胞修复DNA双链断裂的生物学过程。"},
  {name: "DNA双链断裂形成", description: "DNA双链断裂是DNA损伤的一种严重形式，可由多种因素（包括转座子活动）引发。"},
  {name: "DNA弯曲", description: "L1内切酶与DNA结合后诱导DNA发生弯曲，导致DNA小沟变宽，从而将可切割的磷酸二酯键置于催化位点。"},
  {name: "DNA损伤", description: "DNA损伤是指DNA分子结构的改变，逆转录转座过程可能促进DNA损伤。"},
  {name: "DNA损伤信号通路激活", description: "由LINE-1插入诱导的DNA双链断裂所触发的细胞反应。"},
  {name: "DNA损伤修复", description: "摘要中提及，MILs偏好位于具有此关键功能的长基因中。"},
  {name: "DNA损伤反应", description: "细胞对DNA损伤的识别和修复过程，是L1-SIRT6相互作用网络富集的通路之一。"},
  {name: "DNA损伤应答", description: "DNA损伤应答是细胞感知和修复DNA损伤的一系列信号通路。"},
  {name: "DNA甲基化", description: "一种调控基因表达的表观遗传机制，在摘要中主要调控LINE-1的活性。"},
  {name: "DNA甲基化介导的启动子抑制", description: "DNA甲基化是介导LINE-1启动子沉默和抑制其活性的主要表观遗传机制。"},
  {name: "DNA甲基化抑制", description: "通过DNA甲基化修饰来抑制LINE-1等转座子的活性。"},
  {name: "DNA甲基化改变", description: "在精神疾病患者前额叶皮层中发现的L1启动子区域的DNA甲基化水平差异。"},
  {name: "DNA甲基化缺失", description: "DNA分子上甲基基团的丢失，通常导致基因或转座子表观遗传抑制的解除。"},
  {name: "DNA第二链切口", description: "在第一链逆转录过程中，DNA第二链被切割的现象。"},
  {name: "DNA结合活性", description: "当RNA被ORF1p过饱和时，L1 RNP凝聚物获得结合DNA的能力。"},
  {name: "DNA编辑", description: "由AID/APOBEC蛋白介导的DNA序列改变，如G到A突变。"},
  {name: "DNA羟甲基化", description: "一种DNA修饰，与DNA甲基化一同被用于鉴定表观遗传活跃的L1。"},
  {name: "DNA聚合", description: "LINE-1逆转录酶在体外以其自身模板催化DNA依赖或RNA依赖的DNA合成。"},
  {name: "DNA脱氨基", description: "APOBEC3蛋白家族成员通过将胞嘧啶脱氨基为尿嘧啶，从而编辑DNA或RNA的机制。"},
  {name: "DNA识别", description: "L1内切酶通过识别DNA的物理结构特征（如TpA连接处的特殊构象）来结合底物。"},
  {name: "DNA转导", description: "LINE-1逆转录转座过程中，其下游的独特DNA片段被异常地作为转座事件的一部分而移动的机制。"},
  {name: "DNA靶向与切割", description: "LINE-1的ORF2p蛋白识别并切割特定DNA位点的过程。"},
  {name: "dNTPase活性", description: "SAMHD1蛋白水解脱氧核苷三磷酸（dNTP）的酶活性。"},
  {name: "double-strand break repair", description: "双链断裂修复，是细胞修复DNA双链断裂的机制。"},
  {name: "downregulation", description: "表达下调，指基因或转座子表达水平异常降低。"},
  {name: "downregulation of AMPKalpha", description: "AMPKα水平下调，AMPK是细胞能量稳态和应激反应的关键调节因子。"},
  {name: "downregulation of mTORC1 activity", description: "mTORC1活性下调，mTORC1是调控细胞生长、增殖和存活的关键信号复合物。"},
  {name: "dysfunctional metabolism", description: "代谢功能障碍，指细胞能量代谢等代谢过程出现异常。"},
  {name: "dysregulation of cell energy metabolism and cytokine/chemotaxin transcription", description: "细胞能量代谢和细胞因子/趋化因子转录失调，是肿瘤发生发展中的重要分子事件。"},
  {name: "dysregulation of retrotransposon activity", description: "逆转录转座子活性的失调。"},
  {name: "eIF2α磷酸化", description: "真核翻译起始因子2α亚基的磷酸化，是细胞应对压力、抑制全局蛋白质翻译的关键信号。"},
  {name: "eIF3结合", description: "真核起始因子3（eIF3）结合到L1 RNA的5' UTR m6A簇上。"},
  {name: "eIF4A/eIF4G相互作用减弱", description: "翻译起始复合物关键组分之间相互作用的减少，是翻译抑制的表现之一。"},
  {name: "endonuclease activity", description: "核酸内切酶活性是ORF2p切割靶DNA以启动逆转录转座的能力。"},
  {name: "endonuclease independent mechanisms", description: "不依赖核酸内切酶的机制，是大多数L1脑插入事件中编码的核酸内切酶非依赖性的整合机制。"},
  {name: "endonuclease-independent retrotransposition", description: "内切核酸酶非依赖性逆转录转座是LINE-1不依赖其内切核酸酶活性，而利用其他DNA断裂（如复制叉）进行整合的转座方式。"},
  {name: "endothelial cell migration", description: "内皮细胞迁移，是血管内皮细胞移动的过程，在血管生成中起关键作用。"},
  {name: "endothelial cell proliferation", description: "内皮细胞增殖，是血管内皮细胞分裂和数量增加的过程。"},
  {name: "EN非依赖性逆转录转座", description: "LINE-1转座子不依赖其自身核酸内切酶切割，而是利用基因组DNA损伤、功能失调的端粒或停滞的复制叉等位点产生的3'-羟基末端来启动逆转录的转座机制。"},
  {name: "epigenetic changes", description: "表观遗传学改变，如DNA甲基化水平的变化，可影响基因表达。"},
  {name: "epigenetic drift", description: "表观遗传漂变是指随着年龄增长，表观遗传模式（如DNA甲基化）发生系统性改变的过程。"},
  {name: "epigenetic on/off", description: "表观遗传调控，决定源元件（如L1）是否处于活跃状态。"},
  {name: "epigenetic regulation (DNA methylation)", description: "表观遗传调控（DNA甲基化），宿主防御机制之一，用于抑制LINE-1活性。"},
  {name: "epigenetic regulation of gene expression", description: "表观遗传调控是指通过非DNA序列改变（如DNA甲基化、组蛋白修饰）来影响基因表达的过程。"},
  {name: "ERK激活", description: "细胞外信号调节激酶信号通路的活化过程。"},
  {name: "ESCRT相互作用", description: "LINE-1通过其晚期结构域基序与ESCRT（运输所需的内体分选复合体）膜出芽复合体发生相互作用。"},
  {name: "exon definition", description: "外显子定义，是一种传统的分子机制，可用于解释逆转录转座子引起的许多诱变效应。"},
  {name: "exon-skipping", description: "外显子跳跃是一种剪接异常，导致特定外显子从成熟mRNA中被排除。"},
  {name: "exonization using cryptic splice sites", description: "利用隐蔽剪接位点进行外显子化，指逆转录转座子序列被识别为新的外显子并入成熟mRNA的过程。"},
  {name: "expression of angiogenic factors", description: "血管生成因子表达，是编码血管生成相关蛋白（如VEGF、Tie-2）的基因被转录和翻译的过程。"},
  {name: "FOXR2激活", description: "FOXR2激活是指FOXR2基因通过多种机制（如启动子捐赠、增强子劫持、替代启动子激活或转座子插入）导致其异常表达。"},
  {name: "G-四链体结构形成", description: "鸟嘌呤富集序列通过氢键作用形成的非典型核酸二级结构。"},
  {name: "G-四链体结构调控", description: "位于3' UTR的G-四链体结构可以调节LINE-1的逆转录转座活性。"},
  {name: "G0/G1 cell cycle arrest", description: "G0/G1期细胞周期阻滞，是细胞周期在G0或G1期停滞的过程。"},
  {name: "gene disruption", description: "基因破坏，指转座子插入导致基因功能受损或丧失的过程。"},
  {name: "gene expression alteration", description: "基因表达改变是指转座子插入影响基因转录水平的过程。"},
  {name: "generating antisense and/or regulatory noncoding RNAs", description: "产生反义和/或调控性非编码RNA，是逆转录转座子影响基因表达的一种方式。"},
  {name: "generation of neural diversity", description: "在发育中或成年神经发生过程中，逆转录转座为神经多样性产生提供了环境。"},
  {name: "genetic heterogeneity", description: "遗传异质性，指同一疾病可由不同基因的突变引起，或同一基因的不同突变导致不同表型。"},
  {name: "genetic variation", description: "L1活动在个体间和个体内产生的遗传变异。"},
  {name: "genome expansion", description: "基因组扩增，由转座子插入导致的基因组大小增加。"},
  {name: "genome rearrangement", description: "基因组重排，指基因组结构发生大规模改变的事件，如易位、缺失、倒位等。"},
  {name: "genome stability maintenance", description: "基因组稳定性维持是指细胞通过多种机制防止DNA损伤和突变，以保持遗传信息完整性的过程。"},
  {name: "genomic alterations", description: "基因组改变，如插入和缺失，可能由L1逆转录转座活动诱导。"},
  {name: "genomic instability", description: "基因组结构或序列的异常改变，LINE-1的异常活动可导致此现象。"},
  {name: "genomic integrity erosion", description: "基因组完整性侵蚀是指LINE-1作为'内源性时钟'，通过其活性缓慢破坏基因组稳定性的过程。"},
  {name: "germline retrotransposition event", description: "种系逆转录转座事件，指发生在生殖细胞中并可遗传给后代的转座子插入。"},
  {name: "germline structural variation", description: "种系结构变异是指发生在生殖细胞中并可遗传给后代的基因组结构改变。"},
  {name: "germline variation", description: "种系变异，指存在于生殖细胞中并可遗传给后代的遗传变异。"},
  {name: "G到A超突变", description: "由AID/APOBEC蛋白的胞苷脱氨酶活性引起的DNA编辑，是限制逆转录病毒和逆转录转座子的标志。"},
  {name: "H3K18去乙酰化", description: "由SIRT7介导的组蛋白H3第18位赖氨酸残基的去乙酰化修饰，通常与基因沉默相关。"},
  {name: "H3K9me3 deposition", description: "H3K9三甲基化沉积，一种与基因沉默相关的组蛋白修饰。"},
  {name: "H3K9me3去甲基化", description: "由KDM4A/C组蛋白去甲基化酶介导的组蛋白修饰过程，导致H3K9me3标记的丢失。"},
  {name: "hA3G寡聚化", description: "人类APOBEC3G蛋白通过其N端氨基酸形成寡聚体，是其抑制逆转录转座活性的关键机制。"},
  {name: "Hallmark Myc靶标V1", description: "与肿瘤侵袭性评分相关的Myc癌基因靶标通路。"},
  {name: "harmful mutagenesis", description: "有害的诱变，指不受控制的逆转录转座可能突破保护机制，导致有害的基因突变。"},
  {name: "HDM2/TP53/RB调控轴失调", description: "涉及HDM2、TP53和RB蛋白的关键肿瘤抑制信号通路发生功能紊乱。"},
  {name: "heritable insertion", description: "可遗传插入，指转座子插入发生在生殖细胞中，可传递给后代。"},
  {name: "heritable retrotransposition", description: "可遗传的逆转录转座，指LINE-1在生殖系或早期胚胎中发生的新插入事件，能够传递给后代。"},
  {name: "hnRNPA1促进L1转座", description: "异质核核糖核蛋白A1是LINE-1逆转录转座所需的关键细胞辅助因子，其表达增强会促进L1的移动。"},
  {name: "homologous recombination", description: "同源重组，是一种高保真的DNA双链断裂修复机制。"},
  {name: "host defense factor restriction", description: "宿主防御因子限制，指APOBEC3、MOV10、SAMHD1等因子抑制LINE-1移动性的过程。"},
  {name: "host gene downregulation", description: "宿主基因表达水平降低的过程。"},
  {name: "hyperactive retrotransposition", description: "过度活跃的逆转录转座，指L1转座子以异常高的频率和效率进行转座。"},
  {name: "hypomethylation", description: "低甲基化，指DNA甲基化水平降低，可能导致基因或转座子活性增加。"},
  {name: "IFN-β产生", description: "I型干扰素β的产生，是先天免疫反应的关键环节。"},
  {name: "immune modulation", description: "免疫调节，指对免疫系统功能进行调控的过程。"},
  {name: "impact neuronal transcriptional expression", description: "影响神经元转录表达，指新的LINE-1插入能够改变神经元的基因表达模式。"},
  {name: "in vitro retrotransposition activity", description: "在实验室条件下测量到的LINE-1转座能力。"},
  {name: "in vivo fitness", description: "LINE-1在生物体内（如人类基因组中）的适应性和复制能力。"},
  {name: "increase in apoptosis", description: "细胞凋亡增加，一种程序性细胞死亡过程。"},
  {name: "increased copy number", description: "拷贝数增加，指基因组中特定DNA序列（如转座子）的数量增多。"},
  {name: "inducing alternative splicing via exon skipping", description: "通过外显子跳跃诱导可变剪接，是逆转录转座子干扰基因表达的机制之一。"},
  {name: "innate immune response", description: "先天免疫反应，是机体抵御病原体入侵的第一道防线。"},
  {name: "innate immune signaling activation", description: "先天免疫信号激活指RNA:DNA杂交体通过cGAS/STING通路触发干扰素产生的过程。"},
  {name: "innate immune system activation", description: "由LINE-1逆转录转座过程触发的先天性免疫系统反应。"},
  {name: "insertion", description: "插入，指转座子整合到基因组新位置的过程，可能导致基因功能破坏。"},
  {name: "insertion allele frequency", description: "插入等位基因频率，用于衡量特定转座子插入在群体中的存在与否及其频率。"},
  {name: "insertion into exons and introns", description: "插入外显子和内含子，指逆转录转座子直接插入基因的编码区或非编码区，可能导致不同类型的遗传病。"},
  {name: "insertion into synapse- and schizophrenia-related genes", description: "插入突触和精神分裂症相关基因，指转座子优先插入与突触功能和疾病相关的基因区域。"},
  {name: "insertion mutations", description: "插入突变是指转座子插入基因组导致基因序列改变的过程。"},
  {name: "insertion polymorphism", description: "插入多态性，指特定DNA序列（如RC-L1）在群体中是否存在或位置不同的遗传变异。"},
  {name: "insertional mutagenesis", description: "插入突变，指转座子插入基因组导致基因功能破坏的过程。"},
  {name: "insertional mutation", description: "插入突变，由转座子插入基因组导致。"},
  {name: "integration into cellular DNA", description: "整合到细胞DNA中，是LINE-1逆转录转座的最终步骤，导致新插入事件。"},
  {name: "integration into replicating DNA", description: "整合到复制DNA中是LINE-1转座子偏好于在DNA复制过程中进行整合的现象。"},
  {name: "integration site polymorphism", description: "整合位点多态性，转座子插入位置不同导致的遗传变异。"},
  {name: "interchromosomal translocation", description: "染色体间易位，在本研究中首次被描述为由异位L1逆转录转座在神经祖细胞中触发。"},
  {name: "interferon signaling activation", description: "干扰素信号激活是细胞在感知病毒或转座子等核酸时触发的先天免疫反应。"},
  {name: "interferon system activation", description: "干扰素系统激活是细胞对病原体或异常核酸（如RTE衍生的cDNA中间体）的免疫反应。"},
  {name: "intragenic insertion", description: "基因内插入，指转座子插入到基因编码区内部。"},
  {name: "intragenic L1 insertion", description: "基因内L1插入，指LINE-1转座子插入到基因编码区或内含子区域。"},
  {name: "I型干扰素反应", description: "由cGAS-STING通路介导的先天性免疫反应，通常由胞质DNA（如逆转录转座产生的DNA）激活。"},
  {name: "I型干扰素诱导", description: "由LINE-1 RNA介导的免疫反应，导致IFN-α等I型干扰素的表达。"},
  {name: "KRAB/KAP1诱导的转录抑制", description: "由KRAB锌指蛋白及其辅因子KAP1介导的转录抑制机制。"},
  {name: "L1 5' UTR m6A簇", description: "位于L1 5'非翻译区的m6A修饰簇，作为真核起始因子3（eIF3）的结合位点。"},
  {name: "L1 5'UTR活性", description: "L1 5'UTR活性是指LINE-1转座子5'非翻译区启动转录的能力，调控其表达水平。"},
  {name: "L1 cDNA生成", description: "LINE-1逆转录转座过程中，由其RNA模板逆转录产生的互补DNA。"},
  {name: "L1 endonuclease activity", description: "L1内切核酸酶活性是LINE-1编码的ORF2蛋白的功能，用于切割DNA，为逆转录转座提供整合位点。"},
  {name: "L1 expression", description: "LINE-1的转录水平。"},
  {name: "L1 hypomethylation", description: "L1转座子的低甲基化，通常导致其转录和转座活性增加。"},
  {name: "L1 insertion", description: "L1插入是LINE-1逆转录转座子整合到新基因组位点的过程。"},
  {name: "L1 mobilization", description: "L1转座子的动员，指其从基因组中原位点移动到新位点的过程。"},
  {name: "L1 mRNA binding", description: "L1 mRNA结合，指蛋白质与LINE-1的mRNA分子特异性结合的过程。"},
  {name: "L1 mRNA表达上调", description: "p53通过其应答元件增加LINE-1 mRNA的表达水平。"},
  {name: "L1 ORF1p protein expression", description: "LINE-1 ORF1p蛋白表达，在许多人类癌症中检测到。"},
  {name: "L1 ORF1p与APOBEC3C相互作用", description: "LINE-1的ORF1p蛋白与宿主限制因子APOBEC3C之间发生RNA依赖性的物理相互作用。"},
  {name: "L1 ORF1p表达抑制", description: "肠道病毒蛋白ORF2p抑制LINE-1 ORF1蛋白的表达。"},
  {name: "L1 ORF2 protein translation", description: "L1 ORF2蛋白翻译，是LINE-1逆转录转座所必需的逆转录酶和内切酶蛋白的合成过程。"},
  {name: "L1 ORF2p pausing", description: "LINE-1编码的ORF2蛋白在逆转录转座过程中的暂停现象，可能与Alu序列的5'端截断有关。"},
  {name: "L1 ORF2p内切酶介导的插入", description: "由LINE-1编码的ORF2蛋白的内切酶活性介导的DNA切割，是靶向引物逆转录机制的关键步骤。"},
  {name: "L1 promoter hypomethylation", description: "LINE-1启动子区域的低甲基化状态，通常与转座子活性增加相关。"},
  {name: "L1 retrotransposition (L1-RTP)", description: "LINE-1的逆转录转座过程，即其通过'复制-粘贴'机制在基因组中移动并产生新插入位点的活性。"},
  {name: "L1 ribonucleoprotein complex integrity", description: "L1核糖核蛋白复合体完整性，是影响LINE-1逆转录转座活性的关键因素。"},
  {name: "L1 RNA 3'UTR依赖的蛋白复合物结合", description: "凝缩蛋白II、GAIT蛋白以及凝缩蛋白I通过LINE-1 RNA的3'非翻译区与其结合的过程。"},
  {name: "L1 RNA与RNA/DNA结合蛋白相互作用", description: "L1 RNA与宿主蛋白相互作用，编码特定信息以激活或抑制转录程序。"},
  {name: "L1 RNA和核糖核蛋白颗粒完整性丧失", description: "ZAP蛋白通过破坏L1 RNA及其核糖核蛋白颗粒的完整性来抑制逆转录转座。"},
  {name: "L1 RNA表达", description: "指LINE-1转座子转录产生的RNA水平。"},
  {name: "L1 RNP formation", description: "LINE-1核糖核蛋白复合物的形成过程，该复合物对逆转录转座至关重要。"},
  {name: "L1 RNP translocation", description: "LINE-1核糖核蛋白复合物在宿主细胞内的转运过程。"},
  {name: "L1 RNP复合物形成", description: "LINE-1 RNA与ORF1p和ORF2p蛋白结合，形成功能性的逆转录转座复合物的过程。"},
  {name: "L1 transcription", description: "LINE-1转录，产生编码ORF1p和ORF2p的双顺反子转录本。"},
  {name: "L1 transcription inhibition", description: "L1转录抑制是指通过降低LINE-1 RNA的合成来限制其活性的过程。"},
  {name: "L1 transcriptional repression", description: "LINE-1转录抑制，指LINE-1基因表达水平的下调。"},
  {name: "L1 translation", description: "LINE-1的翻译过程。"},
  {name: "L1 translation inhibition", description: "L1翻译抑制是指通过阻止LINE-1 RNA翻译成蛋白质来限制其活性的过程。"},
  {name: "L1-EN序列特异性切割", description: "L1-EN内切酶结构域通过识别并切割共有序列5'-TTTTT/AA-3'来启动新的L1整合。"},
  {name: "L1-mediated retrotransposition", description: "L1介导的逆转录转座，是LINE-1转座子移动并导致新插入事件的机制。"},
  {name: "L1-MET expression increase", description: "L1-MET表达增加，由LINE-1反义启动子驱动的嵌合转录本表达水平升高。"},
  {name: "L1-ORF overexpression", description: "L1开放阅读框的过表达，指其编码蛋白（如ORF1p和ORF2p）的转录或翻译水平异常升高。"},
  {name: "L1-ORF1p核定位", description: "LINE-1编码的ORF1蛋白从细胞质转移到细胞核的现象。"},
  {name: "L1-ORF1p表达", description: "LINE-1编码的ORF1蛋白在细胞中的产生。"},
  {name: "L1-ORF1蛋白染色质招募", description: "LINE-1编码的ORF1蛋白被募集到染色质的过程，是逆转录转座的关键步骤。"},
  {name: "L1-RNP形成", description: "LINE-1 RNA与自身编码的ORF1p和ORF2p蛋白结合，形成核糖核蛋白颗粒的过程。"},
  {name: "L1-RTP induction", description: "LINE-1逆转录转座的诱导过程。"},
  {name: "L1-宿主相互作用", description: "宿主细胞因子与LINE-1元件之间的相互作用，影响其活性。"},
  {name: "L1Hs 5'UTR反义启动子活性", description: "指位于L1Hs 5'UTR区域的反义启动子驱动基因转录的能力。"},
  {name: "L1Hs转录", description: "指L1Hs基因的转录过程，受其5'UTR内部启动子调控。"},
  {name: "L1Hs逆转录转座", description: "指L1Hs通过逆转录和整合机制在基因组中移动的过程。"},
  {name: "L1ORF1p三聚化", description: "L1ORF1p通过卷曲螺旋结构域形成同源三聚体的过程。"},
  {name: "L1ORF1p表达", description: "LINE-1编码的ORF1蛋白的表达，通常用于评估LINE-1活性。"},
  {name: "L1ORF2p表达", description: "LINE-1编码的ORF2蛋白的表达，该蛋白提供核酸内切酶和逆转录酶活性，对逆转录转座至关重要。"},
  {name: "L1RNA包装", description: "L1ORF1p将L1 RNA包装成大型组装体的过程。"},
  {name: "L1介导的突变", description: "由LINE-1逆转录转座子活动导致的新突变。"},
  {name: "L1介导的逆转座", description: "由LINE-1转座子介导的逆转录转座过程，导致遗传物质在基因组中移动和插入新位点。"},
  {name: "L1介导的逆转录转座", description: "LINE-1转座子通过逆转录转座机制在基因组中移动，可能导致插入突变。"},
  {name: "L1介导的逆转录转座事件", description: "由LINE-1转座子活性驱动的基因组插入和变异事件。"},
  {name: "L1介导的逆转录转座机制", description: "一种由LINE-1转座子核酸内切酶介导的逆转录转座过程，其靶位点复制（TSD）侧翼序列具有TT/AAAA共有序列特征。"},
  {name: "L1依赖的超凝缩蛋白复合物形成", description: "在LINE-1存在的情况下，凝缩蛋白I和凝缩蛋白II亚基相互作用，在细胞质中形成复合物。"},
  {name: "L1元件依赖性逆转录转座", description: "指由LINE-1转座子介导的、通过逆转录机制产生新拷贝并插入基因组的过程。"},
  {name: "L1元件倒位", description: "LINE-1插入过程中，其自身序列发生方向颠倒的现象。"},
  {name: "L1内切酶介导的DNA切割", description: "具有催化活性的LINE-1内切酶可以切割DNA，导致双链断裂。"},
  {name: "L1内切酶介导的插入", description: "LINE-1通过其编码的内切酶（L1 EN）在基因组DNA上制造切口，从而介导新拷贝的插入。"},
  {name: "L1内切酶依赖性逆转录转座", description: "一种由LINE-1编码的内切酶在靶位点产生切口，从而启动逆转录转座过程的机制。"},
  {name: "L1内切酶切割", description: "摘要中提及的机制，大多数新发现的逆转录转座子表现出特定的L1内切酶切割基序。"},
  {name: "L1内切酶活性", description: "L1内切酶识别并切割特定DNA序列（TA连接处），为LINE-1逆转录转座提供切口。"},
  {name: "L1内切酶非依赖性逆转录转座", description: "一种不依赖于LINE-1内切酶活性，可能利用基因组中预先存在的断裂来启动逆转录转座的机制。"},
  {name: "L1再激活", description: "在DNA低甲基化（如癌细胞和iPSCs中）条件下，L1活性被重新启动。"},
  {name: "L1去甲基化", description: "指LINE-1转座子启动子区域CpG岛的甲基化水平降低，可能导致其异常激活。"},
  {name: "L1反义启动子活性", description: "LINE-1反义启动子驱动嵌合转录本转录的能力。"},
  {name: "L1反义启动子转录", description: "L1反义启动子驱动转录，产生包含邻近外显子序列的L1-基因嵌合RNA。"},
  {name: "L1启动子低甲基化", description: "L1启动子区域甲基化水平降低，可能导致其在体细胞组织中解除抑制。"},
  {name: "L1启动子去甲基化", description: "LINE-1转座子启动子区域DNA甲基化水平降低，通常导致其转录激活。"},
  {name: "L1启动子转录", description: "从LINE-1自身启动子起始的转录过程，产生'真实的'L1转录本。"},
  {name: "L1复制", description: "L1通过逆转录转座机制在基因组中产生新的拷贝，实现自我复制。"},
  {name: "L1失调", description: "LINE-1转座子的活性或表达调控发生异常。"},
  {name: "L1嵌合转录本形成", description: "指LINE-1序列与宿主基因或病毒基因融合产生异常转录本的过程。"},
  {name: "L1抑制", description: "细胞通过特定机制（如SAMHD1蛋白）限制LINE-1逆转录转座活性的过程。"},
  {name: "L1抑制反馈环路", description: "上皮细胞中LINE-1表达增加促进细胞质凝缩蛋白复合物形成，进而协同介导对LINE-1的抑制。"},
  {name: "L1插入中间体与远端DNA断裂重组", description: "L1逆转录转座中间体与基因组中其他位置的DNA断裂发生重组，导致染色体重排。"},
  {name: "L1插入中间体相互重组", description: "两个不同的L1插入中间体相互重组，导致染色体重排。"},
  {name: "L1插入生成", description: "LINE-1逆转录转座事件导致新的LINE-1序列整合到宿主基因组中。"},
  {name: "L1整合", description: "L1整合是指LINE-1逆转录转座子插入基因组的过程。"},
  {name: "L1杂交富集法", description: "一种通过使用L1特异性生物素化寡核苷酸杂交捕获，然后通过链霉亲和素包被的顺磁珠进行捕获，来富集和获取全长L1插入序列的方法。"},
  {name: "L1样逆转录转座", description: "L1样逆转录转座是指与哺乳动物LINE-1介导的事件非常相似的逆转录转座过程。"},
  {name: "L1核糖核蛋白复合体形成", description: "LINE-1逆转录转座所必需的前体复合体，包含L1 RNA和ORF1蛋白等。"},
  {name: "L1核糖核蛋白（RNP）形成", description: "L1 RNA与其编码的蛋白（如ORF1p和ORF2p）组装形成核糖核蛋白复合物，这是逆转录转座所必需的。"},
  {name: "L1核输入", description: "L1核糖核蛋白复合体进入细胞核的过程，是逆转录转座的关键步骤。"},
  {name: "L1核酸内切酶依赖的逆转录转座", description: "L1逆转录转座的一种机制，依赖于其自身的核酸内切酶活性来切割靶DNA。"},
  {name: "L1核酸内切酶切割活性", description: "LINE-1编码的核酸内切酶对DNA双链进行切割的活性。"},
  {name: "L1活性抑制", description: "通过分子机制（如miRNA结合、蛋白因子调控）降低LINE-1的转录或转座能力。"},
  {name: "L1生命周期", description: "包括LINE-1的结构、转录调控、翻译和逆转录转座机制。"},
  {name: "L1生命周期调控", description: "对LINE-1逆转录转座子从转录、翻译、核糖核蛋白复合物形成到逆转录插入整个过程的调节。"},
  {name: "L1直接插入", description: "LINE-1转座子自身序列的直接插入。"},
  {name: "L1移动性", description: "指LINE-1转座子在基因组中发生转座活动的程度或频率。"},
  {name: "L1编码蛋白表达", description: "指LINE-1转座子编码的蛋白质（如ORF1p和ORF2p）的表达水平。"},
  {name: "L1蛋白表达", description: "LINE-1 RNA翻译产生其自身逆转录转座所需蛋白（如ORF1p和ORF2p）的过程。"},
  {name: "L1蛋白表达抑制", description: "病毒蛋白（如EV-D68 2A）抑制LINE-1蛋白的表达。"},
  {name: "L1表达", description: "L1表达是指LINE-1转座子基因的转录和翻译过程，是其发挥转座活性的前提。"},
  {name: "L1诱导的损伤", description: "由LINE-1逆转录转座活动引起的基因组DNA损伤。"},
  {name: "L1转座驱动的Alu插入", description: "一种由LINE-1转座子活性介导的Alu元件插入机制。"},
  {name: "L1转座驱动的SVA插入", description: "一种由LINE-1转座子活性介导的SVA元件插入机制。"},
  {name: "L1辅助的Alu逆转录转座", description: "LINE-1转座机制被非自主的Alu逆转录转座子利用，协助其完成逆转录和整合。"},
  {name: "L1逆转录", description: "由LINE-1 ORF2蛋白介导的，将LINE-1 RNA逆转录为cDNA的关键步骤。"},
  {name: "L1逆转录抑制", description: "病毒蛋白（如EV-D68 3A和3C）在L1核糖核蛋白复合体中抑制ORF2p介导的逆转录。"},
  {name: "L1逆转录转座", description: "LINE-1转座子通过逆转录过程在基因组中移动和插入新拷贝的活动。"},
  {name: "L1逆转录转座子活性", description: "LINE-1转座子通过逆转录机制在基因组中移动的能力。"},
  {name: "L1逆转录转座活性", description: "指LINE-1转座子通过其编码的蛋白进行逆转录和基因组插入的能力。"},
  {name: "L1逆转录转座诱导", description: "指在特定条件下（如砷暴露），LINE-1转座子的逆转录转座活性被激活和增强的过程。"},
  {name: "L1逆转录酶活性", description: "LINE-1编码的逆转录酶将L1 RNA逆转录为cDNA的过程。"},
  {name: "LINE-1 5' UTR启动子活性抑制", description: "BST2通过降低LINE-1 5'非翻译区的启动子活性来抑制其转录。"},
  {name: "LINE-1 5'-UTR启动子活性", description: "位于LINE-1元件5'非翻译区的序列驱动其自身RNA转录的活性。"},
  {name: "LINE-1 insertion", description: "摘要中描述的LINE-1逆转录转座子插入基因组的过程。"},
  {name: "LINE-1 ORF1p and ORF2p expression", description: "LINE-1编码的ORF1和ORF2蛋白的表达。"},
  {name: "LINE-1 ORF2p逆转录酶活性", description: "LINE-1编码的ORF2蛋白所具有的逆转录酶功能，是完成逆转录转座的关键。"},
  {name: "LINE-1 polymorphisms", description: "LINE-1多态性是指人群中LINE-1序列或活性存在的个体差异。"},
  {name: "LINE-1 reverse transcription", description: "LINE-1逆转录是由其编码的ORF2蛋白介导的，将LINE-1 RNA逆转录为cDNA的过程。"},
  {name: "LINE-1 RNA generation", description: "LINE-1 RNA的转录生成。"},
  {name: "LINE-1 RNA去帽", description: "MOV10招募DCP2对LINE-1 RNA进行去帽修饰。"},
  {name: "LINE-1 RNP隔离", description: "LINE-1的核糖核蛋白复合物被隔离在应激颗粒中，从而阻止其完成逆转录转座过程。"},
  {name: "LINE-1介导的插入", description: "由LINE-1逆转录转座活性驱动的、导致新转座子插入基因组的过程。"},
  {name: "LINE-1介导的逆转录转座", description: "一种由LINE-1转座子介导的、通过RNA中间体进行复制和插入的基因组重排机制。"},
  {name: "LINE-1去抑制", description: "在细胞衰老等背景下，LINE-1的转录抑制被解除，导致其表达和活性增加。"},
  {name: "LINE-1启动子低甲基化", description: "LINE-1启动子区域DNA甲基化水平降低，通常与转录活性增加相关。"},
  {name: "LINE-1启动子抑制", description: "通过激活先天免疫信号通路，导致LINE-1启动子活性被强烈阻断。"},
  {name: "LINE-1启动子活性下调", description: "由TRIM5α激活的先天免疫信号导致LINE-1启动子活性降低。"},
  {name: "LINE-1抑制", description: "SAMHD1蛋白对LINE-1逆转录转座活性的负调控作用。"},
  {name: "LINE-1核糖核蛋白颗粒形成", description: "LINE-1 RNA与其编码的ORF1p蛋白结合形成的复合物，是逆转录转座的关键中间体。"},
  {name: "LINE-1激活", description: "LINE-1转座子表达水平或活性升高的状态。"},
  {name: "LINE-1表达", description: "LINE-1转座子转录生成RNA的过程。"},
  {name: "LINE-1表达增加", description: "LINE-1转座子转录水平或拷贝数的升高。"},
  {name: "LINE-1转录", description: "LINE-1转座子的基因表达过程，其活性与体细胞插入事件相关。"},
  {name: "LINE-1逆转录转座", description: "LINE-1通过逆转录机制在基因组中移动的过程。"},
  {name: "LINE-1逆转录酶活性", description: "LINE-1编码的逆转录酶将其RNA基因组逆转录为DNA的过程。"},
  {name: "LINE-1限制活性", description: "宿主因子（如APOBEC3A）抑制LINE-1逆转录转座活性的功能。"},
  {name: "LINE1 retrotransposition", description: "LINE-1的逆转录转座过程，在本研究中被证明不是其触发免疫激活所必需的。"},
  {name: "LINE1 RNA共表达", description: "在特定应激条件下，与Alu RNA同时增加的LINE-1 RNA表达。"},
  {name: "LINE1-triggered immune activation", description: "由LINE-1成分触发的免疫激活，导致IFNβ产生，不依赖于其DNA合成和逆转录转座活性，但依赖于RNA感应通路。"},
  {name: "LINE1表达上调", description: "在特定条件下，如病毒感染引起的细胞应激，LINE1的表达水平显著增加。"},
  {name: "LINE整合机制", description: "LINE转座子整合到宿主基因组中的分子过程。"},
  {name: "local immune evasion", description: "局部免疫逃逸，指肿瘤微环境中肿瘤细胞逃避机体免疫系统识别和攻击的能力。"},
  {name: "m6A modification", description: "发生在LINE-1 mRNA上的N6-腺苷甲基化修饰，是真核生物RNA中最丰富的表观遗传修饰。"},
  {name: "m6A介导的L1 mRNA降解", description: "m6A阅读蛋白YTHDF2识别METTL3催化的L1 RNA上的m6A修饰，并通过自噬途径降解L1 mRNA。"},
  {name: "m6A修饰", description: "RNA上N6-甲基腺苷的化学修饰，在多种生物学过程中发挥重要作用。"},
  {name: "MAPK信号通路", description: "丝裂原活化蛋白激酶信号通路，参与细胞增殖、分化等多种过程。"},
  {name: "MAPK激活", description: "丝裂原活化蛋白激酶的激活，参与将LINE-1的ORF1蛋白募集到染色质的过程。"},
  {name: "MDA5-induced IFN expression", description: "由MDA5蛋白诱导产生的干扰素表达。"},
  {name: "MDA5-mediated RNA sensing", description: "一种RNA感应通路，在本研究中被证明参与介导LINE-1触发的免疫激活。"},
  {name: "MET protein level control", description: "MET蛋白水平调控，L1-MET表达增加对MET蛋白表达水平（从低到高）的调控作用。"},
  {name: "methylation", description: "甲基化，一种常见的DNA表观遗传修饰，通常与基因沉默相关。"},
  {name: "METTL3促进L1逆转录转座", description: "m6A甲基转移酶METTL3通过促进L1 RNA的m6A修饰，从而增强L1的逆转录转座活性。"},
  {name: "Mg2+依赖性催化", description: "L1内切酶的催化活性需要Mg2+阳离子的参与。"},
  {name: "miR-128介导的L1抑制", description: "miR-128通过直接靶向L1 RNA降解和间接抑制L1依赖的细胞辅助因子来限制LINE-1的逆转录转座。"},
  {name: "miR-128抑制L1逆转录转座", description: "miR-128通过直接结合L1 RNA来抑制新的逆转录转座事件。"},
  {name: "misregulation of expression", description: "表达失调，指基因或转座子表达水平异常升高或降低。"},
  {name: "mobilization", description: "转座子从基因组一个位置移动到另一个位置的过程。"},
  {name: "modulation of cellular plasticity", description: "细胞可塑性的调节是指细胞改变其表型或功能状态的能力。"},
  {name: "modulation of oncogenic signaling gene expression", description: "调节致癌信号通路相关基因的表达。"},
  {name: "MOV10/LINE-1相互作用", description: "MOV10蛋白通过其延伸的motif II结构域与LINE-1发生相互作用。"},
  {name: "MOV10抑制逆转录转座", description: "细胞因子MOV10通过其RNA解旋酶活性，抑制内源性逆转录转座子（包括LINE-1）的复制和转座。"},
  {name: "MOV10颗粒形成", description: "MOV10蛋白通过其C端结构域与G3BP1结合，驱动液-液相分离形成颗粒。"},
  {name: "mRNA expression", description: "mRNA表达，L1元件转录产生mRNA的过程。"},
  {name: "mRNA伴侣功能", description: "ORF1蛋白作为mRNA伴侣，可能参与保护或转运L1转录本。"},
  {name: "mRNA剪接异常", description: "L1插入影响基因转录本的正确剪接过程。"},
  {name: "mRNA去稳定化", description: "降低mRNA的稳定性，导致其更快降解。"},
  {name: "mutation", description: "在人类中，逆转录转座子整合可能是一种普遍的突变机制。"},
  {name: "NADPH氧化酶活性缺陷", description: "中性粒细胞中负责产生活性氧以杀灭病原体的关键酶功能受损。"},
  {name: "naïve多能性关闭", description: "胚胎干细胞从naïve多能状态向primed多能状态转变的过程。"},
  {name: "Neddylation", description: "一种蛋白质翻译后修饰过程，涉及NEDD8蛋白的共价连接，对某些蛋白质（如Cullin-RING E3连接酶）的活性至关重要。"},
  {name: "Nef蛋白介导的LINE-1抑制", description: "HIV Nef蛋白通过抑制LINE-1启动子活性和破坏ORF1p-RNA相互作用来抑制LINE-1逆转录转座的机制。"},
  {name: "negative feedback loop", description: "负反馈环路，一种维持系统稳定的生物学调控机制。"},
  {name: "nested insertions", description: "嵌套插入，指转座子整合到已存在的重复元件（如L1序列）中。"},
  {name: "neuroinflammation", description: "神经炎症是中枢神经系统内的炎症反应，逆转录转座子可能通过促进神经炎症参与AD发病。"},
  {name: "neurological degeneration", description: "神经组织结构和功能的进行性丧失。"},
  {name: "NF-κB介导的炎症反应基因表达", description: "由转录因子NF-κB调控的炎症相关基因的表达。"},
  {name: "nicking target DNA", description: "切割靶DNA，是ORF2p在靶标引发的逆转录过程中的关键步骤，为cDNA合成提供引物。"},
  {name: "non-classical insertions", description: "非经典插入，指L1在脑中的插入事件具有两端截短、与宿主元件同向整合、靶序列富含CCATT基序等特征。"},
  {name: "non-homologous end-joining repair", description: "非同源末端连接修复，一种DNA修复机制，参与LINE-1逆转录转座过程。"},
  {name: "non-templated base addition", description: "非模板碱基添加是ORF2p在合成链末端添加非模板编码核苷酸的能力。"},
  {name: "nuclear import of LINE-1 RNA", description: "LINE-1 RNA的核输入，是LINE-1逆转录转座过程中的一个关键步骤。"},
  {name: "nuclear localization", description: "核定位，指蛋白质（如LINE-1 ORF1p）在细胞核内的分布。"},
  {name: "oncogenic β-catenin/Wnt signaling", description: "致癌性β-连环蛋白/Wnt信号通路，一种在多种癌症中被异常激活的细胞信号通路。"},
  {name: "ORF1/p40依赖性过程", description: "摘要中描述的机制，指由LINE-1的ORF1编码的p40蛋白介导的生物学过程。"},
  {name: "ORF1p expression", description: "LINE-1编码的ORF1蛋白的表达。"},
  {name: "ORF1p 增强 Alu 转座", description: "LINE-1编码的ORF1蛋白能够直接或间接地促进Alu RNA与逆转录转座所需因子之间的相互作用，从而增强Alu的转座效率。"},
  {name: "ORF1p-LINE-1 RNA相互作用", description: "LINE-1编码的ORF1蛋白与其自身RNA的结合，对形成功能性逆转录转座复合体至关重要。"},
  {name: "ORF1p-RNA结合", description: "ORF1p蛋白结合LINE-1 RNA。"},
  {name: "ORF1p三聚体形成", description: "ORF1蛋白形成同源三聚体、不对称哑铃状结构。"},
  {name: "ORF1p与Pin1相互作用", description: "磷酸化的ORF1p与肽基脯氨酰异构酶1之间的相互作用，是脯氨酸导向蛋白激酶介导调控的关键组成部分。"},
  {name: "ORF1p与RNA退火", description: "ORF1蛋白在体外与RNA结合的能力，是其重要的生化特性。"},
  {name: "ORF1p介导的RNP分布", description: "LINE-1编码的ORF1p蛋白能够指导其核糖核蛋白颗粒在细胞内的分布。"},
  {name: "ORF1p凝聚", description: "ORF1p通过静电相互作用和三聚体构象动力学进行组装和相分离，形成核糖核蛋白复合物凝聚体的过程。"},
  {name: "ORF1p功能", description: "LINE-1编码的蛋白质之一，是逆转录转座所必需的，其功能可能影响转座效率。"},
  {name: "ORF1p寡聚化", description: "ORF1p蛋白快速形成寡聚体的过程，是LINE-1逆转录转座所必需的。"},
  {name: "ORF1p磷酸化", description: "LINE-1编码的ORF1蛋白在特定基序上发生的磷酸化修饰，是其活性所必需的。"},
  {name: "ORF1p细胞内积累", description: "LINE-1编码的ORF1蛋白在细胞内的聚集水平。"},
  {name: "ORF1p细胞质灶形成", description: "LINE-1 ORF1蛋白在细胞质中聚集形成焦点结构，与逆转录转座复合体组装相关。"},
  {name: "ORF1p表达", description: "ORF1p是LINE-1编码的RNA结合蛋白，在死后人脑样本（包括海马体）中观察到其广泛表达。"},
  {name: "ORF1p表达上调", description: "在衰老小鼠大脑中观察到的LINE-1编码的RNA结合蛋白ORF1p表达水平增加。"},
  {name: "ORF1p过表达", description: "在肿瘤发生过程中，LINE-1编码的RNA结合伴侣蛋白ORF1p的表达水平异常升高。"},
  {name: "ORF1p降解", description: "STING与LINE-1 ORF1p相互作用，并将其分选至溶酶体进行降解的过程。"},
  {name: "ORF1与ARNT1相互作用", description: "LINE-1编码的ORF1蛋白与AhR核转位蛋白-1 (ARNT1) 之间的分子相互作用。"},
  {name: "ORF1募集至染色质", description: "L1编码的开放阅读框1蛋白被招募到染色质上的过程，在本研究中依赖于CREB的激活。"},
  {name: "ORF1蛋白表达", description: "LINE-1编码的ORF1蛋白的表达过程，该蛋白对逆转录转座至关重要。"},
  {name: "ORF1蛋白需求", description: "ORF1蛋白需求是指某些逆转录元件（如由RNA聚合酶II驱动的Alu转录本）的转座过程需要LINE-1编码的ORF1蛋白的补充。"},
  {name: "ORF2 IRES介导的翻译", description: "通过ORF2上游的内部核糖体进入序列（IRES）启动ORF2蛋白的翻译。"},
  {name: "ORF2p RNA结合", description: "LINE-1编码的ORF2蛋白与RNA（包括自身RNA或Alu RNA）结合的过程，是启动逆转录转座的关键步骤。"},
  {name: "ORF2p与Alu RNA结合", description: "LINE-1 ORF2蛋白与Alu RNA的poly(A)尾结合，这是启动Alu逆转录转座的关键步骤。"},
  {name: "ORF2p与L1 RNA结合", description: "L1 ORF2编码的蛋白质与L1 RNA结合以促进逆转录的过程。"},
  {name: "ORF2p介导的LINE-1 RNP逆转录", description: "由LINE-1编码的ORF2蛋白在逆转录核糖核蛋白复合物（RNP）中催化LINE-1 RNA逆转录为cDNA的过程。"},
  {name: "ORF2p功能", description: "LINE-1编码的蛋白质之一，具有逆转录酶和内切酶活性，是逆转录转座所必需的，并能驱动Alu元件的转座。"},
  {name: "ORF2p核酸内切酶活性", description: "ORF2p蛋白具有切割DNA的核酸内切酶活性。"},
  {name: "ORF2p翻译", description: "LINE-1 mRNA翻译产生其第二个编码蛋白ORF2p的过程。"},
  {name: "ORF2p逆转录酶活性", description: "ORF2p蛋白具有将RNA逆转录为DNA的活性。"},
  {name: "ORF2p降解", description: "ORF2p降解是指通过泛素化等途径降低LINE-1逆转录酶/核酸内切酶（ORF2p）蛋白稳定性的过程。"},
  {name: "ORF2p驱动的Alu逆转录转座", description: "LINE-1的ORF2蛋白促进寄生性Alu元件进行逆转录转座的过程。"},
  {name: "ORF2与ORF1表达不一致", description: "ORF2与ORF1表达不一致是指在人脑神经元中，编码ORF2和ORF1的LINE-1转录本表达水平不协调的现象。"},
  {name: "ORF2翻译", description: "LINE-1转座子编码蛋白ORF2p的翻译过程。"},
  {name: "ORF2蛋白C端功能", description: "LINE-1 ORF2蛋白羧基末端区域，除介导RNP相互作用外，还为逆转录转座子扩增提供独立且必需的功能。"},
  {name: "ORF2蛋白依赖", description: "ORF2蛋白依赖是指非自主逆转录元件（如Alu）的转座需要LINE-1编码的ORF2蛋白。"},
  {name: "ORF2蛋白功能", description: "LINE-1的ORF2蛋白具有逆转录酶和内切酶活性，是驱动逆转录转座的核心蛋白。"},
  {name: "orphan 3' transduction", description: "一种由LINE-1介导的、仅包含其下游侧翼序列（而LINE-1自身序列严重截短或缺失）的转导事件。"},
  {name: "p300降解", description: "p300是一种组蛋白乙酰转移酶和转录共激活因子，其蛋白被β-HPV E6靶向降解。"},
  {name: "p38delta MAP激酶诱导", description: "摘要中描述的过程，指LINE-1转座子或其编码的蛋白能够诱导p38delta MAP激酶的表达。"},
  {name: "p53介导的L1抑制", description: "p53通过协同组蛋白甲基转移酶SETDB1和G9a，在L1启动子区沉积H3K9me3抑制性标记，从而沉默转座子。"},
  {name: "p53介导的凋亡通路激活", description: "在具有野生型p53的细胞中，由LINE-1逆转录转座触发的细胞程序性死亡通路。"},
  {name: "p53结合", description: "p53蛋白直接结合到LINE-1启动子内一个15个核苷酸的短序列上。"},
  {name: "PI3K信号通路", description: "PI3K信号通路是胰岛素信号通路下游的关键分支，参与调控细胞生长、增殖和存活。"},
  {name: "PIN1胞质定位增加", description: "肽基脯氨酰顺反异构酶PIN1在细胞质中的定位增多。"},
  {name: "preintegration barrier", description: "APOBEC3B或APOBEC3F在LINE-1逆转录转座整合前提供的抑制屏障。"},
  {name: "premature insertion mechanisms", description: "指转座子插入过程中可能发生的提前终止或异常插入机制。"},
  {name: "premature stop codon creation", description: "提前终止密码子的产生是指基因突变导致在正常终止密码子之前出现新的终止密码子，从而产生截短的蛋白质。"},
  {name: "processivity", description: "持续合成能力是ORF2p在解离前连续添加多个核苷酸的能力。"},
  {name: "programmed cell death", description: "程序性细胞死亡，一种受基因调控的细胞主动死亡过程。"},
  {name: "promoter activity regulation of LINE-1 5'-UTR", description: "对LINE-1 5'非翻译区启动子活性的调控。"},
  {name: "protein aggregation", description: "蛋白质聚集，指蛋白质（如LINE-1 ORF1p）形成不溶性细胞质聚集体的过程。"},
  {name: "protein expression", description: "蛋白表达，L1元件编码的蛋白（如ORF1p和ORF2p）的产生过程。"},
  {name: "protein sequestration", description: "蛋白质隔离是指蛋白质被限制或隔离在特定的细胞区室（如应激颗粒）中，从而影响其功能。"},
  {name: "providing alternative promoters", description: "提供替代启动子，是逆转录转座子通过其序列为基因提供新的转录起始位点，从而促进或抑制基因转录的机制。"},
  {name: "providing polyadenylation signals", description: "提供多聚腺苷酸化信号，是逆转录转座子序列提前终止基因转录的一种机制。"},
  {name: "R-loop形成", description: "由RNA-DNA杂交体（如L1 mRNA与基因组DNA或互补DNA形成的杂交体）和一条被置换的DNA单链组成的三链结构。"},
  {name: "rare heritable germline insertion", description: "罕见的可遗传种系插入，指通过生殖细胞传递给后代的转座子插入。"},
  {name: "rc-L1s表达", description: "具有逆转录转座能力的LINE-1的表达水平，是理解逆转录转座影响的关键。"},
  {name: "reactivation", description: "再激活，指转座子从沉默状态重新获得转录或转座活性的过程。"},
  {name: "readthrough transcription", description: "通读转录，指转录过程越过正常的终止信号，产生更长的转录本。"},
  {name: "reciprocal translocation", description: "相互易位，指两条非同源染色体之间交换片段的重排事件。"},
  {name: "recombination", description: "重组，DNA断裂修复或异常重排过程。"},
  {name: "recombination events", description: "重组事件是指基因组DNA序列之间发生交换的过程。"},
  {name: "reduced gene expression", description: "基因表达降低是指基因的转录或翻译水平下降。"},
  {name: "regulation of gene expression", description: "基因表达调控是指LINE-1插入可能影响基因的转录水平或模式。"},
  {name: "regulation of L1 expression", description: "对LINE-1转录水平的调控过程。"},
  {name: "regulation of retrotransposition", description: "对LINE-1逆转录转座过程的调控。"},
  {name: "replication-coupled DNA repair", description: "复制偶联DNA修复是DNA复制过程中修复损伤DNA的机制。"},
  {name: "replication-fork restart", description: "复制叉重启是停滞的DNA复制叉恢复复制的过程。"},
  {name: "replication-stress signaling", description: "复制应激信号是细胞在DNA复制受阻或出错时激活的信号通路。"},
  {name: "repression of L1 by Mecp2/Mbd2", description: "Mecp2和Mbd2蛋白对L1的抑制，指这些甲基化CpG结合蛋白通过阻止L1启动子区域形成5hmC来抑制L1转座子的激活。"},
  {name: "retrotransposal integration", description: "逆转录转座子通过逆转录和整合机制插入基因组的过程。"},
  {name: "retrotransposition repression", description: "逆转录转座抑制是指细胞中存在抑制转座子活性的机制。"},
  {name: "retrotransposition-dependent disease initiation", description: "依赖逆转录转座的疾病起始机制，指通过逆转录转座插入事件破坏基因位点。"},
  {name: "retrotransposition-dependent mechanisms", description: "依赖于逆转录转座的机制，可导致DNA移动，产生插入突变和DNA缺失。"},
  {name: "retrotransposition-independent disease initiation", description: "不依赖逆转录转座的疾病起始机制，指通过L1 si/piRNAs、mRNAs、ORF1和ORF2蛋白的活性参与疾病。"},
  {name: "retrotransposition-independent mechanisms", description: "不依赖于逆转录转座的机制，可破坏上皮细胞的编程和分化。"},
  {name: "retrotransposition-replication conflict", description: "逆转录转座-复制冲突是指逆转录转座过程与DNA复制过程相互干扰的分子状态。"},
  {name: "retrotransposon-mediated mobilization", description: "逆转录转座子介导的移动是指逆转录转座子通过“复制-粘贴”机制在基因组中移动的过程。"},
  {name: "reverse transcriptase activity", description: "逆转录酶活性是指逆转录酶将RNA逆转录为DNA的催化功能。"},
  {name: "reverse transcription", description: "逆转录是ORF2p将LINE-1 RNA模板复制成DNA的过程。"},
  {name: "RIG-I-mediated RNA sensing", description: "一种RNA感应通路，在本研究中被证明参与介导LINE-1触发的免疫激活。"},
  {name: "RNA 3'末端多聚腺苷酸化", description: "RNA 3'末端多聚腺苷酸化是RNA成熟和稳定性的关键步骤，也参与逆转录转座子RNA的调控。"},
  {name: "RNA 3'末端尿苷化", description: "RNA 3'末端尿苷化是一种RNA修饰，通常标记RNA以进行降解，参与逆转录转座子RNA的调控。"},
  {name: "RNA m6A修饰", description: "RNA m6A修饰是一种常见的RNA表观遗传修饰，涉及甲基化酶（writer）和去甲基化酶（eraser）的调控。"},
  {name: "RNA-DNA杂交体形成", description: "在逆转录转座过程中，LINE-1 RNA与基因组DNA或新合成的cDNA之间形成的异源双链结构。"},
  {name: "RNA:DNA hybrid production", description: "RNA:DNA杂交体产生是ORF2p在细胞质中逆转录活动产生的副产物。"},
  {name: "RNase H2降解LINE-1 RNA", description: "逆转录后，RNase H2降解LINE-1 RNA，从而促进逆转录转座完成。"},
  {name: "RNA二级结构识别", description: "LINE-1编码的逆转录酶通过识别RNA分子（如自身或Alu RNA）的特定二级结构（如茎环结构）来启动逆转录转座。"},
  {name: "RNA伴侣活性", description: "L1-ORF1p蛋白帮助LINE-1 RNA正确折叠和维持功能构象的能力。"},
  {name: "RNA剪接", description: "LINE-1元件包含多个功能性剪接供体和受体位点，导致其mRNA发生广泛而复杂的剪接。"},
  {name: "RNA加工", description: "对LINE-1转录本进行剪接等处理的过程，是L1活性的主要调节方式。"},
  {name: "RNA包装", description: "L1ORF1蛋白通过其结构域特异性识别并结合单链RNA底物，形成核糖核蛋白复合物，为逆转录转座做准备。"},
  {name: "RNA和蛋白积累减少", description: "锌指抗病毒蛋白（ZAP）通过降低全长LINE-1 RNA及其编码蛋白的积累来抑制逆转录转座。"},
  {name: "RNA外切体复合物介导的RNA降解", description: "RNA外切体复合物是一种多亚基核糖核酸酶复合物，能够降解多种RNA分子，并与转座子控制相关。"},
  {name: "RNA干扰", description: "一种由小干扰RNA介导的基因沉默机制，通过降解靶mRNA或抑制其翻译来发挥作用。"},
  {name: "RNA提前多聚腺苷酸化", description: "LINE-1的A富集编码链包含多个功能性的典型和非典型多聚腺苷酸化信号，导致全长转录本被截断。"},
  {name: "RNA来源的附加体产物", description: "由LINE-1逆转录转座产生的、未整合到染色体中的环状DNA分子。"},
  {name: "RNA甲基化", description: "发生在RNA分子上的甲基化修饰，如m6A修饰。"},
  {name: "RNA结合", description: "LINE-1 ORF1p蛋白与RNA结合的能力。"},
  {name: "RNA聚合酶II驱动转录", description: "RNA聚合酶II驱动转录是指由RNA聚合酶II启动子（如CMV）启动的转录过程，影响逆转录元件的转座动力学。"},
  {name: "RNA脱帽", description: "由DCP2酶介导的去除mRNA 5'端帽子结构的过程，通常导致RNA降解。"},
  {name: "RNA表达增加", description: "特定基因或序列的转录水平升高。"},
  {name: "RNA质量控制", description: "确保RNA分子正确性和功能的过程，是L1-SIRT6相互作用网络富集的通路之一。"},
  {name: "RNA连接", description: "一种可能导致LINE-1与其它RNA序列形成嵌合体的潜在分子机制。"},
  {name: "RNA遗传", description: "在生殖细胞中转录的RNA可以通过受精过程传递到胚胎，并在胚胎期介导整合，这是一种独立于其编码DNA的遗传方式。"},
  {name: "RNA降解", description: "RNA降解是细胞清除不需要的RNA（包括逆转录转座子RNA）的重要机制。"},
  {name: "RNA靶向干扰", description: "APOBEC3蛋白可能通过干扰LINE-1 RNA的靶向或功能来间接抑制其转座。"},
  {name: "RNP凝聚物形成", description: "多个ORF1p拷贝组装到LINE-1 RNA上形成核糖核蛋白凝聚物。"},
  {name: "RNP复合物组装", description: "LINE-1 RNA与ORF1p和ORF2p蛋白相互作用，形成功能性的核糖核蛋白复合物，这是逆转录转座的关键步骤。"},
  {name: "RNP形成", description: "LINE-1 RNA与蛋白质结合形成核糖核蛋白复合体的过程。"},
  {name: "RNP运输", description: "LINE-1核糖核蛋白复合体在细胞内向细胞核移动的过程。"},
  {name: "RNP隔离", description: "逆转录转座子核糖核蛋白复合物被隔离在细胞质凝聚体中，以限制其活性。"},
  {name: "RT burden", description: "样本中逆转录转座事件的数量或负荷。"},
  {name: "RT inhibition", description: "逆转录酶抑制，通过抑制逆转录酶活性来影响细胞调控，是逆转录酶抑制剂发挥细胞毒性的核心机制。"},
  {name: "RTE copy number accumulation", description: "逆转录转座元件拷贝数随时间的增加。"},
  {name: "RUNX3与L1Hs结合", description: "指转录因子RUNX3特异性结合到L1Hs 5'UTR的RUNX位点。"},
  {name: "S/G2 phase DNA repair", description: "S/G2期DNA修复，指在细胞周期S期和G2期活跃的DNA修复通路。"},
  {name: "self-priming", description: "自引发，指逆转录转座子RNA自身结构能够启动逆转录过程。"},
  {name: "self-replication", description: "自我复制是LINE-1转座子通过逆转录转座机制进行增殖的基本功能。"},
  {name: "sequence-specific RNA recognition", description: "序列特异性RNA识别，指LINE-1 ORF2p通过五个不同的结构域特异性识别模板RNA的多聚腺苷酸序列。"},
  {name: "SINE元件移动", description: "某些剪接后的LINE-1 mRNA可能有助于表达ORF2相关产物，从而影响SINE元件的移动性。"},
  {name: "siRNA递送", description: "将小干扰RNA（siRNA）导入细胞以触发RNA干扰（RNAi）的过程。"},
  {name: "smoke-induced hypomethylation of the LINE-1 promoter", description: "吸烟诱导的LINE-1启动子低甲基化，是导致LINE-1表达和转座活性增加的表观遗传机制。"},
  {name: "snRNA加工假基因形成", description: "LINE-1在逆转录转座周期中通过招募小核RNA（snRNA）形成其加工假基因的过程。"},
  {name: "somatic expression", description: "转座子在体细胞组织中的转录过程。"},
  {name: "somatic genome variation", description: "体细胞基因组变异是指在个体体细胞中发生的基因组序列改变。"},
  {name: "somatic L1 insertion", description: "体细胞L1插入，指LINE-1转座子在体细胞基因组中新产生的插入位点。"},
  {name: "somatic L1 insertions", description: "体细胞LINE-1插入，指在体细胞基因组中新获得的LINE-1插入突变。"},
  {name: "somatic L1 retrotransposition", description: "体细胞中的LINE-1逆转录转座事件，可在基因组中插入新的拷贝。"},
  {name: "somatic mobilization", description: "体细胞中LINE-1的移动，与癌症病因相关。"},
  {name: "somatic mosaicism", description: "由体细胞突变（如L1逆转录转座）导致的个体内不同细胞基因组存在差异的现象。"},
  {name: "somatic mutation", description: "体细胞突变，由逆转录转座等过程在非生殖细胞中引发的基因组改变。"},
  {name: "somatic retrotransposition", description: "体细胞逆转录转座，指发生在体细胞而非生殖细胞中的LINE-1插入事件。"},
  {name: "somatic retrotransposition events", description: "体细胞逆转录转座事件，发生在非生殖细胞中的转座活动。"},
  {name: "somatic TE mobilization", description: "体细胞转座子动员，指在体细胞（如肿瘤细胞）中发生的转座子插入事件。"},
  {name: "Sox2介导的调控", description: "Sox2表达下调与L1转录和逆转录转座活性增加相关。"},
  {name: "Sp1依赖性基因表达", description: "由宿主转录因子Sp1驱动的基因转录过程。"},
  {name: "SRP9/14结合", description: "Alu RNA的特定结构域与信号识别颗粒蛋白SRP9/14结合的过程，这对Alu的逆转录转座功能很重要。"},
  {name: "staggered DNA break", description: "交错DNA断裂，指LINE-1 ORF2p在靶DNA上产生单一切口后形成的交错DNA断裂。"},
  {name: "STAT1磷酸化", description: "信号转导和转录激活因子1的磷酸化，是其激活并调控下游基因表达的关键步骤。"},
  {name: "stress granule formation", description: "应激颗粒形成是细胞在压力条件下（如病毒感染）将翻译停滞的mRNA和蛋白质聚集到细胞质颗粒中的过程。"},
  {name: "stress granule pathway", description: "应激颗粒通路，一种通过将LINE-1 RNA-蛋白复合物隔离在细胞质应激颗粒中来抑制LINE-1逆转录转座的机制。"},
  {name: "structural modification of endogenous genes", description: "内源基因的结构修饰是指LINE-1插入可能改变基因的物理结构。"},
  {name: "SUMO化", description: "一种控制蛋白质-蛋白质相互作用、亚细胞定位和其他翻译后修饰的修饰过程。"},
  {name: "suppression of transposable elements", description: "转座子抑制，逆转录酶抑制剂抑制包括LINE-1在内的转座元件的活性。"},
  {name: "SVA反式动员", description: "非自主性SVA元件在反式（trans）中被LINE-1编码的蛋白质机器动员的过程。"},
  {name: "S期逆转录转座", description: "LINE-1逆转录转座在细胞周期的S期达到峰值。"},
  {name: "target-primed reverse transcription", description: "靶标引发的逆转录，是LINE-1逆转录转座的机制，其编码的酶（ORF2p）切割靶DNA以启动自身或非自身RNA的逆转录。"},
  {name: "target-site primed reverse transcription", description: "靶位点引发的逆转录，是LINE-1逆转录转座的一种经典机制。"},
  {name: "template switching", description: "模板转换是ORF2p在合成过程中从一个核酸模板切换到另一个的能力。"},
  {name: "Tet1-mediated activation of L1", description: "Tet1蛋白介导的L1激活，指Tet1蛋白通过修饰L1启动子区域的DNA甲基化状态来激活L1转座子的过程。"},
  {name: "TE沉默", description: "PIWI通路通过非经典piRNA靶向转座子，抑制其活性。"},
  {name: "TGF-β1信号通路激活", description: "本文发现的介导AhR配体激活LINE-1的经典信号通路。"},
  {name: "TGFβ信号通路激活", description: "转化生长因子β信号通路的活化状态。"},
  {name: "Toll样受体4信号通路", description: "一种模式识别受体信号通路，在本研究中被证明介导了吗啡和枸橼酸芬太尼诱导的LINE-1逆转录转座。"},
  {name: "TP53-dependent growth arrest", description: "TP53依赖性生长停滞是细胞在DNA损伤等应激条件下，由p53蛋白介导的细胞周期停滞。"},
  {name: "transcriptional control by LINE-1 promoters", description: "由LINE-1启动子进行的转录调控，包括其自身启动子和反义启动子对宿主基因表达的调控。"},
  {name: "transcriptional deregulation", description: "转录失调，基因表达调控异常。"},
  {name: "transcriptional interference", description: "转录干扰，是一种先前未被充分认识的分子机制，可解释逆转录转座子引起的许多诱变效应。"},
  {name: "transcriptional silencing", description: "通过表观遗传修饰（如H3K9me3沉积）抑制基因或转座子转录的过程。"},
  {name: "tumor vascularisation", description: "肿瘤血管化，是肿瘤内部形成新血管网络的过程，为肿瘤生长提供营养。"},
  {name: "tumor-specific L1 insertion", description: "肿瘤特异性L1插入，指在肿瘤细胞中发生、但在正常细胞中不存在的LINE-1转座子插入事件。"},
  {name: "tumorigenesis", description: "肿瘤发生，指正常细胞转化为肿瘤细胞并形成肿瘤的过程。"},
  {name: "T细胞活性", description: "T淋巴细胞识别抗原、增殖并执行免疫效应的功能。"},
  {name: "U6 snRNA转座", description: "L1逆转录转座机制能够将U6小核RNA动员到新的基因组位置。"},
  {name: "U6 snRNA逆转录转座", description: "U6小核RNA被LINE-1编码的蛋白质动员，整合到基因组中的过程。"},
  {name: "U6/L1假基因形成", description: "U6/L1嵌合RNA发生逆转录转座，导致基因组中产生U6/L1假基因。"},
  {name: "U6/L1嵌合RNA形成", description: "由U6小核RNA与5‘端截短的L1 RNA连接形成嵌合RNA的过程。"},
  {name: "upregulation", description: "表达上调，指基因或转座子表达水平异常升高。"},
  {name: "viral-host genome interaction", description: "病毒-宿主基因组相互作用，指病毒DNA与宿主基因组之间的物理和功能联系。"},
  {name: "VNTR结构域决定动员效率", description: "在LAVA转座子中，其中心的可变数目串联重复序列结构域是决定其被LINE-1反式动员效率的关键因素。"},
  {name: "YY1结合位点介导的DNA甲基化", description: "保守的YY1转录因子结合位点介导了L1启动子在多能细胞和分化细胞中的DNA甲基化。"},
  {name: "ZAP与L1核糖核蛋白颗粒结合", description: "ZAP蛋白与L1的核糖核蛋白颗粒发生相互作用，这通过免疫共沉淀和共定位实验证实。"},
  {name: "ZAP抗逆转录元件活性", description: "ZAP蛋白通过多种机制（如RNA降解、伴侣蛋白复合物、染色质修饰等）在细胞质和细胞核中抑制逆转录元件的活性。"},
  {name: "β-catenin/Wnt信号通路激活", description: "肿瘤抑制基因MCC失活后，导致致癌的β-catenin/Wnt信号通路被激活。"},
  {name: "γ-H2AX foci形成", description: "DNA双链断裂位点处组蛋白H2AX磷酸化形成的焦点，是DNA损伤的标志。"},
  {name: "上皮-间质转化", description: "一种细胞表型转化过程，在本文中由LINE-1异位表达诱导。"},
  {name: "与宿主蛋白相互作用", description: "LINE-1编码的蛋白（如ORF1p）与宿主细胞蛋白（如ZAP）发生相互作用。"},
  {name: "与核纤层关联", description: "基因组区域（如L1富集区）在细胞核外围与核纤层蛋白（如Lamin A/C）相互作用并锚定在核膜上的过程。"},
  {name: "与远端增强子相关", description: "转座子来源的调控序列与远端增强子存在关联。"},
  {name: "与非编码RNA相关", description: "转座子来源的调控序列与非编码RNA存在关联。"},
  {name: "个体特异性指纹", description: "由个体特有的转座子插入模式构成的基因组特征。"},
  {name: "个体转座能力变异", description: "由于L1等位基因的序列多态性和活性差异，导致不同个体间L1逆转录转座潜能存在巨大差异的现象。"},
  {name: "个体间基因组变异", description: "由剪接后L1转录本的逆转录转座事件在不同个体基因组中产生的差异。"},
  {name: "个体间插入多态性", description: "不同个体间存在的LINE-1插入位点差异。"},
  {name: "书签机制", description: "一种可能决定CpG岛最终被高甲基化或低甲基化的机制。"},
  {name: "亚细胞RNA分区", description: "不同逆转座子RNA在细胞内的特定区域（如细胞质、细胞核）呈现独特的分布模式。"},
  {name: "亚细胞定位", description: "指逆转录转座中间体（如ORF1p、ORF2p和L1 mRNA）在细胞内的具体位置分布。"},
  {name: "交错DNA双链断裂修复", description: "交错DNA双链断裂修复是一种DNA损伤修复机制，可能与内部引物插入位点的形成有关。"},
  {name: "产生加工假基因", description: "L1编码的蛋白质反式促进细胞mRNA的逆转录转座，从而在基因组中形成无内含子的假基因拷贝。"},
  {name: "产生嵌合L1转录本", description: "LINE-1序列与邻近基因序列融合，形成新的转录本。"},
  {name: "产生无尾逆转录假基因", description: "LINE-1介导的逆转录转座事件中，产生的整合序列缺乏典型的寡聚腺苷酸尾巴。"},
  {name: "介导Alu转座", description: "LINE-1编码的蛋白质能够介导非自主的Alu元件的逆转录转座。"},
  {name: "介导mRNA逆转座", description: "LINE-1编码的蛋白质能够介导细胞mRNA的逆转录转座，可能产生假基因。"},
  {name: "介导SINE转座", description: "LINE-1的ORF2蛋白（ORF2p）被非自主的SINE元件（如Alu）劫持，以协助其完成逆转录和基因组整合的过程。"},
  {name: "介导SINE逆转录转座", description: "LINE-1的ORF2蛋白（ORF2p）能够识别并协助非自主的SINE元件（如Alu）完成逆转录和基因组整合。"},
  {name: "介导非L1 RNA转座", description: "LINE-1能够以不同方式、在逆转录转座周期的不同步骤中，介导假基因、tRNA、snRNA和SINE等非L1 RNA的转座。"},
  {name: "从头L1插入", description: "在个体发育或肿瘤发生过程中新发生的LINE-1转座子插入事件。"},
  {name: "从头插入", description: "LINE-1转座子新发生的插入事件。"},
  {name: "从头整合", description: "L1-EN通过切割DNA启动新的L1逆转录转座事件。"},
  {name: "位于高甲基化转录活跃DNA区", description: "转座子来源的候选人类特异性调控位点优先位于人类胚胎干细胞中高甲基化的转录活跃DNA片段基质内。"},
  {name: "位点特异性调控", description: "每个L1反义启动子位点的激活机制和功能影响可能各不相同。"},
  {name: "位点特异性逆转录转座", description: "LINE-1转座子在其编码的位点特异性内切酶作用下，插入到基因组特定序列位点的过程。"},
  {name: "低甲基化", description: "低甲基化是指DNA序列上甲基化修饰水平降低的现象。"},
  {name: "体细胞L1逆转录转座", description: "L1在体细胞组织（如癌细胞）中发生的逆转录转座活动。"},
  {name: "体细胞RNA基因重组", description: "一种生理过程，通过将无内含子的mRNA/ncRNA整合到基因组中，对单个神经元的功能状态进行索引。"},
  {name: "体细胞TE插入", description: "在体细胞（非生殖细胞）中发生的转座子插入事件，是基因组变异的一个来源。"},
  {name: "体细胞与生殖系嵌合", description: "在同一个体中，部分细胞携带突变而部分细胞不携带的现象，表明突变发生在胚胎发育早期。"},
  {name: "体细胞动员", description: "转座子在发育中的胚胎或特定体细胞（如神经细胞）中被激活并移动。"},
  {name: "体细胞基因组效应", description: "逆转录转座子活动持续影响体细胞基因组，可能影响癌症等生理过程。"},
  {name: "体细胞基因组镶嵌现象", description: "体细胞基因组镶嵌现象是指个体内不同细胞间存在基因组序列差异的现象，可由逆转录转座等过程引起。"},
  {name: "体细胞基因重组/逆转录插入", description: "体细胞基因重组/逆转录插入是指由逆转录酶介导的、在体细胞基因组中发生的基因序列重排或新序列插入事件。"},
  {name: "体细胞多态性", description: "转座子插入在个体不同体细胞中产生的基因组差异。"},
  {name: "体细胞嵌合", description: "指在同一个体的不同细胞中，基因组存在差异的现象，本文中由L1介导。"},
  {name: "体细胞抑制", description: "在体细胞中，SAFB蛋白通过剪接抑制机制，防止已整合的转座子被异常剪接和外显子化。"},
  {name: "体细胞抑制逃逸", description: "活跃的LINE-1源元件在正常组织中逃避了体细胞水平的抑制机制。"},
  {name: "体细胞拷贝数变异", description: "在体细胞中发生的基因组DNA片段拷贝数的增加或减少。"},
  {name: "体细胞插入", description: "体细胞插入是指转座子插入发生在体细胞基因组中，而非生殖细胞。"},
  {name: "体细胞插入突变", description: "转座子在体细胞基因组中发生的新插入事件，可能导致基因功能改变。"},
  {name: "体细胞移动元件插入", description: "体细胞移动元件插入是指在非癌性体细胞组织中发生的转座子插入事件，通常具有较低的等位基因频率。"},
  {name: "体细胞突变", description: "发生在体细胞而非生殖细胞中的基因突变。"},
  {name: "体细胞组织活性", description: "LINE-1在体细胞组织中具有活性，其中大脑的某些区域高度允许其活动。"},
  {name: "体细胞逆转录转座", description: "指逆转录转座子在体细胞基因组中发生新的插入事件，可能导致突变。"},
  {name: "体细胞镶嵌", description: "个体内不同细胞具有不同基因型的现象，在发育中由遗传或表观遗传改变逐步积累导致。"},
  {name: "体细胞镶嵌现象", description: "同一个体由遗传背景不同的细胞群组成的现象。"},
  {name: "作为结构元件", description: "LINE-1在基因组中作为结构元件发挥功能。"},
  {name: "侧翼序列共移动", description: "在LINE-1插入过程中，其5'端上游的基因组序列被一同转座到新位点的现象，也称为5'转导。"},
  {name: "侵袭能力", description: "肿瘤细胞侵入周围组织的能力。"},
  {name: "促炎信号传导", description: "导致促炎细胞因子（如干扰素）产生和释放的信号事件。"},
  {name: "促进非自主性转座元件逆转录转座", description: "LINE-1转座子能够利用自身机制，协助其他非自主性转座元件（如Alu、SVA）在基因组中移动。"},
  {name: "信号通路调控", description: "通过基因表达变化对细胞信号传导通路进行调节。"},
  {name: "倒位形成", description: "基因组片段发生方向反转的结构变异。"},
  {name: "假基因化", description: "基因因突变（如点突变）而失去功能，成为假基因的过程。"},
  {name: "假基因形成", description: "通过LINE-1介导的逆转录转座，将mRNA逆转录并整合到基因组中形成无功能的基因拷贝。"},
  {name: "先天免疫信号激活", description: "TRIM5α与LINE-1核糖核蛋白复合物相互作用后，激活AP-1和NF-κB转录因子。"},
  {name: "先天免疫信号通路激活", description: "细胞质中的LINE-1复合物被TRIM5α感知后，触发NF-κB和AP-1等信号通路级联反应的过程。"},
  {name: "先天免疫激活", description: "由LINE-1逆转录转座活动引发的宿主先天免疫反应。"},
  {name: "先天免疫限制", description: "先天免疫系统通过识别内源性逆转录转座子模式来限制其活性和复制。"},
  {name: "先天性免疫异常激活", description: "摘要中提及的AGS中可能由LINE-1来源的核酸驱动的异常免疫反应。"},
  {name: "克隆扩增", description: "摘要中观察到的现象，即在相邻正常食管组织中呈亚克隆状态的插入，在后续肿瘤中变为克隆性。"},
  {name: "免疫反应", description: "免疫系统识别和对抗外来物质或异常细胞的过程。"},
  {name: "免疫抑制", description: "ORF1p高表达与免疫抑制、干扰素信号减弱和免疫细胞浸润减少相关。"},
  {name: "免疫毒性级联反应", description: "由特定刺激引发的一系列免疫相关分子事件，可能导致细胞损伤或功能障碍。"},
  {name: "免疫治疗抵抗", description: "肿瘤细胞对免疫检查点抑制剂等免疫疗法不敏感或产生耐受的现象。"},
  {name: "免疫激活", description: "在某些癌症中，ORF1p高表达与免疫激活相关。"},
  {name: "免疫调节", description: "ORF1p在肿瘤微环境中对免疫反应具有双重调节作用，可表现为免疫抑制或免疫激活。"},
  {name: "全基因组DNA甲基化标志物", description: "全基因组DNA甲基化标志物是指能够反映整个基因组甲基化水平的指标。"},
  {name: "全能性", description: "单个细胞发育成完整个体的能力。"},
  {name: "全长形成", description: "全长形成是指逆转录转座子成功插入基因组并保持其完整序列结构的过程。"},
  {name: "全长插入", description: "指新插入的LINE-1转座子序列保持完整，包含ORF1和ORF2等编码区。"},
  {name: "共转录", description: "L1相关序列被整合到其他细胞RNA中，并随宿主基因一起被转录的过程。"},
  {name: "内切核酸酶依赖性插入", description: "一种经典的LINE-1插入机制，涉及靶标引物逆转录。"},
  {name: "内切核酸酶活性", description: "内切核酸酶活性是指切割DNA链的酶活性，在本文中特指人脑内源性LINE-1 ORF2蛋白的活性。"},
  {name: "内切核酸酶非依赖性插入", description: "不依赖于内切核酸酶进行靶向DNA切割的逆转录转座插入机制。"},
  {name: "内切核酸酶非依赖性逆转录转座", description: "一种不依赖L1内切核酸酶活性的LINE-1逆转录转座途径。"},
  {name: "内切酶域功能", description: "LINE-1 ORF2蛋白的内切酶域除了切割DNA外，可能还具有逆转录转座所需的其他功能。"},
  {name: "内切酶活性", description: "LINE-1 ORF2蛋白所具有的切割靶DNA以启动逆转录整合的功能。"},
  {name: "内源性L1 mRNA水平", description: "指基因组内源性LINE-1转座子转录产生的信使RNA的表达量。"},
  {name: "内源性从头插入", description: "内源性从头插入是指基因组中原本存在的转座子发生新的插入事件。"},
  {name: "内源性诱变", description: "LINE-1逆转录转座是导致人类基因组发生内源性突变的重要机制。"},
  {name: "内源性调控", description: "基因组内存在的机制对转座子活性进行的调节。"},
  {name: "内源性逆转录转座", description: "内源性逆转录转座子（如LINE-1）在基因组中移动的过程。"},
  {name: "内部启动子", description: "位于LINE-1 5'非翻译区内的启动子序列，驱动其自身转录。"},
  {name: "内部引物", description: "内部引物是逆转录转座子整合的一种替代机制，逆转录可在3' poly-A尾上游启动。"},
  {name: "内部引物事件", description: "LINE-1逆转录转座过程中，其第一链cDNA合成可能由基因组内部的序列启动，而非仅依赖于其自身的RNA模板。"},
  {name: "内部重排", description: "指在逆转录转座事件中，转座子自身的结构发生改变。"},
  {name: "再激活", description: "处于沉默状态的基因或转座子重新恢复表达或活性的过程。"},
  {name: "再表达/重新激活", description: "原本沉默的基因或转座子重新开始表达的过程。"},
  {name: "分化程序下调", description: "指L1表达导致细胞分化相关分子标记表达减少，抑制细胞向成熟状态分化的过程。"},
  {name: "创建CpG岛", description: "LINE-1转座事件导致基因组中产生新的CpG岛。"},
  {name: "创建人类特异性调控位点", description: "转座子来源序列在人类胚胎干细胞基因组中形成候选的人类特异性调控位点。"},
  {name: "利用DNA修复机制", description: "逆转录转座子可以利用宿主细胞的DNA修复机制来完成其复制周期。"},
  {name: "利用切割的poly-T链作为引物", description: "L1-EN切割DNA产生的多聚T链可作为逆转录的引物。"},
  {name: "刺激先天免疫", description: "逆转录转座子的表达可以通过内源性模式刺激细胞的先天免疫反应。"},
  {name: "剪接抑制", description: "SAFB蛋白通过结合转座子序列，阻止其被剪接体识别和保留，从而抑制其外显子化。"},
  {name: "剪接整合逆转录元件形成", description: "由剪接后的L1 mRNA（如5'UTR内或5'UTR/ORF1剪接体）发生逆转录转座而产生的基因组元件。"},
  {name: "剪接缺陷", description: "转座子插入导致基因的mRNA前体剪接过程发生异常，是本文中NF1基因突变的主要效应。"},
  {name: "功能蛋白提供", description: "LINE-1编码的蛋白质被宿主利用，执行特定生物学功能。"},
  {name: "加工假基因形成", description: "加工假基因形成是LINE-1介导的逆转录转座事件的结果，导致无内含子的基因拷贝插入基因组。"},
  {name: "单体增强活性", description: "小鼠L1 5'UTR由串联重复的单体组成，其中第二个单体能一致地增强整体启动子活性。"},
  {name: "单体间相互作用", description: "小鼠L1启动子中，单体1、单体2和tether结构域之间存在复杂的、亚家族特异性的相互作用。"},
  {name: "单链DNA断裂", description: "由LINE-1内切酶诱导产生的DNA损伤，是LINE-1整合过程的关键步骤。"},
  {name: "单链核酸结合", description: "LINE-1编码的ORF1p蛋白能够结合单链核酸，并表现出核酸伴侣活性。"},
  {name: "单顺反子ORF2 mRNA表达", description: "单顺反子ORF2 mRNA表达是指仅编码ORF2蛋白的LINE-1转录本在人脑中的表达模式。"},
  {name: "印记基因表达异常", description: "基因的等位基因特异性表达模式发生改变，例如父源等位基因表达缺失。"},
  {name: "卵母细胞激活", description: "人类卵母细胞成熟和激活的过程，可由增加细胞内Ca2+和ROS水平的化合物诱导。"},
  {name: "卵裂异常", description: "胚胎细胞分裂过程中出现的加速、不对称分裂、卵裂停滞和退化等现象。"},
  {name: "去抑制", description: "去抑制是指转座子在特定条件下（如癌症中）从表观遗传沉默状态被重新激活。"},
  {name: "双向转录", description: "由LINE-1 5' UTR中的正义和反义启动子驱动的转录过程，产生正义和反义RNA。"},
  {name: "双向转录活性", description: "L1内部启动子能够驱动正义和反义两个方向的转录。"},
  {name: "双引物合成", description: "双引物合成是逆转录转座过程中的一种机制，涉及两个引物启动合成。"},
  {name: "双引物机制", description: "双引物机制是靶向引物逆转录的一种变体，可产生具有特殊序列结构的插入。"},
  {name: "双链断裂", description: "双链断裂是DNA双螺旋结构的两条链同时断裂的损伤类型。"},
  {name: "双链断裂修复", description: "细胞修复DNA双链断裂的机制，其动力学可被改变。"},
  {name: "反义转录", description: "从与编码链方向相反的DNA链上启动的转录过程。"},
  {name: "反式mRNA逆转录转座", description: "LINE-1具有在反式作用中动员mRNA序列，使其逆转录并插入基因组的能力。"},
  {name: "反式互补", description: "LINE-1的逆转录转座活性可以被其自身或其他元件的蛋白质产物在细胞质中提供功能支持。"},
  {name: "反式介导的细胞RNA动员", description: "指由LINE-1编码的蛋白质（ORF1p和ORF2p）促进非L1来源的细胞RNA（如Alu、SVA、U6 snRNA）进行逆转录转座的过程。"},
  {name: "反式作用介导", description: "LINE-1编码的蛋白质可以协助其他非自主逆转录转座子（如Alu）和细胞mRNA完成逆转录转座过程。"},
  {name: "反式促进逆转录转座", description: "LINE-1编码的蛋白质能够促进SINE RNA、非编码RNA和信使RNA的逆转录转座。"},
  {name: "反式剪接", description: "一种被提名可能导致LINE-1嵌合体形成的新颖分子机制。"},
  {name: "反式动员", description: "LINE-1编码的蛋白质机器动员其他非自主性逆转录元件（如SVA/LAVA）的过程。"},
  {name: "反式转座", description: "短散布核元件利用LINE-1提供的酶机制进行逆转录转座的过程。"},
  {name: "反式逆转录转座", description: "LINE-1介导其他序列（如Alu、SVA、mRNA）的逆转录转座过程。"},
  {name: "可遗传的结构变异", description: "基因组中可遗传的、涉及较大DNA片段（如插入、缺失、倒位）的变异。"},
  {name: "合子基因组激活", description: "胚胎发育早期，合子基因组从沉默状态被激活并开始转录的过程。"},
  {name: "合成暂停", description: "LINE-1逆转录酶在L1 mRNA 3'非翻译区进行DNA聚合时，因多嘌呤序列的rG串和相邻的茎环结构而出现强烈暂停。"},
  {name: "同源序列介导的重组", description: "当重组序列之间存在同源性时，会强烈诱导L1逆转录转座介导的重排。"},
  {name: "同源重组介导的基因组重排", description: "指LINE-1的大量同源拷贝在基因组异位位点间发生同源重组，导致基因组结构变异的过程。"},
  {name: "同源非依赖性修复", description: "一种双链断裂修复方式，在慢性双链断裂下其速率可能增加。"},
  {name: "启动子低甲基化", description: "L1启动子区域甲基化水平降低，与活性相关。"},
  {name: "启动子区CpG甲基化降低", description: "LINE-1启动子区域的CpG位点甲基化水平下降，通常与转录激活相关。"},
  {name: "启动子活性", description: "位于LINE-1 5'UTR内的启动子活性，对调节L1的多种活动至关重要。"},
  {name: "启动子活性降低", description: "剪接整合逆转录元件由于缺乏顺式作用转录因子结合位点而表现出的转录活性下降。"},
  {name: "启动子甲基化", description: "一种表观遗传修饰，通常抑制基因或转座子元件的活性。"},
  {name: "启动子结合", description: "特定蛋白质或蛋白质复合物与L1Hs启动子区域结合，调控其转录。"},
  {name: "启动子高密度胞嘧啶甲基化", description: "细胞通过LINE-1启动子的高密度胞嘧啶甲基化来下调其蛋白表达。"},
  {name: "在G1/S期阻滞细胞中转座", description: "LINE-1在细胞周期被阻滞在G1/S期的细胞中发生逆转录转座的现象。"},
  {name: "在分化原代体细胞中转座", description: "LINE-1在已分化的原代人体细胞中发生逆转录转座的现象。"},
  {name: "在核酸上形成紧密堆积的寡聚体", description: "ORF1p蛋白在单链DNA等核酸上快速组装成稳定、紧密排列的多聚体结构。"},
  {name: "在神经发生中表达", description: "LINE-1元件的转录激活模拟了NeuroD1基因的转录激活，表明其在神经发生过程中有重要作用。"},
  {name: "在细胞质灶中共定位", description: "ZAP与LINE-1 RNA、ORF1p以及应激颗粒相关蛋白在细胞质灶中共定位。"},
  {name: "在非分裂体细胞中转座", description: "LINE-1在已退出细胞周期的、非分裂的体细胞中发生逆转录转座的现象。"},
  {name: "基因/外显子/调控元件易位", description: "3'转导将基因、外显子和调控元件传播到基因组的新位置。"},
  {name: "基因功能破坏", description: "转座子插入可能干扰或中断基因的正常功能。"},
  {name: "基因型变异", description: "个体内不同细胞之间存在的基因组序列差异。"},
  {name: "基因复制", description: "病毒在捕获宿主基因后，能够快速复制这些基因，以促进自身适应。"},
  {name: "基因失活", description: "基因失活是指转座子插入基因编码区或调控区，导致基因功能丧失或表达沉默。"},
  {name: "基因完整性破坏", description: "转座子插入可能破坏基因的结构和功能。"},
  {name: "基因形成", description: "通过逆转录转座等事件，从现有基因产生新基因的过程。"},
  {name: "基因拷贝数变异", description: "基因组DNA片段拷贝数的增加或减少，是基因组不稳定性的标志之一。"},
  {name: "基因毒性应激", description: "基因毒性应激（如DNA双链断裂）可能协助转座子的动员。"},
  {name: "基因破坏", description: "L1逆转录转座子插入基因组可能破坏重要基因的功能。"},
  {name: "基因突变", description: "转座子重新激活可能导致基因组序列的改变。"},
  {name: "基因组DNA不稳定性", description: "基因组结构或序列完整性的破坏。"},
  {name: "基因组DNA损伤", description: "由LINE-1逆转录转座活动引起的基因组DNA结构破坏。"},
  {name: "基因组DNA缺失", description: "基因组DNA缺失是指LINE-1逆转录转座事件在靶位点导致伴随的基因组DNA序列丢失。"},
  {name: "基因组不稳定", description: "基因组不稳定是指基因组结构或序列发生改变的倾向，是癌症等疾病的重要驱动因素。"},
  {name: "基因组不稳定性", description: "基因组发生突变、重排等变化的倾向性增加的状态，与转座子插入活动相关。"},
  {name: "基因组低甲基化", description: "摘要中描述的现象，指基因组特定区域（如L1 5'-UTR）的CpG岛甲基化水平降低。"},
  {name: "基因组倒位", description: "基因组中一段DNA序列发生方向反转的事件。"},
  {name: "基因组分散", description: "DNA序列在基因组不同染色体位置广泛分布的现象。"},
  {name: "基因组功能障碍", description: "基因组功能异常，可由包括表观遗传改变在内的多种机制导致。"},
  {name: "基因组变异", description: "由转座子插入等事件引起的基因组结构变化。"},
  {name: "基因组变异性", description: "人类基因组的体细胞变异性与某些LINE-1亚家族的活性有关。"},
  {name: "基因组可塑性", description: "基因组结构发生改变的能力，LINE-1的逆转录转座活动是其主要驱动力之一。"},
  {name: "基因组多态性变异", description: "由LINE-1从头插入事件导致的人类基因组变异。"},
  {name: "基因组多样化", description: "由L1逆转录转座活动介导的基因组序列和结构的改变。"},
  {name: "基因组大片段重复", description: "在转座子插入位点出现的异常大片段DNA重复，具有潜在的致突变性。"},
  {name: "基因组完整性挑战", description: "指可能破坏基因组稳定性的因素或过程。"},
  {name: "基因组嵌合", description: "由于体细胞中发生LINE-1逆转录转座，导致个体内不同细胞基因组存在差异的现象。"},
  {name: "基因组序列偏好性", description: "在局部尺度上，L1的整合主要受基因组序列偏好性的限制。"},
  {name: "基因组扩张", description: "基因组扩张是指转座子通过持续的插入事件增加基因组的大小和复杂性。"},
  {name: "基因组损伤", description: "转座子活动可能通过插入或插入后机制对基因组完整性造成损害。"},
  {name: "基因组整合", description: "LINE-1元件整合进入宿主基因组的阶段。"},
  {name: "基因组索引", description: "通过体细胞RNA基因重组，将特定mRNA转录本的存在状态在特定时间背景下“冻结”并记录下来的过程。"},
  {name: "基因组结构变异", description: "基因组中DNA序列发生较大规模改变的现象，如插入、缺失、重复等。"},
  {name: "基因组缺失", description: "由LINE-1逆转录转座插入事件导致的大片段DNA序列丢失。"},
  {name: "基因组缺失和重排", description: "与Alu插入相关的基因组结构变异。"},
  {name: "基因组调控网络", description: "由基因组调控元件构成的网络，控制基因表达模式。"},
  {name: "基因组进化", description: "基因组进化是指基因组结构、序列和功能随时间发生的变化。"},
  {name: "基因组重排", description: "涉及染色体或大片染色体区域的重大改变，包括缺失、重复、插入、倒位或易位。"},
  {name: "基因组重排与不稳定性", description: "基因组结构发生改变或维持稳定的能力受损的状态。"},
  {name: "基因组镶嵌现象", description: "个体内不同细胞间存在基因组差异的现象，可由体细胞转座事件导致。"},
  {name: "基因结构改变", description: "基因结构改变是指转座子插入导致基因的DNA序列或组织发生改变。"},
  {name: "基因表达下调", description: "L1插入导致受影响等位基因的表达水平降低。"},
  {name: "基因表达差异修饰", description: "通过影响基因的表达水平来改变个体特征。"},
  {name: "基因表达干扰", description: "LINE-1元件通过提供功能性剪接位点，可能破坏正常基因表达或形成替代性mRNA转录本。"},
  {name: "基因表达改变", description: "转座子插入可能通过改变基因组调控区域来影响基因表达水平。"},
  {name: "基因表达破坏", description: "转座子插入基因内部（如内含子）导致该基因的正常表达被干扰或中断。"},
  {name: "基因表达紊乱", description: "基因表达模式发生异常改变，可能影响细胞功能。"},
  {name: "基因表达调控", description: "L1 DNA甲基化的改变可以局部影响基因的表达水平。"},
  {name: "基因表达重编程", description: "LINE-1活动对宿主基因表达模式的改变。"},
  {name: "基因转换", description: "一种同源重组事件，导致一个DNA序列被另一个同源序列所替换。"},
  {name: "基因进化", description: "基因进化是指基因在物种演化过程中通过突变、复制、重组等机制发生结构和功能变化的过程。"},
  {name: "基因递送", description: "利用腺病毒-L1嵌合载体将转基因高效递送至人类细胞的过程。"},
  {name: "增强子", description: "能够远距离调控基因转录活性的非编码DNA序列。"},
  {name: "增强子功能", description: "调控基因转录的DNA序列元件，能够增强附近基因的表达。"},
  {name: "增殖增加", description: "指L1表达导致细胞分裂速度加快，细胞数量增多的现象。"},
  {name: "复制", description: "复制是指LINE-1等逆转录转座子在基因组中扩增其拷贝数的过程。"},
  {name: "复制应激", description: "DNA复制过程受阻或出现错误，导致基因组不稳定的状态。"},
  {name: "复制性转座", description: "L1元件通过逆转录机制在基因组中移动并复制自身的过程。"},
  {name: "复杂易位", description: "涉及多个染色体断裂和重组的染色体结构变异。"},
  {name: "外显子化", description: "指转座子序列被剪接机制识别并保留在成熟mRNA中，成为外显子一部分的过程。"},
  {name: "外显子复制", description: "外显子复制是基因组中一个或多个外显子被复制到新位置的过程。"},
  {name: "外显子插入", description: "转座子插入到基因的外显子区域，可能直接影响蛋白质编码序列。"},
  {name: "外显子改组", description: "通过转座子介导的序列转导，将不同基因的外显子重新组合，创造新基因的过程。"},
  {name: "外显子洗牌", description: "通过转座事件将不同基因的编码序列（外显子）组合在一起，形成嵌合基因的机制。"},
  {name: "外显子混编", description: "LINE-1逆转录转座过程中，将其3'侧翼序列（如外显子）移动到新基因组位置的现象。"},
  {name: "外显子缺失", description: "LINE-1插入事件可能导致宿主基因的外显子序列被删除。"},
  {name: "外显子转导", description: "L1逆转录转座过程中可能携带并重新插入宿主基因的外显子序列。"},
  {name: "外泌体介导的抑制", description: "由细胞分泌的外泌体包裹APOBEC3蛋白，从而抑制逆转录转座子活性的过程。"},
  {name: "外源DNA整合", description: "克氏锥虫线粒体微环DNA整合到宿主基因组的过程。"},
  {name: "外源逆转录转座子整合", description: "来自外部的逆转录转座子序列被整合到宿主基因组中的过程。"},
  {name: "多态性插入", description: "指在群体中存在的、并非所有个体都携带的转座子插入，是基因组变异的一种形式。"},
  {name: "多聚泛素化与降解", description: "蛋白质被标记上多个泛素分子，从而被蛋白酶体识别并降解的过程。"},
  {name: "多聚腺苷酸化信号旁路", description: "LINE-1逆转录转座过程中，3'端加工机制可能绕过其自身的多聚腺苷酸化信号，转而利用下游的另一个多聚腺苷酸化位点。"},
  {name: "多能性因子表达异常", description: "在胚胎发育过程中，维持细胞多能性的关键转录因子（如OCT4, SOX2, NANOG）的表达模式发生改变。"},
  {name: "多重插入事件", description: "指在单个细胞或基因组中发生多次转座子插入的现象。"},
  {name: "大片段基因组缺失", description: "指在LINE-1插入事件中伴随发生的、涉及插入位点附近大片段的DNA缺失。"},
  {name: "大脑中的插入活动", description: "LINE-1在大脑中存在插入活动，但其功能意义和宿主细胞的调控机制尚不完全清楚。"},
  {name: "大脑特异性遗传镶嵌现象", description: "指L1在脑发育过程中的活动增加了大脑组织内细胞间的遗传异质性。"},
  {name: "大规模重复", description: "基因组中大片段的重复扩增。"},
  {name: "孟德尔遗传", description: "指遗传性状遵循孟德尔定律在家族中传递。"},
  {name: "宿主DNA修复因子", description: "参与修复DNA断裂的宿主细胞蛋白质，可调节LINE逆转录转座。"},
  {name: "宿主因子调控", description: "宿主细胞中的蛋白质或小RNA等因子对LINE-1逆转录转座活性进行上调或下调的调节过程。"},
  {name: "宿主基因组不稳定", description: "LINE-1转座活动频繁导致的宿主基因组结构或序列改变的状态。"},
  {name: "宿主基因组不稳定性", description: "宿主基因组结构或序列发生改变的倾向性增加。"},
  {name: "宿主基因表达调控", description: "宿主通过SAFB阅读器复合体结合m6A-L1s以降低其水平，并保护宿主基因转录的对抗机制。"},
  {name: "宿主细胞防御机制", description: "宿主细胞保护基因组免受不受控制的LINE-1介导的逆转录转座事件影响的机制。"},
  {name: "宿主限制", description: "宿主过程作用于限制L1在培养的人类细胞中的整合。"},
  {name: "宿主限制机制", description: "宿主细胞为限制LINE-1转座而发展的多种抑制机制。"},
  {name: "寿命变化", description: "个体生存时间的变化，在本研究中受父系辐射和I转座子活性的影响。"},
  {name: "小干扰RNA", description: "由长双链RNA加工产生的短RNA分子，是RNA干扰机制的核心效应分子。"},
  {name: "小胶质细胞激活", description: "中枢神经系统中小胶质细胞被激活的状态，是神经炎症的标志。"},
  {name: "尿苷化", description: "在线性RNA的3'末端添加尿苷残基的转录后修饰。"},
  {name: "局部转录激活模型", description: "在体细胞中，L1的转录激活受个体、位点和细胞类型特异性决定因素调控的模型。"},
  {name: "嵌合L1形成", description: "在逆转录转座过程中，内源性L1的5'端与工程化L1精确融合，形成新的嵌合体。"},
  {name: "嵌合体形成", description: "在基因组中形成由不同来源序列（如L1和小RNA基因序列）连接而成的DNA结构。"},
  {name: "嵌合基因", description: "由不同基因的部分序列融合形成的新基因，是基因组不稳定性的标志之一。"},
  {name: "嵌合插入", description: "LINE-1在转座过程中与非编码RNA或mRNA序列融合，形成杂合插入体的现象。"},
  {name: "嵌合转录本形成", description: "由L1 5'UTR的反义启动子产生的嵌合转录本。"},
  {name: "差异表达", description: "L1序列在不同细胞系（如NTera2D1和HeLa）中表达水平存在差异。"},
  {name: "干扰素（IFN）产生", description: "宿主细胞对病毒感染或转座子活动等危险信号产生的一种免疫反应。"},
  {name: "年龄相关炎症", description: "与衰老过程相关的慢性、低度炎症状态。"},
  {name: "年龄相关的LINE-1拷贝数变化", description: "指LINE-1拷贝数随年龄增长而发生的变化。"},
  {name: "序列动员", description: "LINE-1作为载体，能够将非L1序列（如外显子或启动子）移动到新的基因组位置。"},
  {name: "序列扩增", description: "基因组中特定DNA序列拷贝数增加的过程。"},
  {name: "序列特异性DNA识别", description: "L1内切酶通过其结构特征（如βB6-βB5发夹环）特异性识别并靶向TA连接处DNA序列。"},
  {name: "序列转导", description: "在逆转录转座过程中，位于转座子侧翼的宿主基因组序列被一同复制并插入新位点的现象。"},
  {name: "序列转座动员", description: "指活性LINE-1能够顺式或反式移动其他非自主序列（如逆转录假基因）或重复序列的过程。"},
  {name: "应激反应", description: "生物体对内部或外部压力（如辐射）的适应性反应，涉及转座子活性的改变。"},
  {name: "应激颗粒", description: "应激颗粒是细胞在压力条件下形成的、包含蛋白质和RNA的致密细胞质聚集体，含有停滞的翻译前起始复合物。"},
  {name: "应激颗粒定位", description: "LINE-1 ORF1蛋白定位于细胞质应激颗粒，这可能是一种调控机制。"},
  {name: "应激颗粒形成", description: "细胞在压力条件下，将翻译停滞的mRNA、RNA结合蛋白等聚集形成的无膜细胞器。"},
  {name: "底物偏好性", description: "LINE-1编码的蛋白质机器对不同非自主性逆转录元件（如SVA、LAVA）的动员效率差异。"},
  {name: "开放阅读框", description: "一段能够编码蛋白质的DNA序列，在功能性LINE-1元件中存在，是其具有转座活性的证据。"},
  {name: "异位重组", description: "基因组中同源或相似的转座子序列之间发生非等位重组，导致基因组重排。"},
  {name: "异位（非等位）重组", description: "发生在基因组中不同位置、序列相似的LINE-1元件之间的异常重组事件。"},
  {name: "异常mRNA剪接", description: "由于外源序列插入内含子，导致宿主基因mRNA剪接模式发生改变。"},
  {name: "异常免疫反应", description: "免疫系统功能失调，对自身或无害物质产生不适当的反应。"},
  {name: "异常剪接", description: "由于新剪接位点的引入，导致mRNA前体发生非正常剪接的过程。"},
  {name: "异常基因表达", description: "基因的表达水平或模式偏离正常状态。"},
  {name: "异常表观遗传调控", description: "DNA甲基化、组蛋白修饰等表观遗传机制的失调，导致转座子沉默失败或异常激活。"},
  {name: "异常表达", description: "转座子（如LINE-1）在特定组织或疾病状态下转录水平发生改变。"},
  {name: "异染色质化", description: "促进染色质结构变得紧密，从而抑制基因表达的表观遗传过程。"},
  {name: "异染色质转录", description: "在雌性减数分裂期间，转座子从异染色质区域被大量转录。"},
  {name: "形成L1核糖核蛋白", description: "LINE-1编码的蛋白质与其编码的转录本结合，形成介导逆转录转座的L1核糖核蛋白。"},
  {name: "形成加工假基因", description: "LINE-1能够逆转录细胞mRNA并将其插入基因组，导致无内含子的、无功能的基因拷贝形成。"},
  {name: "形成和运输L1核糖核蛋白颗粒", description: "LINE-1 ORF1蛋白与RNA结合形成复合物，并在细胞质中运输的过程。"},
  {name: "形成核糖核蛋白复合体", description: "LINE-1编码的ORF1p和ORF2p蛋白与L1 RNA结合，形成核糖核蛋白复合体。"},
  {name: "形成核糖核蛋白颗粒", description: "LINE-1的ORF1蛋白在体外与RNA结合，形成紧密堆积的簇状结构，模拟了逆转录转座中间体的结构。"},
  {name: "形成紧密压缩的核酸结合复合体", description: "由具有逆转录转座活性的ORF1p三聚体在结合核酸后，通过其卷曲螺旋结构域介导形成的高度有序、紧密的复合体状态。"},
  {name: "影响DNA甲基化", description: "新插入的CpG岛对其侧翼CpG位点的DNA甲基化状态产生梯度影响。"},
  {name: "影响基因组稳定性", description: "转座子的移动或异常表达可能导致DNA双链断裂、染色体重排等基因组损伤事件。"},
  {name: "影响基因组结构", description: "LINE-1通过其转座活动，在功能上与Alu元件和细胞基因相关联，从而影响基因组的塑造。"},
  {name: "影响染色质结构", description: "LINE-1转录的RNA可以影响染色质的结构。"},
  {name: "影响神经元转录表达", description: "LINE-1的插入能够显著影响神经元的转录表达，产生独特的神经元转录组。"},
  {name: "微卫星不稳定性", description: "由于DNA错配修复缺陷导致的微卫星序列长度改变，与转座子插入活动相关的表达特征在此类癌症中降低。"},
  {name: "微卫星产生", description: "指非LTR逆转录转座子（如LINE-1）整合到基因组时或整合后，作为新微卫星重复序列来源的过程。"},
  {name: "微同源介导的修复", description: "一种利用短同源序列进行DNA双链断裂修复的机制。"},
  {name: "微同源介导的末端连接", description: "一种可能用于解决不完全LINE-1逆转录转座中间体的细胞非同源DNA末端连接途径。"},
  {name: "微同源性", description: "插入序列与靶位点之间存在的短序列相似性，可能影响整合机制。"},
  {name: "微同源末端连接", description: "由6-22个富含AC的核苷酸重复序列介导的外源DNA整合机制。"},
  {name: "微同源驱动的单链退火", description: "一种用于解决L1倒位中间体的DNA修复过程。"},
  {name: "患者内肿瘤异质性", description: "同一患者体内不同肿瘤病灶或同一病灶内不同细胞群之间的差异。"},
  {name: "慢性DNA损伤", description: "持续或反复发生的DNA损伤状态。"},
  {name: "慢性炎症", description: "持续存在的低度炎症状态。"},
  {name: "截短的LINE-1逆转录转座", description: "截短的LINE-1逆转录转座是指LINE-1转座子发生不完整的逆转录转座事件，可能导致基因表达异常或功能获得。"},
  {name: "抑制Alu逆转录转座", description: "指APOBEC3H蛋白能够有效阻止Alu元件的逆转录转座过程。"},
  {name: "抑制L1逆转录转座", description: "ADAR1酶被证明具有抑制LINE-1转座子逆转录转座活性的功能。"},
  {name: "抑制LINE-1转座", description: "指APOBEC3H蛋白能够有效阻止LINE-1的逆转录转座过程。"},
  {name: "抑制LINE-1逆转录转座", description: "SAMHD1蛋白通过其磷酸化或特定氨基酸残基来负向调控LINE-1的逆转录转座活性。"},
  {name: "抑制减弱", description: "指细胞对LINE-1转座子的抑制机制在特定细胞类型（如生殖细胞或早期胚胎细胞）中减弱。"},
  {name: "抑制机制", description: "宿主细胞抑制LINE-1逆转录转座活性的机制。"},
  {name: "抑制逆转录转座", description: "抑制逆转录转座是指宿主因子通过特定机制阻止LINE-1等逆转录转座子的转座活性。"},
  {name: "抑制逆转录酶活性", description: "通过抑制LINE-1 ORF2蛋白的逆转录酶活性来限制其移动。"},
  {name: "抗病毒免疫反应", description: "由细胞质核酸感应通路激活引发的免疫应答。"},
  {name: "抗病毒免疫激活", description: "宿主细胞识别病毒成分并启动免疫反应的过程。"},
  {name: "抗病毒基因反应", description: "由血小板生成素促进的、类似于干扰素的基因表达反应，用于抑制逆转录转座子活性。"},
  {name: "拓扑关联结构域", description: "基因组中频繁发生内部互作的染色质区域，是染色质高级结构的基本单元。"},
  {name: "拷贝数变异形成", description: "基因组片段拷贝数增加或减少的结构变异。"},
  {name: "拷贝数改变", description: "癌症特异性的非整倍体变化，可能与ORF1p介导的免疫调节双重性有关。"},
  {name: "捕获宿主基因", description: "病毒基因组获取并整合宿主基因的过程。"},
  {name: "提供新的剪接位点或替代启动子", description: "LINE-1序列的插入可能为邻近基因提供新的转录起始位点或剪接方式，从而改变其表达。"},
  {name: "提供转录因子结合位点", description: "转座子来源序列含有假定的转录因子结合位点，成为调控元件。"},
  {name: "提供逆转录酶", description: "LINE-1能够编码并利用自身的逆转录酶，催化其自身RNA以及其他非自主逆转录元件（如Alu）的逆转录过程。"},
  {name: "提前多聚腺苷酸化", description: "一种通过产生截短的mRNA来下调LINE-1表达的次级机制。"},
  {name: "插入", description: "LINE-1的cDNA整合到宿主基因组新位置的过程。"},
  {name: "插入/缺失多态性", description: "由转座子插入或缺失事件导致的基因组结构变异。"},
  {name: "插入介导的缺失", description: "指在转座子插入过程中，导致其靶位点基因组序列发生缺失的机制。"},
  {name: "插入位点重排", description: "在LINE-1插入位点发生的基因组重排，可导致癌基因扩增。"},
  {name: "插入基因", description: "LINE-1能够插入到正在转录的基因中。"},
  {name: "插入多态性", description: "插入多态性是指转座子插入基因组特定位置在不同个体或群体中存在差异的现象。"},
  {name: "插入新拷贝", description: "LINE-1逆转录转座子通过逆转录转座机制在基因组中产生新的插入拷贝。"},
  {name: "插入机制", description: "指L1通过逆转录转座过程将其拷贝插入到基因组新位点的机制。"},
  {name: "插入沉默", description: "报告基因在通过L1逆转录转座整合入基因组后，被迅速且有效地抑制表达的现象。"},
  {name: "插入突变", description: "插入突变是指转座子插入基因组导致基因功能破坏或调控改变的过程。"},
  {name: "插入诱变", description: "转座子插入基因组导致基因功能破坏的过程。"},
  {name: "插入长度", description: "L1逆转录转座事件中插入到基因组中的L1序列的长度。"},
  {name: "整合", description: "逆转录转座子将其DNA拷贝插入宿主基因组的过程。"},
  {name: "整合位点偏好性", description: "指转座子倾向于插入到基因组特定序列或区域（如低GC含量区域）的特性。"},
  {name: "整合位点招募", description: "细胞蛋白（如PARP2和RPA）被募集到LINE-1整合位点的过程，以促进或限制转座。"},
  {name: "整合位点选择", description: "逆转录转座子插入基因组特定位置的过程，其特异性是整合位点选择的主要决定因素。"},
  {name: "整合入宿主基因组", description: "LINE-1编码的ORF1p和ORF2p蛋白与L1 RNA形成核糖核蛋白复合体，该过程是L1整合入宿主基因组所必需的。"},
  {name: "整合后选择", description: "自然选择对已存在的L1拷贝的分布有显著的重塑作用，表明整合后过程对内源性L1元件的分布起主导作用。"},
  {name: "整合过程", description: "在LINE-1逆转录转座过程中，新合成的cDNA整合到基因组DNA中的步骤。"},
  {name: "整合靶向", description: "指逆转录转座子整合到基因组DNA中的位点选择过程。"},
  {name: "断裂-融合-桥循环", description: "一种导致基因组不稳定的细胞周期过程，可引发基因扩增和重排。"},
  {name: "新基因生成", description: "通过mRNA逆转录转座并伴随5'端倒位，可能产生编码不同N末端肽段的新基因。"},
  {name: "新微卫星序列的创建", description: "LINE-1的插入事件是基因组中产生新的微卫星序列（短串联重复序列）的重要来源。"},
  {name: "新生插入", description: "在个体基因组中新发生的转座子插入事件。"},
  {name: "无义介导的mRNA降解", description: "一种细胞机制，能识别并降解含有提前终止密码子的异常mRNA。"},
  {name: "早期胚胎发育期转座", description: "内源性哺乳动物LINE-1在早期胚胎发育过程中自然发生的逆转录转座活动。"},
  {name: "早期胚胎沉默", description: "在胚胎发育早期阶段对特定基因或遗传元件（如逆转录元件）的转录抑制。"},
  {name: "替代性核酸内切酶活性", description: "LINE-1 ORF2蛋白中，由逆转录酶结构域介导的一种不同于经典核酸内切酶结构域的内切酶活性。"},
  {name: "有丝分裂期染色体结合", description: "在细胞中，L1 RNP凝聚物在有丝分裂期结合到染色体上。"},
  {name: "有害剪接", description: "由内含子中的插入序列诱导，导致外显子缺失和提前终止密码子产生的异常剪接。"},
  {name: "有害的逆转录转座事件", description: "可能导致基因功能破坏并诱发疾病的转座子插入事件。"},
  {name: "杂合性缺失", description: "一个等位基因丢失导致杂合性变为纯合性的现象，是基因组不稳定性的标志之一。"},
  {name: "来源追踪", description: "基于内部序列变异来追溯体细胞LINE-1插入事件的活性来源元件的策略。"},
  {name: "染色体不稳定性", description: "染色体不稳定性，指染色体结构或数目发生改变的倾向，是癌症基因组的一个特征。"},
  {name: "染色体倒位", description: "LINE-1插入事件可能引发的大规模染色体结构重排，导致一段染色体序列方向颠倒。"},
  {name: "染色体外DNA积累", description: "在HIV-1感染的原代CD4+细胞中，LINE-1 DNA主要以染色体外形式积累。"},
  {name: "染色体大片区域缺失", description: "由异常LINE-1整合事件导致的染色体上兆碱基规模区域的丢失。"},
  {name: "染色体整合", description: "逆转录转座的经典产物，转座子序列被整合到宿主染色体DNA中。"},
  {name: "染色体碎裂", description: "一种复杂的基因组重排现象，涉及染色体上发生大量DNA双链断裂和错误修复。"},
  {name: "染色体重排", description: "染色体结构发生改变，如缺失、重复、倒位、易位等，可能与转座子活动相关。"},
  {name: "染色体间易位", description: "不同染色体之间的片段交换，与内切核酸酶非依赖性LINE-1插入相关。"},
  {name: "染色质三维折叠", description: "线性染色质纤维在细胞核内形成的三维空间构象。"},
  {name: "染色质可及性改变", description: "染色质结构变化导致DNA可接近性增加或减少。"},
  {name: "染色质结构开放", description: "染色质从紧密状态转变为松散状态，使转录因子和RNA聚合酶易于接近DNA。"},
  {name: "染色质解凝聚", description: "染色质结构变得松散，通常与基因或转座子活性增加相关。"},
  {name: "核仁定位", description: "蛋白质在细胞核内特定亚结构核仁中的定位过程。"},
  {name: "核内定位", description: "LINE-1蛋白进入细胞核的过程，是其增殖所必需的一步。"},
  {name: "核孔蛋白相互作用", description: "LINE-1 ORF1p与核孔蛋白（如KPNA家族成员）结合，以促进其进入细胞核。"},
  {name: "核定位", description: "蛋白质被运输到细胞核内的过程，对于LINE-1 ORF1p的功能至关重要。"},
  {name: "核心启动子功能", description: "启动子中确保转录在正确位置起始的关键序列元件。"},
  {name: "核糖体停滞", description: "翻译过程中核糖体在mRNA特定位置停止移动的现象，可能由多种因素引发。"},
  {name: "核糖体关联", description: "Alu RNA通过其特定结构域与核糖体结合的过程，有助于其后续的逆转录转座。"},
  {name: "核糖核蛋白复合物形成", description: "LINE-1 RNA与自身编码的ORF1p和ORF2p蛋白结合形成核糖核蛋白复合物。"},
  {name: "核糖核蛋白颗粒形成", description: "LINE-1 RNA与自身编码的蛋白质结合形成复合物，这是其进行逆转录转座的关键步骤。"},
  {name: "核糖核蛋白（RNP）颗粒形成", description: "ORF1p、ORF2p和全长L1 mRNA结合形成L1 RNP颗粒，这是LINE-1逆转录转座所必需的。"},
  {name: "核膜破裂期核进入", description: "LINE-1蛋白和mRNA利用有丝分裂期间核膜破裂的时机进入细胞核。"},
  {name: "核苷酸切除修复", description: "一种修复DNA大片段损伤（如嘧啶二聚体）的修复途径，其激活与转座子插入活动相关。"},
  {name: "核表达", description: "蛋白质在细胞核中定位和表达的模式。"},
  {name: "核输入", description: "L1核糖核蛋白复合体进入细胞核的过程，是逆转录转座得以进行的关键步骤。"},
  {name: "核进入", description: "LINE-1 RNP复合物进入细胞核的过程，对逆转录转座至关重要。"},
  {name: "核酸伴侣活性", description: "LINE-1的ORF1p蛋白表现出核酸伴侣活性。"},
  {name: "核酸内切酶活性", description: "LINE-1编码的ORF2p蛋白具有切割DNA的活性。"},
  {name: "核酸内切酶非依赖性LINE-1逆转录转座", description: "一种不依赖LINE-1核酸内切酶活性，但依赖逆转录酶的LINE-1转座途径。"},
  {name: "核酸内切酶非依赖性整合", description: "一种不依赖于核酸内切酶的逆转录转座子基因组整合替代途径。"},
  {name: "核酸内切酶非依赖性逆转录转座", description: "LINE-1的一种替代性转座途径，不依赖于其核酸内切酶活性，可在非同源末端连接缺陷的细胞中发生。"},
  {name: "核酸分子伴侣活性", description: "ORF1p作为核酸分子伴侣，能以高亲和力结合核酸，在逆转录转座中发挥功能。"},
  {name: "核酸结合", description: "人类L1 ORF1蛋白以高亲和力结合核酸的能力。"},
  {name: "核酸酶活性", description: "LINE-1核糖核蛋白颗粒中存在的活性，可在启动逆转录前处理寡核苷酸接头。"},
  {name: "植入前发育", description: "胚胎从受精到植入子宫壁之前的早期发育阶段。"},
  {name: "模式识别受体感应", description: "TRIM5α作为模式识别受体识别LINE-1核糖核蛋白复合物。"},
  {name: "模板跳跃", description: "一种将新生LINE-1拷贝的5‘端连接到基因组靶位点的模型。"},
  {name: "模板转换", description: "LINE-1逆转录转座过程中招募细胞RNA的另一种途径，发生在细胞核内。"},
  {name: "模板转换机制", description: "LINE-1逆转录酶介导非L1 RNA逆转录转座的另一种机制。"},
  {name: "模板选择", description: "LINE-1逆转录转座过程中招募细胞RNA的一种途径。"},
  {name: "模板选择机制", description: "LINE-1逆转录酶介导非L1 RNA逆转录转座的一种机制。"},
  {name: "氧化应激", description: "一种促氧化状态，已知会增加LINE-1的表达。"},
  {name: "水平基因转移", description: "遗传物质在不同生物体之间的非垂直传递，是病毒获取宿主基因的重要途径。"},
  {name: "水平转移", description: "遗传物质（如转座子RNA）通过细胞外囊泡等途径在细胞间传递的过程。"},
  {name: "沉默解除", description: "细胞分裂或重金属等刺激因素可以移除L1元件的沉默状态，重启其功能。"},
  {name: "沉默调控", description: "在哺乳动物胚胎干细胞和生殖细胞中，通过复杂机制确保转座子处于失活状态的过程。"},
  {name: "泛素化", description: "泛素分子共价连接到靶蛋白上的翻译后修饰过程。"},
  {name: "活性增强", description: "转座子进行逆转录转座的能力得到提升。"},
  {name: "活性抑制", description: "LINE-1的基因间区（IGR）对逆转录转座活性具有抑制作用。"},
  {name: "液-液相分离", description: "MOV10、DCP2和LINE-1 RNP形成具有液体样性质的细胞质颗粒的物理过程。"},
  {name: "滋养层分化", description: "细胞滋养层（CTB）分化为合体滋养层（STB）的过程，对胎盘发育至关重要。"},
  {name: "激活致癌转录因子", description: "LINE-1编码的蛋白ORF1p和ORF2p可能具有激活致癌转录因子的能力。"},
  {name: "激活致癌通路", description: "通过插入突变等方式，导致与癌症发生发展相关的信号通路被异常激活。"},
  {name: "炎症", description: "由LINE-1逆转录转座子活动触发或增强的炎症反应。"},
  {name: "炎症反应", description: "机体对有害刺激（如病原体或损伤）的复杂生物反应。"},
  {name: "父系偏向性", description: "指逆转录转座事件在父系来源的配子或基因组中发生频率更高的现象。"},
  {name: "环境应激反应", description: "L1逆转录转座活性可被多种环境压力因素（如化学、物理、行为因素）所触发。"},
  {name: "生殖潜能降低", description: "个体繁殖后代的能力下降，在本研究中表现为SF不育。"},
  {name: "生殖系插入", description: "转座子在生殖细胞中发生插入，可导致遗传性变异和疾病。"},
  {name: "生殖系突变", description: "生殖系突变是指发生在生殖细胞中并可遗传给后代的基因突变。"},
  {name: "生殖系逆转录转座", description: "指在生殖细胞系中发生的逆转录转座事件，可遗传给后代。"},
  {name: "生殖系逆转录转座子插入多态性", description: "指在人类种群中通过生殖系传递的、由逆转录转座子插入导致的基因组序列差异。"},
  {name: "甲基化改变", description: "转座子（如LINE-1）的DNA甲基化水平在疾病状态下发生异常，通常与转录活性相关。"},
  {name: "病毒RNA逆转录与整合", description: "LINE-1介导的将SARS-CoV-2病毒mRNA逆转录并整合到宿主细胞基因组中的过程。"},
  {name: "病毒基因组整合", description: "病毒基因组整合是指病毒DNA序列插入宿主细胞基因组DNA中的过程。"},
  {name: "病毒模拟", description: "重复元件（如SINE）通过形成双链RNA等方式，模拟病毒感染，激活先天免疫系统。"},
  {name: "癌基因激活", description: "在肝细胞癌中，肿瘤特异性L1插入激活了癌基因ST18的表达。"},
  {name: "癌基因高水平扩增", description: "导致癌基因拷贝数显著增加，从而驱动肿瘤发生的过程。"},
  {name: "癌症基因组重塑", description: "在癌症发生发展过程中，基因组结构发生的广泛改变和重组。"},
  {name: "相分离", description: "ORF1蛋白在体外形成液滴的过程，由N端和卷曲螺旋结构域介导。"},
  {name: "短靶位点重复", description: "由LINE-1内切酶依赖机制在插入位点两侧产生的短重复序列。"},
  {name: "神经元体细胞嵌合", description: "个体内不同神经元基因组存在差异的现象，由新生L1逆转录转座事件导致。"},
  {name: "神经元基因组个体性", description: "神经元之间存在的DNA含量变异，是大脑中的常见现象，可能与记忆形成和疾病有关。"},
  {name: "神经元特异性转录", description: "指L1在神经元前体细胞中，其转录受到Sox2/HDAC1复合物向Wnt介导的TCF/LEF转录激活因子转换的调控。"},
  {name: "神经元细胞命运影响", description: "L1插入导致的基因表达改变可以影响神经元细胞在体外的命运。"},
  {name: "神经多样性诱导", description: "通过在大脑中诱导嵌合体现象来触发神经元的多样性。"},
  {name: "种系多态性", description: "转座子插入在种系细胞中产生并可遗传给后代的基因组差异。"},
  {name: "种系逆转录转座", description: "在生殖细胞中发生的LINE-1逆转录转座事件，可导致可遗传的插入等位基因。"},
  {name: "稳定基因沉默", description: "通过持续表达小干扰RNA（siRNA）实现长期抑制基因表达的过程。"},
  {name: "稳定整合", description: "外源转基因通过L1介导的逆转录转座过程，永久性地整合到宿主染色体中。"},
  {name: "稳定转导", description: "外源基因被稳定地整合并表达于宿主细胞中。"},
  {name: "端粒共定位", description: "LINE-1编码的蛋白质（如Orf1p）与端粒区域在空间上的物理接近或结合。"},
  {name: "端粒相关插入", description: "LINE-1转座子以特定方向插入到完美端粒重复序列（5'-TTAGGG-3'）附近的过程。"},
  {name: "端粒维持", description: "端粒维持是确保染色体末端端粒长度和结构稳定的过程，对细胞无限增殖至关重要。"},
  {name: "端粒重组机制", description: "端粒重组机制是一种不依赖于端粒酶的、基于DNA重组的端粒维持替代途径。"},
  {name: "端粒重编程", description: "在早期胚胎发育（如小鼠2细胞期）发生的端粒长度和结构的动态变化过程。"},
  {name: "端粒靶向", description: "在DNA蛋白激酶催化亚基缺陷细胞中，ENi逆转录转座事件被靶向到功能失调的端粒。"},
  {name: "等位基因异质性", description: "同一基因的不同等位基因在功能上存在显著差异的现象。"},
  {name: "精子介导的转座子转移", description: "精子细胞能够将外源逆转录转座子序列传递给卵母细胞的过程。"},
  {name: "精子端粒长度调节", description: "指精子中端粒长度随年龄增长而延长的现象。"},
  {name: "纤维化", description: "器官或组织中异常纤维结缔组织沉积的过程，在本文中发生在心脏。"},
  {name: "组织特异性表达", description: "摘要中提及的现象，逆转录转座子在不同组织中具有特定的表达模式。"},
  {name: "组蛋白修饰", description: "包括抑制性标记（如H3K9me3， H3K27me3）和激活标记（如H3K4me3， H3K9ac）在L1 5'UTR区域的动态变化，调控L1活性。"},
  {name: "组蛋白去乙酰化", description: "一种表观遗传沉默机制，可逆地沉默在体细胞发育后期（如癌细胞系）中移动的LINE-1报告基因插入。"},
  {name: "组蛋白甲基化", description: "发生在组蛋白尾部的甲基化修饰，影响染色质结构和基因表达。"},
  {name: "细胞凋亡", description: "指由LINE-1来源的核酸和蛋白质表达增加所诱导的程序性细胞死亡。"},
  {name: "细胞周期依赖性", description: "LINE-1的逆转录转座活性在细胞周期中表现出明显的偏向性，在S期达到峰值。"},
  {name: "细胞周期依赖性活性", description: "LINE-1 ORF1蛋白的定位和L1活性随着细胞周期的进程而变化。"},
  {name: "细胞周期依赖的抑制", description: "通过调控宿主细胞周期来抑制LINE-1的移动性。"},
  {name: "细胞周期退出", description: "细胞停止增殖的过程，在本文中由LINE-1再激活所诱导。"},
  {name: "细胞培养逆转录转座", description: "在细胞培养体系中研究逆转录转座子（如L1）的转座活性。"},
  {name: "细胞外囊泡介导的传递", description: "通过外泌体和微囊泡等细胞外囊泡将RNA等分子从供体细胞运送到受体细胞的过程。"},
  {name: "细胞外囊泡装载", description: "具有酶活性的LINE-1组分（mRNA、ORF1p、ORF2p）被包装并释放到细胞外囊泡中的过程。"},
  {name: "细胞多能性调控", description: "对细胞维持分化成多种细胞类型能力的调节过程。"},
  {name: "细胞应激诱导的转座子动员", description: "细胞内活性氧（ROS）和钙离子（Ca2+）水平升高等细胞应激状态可诱导转座子（包括LINE-1）的激活和移动。"},
  {name: "细胞抑制机制", description: "细胞为控制LINE-1活性而演化出的多种机制，例如通过MxB蛋白限制其转座。"},
  {name: "细胞毒性", description: "由LINE-1内切酶结构域（ENp）诱导DNA损伤所导致的细胞毒性效应。"},
  {name: "细胞活力降低", description: "细胞活力降低是指细胞增殖、存活或代谢能力下降的状态。"},
  {name: "细胞类型特异性调控", description: "L1HS-Ta的转录活性在不同细胞系中受到差异调节。"},
  {name: "细胞衰老", description: "细胞进入一种稳定的、不可逆的生长停滞状态，并伴随衰老相关分泌表型的分泌。"},
  {name: "细胞衰老生物标志物", description: "细胞衰老生物标志物是指能够指示细胞进入衰老状态的分子或特征。"},
  {name: "细胞质DNA积累", description: "细胞质中异常存在的DNA，可触发先天免疫反应。"},
  {name: "细胞质应激颗粒靶向", description: "LINE-1核糖核蛋白颗粒被运输并定位于细胞质应激颗粒的过程。"},
  {name: "细胞质核酸感应通路激活", description: "LINE-1可作为内源性上游激活剂，激活细胞质核酸感应通路。"},
  {name: "细胞质焦点定位", description: "LINE-1编码的蛋白质和RNA定位于细胞质中的特定焦点，这些焦点常与应激颗粒相关。"},
  {name: "细胞质相互作用", description: "TRIM5α在细胞质中与LINE-1核糖核蛋白复合物相互作用，这对限制LINE-1至关重要。"},
  {name: "细胞质表达", description: "蛋白质在细胞质中定位和表达的模式。"},
  {name: "细胞迁移", description: "细胞从一个位置移动到另一个位置的过程。"},
  {name: "细胞适应性", description: "细胞在压力或变化环境中调整其功能或状态的能力。"},
  {name: "终止/再起始机制", description: "一种特定的非常规翻译机制，涉及翻译终止后在同一mRNA上重新起始翻译。"},
  {name: "经典的两击CRC通路", description: "结直肠癌发生的一种经典模型，需要两个等位基因的肿瘤抑制基因（如APC）均失活。"},
  {name: "结合LINE-1 RNP复合体", description: "ADAR1蛋白能够与LINE-1的核糖核蛋白复合体结合。"},
  {name: "结合关键调控因子", description: "转座子来源的候选人类特异性调控位点能够选择性和位点特异性地结合NANOG、POU5F1、CTCF、Lamin B1等关键调控因子。"},
  {name: "结合单链核酸", description: "LINE-1的ORF1p蛋白是一种同源三聚体磷蛋白，能以高亲和力结合单链核酸。"},
  {name: "结构依赖性内切酶活性", description: "ORF2p结合双链DNA区域并识别下游的分叉或瓣状结构以实现高效DNA切割的机制。"},
  {name: "结构变异", description: "转座子（如SVA）或线粒体DNA（numts）通过逆转录转座或整合过程，在基因组中产生新的插入，导致DNA序列的结构改变。"},
  {name: "结构变异形成", description: "基因组中DNA序列发生较大规模改变的过程，包括缺失、重复、插入和倒位等。"},
  {name: "结构域灵活性调控", description: "L1ORF1蛋白各结构域之间的连接具有高度灵活性，这种灵活性的精确控制对逆转录转座活性至关重要。"},
  {name: "结构基因组变异", description: "由持续的LINE-1逆转录转座活动引起的基因组结构变化。"},
  {name: "结构约束", description: "L1和Alu转座子3'-末端茎环结构所必须满足的物理、化学和几何特性。"},
  {name: "缺乏RNase H活性", description: "LINE-1 ORF2蛋白在体外缺乏RNase H活性，这是其与逆转录病毒逆转录酶的区别之一。"},
  {name: "罕见或私有生殖系插入", description: "指在群体中频率极低或仅在特定个体/家系中发现的、新发生的生殖系转座子插入。"},
  {name: "翻译", description: "以mRNA为模板合成蛋白质的过程。"},
  {name: "翻译后调控", description: "大脑中可能存在介导LINE-1活性翻译后调控的因子，以解释不同个体间ORF1p表达的差异。"},
  {name: "翻译效率增强", description: "eIF3结合到L1 RNA的m6A修饰位点后，增强了L1蛋白的翻译效率。"},
  {name: "翻译调控", description: "翻译调控是控制蛋白质合成速率的过程，也用于限制逆转录转座子蛋白的产生。"},
  {name: "聚合", description: "人类L1 ORF1蛋白在低盐条件下形成聚合物的过程。"},
  {name: "肿瘤内异质性", description: "同一肿瘤内不同癌细胞在基因型或表型上的差异，与治疗抵抗和预后不良相关。"},
  {name: "肿瘤基因组可塑性", description: "肿瘤细胞基因组在进化过程中发生动态变化的能力。"},
  {name: "肿瘤抑制功能", description: "在特定条件下抑制肿瘤发生或发展的作用，本文中LINE-1在髓系白血病中表现出此功能。"},
  {name: "肿瘤抑制基因失活", description: "通过插入突变等方式导致肿瘤抑制基因功能丧失的过程。"},
  {name: "肿瘤抑制基因缺失", description: "由于基因缺失或失活导致其抑制肿瘤生长的功能丧失。"},
  {name: "肿瘤特异性插入", description: "在肿瘤组织中特异性发生的转座子插入事件。"},
  {name: "肿瘤突变负荷", description: "肿瘤基因组中每百万碱基对中体细胞突变的数量，是基因组不稳定性的标志之一。"},
  {name: "胚胎发生基因功能破坏", description: "指对胚胎发育至关重要的基因功能被破坏。"},
  {name: "胚胎发育受损", description: "逆转录转座子RNA的过表达会影响胚胎形态并损害植入前发育。"},
  {name: "胚胎期整合", description: "转座子整合事件主要发生在胚胎发育阶段，而非生殖细胞中。"},
  {name: "胞嘧啶甲基化", description: "一种表观遗传修饰，在胚胎干细胞和成年小鼠体细胞组织中对新插入的LINE-1序列进行快速沉默。"},
  {name: "胞嘧啶脱氨", description: "APOBEC3A酶将单链DNA底物中的胞嘧啶核苷酸催化脱氨基为尿嘧啶核苷酸（C-to-U）的过程。"},
  {name: "胞苷脱氨", description: "由APOBEC3蛋白介导的DNA修饰过程，可能限制LINE-1逆转录转座。"},
  {name: "胞苷脱氨酶介导的调控", description: "AID/APOBEC家族蛋白通过将DNA或RNA中的胞嘧啶脱氨基为尿嘧啶来调控LINE-1活性。"},
  {name: "胞质定位", description: "LINE-1 ORF1p蛋白主要定位于细胞质中的RNA颗粒（如P-body）。"},
  {name: "胰岛素信号通路", description: "胰岛素信号通路是细胞响应胰岛素刺激，调控代谢、生长和存活的关键信号转导网络。"},
  {name: "脱氨基非依赖性抑制", description: "APOBEC1蛋白抑制LINE-1转座活性的一种不依赖于其胞苷脱氨酶活性的机制。"},
  {name: "脱氨酶依赖性抑制", description: "APOBEC3蛋白通过其胞嘧啶脱氨酶活性，将LINE-1 cDNA上的胞嘧啶脱氨基为尿嘧啶，导致cDNA降解的抑制机制。"},
  {name: "脱氨酶非依赖性抑制", description: "APOBEC3蛋白不依赖其胞嘧啶脱氨酶活性，通过物理阻断等方式抑制LINE-1逆转录转座的机制。"},
  {name: "腺嘌呤甲基化", description: "腺嘌呤甲基化（m6A）是一种常见的RNA转录后修饰，参与调控包括逆转录转座子RNA在内的RNA代谢。"},
  {name: "腺苷脱氨酶介导的调控", description: "ADAR酶通过将双链RNA中的腺苷脱氨基为肌苷来调控LINE-1活性。"},
  {name: "自主性逆转录转座", description: "LINE-1转座子自身编码逆转录和整合所需蛋白，实现“复制-粘贴”式的基因组移动。"},
  {name: "自主细胞生长", description: "转化细胞在不受外界信号持续刺激下仍能持续增殖的能力。"},
  {name: "自主转录", description: "LINE-1通过其5'UTR内的内部启动子驱动自身转录，这是其自主性的关键。"},
  {name: "自主逆转录转座", description: "转座子（如LINE-1）利用自身编码的酶（逆转录酶和内切酶）完成“复制-粘贴”式移动的过程。"},
  {name: "自噬", description: "自噬是一种细胞降解和回收细胞成分的过程，可能参与清除逆转录转座子成分。"},
  {name: "自我转座", description: "LINE-1元件自身在基因组中移动的过程。"},
  {name: "自然遗传变异", description: "自然遗传变异是指种群或品系间存在的遗传差异，本文中主要由L1逆转录转座驱动。"},
  {name: "自身逆转录转座", description: "LINE-1能够介导其自身序列在基因组中的复制和插入。"},
  {name: "致病机制", description: "指转座子通过其活性参与疾病发生发展的过程。"},
  {name: "致病突变", description: "由LINE-1逆转录转座活动在人类基因组中引起的可导致疾病的突变。"},
  {name: "芳烃受体激活", description: "由配体（如苯并芘）激活AhR转录因子，是本文中LINE-1再激活的上游事件。"},
  {name: "蛋白-DNA相互作用", description: "ORF1p与核酸（包括DNA）之间的复杂结合特性，可通过单分子力谱等方法研究。"},
  {name: "蛋白质-蛋白质相互作用", description: "ORF1p能够与其他蛋白质发生相互作用。"},
  {name: "蛋白隔离", description: "MxB蛋白与LINE-1的ORF1p结合，并将其隔离在含有G3BP1的细胞质颗粒中。"},
  {name: "融合转录本表达", description: "由转座子序列与宿主基因序列连接形成的嵌合RNA分子的产生。"},
  {name: "表型变异性", description: "同一基因型个体间表现出的不同表型特征。"},
  {name: "表观遗传修饰", description: "不改变DNA序列但影响基因表达的机制，易受环境因素影响。"},
  {name: "表观遗传修饰改变", description: "表观遗传修饰改变是指不改变DNA序列的情况下，通过化学修饰（如组蛋白修饰、DNA甲基化）影响基因表达。"},
  {name: "表观遗传失调", description: "L1逆转录转座可能引发或伴随DNA甲基化、组蛋白修饰等表观遗传状态的异常改变。"},
  {name: "表观遗传抑制解除", description: "抑制性表观遗传标记（如MeCP2和H3K9me3）与LINE-1序列的结合减少，导致其表达增加。"},
  {name: "表观遗传染色质凝聚", description: "一种通过染色质修饰（如组蛋白甲基化）来有效抑制LINE-1表达的机制。"},
  {name: "表观遗传沉默", description: "表观遗传沉默是通过DNA甲基化、组蛋白修饰等方式抑制转座子活性的过程。"},
  {name: "表观遗传激活", description: "不改变DNA序列，通过调控基因或转座子表达水平的方式。"},
  {name: "表观遗传调控", description: "Zfp281调控的LINE-1元件高度富集5-羟甲基胞嘧啶和H3K4me3组蛋白修饰，其表达受Mll2、Tet1和Sin3A等因子调控。"},
  {name: "表观遗传调控改变", description: "L1 5'UTR的表观遗传调控发生改变，与精神疾病的病理生理学有关。"},
  {name: "表达", description: "指基因或转座子编码的蛋白质（如ORF1p）被转录和翻译的过程。"},
  {name: "表达上调", description: "表达上调是指基因或转座子转录水平异常升高的现象。"},
  {name: "表达增加", description: "基因或转座子转录本水平的升高。"},
  {name: "表达异常", description: "转座子表达水平发生改变，如去抑制后表达增加。"},
  {name: "表达调控", description: "在人类胚胎干细胞中，L1/Alu元件的表达受到表观遗传控制。"},
  {name: "衰老", description: "细胞或生物体随时间推移功能逐渐衰退的过程，本文中与LINE-1活性增强相关。"},
  {name: "衰老样表型", description: "细胞在表达外源性全长LINE-1或SpORF2 mRNA后表现出的类似衰老的状态。"},
  {name: "衰老相关炎症", description: "衰老细胞中因LINE-1等元件去抑制而引发的慢性、低度炎症状态。"},
  {name: "衰老细胞炎症", description: "在衰老细胞中，LINE-1活动所增强的炎症状态。"},
  {name: "被L1机制识别", description: "mRNA的3'-末端茎环结构可能被LINE-1的逆转录转座机制所识别和利用的潜在能力。"},
  {name: "记忆痕迹固定", description: "将与记忆痕迹相关的特定神经元分化或活动状态的信息记录并保存下来的过程。"},
  {name: "诱变", description: "指导致DNA序列发生改变的过程，LINE-1逆转录转座可通过插入等方式引发突变。"},
  {name: "诱导DNA损伤", description: "特指LINE-1内切酶结构域（ENp）切割DNA并造成损伤的能力。"},
  {name: "诱导细胞衰老", description: "一种肿瘤保护系统，使细胞停止分裂。"},
  {name: "诱导表达", description: "指特定转录因子或蛋白能够激活下游基因或转座子表达的过程。"},
  {name: "调控元件获取", description: "启动子失活的LINE-1位点从邻近基因获取调控元件以恢复其逆转录转座活性的过程。"},
  {name: "调控基因表达", description: "TET酶与多能性因子共同结合增强子样转座子，调控胚胎干细胞中高表达基因的表达。"},
  {name: "调节免疫刺激性SINE表达", description: "LINE-1的移动性可以调控SINE的表达，从而影响免疫反应。"},
  {name: "调节基因表达", description: "转座子序列通过提供启动子、增强子或顺式调控元件等方式，影响邻近基因的转录活性。"},
  {name: "谷氨酰胺酶C产生增加", description: "谷氨酰胺酶C是调控谷氨酸合成的关键酶，其产生增加可能导致谷氨酸水平升高。"},
  {name: "负反馈环路中断", description: "L1插入ST18基因，阻断了ST18对其增强子的抑制，从而中断了一个负反馈环路。"},
  {name: "负选择", description: "负选择是一种进化力量，倾向于清除有害的遗传变异，如破坏基因功能的转座子插入。"},
  {name: "负选择（净化选择）", description: "自然选择过程，倾向于从种群中移除有害的等位基因或遗传元件。"},
  {name: "超级增强子结构域", description: "富含超级增强子的特定亚拓扑关联结构域结构。"},
  {name: "转导", description: "转导是指LINE-1等逆转录转座子在转座过程中，将自身3‘或5’端的非重复序列（独特序列）一同携带并插入到基因组新位点的现象。"},
  {name: "转座/移动", description: "LINE-1元件在基因组中发生位置改变的过程。"},
  {name: "转座元件激活", description: "转座元件从沉默状态转变为活跃状态，可能导致其移动和插入。"},
  {name: "转座动员", description: "指一种转座子（如LINE-1）编码的蛋白质能够介导另一种转座子（如Alu）的移动。"},
  {name: "转座子表达上调", description: "转座子转录水平或蛋白水平的增加。"},
  {name: "转录", description: "基因或转座子序列被读取并合成RNA的过程。"},
  {name: "转录去抑制", description: "通过抑制DNA甲基转移酶等方式，解除对转座子转录的抑制。"},
  {name: "转录后基因组防御机制", description: "在转录后水平抑制转座子活性的保护机制。"},
  {name: "转录后抑制", description: "Microprocessor复合物通过识别和结合LINE-1 RNA，并在体外切割其结构区域，从而在转录后水平抑制其活性。"},
  {name: "转录后调控", description: "在转录完成后对RNA或蛋白质水平进行的调控机制。"},
  {name: "转录因子结合位点", description: "转录因子特异性识别并结合的DNA序列。"},
  {name: "转录基因沉默", description: "新插入的序列在癌细胞系中经历快速的转录水平基因沉默。"},
  {name: "转录延伸缺陷", description: "由于序列中高腺苷含量导致的转录效率低下。"},
  {name: "转录异常", description: "转录异常是指基因转录过程发生改变，导致产生异常的转录本。"},
  {name: "转录抑制", description: "通过阻断RNA聚合酶II的招募来抑制基因转录的过程。"},
  {name: "转录水平调控", description: "在细胞周期停滞的细胞中，L1转录本水平显著降低，这限制了逆转录转座的发生。"},
  {name: "转录沉默", description: "通过表观遗传修饰（如H3K9me3）抑制基因或转座子转录活性的过程。"},
  {name: "转录活性", description: "指转座子被RNA聚合酶识别并转录生成RNA的过程。"},
  {name: "转录激活", description: "在特定条件下，如神经元分化过程中，LINE-1基因表达水平升高的过程。"},
  {name: "转录相关性", description: "转录相关性指不同基因或元件的转录活性在特定组织或条件下表现出共变或关联的现象。"},
  {name: "转录表达", description: "指基因或转座子序列被转录成RNA的过程。"},
  {name: "转录调控", description: "通过控制基因的转录水平来调节基因表达的过程。"},
  {name: "转录调控失调", description: "在癌细胞中，LINE-1的转录调控机制可能发生异常，导致其异常表达或活性改变。"},
  {name: "转录起始", description: "RNA聚合酶在启动子区域特定位置（+1位点）开始合成RNA的过程。"},
  {name: "转录起始位点分布", description: "指基因或转座子启动子区域转录起始位点的具体位置和模式，与转录活性相关。"},
  {name: "逆转座", description: "LINE-1通过“复制-粘贴”机制在基因组中移动的过程。"},
  {name: "逆转录", description: "以RNA为模板合成DNA的过程。"},
  {name: "逆转录和整合", description: "LINE-1编码的ORF2蛋白介导的，将RNA逆转录为DNA并插入基因组新位点的过程。"},
  {name: "逆转录引物", description: "L1内切核酸酶切割产生的3'-OH末端可作为逆转录的引物。"},
  {name: "逆转录整合", description: "指SARS-CoV-2 RNA被逆转录并整合到人类细胞DNA中的过程，摘要中提出该过程可能由L1逆转录转座子机制介导。"},
  {name: "逆转录起始", description: "逆转录起始是逆转录转座过程中，逆转录酶以转座子转录本为模板开始合成cDNA的关键步骤。"},
  {name: "逆转录起始抑制", description: "阻止LINE-1 mRNA逆转录为cDNA的初始步骤。"},
  {name: "逆转录转座", description: "逆转录转座是逆转录转座子通过“复制-粘贴”机制在基因组中移动的过程。"},
  {name: "逆转录转座介导的缺失", description: "一种由逆转录转座事件（如Alu元件的插入）引发的基因组DNA序列缺失的机制。"},
  {name: "逆转录转座复合体相互作用", description: "逆转录转座复合体组分与参与L1复制的潜在细胞伙伴之间的相互作用。"},
  {name: "逆转录转座子介导的序列转导", description: "逆转录转座子在转座过程中携带并复制其侧翼序列的机制。"},
  {name: "逆转录转座子动员", description: "逆转录转座子移动到基因组新位置的过程，是基因组进化的主要驱动力，但也可能导致突变。"},
  {name: "逆转录转座子插入多态性", description: "逆转录转座子插入多态性是指在特定基因组位置上，不同人群间存在或不存在逆转录转座子插入的遗传变异。"},
  {name: "逆转录转座子活性抑制", description: "抑制逆转录转座子（如LINE-1）活性的功能，是L1-SIRT6相互作用网络富集的通路之一。"},
  {name: "逆转录转座机制", description: "LINE-1通过RNA中间体进行“复制-粘贴”式移动的分子机制。"},
  {name: "逆转录转座活性", description: "逆转录转座活性是指逆转录转座子通过RNA中间体进行“复制-粘贴”式移动的能力。"},
  {name: "逆转录转座相关DNA损伤", description: "由LINE-1逆转录转座活动引发的DNA损伤。"},
  {name: "逆转录转座能力", description: "部分表观遗传活跃的L1具有的、能够在基因组中移动的能力。"},
  {name: "逆转录转座诱导的突变发生", description: "由逆转录转座子（如LINE-1）的插入活动引起的基因组突变过程。"},
  {name: "逆转录酶保真性", description: "L1逆转录酶能够忠实复制其自身转录本，碱基错配率约为1/7000。"},
  {name: "逆转录酶和核酸内切酶活性", description: "LINE-1的ORF2p蛋白提供逆转录酶和核酸内切酶活性。"},
  {name: "逆转录酶抑制剂敏感性", description: "LINE-1逆转录酶对核苷类逆转录酶抑制剂敏感，但对非核苷类抑制剂不敏感的特性。"},
  {name: "逆转录酶活性", description: "逆转录酶活性是指将RNA逆转录为DNA的酶活性，在本文中特指人脑内源性LINE-1 ORF2蛋白的活性。"},
  {name: "造血干细胞功能丧失", description: "造血干细胞因DNA损伤等原因导致的自我更新和分化能力下降。"},
  {name: "遗传不稳定性", description: "基因组结构或序列发生改变的状态，LINE-1对此有主要贡献。"},
  {name: "遗传变异", description: "生物体基因组中发生的可遗传的序列或结构变化。"},
  {name: "遗传损伤", description: "由转座子活动或异常重组导致的基因组DNA序列改变或结构变异。"},
  {name: "遗传改变", description: "由外源逆转录转座子整合或新转座事件引起的基因组序列变化。"},
  {name: "遗传突变", description: "由转座子活动引起的基因组序列改变。"},
  {name: "遗传网络改变", description: "转座子插入可能影响基因之间的相互作用网络。"},
  {name: "重组", description: "遗传物质交换或重排的过程，可能导致基因组结构变异。"},
  {name: "重组机制", description: "基因组DNA断裂和异常修复导致基因重排的过程。"},
  {name: "重金属暴露影响转座频率", description: "暴露于铅等重金属可能直接影响ORF1p的结构参数，从而影响LINE-1的整体逆转录转座频率。"},
  {name: "铅离子结合", description: "LINE-1的开放阅读框1蛋白（ORF1p）能够结合多个铅离子，其结构中的三半胱氨酸层可作为金属结合位点。"},
  {name: "错配修复", description: "一种纠正DNA复制过程中错配碱基的修复途径，其激活与转座子插入活动相关。"},
  {name: "错配延伸", description: "LINE-1 ORF2p逆转录酶能够在DNA引物3‘末端存在碱基错配的情况下，仍能将其延伸的能力。"},
  {name: "镶嵌重组", description: "插入片段在基因组中发生的后续重排和组合。"},
  {name: "长期基因表达", description: "外源基因在宿主细胞中实现稳定、持久的表达。"},
  {name: "间充质向上皮细胞转化", description: "是肾脏发生过程中的一个关键细胞分化事件，L1可以破坏这一过程。"},
  {name: "间接复制非自主逆转录转座子", description: "LINE-1能够通过其逆转录机制，间接复制并促进非自主逆转录转座子（如SINEs）在基因组中的扩增。"},
  {name: "限制逆转录转座", description: "宿主因子（如APOBEC3B）抑制LINE-1等逆转录元件移动的过程。"},
  {name: "随机插入诱变", description: "利用L1元件的逆转录转座活性，将其作为载体随机插入基因组以产生突变。"},
  {name: "隔离肿瘤抑制因子", description: "LINE-1编码的蛋白ORF1p和ORF2p可能通过结合并隔离肿瘤抑制因子来发挥促癌作用。"},
  {name: "非L1转录本的逆转录转座", description: "ORF1p在TPRT过程中从其RNA模板上被置换后，可能结合并破坏下游剩余的L1 RNP，使其易被非L1模板劫持，从而实现非L1转录本的逆转录转座。"},
  {name: "非LTR逆转录转座", description: "非LTR逆转录转座是LINE-1等逆转录转座子通过'复制-粘贴'机制在基因组中移动的过程。"},
  {name: "非功能性ORF1p变异体产生", description: "由5'UTR/ORF1剪接整合逆转录元件编码的、功能受损的ORF1蛋白。"},
  {name: "非参考L1多态性插入", description: "在个体间存在或缺失的L1插入，未在当前基因组版本中注释。"},
  {name: "非同源末端连接", description: "一种DNA双链断裂修复途径，其激活与转座子插入活动相关。"},
  {name: "非常规翻译机制", description: "一种不依赖于标准起始密码子AUG的蛋白质翻译方式。"},
  {name: "非插入机制", description: "指L1不依赖于基因组插入，而是通过其他方式（如影响基因表达网络）发挥作用的机制。"},
  {name: "非等位同源重组", description: "基因组中同源序列（如Alu元件）之间发生错误配对和重组，导致基因缺失或重排的机制。"},
  {name: "非等位基因同源重组", description: "由侧翼重复序列（如节段性重复或逆转录转座子）介导的、可能导致基因组重排的异常重组过程。"},
  {name: "非编码RNA调控", description: "L1 RNA在非编码水平上发挥调控作用，影响细胞有丝分裂潜能。"},
  {name: "靶位点切割", description: "L1内切核酸酶切割基因组DNA，为L1插入创造靶位点。"},
  {name: "靶位点复制", description: "转座子插入后，在插入位点两侧产生的一段短的正向重复序列。"},
  {name: "靶位点引发的逆转录", description: "LINE-1通过靶位点引发的逆转录将其转录本复制到基因组DNA中。"},
  {name: "靶位点引发逆转录", description: "LINE-1转座子通过其ORF2蛋白的核酸内切酶切割基因组DNA，产生3'-羟基末端，再由逆转录酶启动cDNA合成的转座机制。"},
  {name: "靶位点引物逆转录", description: "一种依赖于核酸内切酶的逆转录转座子整合机制。"},
  {name: "靶位点选择", description: "LINE-1转座子通过其核酸内切酶结构域识别并切割特定基因组序列，决定其插入位置。"},
  {name: "靶位点重复", description: "LINE-1逆转录转座插入基因组后，在插入位点两侧产生的短DNA重复序列，是其转座的标志性特征。"},
  {name: "靶向DNA切割", description: "由NLR编码的蛋白质催化的、对目标DNA链进行切割的反应。"},
  {name: "靶向引发逆转录转座", description: "一种逆转录转座机制，转座子通过逆转录其RNA并在基因组新位点整合DNA拷贝进行移动。"},
  {name: "靶向引物逆转录", description: "LINE-1通过逆转录其mRNA到新的基因组位置进行增殖的过程。"},
  {name: "靶向插入", description: "通过融合DNA结合域（DBD）引导LINE-1 ORF2蛋白，使其驱动的逆转录转座事件发生在基因组特定位点。"},
  {name: "靶基因组DNA缺失", description: "目标基因组DNA片段的丢失，与内切核酸酶非依赖性LINE-1插入相关。"},
  {name: "靶基因表达改变", description: "LINE-1逆转录转座插入基因组后，可能导致插入位点附近基因的表达发生变化。"},
  {name: "靶标引发逆转录", description: "靶标引发逆转录是自主非长末端重复逆转录转座子通过靶DNA切割和逆转录的协同反应进行逆转录转座的机制。"},
  {name: "靶标引物逆转录", description: "LINE-1逆转录转座过程中，以内切酶切割DNA产生的3'-OH为引物启动cDNA合成的机制。"},
  {name: "顺式/反式协助逆转录", description: "LINE-1不仅能够自我复制，还能协助其他RNA（如mRNA、小RNA）进行逆转录和基因组插入。"},
  {name: "顺式作用", description: "LINE-1为其他可移动元件（如Alu）的逆转录转座提供必要的分子机器。"},
  {name: "顺式偏好", description: "L1倾向于逆转录转座其自身正在被翻译的转录本的现象。"},
  {name: "顺式偏好性", description: "指哺乳动物LINE-1逆转录转座子倾向于优先插入到自身转录本附近的基因组区域。"},
  {name: "顺式偏好性逆转录", description: "LINE-1编码的逆转录酶（ORF2p）优先使用其自身编码的RNA作为逆转录模板的特性。"},
  {name: "顺式动员", description: "LINE-1编码的蛋白质机器优先或专门动员其自身编码的RNA。"},
  {name: "顺式活性", description: "LINE-1自身编码的蛋白介导其自身逆转录转座的能力。"},
  {name: "顺式调控元件提供", description: "LINE-1序列被宿主利用，为基因表达提供调控序列。"},
  {name: "顺式转座", description: "LINE-1利用自身编码的酶机制进行逆转录转座的过程。"},
  {name: "顺式逆转录转座", description: "LINE-1介导其自身序列的逆转录转座过程。"},
  {name: "额外核苷酸插入", description: "在LINE-1插入位点，伴随出现的非模板来源的额外核苷酸序列。"},
  {name: "驱动Alu和SVA转座", description: "LINE-1的逆转录转座机制可以顺式驱动非自主的Alu和SVA转座子移动。"},
  {name: "驱动突变", description: "能够促进肿瘤发生、演进和转移的突变。"},
  {name: "高持续合成能力", description: "LINE-1逆转录酶在体外表现出比莫洛尼鼠白血病病毒逆转录酶更高的持续合成能力。"},
  {name: "高效递送", description: "将遗传物质有效地导入目标细胞的过程。"},
  {name: "高通量双荧光素酶检测", description: "一种使用萤火虫荧光素酶作为逆转录转座指示剂、海肾荧光素酶作为内参进行标准化的高灵敏度、宽动态范围的功能检测方法。"}
] AS row
MERGE (n:Function {name: row.name})
ON CREATE SET n.description = row.description, n.source_group = "functions";

// Import papers
UNWIND [
  {name: "6-甲酰基吲哚[3,2-b]咔唑 (FICZ) 诱导长散布核元件-1 (L1) 逆转录转座", description: "本论文报道了色氨酸光产物FICZ作为一种候选的生理性配体，能够诱导LINE-1的逆转录转座活性，并揭示了ARNT1介导的细胞机制在此过程中的关键作用。"},
  {name: "A 20.7 kb deletion within the factor VIII gene associated with LINE-1 element insertion.", description: "一篇报道在血友病A患者凝血因子VIII基因中发现一个20.7 kb缺失，且该缺失断点处存在LINE-1元件插入的论文。"},
  {name: "A 3' Poly(A) Tract Is Required for LINE-1 Retrotransposition.", description: "该论文报道了LINE-1逆转录转座需要其RNA 3'端多聚腺苷酸尾的研究。"},
  {name: "A BBS1 SVA F retrotransposon insertion is a frequent cause of Bardet-Biedl syndrome.", description: "一篇报道BBS1基因中SVA-F逆转录转座子插入是Bardet-Biedl综合征常见病因的论文。"},
  {name: "A comprehensive analysis of chimpanzee (Pan troglodytes)-specific LINE-1 retrotransposons.", description: "对黑猩猩特异性LINE-1逆转录转座子的全面分析。"},
  {name: "A comprehensive analysis of the Baboon-specific full-length LINE-1 retrotransposons.", description: "对狒狒特异性全长LINE-1逆转录转座子的综合分析。"},
  {name: "A comprehensive approach to expression of L1 loci.", description: "一种鉴定L1位点表达的综合性方法。"},
  {name: "A conserved role for the ESCRT membrane budding complex in LINE retrotransposition.", description: "ESCRT膜出芽复合体在LINE逆转录转座中具有保守作用。"},
  {name: "A full-length and potentially active LINE element is integrated polymorphically within the IGL locus in a genomically unstable region of chromosome 22.", description: "一篇报道在22号染色体基因组不稳定区域IGL基因座内发现一个具有多态性整合的全长且具潜在活性LINE元件的论文。"},
  {name: "A human genome structural variation sequencing resource reveals insights into mutational mechanisms.", description: "一篇揭示人类基因组结构变异突变机制的论文。"},
  {name: "A LINE-1 component to human aging: do LINE elements exact a longevity cost for evolutionary advantage?", description: "LINE-1对人类衰老的贡献：LINE元件是否为进化优势付出了长寿代价？"},
  {name: "A mouse model of human L1 retrotransposition.", description: "一篇描述人类L1逆转录转座小鼠模型的论文。"},
  {name: "A new exon created by intronic insertion of a rearranged LINE-1 element as the cause of chronic granulomatous disease.", description: "一篇报道由重排的LINE-1元件内含子插入创造新外显子从而导致慢性肉芽肿病的论文。"},
  {name: "A new mechanism to ensure integration during LINE retrotransposition: a suggestion from analyses of the 5' extra nucleotides.", description: "一篇提出LINE逆转录转座过程中5'端整合新机制的论文。"},
  {name: "A new retrotransposable human L1 element from the LRE2 locus on chromosome 1q produces a chimaeric insertion.", description: "一篇报道在染色体1q上发现新的活性人类L1转座子LRE2及其导致嵌合插入的论文。"},
  {name: "A novel active L1 retrotransposon subfamily in the mouse.", description: "一篇报道小鼠中一种新型活跃L1逆转录转座子亚家族的论文。"},
  {name: "A pilot study of LINE-1 copy number and telomere length with aging in human sperm.", description: "一项关于人类精子中LINE-1拷贝数和端粒长度随年龄变化的初步研究。"},
  {name: "A Possible Role for Long Interspersed Nuclear Elements-1 (LINE-1) in Huntington's Disease Progression.", description: "长散布核元件-1（LINE-1）在亨廷顿病进展中的可能作用。"},
  {name: "A potential new mechanism for pregnancy loss: considering the role of LINE-1 retrotransposons in early spontaneous miscarriage.", description: "一篇探讨LINE-1逆转录转座子可能导致人类早期自然流产潜在新机制的论文。"},
  {name: "A potential role for the nucleolus in L1 retrotransposition.", description: "核仁在L1逆转录转座中的潜在作用。"},
  {name: "A role for endogenous reverse transcriptase in tumorigenesis and as a target in differentiating cancer therapy.", description: "这篇综述讨论了内源性逆转录酶在肿瘤发生中的作用，并提出了其作为分化诱导癌症疗法靶点的潜力。"},
  {name: "A systematic analysis of LINE-1 endonuclease-dependent retrotranspositional events causing human genetic disease.", description: "对导致人类遗传病的LINE-1核酸内切酶依赖性逆转录转座事件的系统分析。"},
  {name: "A transient assay reveals that cultured human cells can accommodate multiple LINE-1 retrotransposition events.", description: "一项瞬时转染实验表明，培养的人类细胞能够容纳多个LINE-1逆转录转座事件。"},
  {name: "A yeast model for target-primed (non-LTR) retrotransposition.", description: "一篇关于靶向引发逆转录转座酵母模型的论文。"},
  {name: "A YY1-binding site is required for accurate human LINE-1 transcription initiation.", description: "一篇报道YY1结合位点对于人类LINE-1准确转录起始至关重要的论文。"},
  {name: "Aberrantly High Levels of Somatic LINE-1 Expression and Retrotransposition in Human Neurological Disorders.", description: "人类神经系统疾病中体细胞LINE-1表达和逆转录转座的异常高水平。"},
  {name: "Activation of individual L1 retrotransposon instances is restricted to cell-type dependent permissive loci.", description: "个体L1逆转录转座子实例的激活被限制在细胞类型依赖的许可基因座上。"},
  {name: "Active human retrotransposons: variation and disease.", description: "《活跃的人类逆转录转座子：变异与疾病》"},
  {name: "ADAR1 restricts LINE-1 retrotransposition.", description: "ADAR1限制LINE-1逆转录转座。"},
  {name: "Affinity proteomics reveals human host factors implicated in discrete stages of LINE-1 retrotransposition.", description: "亲和蛋白质组学揭示参与LINE-1逆转录转座不同阶段的人类宿主因子。"},
  {name: "Aging-associated distinctive DNA methylation changes of LINE-1 retrotransposons in pure cell-free DNA from human blood.", description: "人类血液纯细胞游离DNA中LINE-1逆转录转座子与衰老相关的独特DNA甲基化变化。"},
  {name: "All APOBEC3 family proteins differentially inhibit LINE-1 retrotransposition.", description: "所有APOBEC3家族蛋白差异性地抑制LINE-1逆转录转座。"},
  {name: "Alu逆转录转座介导的缺失", description: "这篇论文报道并分析了Alu元件通过一种称为逆转录转座介导的缺失的新机制诱导基因组不稳定性，并评估其对灵长类基因组完整性的影响。"},
  {name: "Amplification of CFTR exon 9 sequences to multiple locations in the human genome.", description: "CFTR基因第9外显子序列在人类基因组中多个位置的扩增。"},
  {name: "An Alternative DNA Endonuclease Activity is Associated with the LINE-1 ORF2-encoded Protein.", description: "LINE-1 ORF2编码蛋白具有一种替代性DNA核酸内切酶活性。"},
  {name: "An antisense promoter in mouse L1 retrotransposon open reading frame-1 initiates expression of diverse fusion transcripts and limits retrotransposition.", description: "小鼠L1逆转录转座子开放阅读框1中的反义启动子启动多种融合转录本的表达并限制逆转录转座。"},
  {name: "An in silico model of LINE-1-mediated neoplastic evolution.", description: "一篇关于LINE-1介导的肿瘤进化计算机模型的论文。"},
  {name: "An in vivo assay for the reverse transcriptase of human retrotransposon L1 in Saccharomyces cerevisiae.", description: "在酿酒酵母中建立了一种用于检测人类逆转录转座子L1逆转录酶活性的体内实验方法。"},
  {name: "An Increased Burden of Highly Active Retrotransposition Competent L1s Is Associated with Parkinson's Disease Risk and Progression in the PPMI Cohort.", description: "在PPMI队列中，高活性逆转录转座能力L1s的负荷增加与帕金森病风险和进展相关。"},
  {name: "An S/MAR-based L1 retrotransposition cassette mediates sustained levels of insertional mutagenesis without suffering from epigenetic silencing of DNA methylation.", description: "一篇报道基于S/MAR的L1逆转录转座盒在人类细胞系中实现高水平、稳定的插入突变，且不受DNA甲基化表观遗传沉默影响的研究论文。"},
  {name: "Analysis of 5' junctions of human LINE-1 and Alu retrotransposons suggests an alternative model for 5'-end attachment requiring microhomology-mediated end-joining.", description: "对人类LINE-1和Alu逆转录转座子5‘连接点的分析，提出了一个需要微同源介导末端连接的5‘端附着替代模型。"},
  {name: "Analysis of LINE-1 Elements in DNA from Postmortem Brains of Individuals with Schizophrenia.", description: "对精神分裂症个体死后大脑DNA中LINE-1元件的分析。"},
  {name: "Analysis of LINE-1 Retrotransposition at the Single Nucleus Level", description: "在单细胞核水平分析LINE-1逆转录转座的研究论文。"},
  {name: "Analysis of LINE1 Retrotransposons in Huntington's Disease", description: "亨廷顿病中LINE1逆转录转座子的分析。"},
  {name: "Ancient repeat sequence derived from U6 snRNA in primate genomes", description: "灵长类基因组中源自U6 snRNA的古老重复序列。"},
  {name: "Antagonistic regulation of LINE-1/Alu elements and their repressor APOBEC3B in cellular senescence.", description: "细胞衰老中LINE-1/Alu元件与其抑制因子APOBEC3B的拮抗调控。"},
  {name: "APOBEC3 proteins inhibit human LINE-1 retrotransposition.", description: "APOBEC3蛋白抑制人类LINE-1逆转录转座。"},
  {name: "APOBEC3 proteins inhibit LINE-1 retrotransposition in the absence of ORF1p binding.", description: "APOBEC3蛋白在无需结合ORF1p的情况下抑制LINE-1逆转录转座。"},
  {name: "APOBEC3A deaminates transiently exposed single-strand DNA during LINE-1 retrotransposition.", description: "APOBEC3A在LINE-1逆转录转座过程中对瞬时暴露的单链DNA进行脱氨基作用。"},
  {name: "APOBEC3B and APOBEC3F inhibit L1 retrotransposition by a DNA deamination-independent mechanism.", description: "APOBEC3B和APOBEC3F通过不依赖DNA脱氨的机制抑制L1逆转录转座。"},
  {name: "APOBEC3DE通过与ORF1p相互作用并影响LINE逆转录酶活性来抑制LINE-1逆转录转座", description: "APOBEC3DE通过与ORF1p相互作用并影响LINE逆转录酶活性来抑制LINE-1逆转录转座。"},
  {name: "APOBEC3G寡聚化与抑制Alu和LINE-1逆转录转座相关", description: "APOBEC3G oligomerization is associated with the inhibition of both Alu and LINE-1 retrotransposition."},
  {name: "APOBEC3G选择性抑制Alu逆转录转座", description: "本论文报道了APOBEC3G和APOBEC3F对Alu逆转录转座及其他L1介导的逆转录转座过程的影响。"},
  {name: "APOBEC3脱氧胞苷脱氨酶对不同DNA底物活性的生化基础", description: "本文讨论了APOBEC3家族酶在不同生物背景下（包括LINE-1逆转录转座）如何找到其单链DNA底物，以及促进脱氨效率的生化特性。"},
  {name: "APOBEC3蛋白：细胞内防御LINE-1介导的逆转录转座的主要参与者", description: "APOBEC3 proteins: major players in intracellular defence against LINE-1-mediated retrotransposition."},
  {name: "Approaches to repurposing reverse transcriptase antivirals in cancer.", description: "这篇综述探讨了逆转录酶抑制剂在癌症治疗中重新利用的方法，重点关注其通过抑制内源性逆转录酶（如LINE-1的逆转录酶）发挥抗癌作用的机制。"},
  {name: "Arsenic toxicity and epimutagenecity: the new LINEage.", description: "这篇综述讨论了砷毒性、表观遗传改变以及LINE-1甲基化作为其潜在生物标志物的研究现状。"},
  {name: "Arxes: retrotransposed genes required for adipogenesis.", description: "Arxes：脂肪生成所需的逆转录转座基因。"},
  {name: "Assessing the combined effect of extremely low-frequency magnetic field exposure and oxidative stress on LINE-1 promoter methylation in human neural cells.", description: "评估极低频磁场暴露和氧化应激对人神经细胞中LINE-1启动子甲基化的联合效应。"},
  {name: "Association of nuclear localization of a long interspersed nuclear element-1 protein in breast tumors with poor prognostic outcomes.", description: "该论文报道了长散布核元件-1蛋白在乳腺肿瘤中的核定位与不良预后的关联。"},
  {name: "Ataxia telangiectasia mutated (ATM) modulates long interspersed element-1 (L1) retrotransposition in human neural stem cells.", description: "《共济失调毛细血管扩张症突变蛋白（ATM）调节人类神经干细胞中的长散布核元件-1（L1）逆转录转座》。"},
  {name: "ATLAS: a system to selectively identify human-specific L1 insertions.", description: "ATLAS：一种选择性识别人类特异性L1插入的系统。"},
  {name: "Author Correction: Reprogramming triggers endogenous L1 and Alu retrotransposition in human induced pluripotent stem cells.", description: "作者更正：重编程触发人诱导多能干细胞中内源性L1和Alu逆转录转座。"},
  {name: "Author Correction: The interferon stimulated gene-encoded protein HELZ2 inhibits human LINE-1 retrotransposition and LINE-1 RNA-mediated type I interferon induction.", description: "勘误：干扰素刺激基因编码的蛋白HELZ2抑制人类LINE-1逆转录转座和LINE-1 RNA介导的I型干扰素诱导。"},
  {name: "BRCA1 and S phase DNA repair pathways restrict LINE-1 retrotransposition in human cells.", description: "BRCA1和S期DNA修复通路限制人类细胞中的LINE-1逆转录转座。"},
  {name: "BST2通过降低LINE-1 5' UTR的启动子活性来抑制LINE-1逆转录转座", description: "本论文报道了宿主限制因子BST2通过抑制LINE-1 5' UTR启动子活性来抑制其逆转录转座，并揭示了BST2作为启动子调节因子、基因组稳定剂和先天免疫抑制因子的新功能。"},
  {name: "Cancer cells co-evolve with retrotransposons to mitigate viral mimicry.", description: "癌细胞与逆转录转座子共同进化以减轻病毒模拟。"},
  {name: "Cell division promotes efficient retrotransposition in a stable L1 reporter cell line.", description: "细胞分裂促进稳定L1报告细胞系中的高效逆转录转座。"},
  {name: "Cell divisions are required for L1 retrotransposition.", description: "细胞分裂是L1逆转录转座所必需的。"},
  {name: "Cell fitness screens reveal a conflict between LINE-1 retrotransposition and DNA replication.", description: "细胞适应性筛选揭示了LINE-1逆转录转座与DNA复制之间的冲突。"},
  {name: "Cell-host, LINE and environment: Three players in search of a balance.", description: "细胞-宿主、LINE和环境：寻求平衡的三个参与者。"},
  {name: "Cellular inhibitors of long interspersed element 1 and Alu retrotransposition.", description: "《长散布元件1和Alu逆转录转座的细胞抑制剂》"},
  {name: "Cellular Localization of Engineered Human LINE-1 RNA and Proteins.", description: "《工程化人类LINE-1 RNA和蛋白质的细胞定位》"},
  {name: "Characterization of a mutagenic B1 retrotransposon insertion in the jittery mouse.", description: "对jittery小鼠中一个致突变性B1插入的表征。"},
  {name: "Characterization of a nondeleterious L1 insertion in an intron of the human factor VIII gene and further evidence of open reading frames in functional L1 elements.", description: "表征了人类凝血因子VIII基因内含子中的一个非致病性L1插入，并进一步提供了功能性L1元件中存在开放阅读框的证据。"},
  {name: "Characterization of a synthetic human LINE-1 retrotransposon ORFeus-Hs.", description: "一篇合成人类LINE-1逆转录转座子ORFeus-Hs的表征论文。"},
  {name: "Characterization of Engineered L1 Retrotransposition Events: The Recovery Method.", description: "工程化L1逆转录转座事件的表征：回收方法。"},
  {name: "Characterization of L1 retrotransposition with high-throughput dual-luciferase assays.", description: "利用高通量双荧光素酶检测方法表征L1逆转录转座。"},
  {name: "Characterization of LINE-1 ribonucleoprotein particles.", description: "LINE-1核糖核蛋白颗粒的表征。"},
  {name: "Characterization of the murine gene encoding 1-Cys peroxiredoxin and identification of highly homologous genes.", description: "对编码1-Cys过氧化物还原酶的小鼠基因进行表征并鉴定高度同源基因。"},
  {name: "Characterizing Complex Nucleic Acid Interactions of LINE1 ORF1p by Single Molecule Force Spectroscopy", description: "通过单分子力谱表征LINE1 ORF1p的复杂核酸相互作用。"},
  {name: "Circular retrotransposition products generated by a LINE retrotransposon.", description: "一篇报道LINE逆转录转座子产生环状逆转录转座产物的论文。"},
  {name: "Cis-preferential LINE-1 reverse transcriptase activity in ribonucleoprotein particles.", description: "该论文报道了LINE-1 RNA、ORF1p和ORF2p在核糖核蛋白颗粒中的共定位，并首次证明了ORF2p具有顺式偏好性逆转录活性。"},
  {name: "Combining Amplification Typing of L1 Active Subfamilies (ATLAS) with High-Throughput Sequencing", description: "结合L1活性亚家族扩增分型（ATLAS）与高通量测序。"},
  {name: "Commentary on Some Recent Theses Relevant to Combating Aging: October 2020", description: "《关于近期与抗衰老相关论文的评论：2020年10月》"},
  {name: "Comparative analysis on the expression of L1 loci using various RNA-Seq preparations.", description: "使用不同RNA-Seq制备方法对L1位点表达进行比较分析的论文。"},
  {name: "Comparative Genomics Reveals LINE-1 Recombination with Diverse RNAs.", description: "比较基因组学揭示LINE-1与多种RNA的重组。"},
  {name: "Complement factor H: sequence analysis of 221 kb of human genomic DNA containing the entire fH, fHR-1 and fHR-3 genes.", description: "补体因子H：对包含完整fH、fHR-1和fHR-3基因的人类基因组221 kb连续序列的分析。"},
  {name: "Comprehensive profiling of L1 retrotransposons in mouse.", description: "对小鼠L1逆转录转座子的全面分析。"},
  {name: "Comprehensive Scanning Mutagenesis of Human Retrotransposon LINE-1 Identifies Motifs Essential for Function.", description: "通过构建和表征538个连续的三丙氨酸替换突变体库，扫描ORF1p和ORF2p，以识别LINE-1逆转录转座功能的关键区域。"},
  {name: "Concurrent L1 retrotransposition events promote reciprocal translocations in human tumorigenesis.", description: "并发L1逆转录转座事件促进人类肿瘤发生中的相互易位。"},
  {name: "Condensation of LINE-1 is critical for retrotransposition.", description: "LINE-1的凝聚对于逆转录转座至关重要。"},
  {name: "Condensin I and condensin II proteins form a LINE-1 dependent super condensin complex and cooperate to repress LINE-1.", description: "凝缩蛋白I和凝缩蛋白II蛋白形成LINE-1依赖的超凝缩蛋白复合物并协同抑制LINE-1。"},
  {name: "Condensin II and GAIT complexes cooperate to restrict LINE-1 retrotransposition in epithelial cells.", description: "这篇论文报道了Condensin II复合物与GAIT复合物合作，通过抑制LINE-1的转录和翻译来限制其在体细胞中的逆转录转座，从而维持基因组稳定性。"},
  {name: "Conservation and Innovation of APOBEC3A Restriction Functions during Primate Evolution.", description: "灵长类进化过程中APOBEC3A限制功能的保守与创新。"},
  {name: "Conserved 3' UTR stem-loop structure in L1 and Alu transposons in human genome: possible role in retrotransposition.", description: "人类基因组中L1和Alu转座子保守的3' UTR茎环结构：在逆转录转座中的可能作用。"},
  {name: "Contemporary retrotransposition of a novel non-coding gene induces exon-skipping in dystrophin mRNA.", description: "一篇报道新型非编码基因的当代逆转录转座导致抗肌萎缩蛋白mRNA中外显子跳跃的论文。"},
  {name: "Control of chicken CR1 retrotransposons is independent of Dicer-mediated RNA interference pathway.", description: "鸡CR1逆转录转座子的控制独立于Dicer介导的RNA干扰通路。"},
  {name: "Control of LINE-1 Expression Maintains Genome Integrity in Germline and Early Embryo Development.", description: "控制LINE-1的表达维持生殖系和早期胚胎发育中的基因组完整性。"},
  {name: "Copy and paste: the impact of a new non-L1 retroposon on the gonosomal heterochromatin of Microtus agrestis.", description: "报道了一种在田鼠Microtus agrestis基因组中近期入侵的新型非L1逆转录转座子，并描述了其转录和转座活性。"},
  {name: "Crossing the LINE Toward Genomic Instability: LINE-1 Retrotransposition in Cancer.", description: "这篇综述旨在简要概述LINE-1逆转录转座与基因组稳定性丧失之间的联系，并讨论人类细胞中抑制逆转录转座的机制及其与癌症的关联。"},
  {name: "Cycling to Maintain and Improve Fitness: Line-1 Modes of Nuclear Entrance and Retrotransposition.", description: "该论文报道了LINE-1转座子蛋白和mRNA在细胞周期中的动态变化及其核进入和逆转录转座的机制。"},
  {name: "Cyclophilin A retrotransposition into TRIM5 explains owl monkey resistance to HIV-1.", description: "环孢素A逆转录转座至TRIM5基因解释了夜猴对HIV-1的抗性。"},
  {name: "Cytoplasmic synthesis of endogenous Alu complementary DNA via reverse transcription and implications in age-related macular degeneration.", description: "通过逆转录在细胞质中合成内源性Alu互补DNA及其在年龄相关性黄斑变性中的意义。"},
  {name: "Database documentation of retrotransposon insertion polymorphisms.", description: "逆转录转座子插入多态性的数据库文档。"},
  {name: "Deamination-independent restriction of LINE-1 retrotransposition by APOBEC3H.", description: "APOBEC3H通过脱氨酶非依赖性机制限制LINE-1逆转录转座。"},
  {name: "Deciphering fact from artifact when using reporter assays to investigate the roles of host factors on L1 retrotransposition.", description: "探讨在使用报告基因检测研究宿主因子对L1逆转录转座作用时，如何区分真实结果与实验假象。"},
  {name: "Deciphering lung adenocarcinoma evolution and the role of LINE-1 retrotransposition.", description: "解读肺腺癌的进化以及LINE-1逆转录转座的作用。"},
  {name: "Defective modulation of LINE-1 retrotransposition by cancer-associated SAMHD1 mutants.", description: "癌症相关SAMHD1突变体对LINE-1逆转录转座调控缺陷的研究。"},
  {name: "Deletion analysis defines distinct functional domains for protein-protein and nucleic acid interactions in the ORF1 protein of mouse LINE-1.", description: "通过缺失分析定义小鼠LINE-1 ORF1蛋白中蛋白质-蛋白质和核酸相互作用的不同功能域。"},
  {name: "Detection of Retrotransposition Activity of Hot LINE-1s by Long-Distance Inverse PCR", description: "通过长距离反向PCR检测活跃LINE-1的逆转录转座活性。"},
  {name: "Detection of the LINE-1 retrotransposon RNA-binding protein ORF1p in different anatomical regions of the human brain.", description: "检测人类大脑不同解剖区域中LINE-1逆转录转座子RNA结合蛋白ORF1p的表达。"},
  {name: "Detection of two Alu insertions in the CFTR gene.", description: "在CFTR基因中检测到两个Alu插入。"},
  {name: "Determination of L1 retrotransposition kinetics in cultured cells.", description: "测定培养细胞中L1逆转录转座动力学。"},
  {name: "Deubiquitinase USP37 enhances the anti-HIV-2/SIV ability of the host restriction factor SAMHD1.", description: "去泛素化酶USP37通过稳定宿主限制因子SAMHD1，增强其抗HIV-2/SIV能力并抑制LINE-1逆转录转座。"},
  {name: "Development of a monoclonal antibody specific to the endonuclease domain of the human LINE-1 ORF2 protein.", description: "开发一种针对人类LINE-1 ORF2蛋白内切核酸酶结构域的特异性单克隆抗体。"},
  {name: "Different evolutionary fates of recently integrated human and chimpanzee LINE-1 retrotransposons", description: "人类和黑猩猩近期整合的LINE-1逆转录转座子的不同进化命运。"},
  {name: "Different integration site structures between L1 protein-mediated retrotransposition in cis and retrotransposition in trans.", description: "顺式与反式L1蛋白介导的逆转录转座之间整合位点结构的差异。"},
  {name: "Differential inhibition of LINE1 and LINE2 retrotransposition by vertebrate AID/APOBEC proteins.", description: "脊椎动物AID/APOBEC蛋白对LINE1和LINE2逆转录转座的差异性抑制。"},
  {name: "Differential L1 regulation in pluripotent stem cells of humans and apes.", description: "人类和猿类多能干细胞中L1调控的差异。"},
  {name: "Differential virus restriction patterns of rhesus macaque and human APOBEC3A: implications for lentivirus evolution.", description: "恒河猴与人类APOBEC3A差异性的病毒限制模式：对慢病毒进化的启示。"},
  {name: "Discovery and characterization of Alu repeat sequences via precise local read assembly.", description: "通过精确局部读取组装发现和表征Alu重复序列。"},
  {name: "Discrete subcellular partitioning of human retrotransposon RNAs despite a common mechanism of genome insertion.", description: "尽管具有共同的基因组插入机制，人类逆转座子RNA在亚细胞水平上呈现离散的分区。"},
  {name: "Distinct mechanisms for trans-mediated mobilization of cellular RNAs by the LINE-1 reverse transcriptase.", description: "LINE-1逆转录酶通过不同机制反式介导细胞RNA动员。"},
  {name: "DNA damage and L1 retrotransposition.", description: "这篇论文回顾了基因毒性应激（特别是DNA双链断裂）可能动员转座子（尤其是逆转录转座子）的证据，并讨论了L1移动性在DNA双链断裂形成背景下的潜在后果。"},
  {name: "DNA polymerization by the reverse transcriptase of the human L1 retrotransposon on its own template in vitro.", description: "人类L1逆转录转座子逆转录酶在体外以其自身模板进行DNA聚合的研究。"},
  {name: "DNA repair mediated by endonuclease-independent LINE-1 retrotransposition.", description: "核酸内切酶非依赖性LINE-1逆转录转座介导的DNA修复。"},
  {name: "DNA repair protein Rad18 restricts LINE-1 mobility.", description: "DNA修复蛋白Rad18限制LINE-1的移动性。"},
  {name: "Do small RNAs interfere with LINE-1?", description: "这篇综述探讨了RNA干扰在抑制转座子移动中的作用，并推测其在保护人类基因组免受LINE-1活性影响方面的潜在角色。"},
  {name: "Drawing a fine line on endogenous retroelement activity.", description: "该论文探讨了内源性逆转录元件的活性调控，特别是KRAB/KAP系统和DNA甲基化在控制LINE-1转座子中的关键作用。"},
  {name: "Dynamic and Ongoing De Novo L1 Retrotransposition Contributes to Genome Plasticity and Intrapatient Heterogeneity in Ovarian Cancer.", description: "动态且持续发生的从头L1逆转录转座促进卵巢癌的基因组可塑性和患者内异质性。"},
  {name: "Dynamic Methylation of an L1 Transduction Family during Reprogramming and Neurodifferentiation", description: "本文报道了在重编程和神经分化过程中，一个L1转导家族的动态甲基化模式。"},
  {name: "Dynamic retrotransposition of ERV-9 LTR and L1 in the beta-globin gene locus during primate evolution.", description: "这篇论文描述了在灵长类动物进化过程中，ERV-9 LTR和L1在β-珠蛋白基因座中的动态逆转录转座。"},
  {name: "Dynamic silencing of somatic L1 retrotransposon insertions reflects the developmental and cellular contexts of their genomic integration.", description: "体细胞L1逆转录转座子插入的动态沉默反映了其基因组整合的发育和细胞背景。"},
  {name: "Effect of heavy metals on silencing of engineered long interspersed element-1 retrotransposon in nondividing neuroblastoma cell line.", description: "重金属对非分裂神经母细胞瘤细胞系中工程化长散布元件-1逆转录转座子沉默的影响。"},
  {name: "Effect of reverse transcriptase inhibitors on LINE-1 and Ty1 reverse transcriptase activities and on LINE-1 retrotransposition.", description: "逆转录酶抑制剂对LINE-1和Ty1逆转录酶活性以及LINE-1逆转录转座的影响。"},
  {name: "Effects of human SAMHD1 polymorphisms on HIV-1 susceptibility.", description: "人类SAMHD1多态性对HIV-1易感性的影响。"},
  {name: "Emergence of primate genes by retrotransposon-mediated sequence transduction.", description: "通过逆转录转座子介导的序列转导产生灵长类基因。"},
  {name: "Endogenous APOBEC3B restricts LINE-1 retrotransposition in transformed cells and human embryonic stem cells.", description: "内源性APOBEC3B在转化细胞和人胚胎干细胞中限制LINE-1逆转录转座。"},
  {name: "Endogenous MOV10 inhibits the retrotransposition of endogenous retroelements but not the replication of exogenous retroviruses.", description: "内源性MOV10抑制内源性逆转录转座子的逆转录转座，但不抑制外源性逆转录病毒的复制。"},
  {name: "Endogenous retrotransposition activates oncogenic pathways in hepatocellular carcinoma.", description: "内源性逆转录转座激活肝细胞癌中的致癌通路。"},
  {name: "Endonuclease-independent insertion provides an alternative pathway for L1 retrotransposition in the human genome.", description: "内切核酸酶非依赖性插入为人类基因组中的L1逆转录转座提供了一条替代途径。"},
  {name: "Endonuclease-independent LINE-1 retrotransposition at mammalian telomeres.", description: "哺乳动物端粒处的内切核酸酶非依赖性LINE-1逆转录转座。"},
  {name: "Engineered LINE-1 retrotransposition in nondividing human neurons.", description: "在非分裂的人类神经元中进行工程化LINE-1逆转录转座。"},
  {name: "Environmental factors affecting transcription of the human L1 retrotransposon. I. Steroid hormone-like agents.", description: "影响人类L1逆转录转座子转录的环境因素。I. 类固醇激素样物质。"},
  {name: "Epigenetic silencing of engineered L1 retrotransposition events in human embryonic carcinoma cells.", description: "在人胚胎癌细胞中，工程化L1逆转录转座事件的表观遗传沉默。"},
  {name: "ERCC1/XPF limits L1 retrotransposition.", description: "ERCC1/XPF限制L1逆转录转座。"},
  {name: "Establishment of a genome-wide and quantitative protocol for assessment of transcriptional activity at human retrotransposon L1 antisense promoters.", description: "建立了一种全基因组、定量的实验方案，用于评估人类逆转录转座子L1反义启动子的转录活性。"},
  {name: "Evidence consistent with human L1 retrotransposition in maternal meiosis I.", description: "该论文报道了人类L1逆转录转座事件很可能发生在母方减数分裂I期的证据。"},
  {name: "Evolutionary insights from profiling LINE-1 activity at allelic resolution in a single human genome", description: "在单个人类基因组中以等位基因分辨率分析LINE-1活性的进化见解。"},
  {name: "Exogenous retroelement integration in sperm and embryos affects preimplantation development.", description: "这篇论文报道了外源逆转录转座子在精子与胚胎中的整合及其对植入前发育的影响。"},
  {name: "Exon shuffling by L1 retrotransposition.", description: "L1逆转录转座介导的外显子混编。"},
  {name: "Exposure of hepatocellular carcinoma cells to low-level As₂O₃‎ causes an extra toxicity pathway via L1 retrotransposition ‎induction.", description: "低剂量As₂O₃暴露通过诱导L1逆转录转座导致肝细胞癌细胞的额外毒性通路。"},
  {name: "Expression of LINE-1 elements is required for preimplantation development and totipotency.", description: "LINE-1元件的表达是植入前发育和全能性所必需的。"},
  {name: "Expression of Retroelements in Mammalian Gametes and Embryos", description: "这篇综述讨论了哺乳动物卵母细胞、精子以及人和小鼠植入前胚胎中逆转录元件的表达和逆转录转座事件。"},
  {name: "Extensive individual variation in L1 retrotransposition capability contributes to human genetic diversity.", description: "L1逆转录转座能力的广泛个体差异对人类遗传多样性有重要贡献。"},
  {name: "Extensive somatic L1 retrotransposition in colorectal tumors.", description: "结直肠肿瘤中广泛的体细胞LINE-1逆转录转座。"},
  {name: "Extensive variation between inbred mouse strains due to endogenous L1 retrotransposition.", description: "该论文报道了内源性L1逆转录转座是导致近交系小鼠品系间广泛基因组变异的主要原因，并影响了多个基因的结构和表达。"},
  {name: "Extracellular vesicles mediate the horizontal transfer of an active LINE-1 retrotransposon.", description: "细胞外囊泡介导活性LINE-1逆转录转座子的水平转移。"},
  {name: "Factors Regulating the Activity of LINE1 Retrotransposons", description: "本文综述了LINE-1逆转录转座的分子遗传机制及其活性调控。"},
  {name: "Feedback inhibition of L1 and alu retrotransposition through altered double strand break repair kinetics.", description: "通过改变双链断裂修复动力学反馈抑制L1和Alu逆转录转座。"},
  {name: "Footprint of APOBEC3 on the genome of human retroelements", description: "APOBEC3在人类逆转录元件基因组上的足迹。"},
  {name: "FOXR2激活并非中枢神经系统神经母细胞瘤所独有", description: "本研究分析了42例FOXR2过表达的中枢神经系统肿瘤，发现其组织学、分子、影像学和临床特征具有显著多样性，并揭示了FOXR2激活的不同机制，包括截短的LINE-1逆转录转座。"},
  {name: "Frequency and methylation status of selected retrotransposition competent L1 loci in amyotrophic lateral sclerosis.", description: "肌萎缩侧索硬化症中选定具有逆转录转座能力的L1基因座的频率和甲基化状态。"},
  {name: "Frequent human genomic DNA transduction driven by LINE-1 retrotransposition.", description: "由LINE-1逆转录转座驱动的频繁人类基因组DNA转导。"},
  {name: "Frequent retrotransposition of endogenous genes in ERCC2-deficient cells derived from a patient with xeroderma pigmentosum.", description: "该论文报道了在源自着色性干皮病患者的ERCC2缺陷细胞中，内源基因的逆转录转座事件频繁发生。"},
  {name: "From the genome's perspective: Bearing somatic retrotransposition to leverage the regulatory potential of L1 RNAs.", description: "从基因组视角：承载体细胞逆转录转座以利用L1 RNA的调控潜力。"},
  {name: "Full-length human L1 insertions retain the capacity for high frequency retrotransposition in cultured cells.", description: "全长人类L1插入在培养细胞中仍保持高频逆转录转座的能力。"},
  {name: "Functional impact of the human mobilome.", description: "这篇论文讨论了人类基因组中可移动元件在疾病中的作用，并重点介绍了近几年的新发现。"},
  {name: "G-quadruplex structures within the 3' UTR of LINE-1 elements stimulate retrotransposition.", description: "LINE-1元件3'非翻译区内的G-四链体结构刺激逆转录转座。"},
  {name: "Gamma radiation increases endonuclease-dependent L1 retrotransposition in a cultured cell assay.", description: "伽马辐射在细胞培养实验中增加核酸内切酶依赖的L1逆转录转座。"},
  {name: "Generation of somatic de novo structural variation as a hallmark of cellular senescence in human lung fibroblasts.", description: "在人肺成纤维细胞中，体细胞新生结构变异作为细胞衰老标志的生成。"},
  {name: "Genes, Proteins, and Biological Pathways Preventing Chromothripsis", description: "这篇论文讨论了防止染色体碎裂的基因、蛋白质和生物通路。"},
  {name: "Genetic and epigenetic variations contributed by Alu retrotransposition.", description: "《Alu逆转录转座贡献的遗传和表观遗传变异》"},
  {name: "Genetic evidence that the non-homologous end-joining repair pathway is involved in LINE retrotransposition.", description: "非同源末端连接修复途径参与LINE逆转录转座的遗传学证据。"},
  {name: "Genome-wide characterization of human L1 antisense promoter-driven transcripts", description: "对人类L1反义启动子驱动转录本的全基因组表征。"},
  {name: "Genome-wide de novo L1 Retrotransposition Connects Endonuclease Activity with Replication", description: "这篇论文报道了在全基因组范围内研究新生L1逆转录转座事件，揭示了其内切核酸酶活性与DNA复制之间的联系。"},
  {name: "Genome-Wide Young L1 Methylation Profiling by bs-ATLAS-seq", description: "通过bs-ATLAS-seq进行全基因组年轻L1甲基化分析"},
  {name: "Genomic characterization of recent human LINE-1 insertions: evidence supporting random insertion.", description: "近期人类LINE-1插入的基因组特征：支持随机插入的证据。"},
  {name: "Genomic deletions created upon LINE-1 retrotransposition.", description: "《LINE-1逆转录转座产生的基因组缺失》"},
  {name: "Genomic Indexing by Somatic Gene Recombination of mRNA/ncRNA - Does It Play a Role in Genomic Mosaicism, Memory Formation, and Alzheimer's Disease?", description: "通过mRNA/ncRNA的体细胞基因重组进行基因组索引--它在基因组镶嵌性、记忆形成和阿尔茨海默病中起作用吗？"},
  {name: "Genomic instability associated with human LINE-1 rétrotransposition", description: "这篇论文报道了人类LINE-1逆转录转座子与基因组不稳定性相关的多种机制。"},
  {name: "Genomic rearrangements by LINE-1 insertion-mediated deletion in the human and chimpanzee lineages.", description: "该论文报道了在人类和黑猩猩谱系中，由LINE-1插入介导的缺失导致的基因组重排。"},
  {name: "Genomic rearrangements in inherited disease and cancer.", description: "遗传病和癌症中的基因组重排。"},
  {name: "Germline Chromothripsis Driven by L1-Mediated Retrotransposition and Alu/Alu Homologous Recombination.", description: "这篇论文报道了由L1介导的逆转录转座和Alu/Alu同源重组驱动的种系染色体碎裂。"},
  {name: "Guardian of the Human Genome: Host Defense Mechanisms against LINE-1 Retrotransposition.", description: "人类基因组的守护者：针对LINE-1逆转录转座的宿主防御机制。"},
  {name: "Heads or tails: L1 insertion-associated 5' homopolymeric sequences.", description: "这篇论文报道了与LINE-1插入相关的5'端同聚物序列，并探讨了其形成的可能机制。"},
  {name: "Heavy metals stimulate human LINE-1 retrotransposition.", description: "重金属刺激人类LINE-1逆转录转座。"},
  {name: "Heritable L1 Retrotransposition Events During Development: Understanding Their Origins: Examination of heritable, endogenous L1 retrotransposition in mice opens up exciting new questions and research directions.", description: "发育过程中可遗传的L1逆转录转座事件：探索其起源：对小鼠中可遗传的内源性L1逆转录转座的检测开辟了令人兴奋的新问题和研究方向。"},
  {name: "HERV-K and LINE-1 DNA Methylation and Reexpression in Urothelial Carcinoma.", description: "《HERV-K和LINE-1在尿路上皮癌中的DNA甲基化与再表达》"},
  {name: "HERV-K(HML-2) rec and np9 transcripts not restricted to disease but present in many normal human tissues.", description: "该论文报道了HERV-K(HML-2)的rec和np9转录本不仅存在于疾病组织中，也广泛存在于多种正常人体组织中，并发现了一个由L1介导的逆转座事件形成的新HERV-K(HML-2)位点。"},
  {name: "High frequency retrotransposition in cultured mammalian cells.", description: "在培养的哺乳动物细胞中的高频率逆转录转座。"},
  {name: "High G+C Content of Herpes Simplex Virus DNA: Proposed Role in Protection Against Retrotransposon Insertion.", description: "单纯疱疹病毒DNA的高G+C含量：在保护免受逆转录转座子插入中的作用。"},
  {name: "High-molecular-mass APOBEC3G complexes restrict Alu retrotransposition.", description: "高分子量APOBEC3G复合物限制Alu逆转录转座。"},
  {name: "High-throughput sequencing reveals extensive variation in human-specific L1 content in individual human genomes.", description: "高通量测序揭示个体人类基因组中人特异性L1含量存在广泛变异。"},
  {name: "Histone Demethylase KDM4B Promotes DNA Damage by Activating Long Interspersed Nuclear Element-1.", description: "组蛋白去甲基化酶KDM4B通过激活长散布核元件-1促进DNA损伤。"},
  {name: "HIV suppressors against LINE-1: one functions as two.", description: "这篇综述讨论了某些HIV抑制因子如何通过不同的机制同时抑制HIV和LINE-1的复制。"},
  {name: "HIV-1 Vpr and p21 restrict LINE-1 mobility.", description: "HIV-1 Vpr和p21限制LINE-1的移动性。"},
  {name: "hnRNPL and nucleolin bind LINE-1 RNA and function as host factors to modulate retrotransposition.", description: "hnRNPL和核仁素结合LINE-1 RNA并作为宿主因子调节逆转录转座。"},
  {name: "Hot L1s account for the bulk of retrotransposition in the human population.", description: "这篇论文报道了人类基因组中具有完整开放阅读框的LINE-1（L1）元件数量、多态性及其逆转录转座活性，并指出大部分逆转录转座活动由少数高活性L1（热L1）驱动。"},
  {name: "HPV 5 and 8 E6 expression reduces ATM protein levels and attenuates LINE-1 retrotransposition.", description: "HPV 5和8 E6蛋白表达降低ATM蛋白水平并减弱LINE-1逆转录转座。"},
  {name: "Human L1 retrotransposition is associated with genetic instability in vivo.", description: "人类L1逆转录转座与体内遗传不稳定性相关。"},
  {name: "Human L1 retrotransposition: cis preference versus trans complementation.", description: "人类L1逆转录转座：顺式偏好性与反式互补。"},
  {name: "Human L1 retrotransposition: insights and peculiarities learned from a cultured cell retrotransposition assay.", description: "人类L1逆转录转座：从培养细胞逆转录转座测定中学到的见解和特性。"},
  {name: "Human L1 retrotransposon encodes a conserved endonuclease required for retrotransposition.", description: "人类L1逆转录转座子编码一个逆转录转座所必需的保守内切核酸酶。"},
  {name: "Human LINE-1 restriction by APOBEC3C is deaminase independent and mediated by an ORF1p interaction that affects LINE reverse transcriptase activity.", description: "APOBEC3C对LINE-1的限制作用是脱氨酶非依赖性的，并由影响LINE逆转录酶活性的ORF1p相互作用介导。"},
  {name: "Human LINE-1 retrotransposition requires a metastable coiled coil and a positively charged N-terminus in L1ORF1p.", description: "人类LINE-1逆转录转座需要L1ORF1p中的一个亚稳态卷曲螺旋和一个带正电荷的N末端。"},
  {name: "Human LINE-1 retrotransposon induces DNA damage and apoptosis in cancer cells.", description: "人类LINE-1逆转录转座子在癌细胞中诱导DNA损伤和细胞凋亡。"},
  {name: "Human LINE-1 retrotransposons: impacts on the genome and regulation by host factors.", description: "人类LINE-1逆转录转座子：对基因组的影响及宿主因子的调控。"},
  {name: "Human Papillomavirus Carcinogenicity and the Need of New Perspectives: Thoughts from a Retrospective Analysis on Human Papillomavirus Outcomes Conducted at the Hospital University of Bari, Apulia, Italy, between 2011 and 2022.", description: "一项回顾性分析，旨在确定意大利普利亚地区不同年龄和性别个体中人乳头瘤病毒基因型的流行率和分布，并探讨致癌机制中可能涉及的变量。"},
  {name: "Human transposon insertion profiling by sequencing (TIPseq) to map LINE-1 insertions in single cells.", description: "通过测序进行人类转座子插入谱分析（TIPseq）以绘制单细胞中的LINE-1插入。"},
  {name: "Human transposon insertion profiling: Analysis, visualization and identification of somatic LINE-1 insertions in ovarian cancer.", description: "人类转座子插入谱分析：卵巢癌中体细胞LINE-1插入的分析、可视化与鉴定。"},
  {name: "Human TRIM5α senses and restricts LINE-1 elements.", description: "人类TRIM5α感知并限制LINE-1元件。"},
  {name: "Hypomethylation of LINE1 retrotransposon in human hepatocellular carcinomas, but not in surrounding liver cirrhosis.", description: "人类肝细胞癌中LINE1逆转座子的低甲基化，但周围肝硬化组织中没有。"},
  {name: "Identification and characterization of MGEs and their insertion sites in the gorilla genome.", description: "识别和表征大猩猩基因组中的可移动遗传元件及其插入位点。"},
  {name: "Identification and characterization of occult human-specific LINE-1 insertions using long-read sequencing technology.", description: "利用长读长测序技术鉴定和表征隐匿的人类特异性LINE-1插入。"},
  {name: "Identification and characterization of small molecule inhibitors of the LINE-1 retrotransposon endonuclease.", description: "鉴定和表征LINE-1逆转录转座子核酸内切酶的小分子抑制剂。"},
  {name: "Identification and solution structure of a highly conserved C-terminal domain within ORF1p required for retrotransposition of long interspersed nuclear element-1.", description: "鉴定并解析了长散布核元件-1逆转录转座所必需的ORF1p蛋白中高度保守的C端结构域的溶液结构。"},
  {name: "Identification of a minimal Alu domain required for retrotransposition", description: "鉴定Alu逆转录转座所需的最小结构域。"},
  {name: "Identification of charged amino acids required for nuclear localization of human L1 ORF1 protein.", description: "鉴定人类L1 ORF1蛋白核定位所需的带电氨基酸。"},
  {name: "Identification of epigenetically active L1 promoters in the human brain and their relationship with psychiatric disorders.", description: "在人脑中鉴定表观遗传活跃的L1启动子及其与精神疾病的关系。"},
  {name: "Identification of L1 ORF2p sequence important to retrotransposition using Bipartile Alu retrotransposition (BAR).", description: "使用双片段Alu逆转录转座（BAR）方法鉴定对逆转录转座重要的L1 ORF2p序列。"},
  {name: "Identification of LINE retrotransposons and long non-coding RNAs expressed in the octopus brain.", description: "鉴定在章鱼脑中表达的LINE逆转录转座子和长链非编码RNA。"},
  {name: "IFI16 Targets the Transcription Factor Sp1 to Suppress HIV-1 Transcription and Latency Reactivation", description: "IFI16靶向转录因子Sp1以抑制HIV-1转录和潜伏期再激活。"},
  {name: "Impact of constitutional copy number variants on biological pathway evolution.", description: "这篇论文研究了组成型拷贝数变异对生物通路进化的影响。"},
  {name: "Impact of retrotransposon protein L1 ORF1p expression on oncogenic pathways in hepatocellular carcinoma: the role of cytoplasmic PIN1 upregulation.", description: "逆转录转座子蛋白L1 ORF1p表达对肝细胞癌致癌通路的影响：胞质PIN1上调的作用。"},
  {name: "Increased l1 retrotransposition in the neuronal genome in schizophrenia.", description: "精神分裂症神经元基因组中L1逆转录转座增加。"},
  {name: "Inheritance of DNA transferred from American trypanosomes to human hosts.", description: "从美洲锥虫转移到人类宿主的DNA的遗传。"},
  {name: "Inhibition of LINE-1 Retrotransposition by Capsaicin.", description: "辣椒素抑制LINE-1逆转录转座。"},
  {name: "Insertion and deletion polymorphisms of the ancient AluS family in the human genome.", description: "人类基因组中古老AluS家族的插入和缺失多态性。"},
  {name: "Insights into LINE-1 reverse transcription guide therapy development.", description: "关于LINE-1逆转录的见解指导疗法开发。"},
  {name: "Integrated mechanism for the generation of the 5' junctions of LINE inserts.", description: "LINE插入5'连接处生成的整合机制。"},
  {name: "Integration of SARS-CoV-2 RNA in infected human cells by retrotransposons: an unlikely hypothesis and old viral relationships.", description: "这篇评论性文章对Zhang等人关于SARS-CoV-2 RNA可能通过L1逆转录转座子机制整合到人类细胞DNA中的发现进行了批判性回顾和讨论。"},
  {name: "Internal priming: an opportunistic pathway for L1 and Alu retrotransposition in hominins.", description: "内部引物：人类谱系中L1和Alu逆转录转座的一条机会主义途径。"},
  {name: "Interplay between RNASEH2 and MOV10 controls LINE-1 retrotransposition.", description: "RNASEH2与MOV10之间的相互作用调控LINE-1逆转录转座。"},
  {name: "Intragenic L1 Insertion: One Possibility of Brain Disorder.", description: "基因内L1插入：脑部疾病的一种可能性。"},
  {name: "Intrinsic restriction activity by AID/APOBEC family of enzymes against the mobility of retroelements.", description: "这篇综述讨论了AID/APOBEC酶家族的作用机制及其在控制内源性逆转录转座子转座中的作用。"},
  {name: "Intrinsic restriction activity by apolipoprotein B mRNA editing enzyme APOBEC1 against the mobility of autonomous retrotransposons.", description: "载脂蛋白B mRNA编辑酶APOBEC1对自主逆转录转座子移动性的内在限制活性。"},
  {name: "Inverse changes in L1 retrotransposons between blood and brain in major depressive disorder.", description: "重度抑郁症患者血液和大脑中L1逆转录转座子的反向变化。"},
  {name: "Investigation of long interspersed element-1 retrotransposons as potential risk factors for idiopathic temporal lobe epilepsy.", description: "研究长散布核元件-1逆转录转座子作为特发性颞叶癫痫潜在风险因素。"},
  {name: "Ionising irradiation alters the dynamics of human long interspersed nuclear elements 1 (LINE1) retrotransposon.", description: "电离辐射改变人类长散布核元件1（LINE1）逆转录转座子动力学的研究。"},
  {name: "L1 integration in a transgenic mouse model.", description: "一篇关于在转基因小鼠模型中研究人类LINE-1逆转录转座子整合的论文。"},
  {name: "L1 Mosaicism in Mammals: Extent, Effects, and Evolution.", description: "哺乳动物中的L1嵌合现象：范围、影响与演化。"},
  {name: "L1 retrotransposition can occur early in human embryonic development.", description: "L1逆转录转座可发生在人类胚胎发育早期。"},
  {name: "L1 retrotransposition in human neural progenitor cells.", description: "人类神经祖细胞中的L1逆转录转座。"},
  {name: "L1 Retrotransposition in Neural Progenitor Cells", description: "《神经前体细胞中的L1逆转录转座》，描述了LINE-1在神经前体细胞中的活性及其对神经元功能和疾病可能的影响。"},
  {name: "L1 retrotransposition in neurons is modulated by MeCP2.", description: "神经元中的L1逆转录转座受MeCP2调控。"},
  {name: "L1 retrotransposition in nondividing and primary human somatic cells", description: "在非分裂和原代人体细胞中的L1逆转录转座。"},
  {name: "L1 retrotransposition is activated by Ten-eleven-translocation protein 1 and repressed by methyl-CpG binding proteins.", description: "这篇论文报道了Ten-eleven-translocation蛋白1激活L1逆转录转座，而甲基-CpG结合蛋白抑制该过程。"},
  {name: "L1 retrotransposition is suppressed by endogenously encoded small interfering RNAs in human cultured cells.", description: "该论文报道了在人类培养细胞中，内源性编码的小干扰RNA可以抑制L1逆转录转座。"},
  {name: "L1 retrotransposon-mediated stable gene silencing", description: "L1逆转录转座子介导的稳定基因沉默。"},
  {name: "L1 retrotransposons and somatic mosaicism in the brain.", description: "大脑中的L1逆转录转座子与体细胞嵌合。"},
  {name: "L1 retrotransposons exploit RNA m6A modification as an evolutionary driving force.", description: "L1逆转录转座子利用RNA m6A修饰作为进化驱动力。"},
  {name: "L1 Retrotransposons: A Potential Endogenous Regulator for Schizophrenia.", description: "L1逆转录转座子：精神分裂症的潜在内源性调节因子。"},
  {name: "L1-associated genomic regions are deleted in somatic cells of the healthy human brain.", description: "健康人脑体细胞中与L1相关的基因组区域发生缺失。"},
  {name: "L1-mediated retrotransposition of murine B1 and B2 SINEs recapitulated in cultured cells.", description: "在培养细胞中重现L1介导的小鼠B1和B2 SINEs逆转录转座。"},
  {name: "L1-ORF1p核蛋白能迅速呈现不同的构象并同时结合多个核酸分子。", description: "L1-ORF1p核蛋白能迅速呈现不同的构象并同时结合多个核酸分子。"},
  {name: "L1Base 2: more retrotransposition-active LINE-1s, more mammalian genomes.", description: "L1Base 2：更多具有逆转录转座活性的LINE-1，更多哺乳动物基因组。"},
  {name: "L1插入中间体相互重组或与DNA断裂重组以形成基因组重排", description: "报道了L1逆转录转座中间体通过重组机制导致基因组重排的研究。"},
  {name: "L1杂交富集法：一种直接获取人类种系中新生L1插入的方法", description: "L1杂交富集法：一种直接获取人类种系中新生L1插入的方法。"},
  {name: "L1逆转录元件相关的p40蛋白诱导p38delta MAP激酶", description: "该论文报道了在类风湿关节炎滑膜组织中鉴定出全长L1 mRNA，并研究了其甲基化状态以及其诱导p38delta MAP激酶的能力。"},
  {name: "L1逆转录转座主要发生在胚胎发生期并导致体细胞嵌合", description: "论文标题的中文翻译。"},
  {name: "L1逆转录转座子、癌症干细胞与肿瘤发生", description: "本文献讨论了L1逆转录转座如何可能触发肿瘤转化，基于L1活性与细胞可塑性之间的相关性，以及L1介导的插入突变改变基因表达和功能输出的能力。"},
  {name: "L1逆转录转座子对胚胎肾细胞分化的表观遗传控制", description: "本研究探讨了L1逆转录转座子通过插入和非插入机制调控小鼠胚胎肾细胞分化的作用。"},
  {name: "L1逆转录转座是哺乳动物肝癌发生的一个共同特征", description: "本论文报道了LINE-1逆转录转座在人类和小鼠肝癌发生中的普遍作用。"},
  {name: "L1逆转录转座测定：回顾与工具包", description: "本文回顾了L1逆转录转座测定法的起源、应用和未来展望，并提供了详细的操作方案。"},
  {name: "L1逆转录转座需要快速的ORF1p寡聚化，这是一种尽管经历了广泛重塑但仍保守的、依赖于卷曲螺旋的新特性。", description: "本文研究了LINE-1转座子ORF1p蛋白的寡聚化速率对其逆转录转座活性的关键作用。"},
  {name: "Lamivudine (3TC), a Nucleoside Reverse Transcriptase Inhibitor, Prevents the Neuropathological Alterations Present in Mutant Tau Transgenic Mice.", description: "拉米夫定（3TC），一种核苷逆转录酶抑制剂，可预防突变Tau转基因小鼠中存在的神经病理学改变。"},
  {name: "Lamivudine modulates the expression of neurological impairment-related genes and LINE-1 retrotransposons in brain tissues of a Down syndrome mouse model.", description: "拉米夫定调节唐氏综合征小鼠模型脑组织中神经损伤相关基因和LINE-1逆转录转座子的表达。"},
  {name: "LEAP: L1 Element Amplification Protocol", description: "LEAP: L1元件扩增方案。"},
  {name: "Leptin receptor isoform 219.1: an example of protein evolution by LINE-1-mediated human-specific retrotransposition of a coding SVA element.", description: "瘦素受体亚型219.1：一个通过LINE-1介导的人类特异性编码SVA元件逆转录转座进行蛋白质进化的例子。"},
  {name: "LINE-1 Cargo and Reverse Transcriptase Activity Profiles in Extracellular Vesicles from Lung Cancer Cells and Human Plasma", description: "肺癌细胞和人血浆细胞外囊泡中LINE-1组分及逆转录酶活性的分布特征研究。"},
  {name: "LINE-1 Cultured Cell Retrotransposition Assay", description: "《培养细胞LINE-1逆转录转座实验》"},
  {name: "LINE-1 elements in structural variation and disease.", description: "论文《结构变异与疾病中的LINE-1元件》讨论了LINE-1转座子在人类基因组中的作用及其与疾病的关系。"},
  {name: "LINE-1 Evasion of Epigenetic Repression in Humans.", description: "LINE-1在人体中逃避表观遗传抑制的研究。"},
  {name: "LINE-1 expression and retrotransposition in Barrett's esophagus and esophageal carcinoma.", description: "巴雷特食管和食管癌中的LINE-1表达与逆转录转座。"},
  {name: "LINE-1 expression in cancer correlates with p53 mutation, copy number alteration, and S phase checkpoint.", description: "癌症中LINE-1的表达与p53突变、拷贝数改变和S期检查点相关。"},
  {name: "LINE-1 in cancer: multifaceted functions and potential clinical implications", description: "本文介绍了L1逆转录转座的组成和机制，讨论了L1在癌症中的活动情况、可能的功能和调控，并探讨了其作为诊断生物标志物和治疗靶点的潜力。"},
  {name: "LINE-1 ORF1 protein enhances Alu SINE retrotransposition.", description: "LINE-1 ORF1蛋白增强Alu SINE逆转录转座。"},
  {name: "LINE-1 ORF2p C端保守氨基酸在逆转录转座中的作用", description: "论文标题的中文翻译。"},
  {name: "LINE-1 ORF2p expression is nearly imperceptible in human cancers.", description: "该论文报道了在人类癌症中，尽管存在体细胞逆转录转座的遗传证据，但使用多种标准方法几乎无法检测到LINE-1 ORF2p蛋白的表达。"},
  {name: "LINE-1 ORF2蛋白的内切酶结构域可以耐受多种突变", description: "该论文报道了LINE-1 ORF2蛋白内切酶结构域中多个预测的磷酸化位点突变对其功能影响的研究。"},
  {name: "LINE-1 preTa elements in the human genome.", description: "人类基因组中的LINE-1 preTa元件。"},
  {name: "LINE-1 repression in Epstein-Barr virus-associated gastric cancer through viral-host genome interaction.", description: "通过病毒-宿主基因组相互作用在EBV相关胃癌中抑制LINE-1。"},
  {name: "LINE-1 retrotransposition activity in human genomes.", description: "人类基因组中的LINE-1逆转录转座活性。"},
  {name: "LINE-1 Retrotransposition Assays in Embryonic Stem Cells", description: "该论文描述了在胚胎干细胞中研究人类/小鼠LINE-1（顺式）和SINE（反式）逆转录转座的稳健且定量的实验方案。"},
  {name: "LINE-1 retrotransposition in a mouse TDP-43 model of neurodegeneration marks motor cortex neurons for cell-intrinsic and cell non-autonomous programmed cell death.", description: "在神经退行性TDP-43小鼠模型中，LINE-1逆转录转座标记运动皮层神经元，使其发生细胞自主性和非自主性的程序性细胞死亡。"},
  {name: "LINE-1 retrotransposition in human embryonic stem cells.", description: "人类胚胎干细胞中的LINE-1逆转录转座。"},
  {name: "LINE-1 retrotransposition in human neuroblastoma cells is affected by oxidative stress.", description: "氧化应激影响人神经母细胞瘤细胞中LINE-1逆转录转座的研究论文。"},
  {name: "LINE-1 Retrotransposition Promotes the Development and Progression of Lung Squamous Cell Carcinoma by Disrupting the Tumor-Suppressor Gene FGGY.", description: "LINE-1逆转录转座通过破坏肿瘤抑制基因FGGY促进肺鳞状细胞癌的发生和进展。"},
  {name: "LINE-1 retrotransposon encoded ORF1p expression and promoter methylation in oral squamous cell carcinoma: a pilot study", description: "口腔鳞状细胞癌中LINE-1逆转录转座子编码的ORF1p表达及启动子甲基化的初步研究。"},
  {name: "LINE-1 retrotransposons in healthy and diseased human brain.", description: "健康与疾病人脑中的LINE-1逆转录转座子。"},
  {name: "LINE-1 retrotransposons: modulators of quantity and quality of mammalian gene expression?", description: "LINE-1逆转录转座子：哺乳动物基因表达数量与质量的调节者？"},
  {name: "LINE-1 RNA剪接及其对哺乳动物基因表达的影响", description: "论文标题的中文翻译。"},
  {name: "LINE-1: creators of neuronal diversity.", description: "LINE-1：神经元多样性的创造者。"},
  {name: "Line-1: Implications in the etiology of cancer, clinical applications, and pharmacologic targets.", description: "LINE-1：在癌症病因学、临床应用和药理学靶点中的意义。"},
  {name: "LINE-1低甲基化、逆转录转座增加和肿瘤特异性插入在上消化道癌症中的作用", description: "LINE-1 hypomethylation, increased retrotransposition and tumor-specific insertion in upper gastrointestinal cancer."},
  {name: "LINE-1低甲基化是乳糜泻相关肠粘膜和小肠腺癌炎症反应的特征", description: "本研究评估了LINE-1甲基化在乳糜泻相关小肠腺癌中的作用，并探讨了其在乳糜泻炎症反应中的可逆性。"},
  {name: "LINE-1和SINE逆转录转座子对哺乳动物基因组的影响", description: "本文综述了LINE-1和SINE逆转录转座子对哺乳动物基因组结构和功能的影响，包括其转座机制、致病性及宿主防御。"},
  {name: "LINE-1核糖核蛋白凝聚物结合DNA以实现有丝分裂期间的核进入", description: "LINE-1核糖核蛋白凝聚物结合DNA以实现有丝分裂期间的核进入。"},
  {name: "LINE-1蛋白在细胞周期中的定位和功能动态", description: "LINE-1蛋白在细胞周期中的定位和功能动态。"},
  {name: "LINE-1诱导的逆转录转座影响早期植入前胚胎DNA完整性和多能性", description: "本研究探讨了LINE-1过表达对人类胚胎植入前阶段DNA完整性、甲基化以及多能性因子表达的影响。"},
  {name: "LINE-1逆转录转座与人类肿瘤发生之间的联系", description: "这篇综述总结了关于LINE-1逆转录转座与人类肿瘤发生之间联系的最新研究进展。"},
  {name: "LINE-1逆转录转座事件在X射线照射后调节基因表达。", description: "本研究评估了X射线照射后，LINE-1从头逆转录转座对人内皮细胞中不同基因表达的潜在影响。"},
  {name: "LINE-1逆转录转座事件影响内皮细胞增殖和迁移", description: "LINE-1逆转录转座事件影响内皮细胞增殖和迁移。"},
  {name: "LINE-1逆转录转座子DNA在HIV-1感染细胞中积累", description: "报道HIV-1感染增强LINE-1逆转录转座并导致其DNA积累的论文。"},
  {name: "LINE-1逆转录转座子的沉默是髓系白血病的选择性依赖", description: "本文报道了LINE-1在髓系白血病中的肿瘤抑制功能及其沉默机制。"},
  {name: "LINE-1逆转录转座子表达及其亚细胞定位在乳腺癌中的预后价值", description: "本研究首次在乳腺癌组织中检测了ORF1p和ORF2p的表达，并探讨了其亚细胞定位与临床病理参数及患者生存的关系。"},
  {name: "LINE-1逆转录转座活性的等位基因异质性", description: "论文标题的中文翻译。"},
  {name: "LINE-1逆转录转座：对基因组稳定性和多样性以及人类疾病的影响", description: "LINE-1逆转录转座：对基因组稳定性和多样性以及人类疾病的影响"},
  {name: "LINE-1靶向引物逆转录的结构机制", description: "报道了人类LINE-1 TPRT复合物的冷冻电镜结构，揭示了ORF2p的构象动力学及其对靶DNA的重塑机制。"},
  {name: "LINE-like retrotransposition in Saccharomyces cerevisiae.", description: "酿酒酵母中的LINE样逆转录转座。"},
  {name: "LINE1 contributes to autoimmunity through both RIG-I- and MDA5-mediated RNA sensing pathways.", description: "LINE1通过RIG-I和MDA5介导的RNA感应通路促进自身免疫。"},
  {name: "LINE1 insertion into the NACC2 locus disrupts the HDM2 axis and activates lung oncogenic signaling.", description: "LINE1插入NACC2基因座破坏HDM2轴并激活肺癌信号通路。"},
  {name: "LINE1 insertions as a genomic risk factor for schizophrenia: Preliminary evidence from an affected family.", description: "LINE1插入作为精神分裂症的基因组风险因素：来自一个受累家庭的初步证据。"},
  {name: "LINE1介导的SARS-CoV-2 mRNA逆转录和基因组整合在病毒感染的细胞中被检测到，但在病毒mRNA转染的细胞中未被检测到。", description: "本论文的标题，描述了LINE-1在SARS-CoV-2感染过程中的作用。"},
  {name: "Lineage specific evolution of the VNTR composite retrotransposon central domain and its role in retrotransposition of gibbon LAVA elements.", description: "谱系特异性VNTR复合逆转录转座子中心结构域的进化及其在长臂猿LAVA元件逆转录转座中的作用。"},
  {name: "LINEing germ and embryonic stem cells' silencing of retrotransposons.", description: "该论文报道了关于人类胚胎干细胞和小鼠生殖细胞中LINE-1调控的新见解。"},
  {name: "LINE逆转录转座与宿主DNA修复机制", description: "讨论LINE逆转录转座的5'-末端连接通路，并提出LINE整合通路采用特定宿主修复因子的论文。"},
  {name: "LINE驱动：逆转录转座与基因组不稳定性", description: "论文标题的中文翻译。"},
  {name: "Links between repeated sequences", description: "这篇论文探讨了重复序列之间的联系，特别是LINE-1和Alu元件在人类基因组中的功能关联。"},
  {name: "Locus-resolution analysis of L1 regulation and retrotransposition potential in mouse embryonic development.", description: "在小鼠胚胎发育过程中对L1调控和逆转录转座潜能的位点分辨率分析。"},
  {name: "Long Interspersed Element Sequencing (L1-Seq): A Method to Identify Somatic LINE-1 Insertions in the Human Genome.", description: "长散布元件测序（L1-Seq）：一种鉴定人类基因组中体细胞LINE-1插入的方法。"},
  {name: "Long interspersed element-1 is differentially regulated by food-borne carcinogens via the aryl hydrocarbon receptor.", description: "长散布核元件-1通过芳烃受体被食物源性致癌物差异调控。"},
  {name: "Long INterspersed element-1 mobility as a sensor of environmental stresses.", description: "长散在核元件-1的移动性作为环境压力的传感器。"},
  {name: "Long interspersed nuclear element 1 methylation in non-small cell lung cancer: implications for diagnosis, prognosis, and therapeutic targeting.", description: "长散布核元件1甲基化在非小细胞肺癌中的作用：对诊断、预后和治疗靶向的意义。"},
  {name: "Long Interspersed Nuclear Elements 1 (LINE1): The chimeric transcript L1-MET and its involvement in cancer.", description: "长散布核元件1 (LINE1)：嵌合转录本L1-MET及其在癌症中的参与。"},
  {name: "Long-read assembly of a Great Dane genome highlights the contribution of GC-rich sequence and mobile elements to canine genomes.", description: "通过长读长测序组装大丹犬基因组，揭示了富含GC序列和可移动元件对犬基因组的贡献。"},
  {name: "Long-read sequencing and structural variant characterization in 1,019 samples from the 1000 Genomes Project", description: "利用纳米孔长读长测序技术，对来自1000基因组计划的1019个样本进行测序，构建了结构变异资源，并详细分析了包括LINE-1在内的转座子活动。"},
  {name: "Loss of Nexmif results in the expression of phenotypic variability and loss of genomic integrity.", description: "Nexmif缺失导致表型变异性表达和基因组完整性丧失。"},
  {name: "Lung genotoxicity of benzo(a)pyrene in vivo involves reactivation of LINE-1 retrotransposon and early reprogramming of oncogenic regulatory networks.", description: "苯并(a)芘的体内肺遗传毒性涉及LINE-1逆转录转座子的再激活和致癌调控网络的早期重编程。"},
  {name: "Machine learning reveals bilateral distribution of somatic L1 insertions in human neurons and glia", description: "机器学习揭示人类神经元和胶质细胞中体细胞L1插入的双侧分布。"},
  {name: "Many human L1 elements are capable of retrotransposition.", description: "许多人类L1元件具有逆转录转座能力。"},
  {name: "Mapping the LINE1 ORF1 protein interactome reveals associated inhibitors of human retrotransposition", description: "对“Mapping the LINE1 ORF1 protein interactome reveals associated inhibitors of human retrotransposition”一文的更正。"},
  {name: "Mapping the LINE1 ORF1 protein interactome reveals associated inhibitors of human retrotransposition.", description: "通过共免疫沉淀和质谱分析，鉴定与L1 ORF1蛋白及其核糖核蛋白相互作用的蛋白质，并发现其中一些是逆转录转座的强效抑制剂。"},
  {name: "Mercury specifically induces LINE-1 activity in a human neuroblastoma cell line.", description: "汞特异性地诱导人神经母细胞瘤细胞系中的LINE-1活性。"},
  {name: "Meta-analysis of gross insertions causing human genetic disease: novel mutational mechanisms and the role of replication slippage.", description: "关于导致人类遗传病的大片段插入突变的荟萃分析：新的突变机制和复制滑动的作用。"},
  {name: "Methyl-CpG-binding protein 2 represses LINE-1 expression and retrotransposition but not Alu transcription.", description: "甲基化CpG结合蛋白2抑制LINE-1的表达和逆转录转座，但不抑制Alu转录。"},
  {name: "Methylation of endogenous human retroelements in health and disease.", description: "《健康与疾病中内源性人类逆转录元件的甲基化》"},
  {name: "MicroRNA miR-128 represses LINE-1 (L1) retrotransposition by down-regulating the nuclear import factor TNPO1.", description: "MicroRNA miR-128通过下调核输入因子TNPO1来抑制LINE-1 (L1)的逆转录转座。"},
  {name: "miR-128 Restriction of LINE-1 (L1) Retrotransposition Is Dependent on Targeting hnRNPA1 mRNA.", description: "miR-128通过靶向hnRNPA1 mRNA抑制LINE-1逆转录转座。"},
  {name: "miR-128通过直接结合L1 RNA抑制L1逆转录转座", description: "本论文报道了miR-128在人类癌细胞和iPSCs中通过直接结合L1 RNA来抑制新的逆转录转座事件。"},
  {name: "Mobile elements create structural variation: analysis of a complete human genome.", description: "移动元件产生结构变异：对一个完整人类基因组的分析。"},
  {name: "Mobility pathways for vertebrate L1, L2, CR1, and RTE clade retrotransposons.", description: "关于脊椎动物L1、L2、CR1和RTE进化枝逆转录转座子移动途径的论文。"},
  {name: "Mobilization of LINE-1 retrotransposons is restricted by Tex19.1 in mouse embryonic stem cells.", description: "在小鼠胚胎干细胞中，Tex19.1 限制 LINE-1 逆转录转座子的动员。"},
  {name: "Modulation of LINE-1 and Alu/SVA retrotransposition by Aicardi-Goutières syndrome-related SAMHD1.", description: "该论文报道了Aicardi-Goutières综合征相关蛋白SAMHD1对LINE-1和Alu/SVA逆转录转座的调控作用。"},
  {name: "Modulation of LINE-1 Retrotransposition by a Human SAMHD1 Polymorphism.", description: "人类SAMHD1多态性对LINE-1逆转录转座的调控。"},
  {name: "More active human L1 retrotransposons produce longer insertions.", description: "更活跃的人类L1逆转录转座子产生更长的插入。"},
  {name: "MORE-RNAseq: a pipeline for quantifying retrotransposition-capable LINE1 expression based on RNA-seq data.", description: "MORE-RNAseq：一个基于RNA-seq数据量化具有逆转录转座能力的LINE1表达的流程。"},
  {name: "MOV10 RNA helicase is a potent inhibitor of retrotransposition in cells.", description: "MOV10 RNA解旋酶是细胞内逆转录转座的强效抑制剂。"},
  {name: "MOV10对LINE-1逆转录转座的最大抑制效应需要MOV10/LINE-1结合和颗粒形成", description: "该论文报道了MOV10通过其延伸的motif II和C端结构域协同作用，分别介导与LINE-1的相互作用和颗粒形成，从而实现对LINE-1逆转录转座的最大抑制。"},
  {name: "MOV10通过形成具有相分离特性的细胞质颗粒招募DCP2来脱帽人类LINE-1 RNA", description: "MOV10通过形成具有相分离特性的细胞质颗粒招募DCP2来脱帽人类LINE-1 RNA"},
  {name: "mRNA retrotransposition coupled with 5' inversion as a possible source of new genes.", description: "mRNA逆转录转座与5'端倒位偶联作为新基因的可能来源。"},
  {name: "Multi-platform framework for mapping somatic retrotransposition in human tissues.", description: "用于绘制人体组织中体细胞逆转录转座的多平台框架。"},
  {name: "Multiple fates of L1 retrotransposition intermediates in cultured human cells.", description: "培养人类细胞中L1逆转录转座中间体的多种命运。"},
  {name: "Multiple Mechanisms Contribute To Telomere Maintenance", description: "这篇综述讨论了多种端粒维持机制，并提出了LINE-1逆转录转座可能在不依赖端粒酶的肿瘤中贡献于端粒维持的假说。"},
  {name: "MxB inhibits long interspersed element type 1 retrotransposition.", description: "MxB抑制长散在核元件1型的逆转录转座。"},
  {name: "N6-腺苷甲基化及其对LINE-1的调控机制", description: "综述了LINE-1 m6A修饰的研究进展，包括其修饰位点、模式和相关机制。"},
  {name: "Nanopore Sequencing Enables Comprehensive Transposable Element Epigenomic Profiling", description: "纳米孔测序实现全面的转座子元件表观基因组分析。"},
  {name: "Nef通过两种不同的机制抑制LINE-1逆转录转座", description: "本论文报道了HIV Nef蛋白通过抑制LINE-1启动子活性和破坏ORF1p-RNA相互作用来抑制LINE-1逆转录转座，从而下调宿主细胞干扰素产生。"},
  {name: "Neurotoxic Methamphetamine Doses Increase LINE-1 Expression in the Neurogenic Zones of the Adult Rat Brain.", description: "神经毒性剂量的甲基苯丙胺增加成年大鼠脑神经源性区域的LINE-1表达。"},
  {name: "New Understanding of the Relevant Role of LINE-1 Retrotransposition in Human Disease and Immune Modulation", description: "这篇综述讨论了LINE-1的组成和调控机制、其与疾病和免疫的相关性，以及多种LINE-1抑制剂，为理解LINE-1提供了新的视角。"},
  {name: "Nickel stimulates L1 retrotransposition by a post-transcriptional mechanism.", description: "镍通过转录后机制刺激L1逆转录转座。"},
  {name: "No evidence of human genome integration of SARS-CoV-2 found by long-read DNA sequencing.", description: "通过长读长DNA测序未发现SARS-CoV-2整合入人类基因组的证据。"},
  {name: "Northern blotting of endogenous full-length human-specific LINE-1 RNA.", description: "本文描述了一种通过设计RNA探针，利用优化的条件和工具，通过Northern印迹检测内源性全长活性LINE-1 RNA的方法。"},
  {name: "Novel family of human transposable elements formed due to fusion of the first exon of gene MAST2 with retrotransposon SVA", description: "报道了一种由MAST2基因第一外显子与SVA逆转录转座子融合形成的新型人类特异性转座子家族CpG-SVA，并描述了其形成机制。"},
  {name: "Novel retrotransposon analysis reveals multiple mobility pathways dictated by hosts.", description: "通过新型逆转录转座子分析揭示由宿主决定的多重移动途径。"},
  {name: "Nuclear cGAS restricts L1 retrotransposition by promoting TRIM41-mediated ORF2p ubiquitination and degradation.", description: "核cGAS通过促进TRIM41介导的ORF2p泛素化和降解来限制LINE-1逆转录转座。"},
  {name: "On the interface of aging, cancer, and neurodegeneration with SIRT6 and L1 retrotransposon protein interaction network.", description: "关于衰老、癌症和神经退行性疾病与SIRT6及L1逆转录转座子蛋白质相互作用网络界面的研究。"},
  {name: "Opossum APOBEC1 is a DNA mutator with retrovirus and retroelement restriction activity.", description: "负鼠APOBEC1是一种具有逆转录病毒和逆转录元件限制活性的DNA突变因子。"},
  {name: "Opposing roles of pseudokinases NRBP1 and NRBP2 in regulating L1 retrotransposition.", description: "假激酶NRBP1和NRBP2在调控L1逆转录转座中的相反作用。"},
  {name: "ORF1p的磷酸化是L1逆转录转座所必需的", description: "报道了L1活性需要其ORF1编码蛋白的磷酸化，并揭示了该磷酸化事件与细胞磷酸化调控级联的整合关系。"},
  {name: "ORF1蛋白中单个氨基酸替换显著降低L1逆转录转座活性并为核酸分子伴侣活性提供见解", description: "ORF1蛋白中单个氨基酸替换显著降低L1逆转录转座活性并为核酸分子伴侣活性提供见解。"},
  {name: "p53 responsive elements in human retrotransposons", description: "人类逆转录转座子中的p53应答元件。"},
  {name: "p53-mediated regulation of LINE1 retrotransposon-derived R-loops.", description: "p53介导的LINE1逆转录转座子来源的R-loop调控。"},
  {name: "Pan-cancer analysis of whole genomes identifies driver rearrangements promoted by LINE-1 retrotransposition.", description: "全癌种全基因组分析鉴定出由LINE-1逆转录转座促进的驱动性重排。"},
  {name: "Pan-cancer analysis reveals context-dependent roles of LINE-1 ORF1p in immune regulation and copy number alterations.", description: "泛癌分析揭示LINE-1 ORF1p在免疫调节和拷贝数改变中的背景依赖性作用。"},
  {name: "Pan-cancer multi-omic model of LINE-1 activity reveals locus heterogeneity of retrotransposition efficiency.", description: "本文报道了基于TCGA数据的泛癌分析，改进了LINE-1逆转录转座检测算法，并建模了p53的双重调控作用，揭示了与L1活性相关的基因突变。"},
  {name: "Pathogenic orphan transduction created by a nonreference LINE-1 retrotransposon.", description: "由非参考LINE-1逆转录转座子产生的致病性孤儿转导。"},
  {name: "PDHX基因中因全长LINE-1元件逆转录转座插入导致的大片段基因组缺失", description: "报道了在PDHX基因中发现由全长LINE-1元件逆转录转座插入引起的约46-kb致病性基因组缺失的论文。"},
  {name: "Pedigree-based estimation of human mobile element retrotransposition rates.", description: "基于谱系的人类可移动元件逆转录转座率估计。"},
  {name: "Pharmacological inhibition of neddylation impairs long interspersed element 1 retrotransposition.", description: "这篇论文报道了蛋白质Neddylation修饰过程对LINE-1逆转录转座至关重要，其抑制剂MLN4924可抑制LINE-1逆转录和转座活性。"},
  {name: "Phase separation of the LINE-1 ORF1 protein is mediated by the N-terminus and coiled-coil domain.", description: "LINE-1 ORF1蛋白的相分离由N端和卷曲螺旋结构域介导。"},
  {name: "PML and PML-like exonucleases restrict retrotransposons in jawed vertebrates.", description: "PML和PML样核酸外切酶在有颌脊椎动物中限制逆转录转座子。"},
  {name: "Poly(A) binding protein C1 is essential for efficient L1 retrotransposition and affects L1 RNP formation.", description: "该论文报道了多聚腺苷酸结合蛋白C1对于高效LINE-1逆转录转座至关重要，并影响LINE-1核糖核蛋白复合物的形成。"},
  {name: "Poly(ADP-Ribose) Polymerase 2 Recruits Replication Protein A to Sites of LINE-1 Integration to Facilitate Retrotransposition.", description: "聚(ADP-核糖)聚合酶2募集复制蛋白A至LINE-1整合位点以促进逆转录转座。"},
  {name: "Positional cloning of the gene for X-linked retinitis pigmentosa 2", description: "X连锁视网膜色素变性2基因的定位克隆。"},
  {name: "Post-Transcriptional Control of LINE-1 Retrotransposition by Cellular Host Factors in Somatic Cells", description: "体细胞中细胞宿主因子对LINE-1逆转录转座的转录后调控。"},
  {name: "Post-transcriptional regulation of LINE-1 retrotransposition by AID/APOBEC and ADAR deaminases.", description: "AID/APOBEC和ADAR脱氨酶对LINE-1逆转录转座的转录后调控。"},
  {name: "Potential for genomic instability associated with retrotranspositionally-incompetent L1 loci", description: "这篇论文探讨了无逆转录转座能力的L1基因座与基因组不稳定性相关的潜力。"},
  {name: "Poxviruses capture host genes by LINE-1 retrotransposition.", description: "痘病毒通过LINE-1逆转录转座捕获宿主基因。"},
  {name: "Primary immunodeficiency caused by an exonized retroposed gene copy inserted in the CYBB gene.", description: "报道了一种由LINE-1介导的TMF1转录本插入CYBB基因导致的新型原发性免疫缺陷病。"},
  {name: "Progress in understanding the biology of the human mutagen LINE-1.", description: "理解人类诱变剂LINE-1生物学的最新进展。"},
  {name: "Promoter binding proteins of an active human L1 retrotransposon.", description: "一篇活跃的人类L1逆转录转座子启动子结合蛋白的研究论文。"},
  {name: "Properties of LINE-1 proteins and repeat element expression in the context of amyotrophic lateral sclerosis.", description: "本研究探讨了LINE-1蛋白的特性及其在肌萎缩侧索硬化症背景下的重复元件表达。"},
  {name: "Prostate-specific loss of UXT promotes cancer progression.", description: "前列腺特异性UXT缺失促进癌症进展。"},
  {name: "Proteome Profile of Endogenous Retrotransposon-Associated Complexes in Human Embryonic Stem Cells.", description: "人胚胎干细胞中内源性逆转录转座子相关复合物的蛋白质组谱。"},
  {name: "Purification of L1-Ribonucleoprotein Particles (L1-RNPs) from Cultured Human Cells.", description: "从培养的人类细胞中纯化L1-核糖核蛋白颗粒的详细免疫亲和方法。"},
  {name: "Rad18抑制人类免疫缺陷病毒1型的晚期复制步骤", description: "Rad18 suppresses the late step of human immunodeficiency virus type 1 replication."},
  {name: "Rapid amplification of a retrotransposon subfamily is evolving the mouse genome.", description: "这篇论文报道了小鼠T(F)亚家族LINE-1逆转录转座子的活性及其对基因组进化的贡献。"},
  {name: "Rates and patterns of great ape retrotransposition.", description: "《类人猿逆转录转座的速率与模式》"},
  {name: "RDA coupled with deep sequencing detects somatic SVA-retrotranspositions and mosaicism in the human brain.", description: "结合深度测序的RDA技术检测人脑中的体细胞SVA逆转录转座和镶嵌现象。"},
  {name: "Reading between the LINEs: human genomic variation induced by LINE-1 retrotransposition.", description: "解读LINE序列之间：由LINE-1逆转录转座诱导的人类基因组变异。"},
  {name: "Recessive inheritance of population-specific intronic LINE-1 insertion causes a rotor syndrome phenotype.", description: "隐性遗传的人群特异性内含子LINE-1插入导致Rotor综合征表型。"},
  {name: "Recognition of 3'-end L1, Alu, processed pseudogenes, and mRNA stem-loops in the human genome using sequence-based and structure-based machine-learning models.", description: "利用基于序列和基于结构的机器学习模型识别人类基因组中L1、Alu、加工假基因和mRNA的3'-末端茎环结构。"},
  {name: "Recurrent evolution of an inhibitor of ESCRT-dependent virus budding and LINE-1 retrotransposition in primates.", description: "灵长类动物中抑制ESCRT依赖性病毒出芽和LINE-1逆转录转座的抑制剂的反复进化。"},
  {name: "Regulatory Role of Insulin on Endogenous L1 ORF1 and NEFM Gene Expression through PI3K Signaling Pathway Specifically in Neuroblastoma Cell Line.", description: "该论文研究了胰岛素通过PI3K信号通路对神经母细胞瘤细胞系中内源性L1 ORF1和NEFM基因表达的调控作用。"},
  {name: "Replicative Senescence-Associated LINE1 Methylation and LINE1-Alu Expression Levels in Human Endothelial Cells", description: "人类内皮细胞中与复制性衰老相关的LINE1甲基化和LINE1-Alu表达水平研究。"},
  {name: "Reprogramming somatic cells into iPS cells activates LINE-1 retroelement mobility.", description: "将体细胞重编程为iPS细胞激活LINE-1逆转录元件的移动性。"},
  {name: "Reprogramming triggers endogenous L1 and Alu retrotransposition in human induced pluripotent stem cells.", description: "重编程触发人诱导多能干细胞中内源性L1和Alu逆转录转座。"},
  {name: "Requirements for polyadenylation at the 3' end of LINE-1 elements.", description: "LINE-1元件3'端多聚腺苷酸化的要求。"},
  {name: "Research and application on LINE-1 in diagnosis and treatment of tumorigenesis.", description: "关于LINE-1在肿瘤发生诊断和治疗中应用的研究综述。"},
  {name: "Resolving rates of mutation in the brain using single-neuron genomics.", description: "使用单神经元基因组学解析大脑中的突变率。"},
  {name: "Restricting retrotransposons: ADAR1 is another guardian of the human genome.", description: "限制逆转录转座子：ADAR1是人类基因组的另一位守护者。"},
  {name: "Resveratrol blocks retrotransposition of LINE-1 through PPAR α and sirtuin-6.", description: "白藜芦醇通过PPARα和sirtuin-6阻断LINE-1的逆转录转座。"},
  {name: "Retroelements in human disease", description: "这篇综述总结了逆转录转座子导致人类疾病的分子机制，并对其诱变效应进行了分类。"},
  {name: "Retroposed copies of the HMG genes: a window to genome dynamics.", description: "《HMG基因的逆转录拷贝：基因组动态的一扇窗》"},
  {name: "Retropseudogenes derived from the human Ro/SS-A autoantigen-associated hY RNAs", description: "该论文报道了源自人类Ro/SS-A自身抗原相关hY RNA的逆转录假基因的表征。"},
  {name: "RetroSeeker揭示了大量新型逆转录转座子的特征、表达和进化", description: "本文开发了retroSeeker软件，用于从基因组比对中识别新型逆转录转座子，并解析其生物发生、表达、进化和潜在功能。"},
  {name: "Retrotransposal integration of mobile genetic elements in human diseases.", description: "关于移动遗传元件（逆转录转座子）整合在人类疾病中作用的论文。"},
  {name: "Retrotransposed genes such as Frat3 in the mouse Chromosome 7C Prader-Willi syndrome region acquire the imprinted status of their insertion site.", description: "关于小鼠7C染色体普拉德-威利综合征区域中逆转录转座基因（如Frat3）获得其插入位点印记状态的研究。"},
  {name: "Retrotransposition and Crystal Structure of an Alu RNP in the Ribosome-Stalling Conformation.", description: "该论文报道了Alu RNP在核糖体停滞构象中的逆转录转座和晶体结构研究。"},
  {name: "Retrotransposition and senescence in mouse heart tissue by viral protein R of human immunodeficiency virus-1.", description: "人免疫缺陷病毒-1病毒蛋白R在小鼠心脏组织中诱导逆转录转座和衰老的研究。"},
  {name: "Retrotransposition creates sloping shores: a graded influence of hypomethylated CpG islands on flanking CpG sites.", description: "逆转录转座创造倾斜海岸：低甲基化CpG岛对侧翼CpG位点的梯度影响。"},
  {name: "Retrotransposition in tumors and brains.", description: "这篇评论文章讨论了逆转录转座在肿瘤和大脑细胞中的发生。"},
  {name: "Retrotransposition of long interspersed element 1 induced by methamphetamine or cocaine.", description: "甲基苯丙胺或可卡因诱导的长散布元件1逆转录转座。"},
  {name: "Retrotransposition of marked SVA elements by human L1s in cultured cells", description: "在培养细胞中，人类L1介导标记SVA元件的逆转录转座。"},
  {name: "Retrotransposition-Competent Human LINE-1 Induces Apoptosis in Cancer Cells With Intact p53", description: "具有逆转录转座活性的人类LINE-1在具有完整p53的癌细胞中诱导凋亡。"},
  {name: "Retrotransposition-competent L1s are increased in the genomes of individuals with amyotrophic lateral sclerosis.", description: "具有逆转录转座能力的L1在肌萎缩侧索硬化症患者基因组中增加。"},
  {name: "Retrotransposon Activation in the Aged and Alzheimer's Disease Brain Examined by Nanopore Long-read DNA Sequencing", description: "通过纳米孔长读长DNA测序研究衰老和阿尔茨海默病大脑中的逆转录转座子激活。"},
  {name: "Retrotransposon expression and incorporation of cloned human and mouse retroelements in human spermatozoa.", description: "研究人类精子中逆转录转座子表达及克隆的人类和小鼠逆转录元件整合的论文。"},
  {name: "Retrotransposon instability dominates the acquired mutation landscape of mouse induced pluripotent stem cells.", description: "逆转录转座子不稳定性主导了小鼠诱导多能干细胞的获得性突变图谱。"},
  {name: "Retrotransposon Protein L1 ORF1p Expression in Aging Central Nervous System.", description: "该论文描述了衰老小鼠大脑中LINE-1蛋白ORF1p的表达上调，并探讨了其与神经炎症的关系。"},
  {name: "Retrotransposon RNA expression and evidence for retrotransposition events in human oocytes.", description: "人类卵母细胞中逆转录转座子RNA表达及转座事件的证据。"},
  {name: "Retrotransposon-induced mosaicism in the neural genome.", description: "逆转录转座子诱导的神经基因组嵌合现象。"},
  {name: "Retrotransposons as a Source of DNA Damage in Neurodegeneration.", description: "这篇综述论文讨论了逆转录转座子作为神经退行性疾病中DNA损伤来源的潜在作用。"},
  {name: "Retrotransposons: a new and credible source of inherited and somatically acquired hepatocellular carcinoma mutations.", description: "逆转录转座子：遗传性和体细胞获得性肝细胞癌突变的一个新的可靠来源。"},
  {name: "Retrotransposons: mobile and mutagenic from conception to death.", description: "逆转录转座子：从受孕到死亡都具有移动性和致突变性。"},
  {name: "Reverse transcriptase encoded by a human transposable element.", description: "一篇报道人类转座子编码逆转录酶的论文。"},
  {name: "Reviving a 60 million year old LINE-1 element.", description: "该论文报道了重建并复活一个约6000万年前活跃的LINE-1亚家族（L1PA13A），并研究了其逆转录转座活性及调控机制。"},
  {name: "Reviving the dead: history and reactivation of an extinct l1.", description: "关于巨型蝙蝠中已灭绝的LINE-1转座子的历史及其在体外实验中重新激活的研究。"},
  {name: "RNA m6A modification orchestrates a LINE-1-host interaction that facilitates retrotransposition and contributes to long gene vulnerability.", description: "RNA m6A修饰协调LINE-1与宿主的相互作用，促进逆转录转座并导致长基因脆弱性。"},
  {name: "RNA m6A修饰在体外和体内调节人精原干细胞分化中的L1逆转录转座子", description: "RNA m6A修饰在体外和体内调节人精原干细胞分化中的L1逆转录转座子。"},
  {name: "RNA sensor MDA5 suppresses LINE-1 retrotransposition by regulating the promoter activity of LINE-1 5'-UTR.", description: "RNA传感器MDA5通过调控LINE-1 5'-UTR的启动子活性来抑制LINE-1逆转录转座。"},
  {name: "RNA truncation by premature polyadenylation attenuates human mobile element activity.", description: "RNA通过提前多聚腺苷酸化被截断从而减弱人类可移动元件的活性。"},
  {name: "RNase H2, mutated in Aicardi-Goutières syndrome, promotes LINE-1 retrotransposition.", description: "该论文报道了RNase H2（AGS中最常见的突变基因）对LINE-1逆转录转座的作用。"},
  {name: "RNase H2-RED carpets the path to eukaryotic RNase H2 functions.", description: "RNase H2-RED为阐明真核生物RNase H2的功能铺平了道路。"},
  {name: "RNase L restricts the mobility of engineered retrotransposons in cultured human cells.", description: "RNase L限制工程化逆转录转座子在培养人类细胞中的移动性。"},
  {name: "RNA聚合酶决定LINE和SINE逆转录转座的ORF1需求和时机", description: "该论文报道了RNA聚合酶类型如何影响LINE和SINE逆转录转座的动力学和蛋白需求。"},
  {name: "RNA连接先于U6/LINE-1嵌合RNA的逆转录转座", description: "本论文报道了RNA连接酶RtcB参与U6/L1嵌合RNA的形成，以及该嵌合RNA的逆转录转座导致假基因形成和个体间遗传变异。"},
  {name: "Robust expression of LINE-1 retrotransposon encoded proteins in oral squamous cell carcinoma.", description: "口腔鳞状细胞癌中LINE-1逆转录转座子编码蛋白的强表达。"},
  {name: "Role of long interspersed nuclear element-1 in the regulation of chromatin landscapes and genome dynamics.", description: "长散布核元件-1在染色质景观和基因组动力学调控中的作用。"},
  {name: "Roles for retrotransposon insertions in human disease", description: "这篇综述概述了LINE-1生物学，并重点介绍了新报道的LINE-1介导的人类遗传疾病。"},
  {name: "S100A9核转位通过异染色质侵蚀去抑制LINE1触发分娩时人羊膜成纤维细胞衰老", description: "本论文报道了S100A9蛋白在分娩时通过核转位导致异染色质侵蚀，从而去抑制LINE1，进而引发羊膜成纤维细胞衰老的机制。"},
  {name: "SAMHD1的核质穿梭对LINE-1抑制很重要", description: "该论文报道了SAMHD1是一种核质穿梭蛋白，并揭示了其亚细胞定位与抑制LINE-1逆转录转座能力之间的关系。"},
  {name: "SAMHD1通过促进应激颗粒形成抑制LINE-1逆转录转座", description: "SAMHD1通过促进应激颗粒形成抑制LINE-1逆转录转座。"},
  {name: "SARS-CoV-2-encoded inhibitors of human LINE-1 retrotransposition.", description: "SARS-CoV-2编码的人类LINE-1逆转录转座抑制剂。"},
  {name: "Selection against deleterious LINE-1-containing loci in the human lineage.", description: "对人类谱系中有害LINE-1位点的选择作用的研究。"},
  {name: "Selection against LINE-1 retrotransposons results principally from their ability to mediate ectopic recombination.", description: "针对LINE-1逆转录转座子的选择主要源于其介导异位重组的能力。"},
  {name: "Selective silencing of euchromatic L1s revealed by genome-wide screens for L1 regulators.", description: "通过全基因组筛选揭示常染色质L1选择性沉默的L1调控因子。"},
  {name: "Sequence Diversity and Encoded Enzymatic Differences of Monocistronic L1 ORF2 mRNA Variants in the Aged Normal and Alzheimer's Disease Brain", description: "该论文报道了在衰老正常和阿尔茨海默病大脑中，单顺反子L1 ORF2 mRNA变体的序列多样性及其编码的酶活性差异。"},
  {name: "SINE逆转录转座：Alu活性评估与新插入的回收", description: "本文介绍了SINE逆转录转座实验的细节以及新插入的回收方法，并重点讨论了SINE实验特有的细微差别。"},
  {name: "Single-neuron sequencing analysis of L1 retrotransposition and somatic mutation in the human brain.", description: "通过单神经元测序分析人脑中L1逆转录转座和体细胞突变的研究。"},
  {name: "SIRT7 mediates L1 elements transcriptional repression and their association with the nuclear lamina.", description: "SIRT7介导L1元件的转录抑制及其与核纤层的关联。"},
  {name: "Site-specific retrotransposition of L1 elements within human alphoid satellite sequences.", description: "L1元件在人类α卫星序列中的位点特异性逆转录转座。"},
  {name: "SLFN11 Restricts LINE-1 Mobility.", description: "SLFN11限制LINE-1的移动性。"},
  {name: "SLFN14抑制LINE-1转座活性", description: "本文报道了宿主因子SLFN14通过影响LINE-1的转录和降解来抑制其逆转录转座的机制。"},
  {name: "Sole copy of Z2-type human cytidine deaminase APOBEC3H has inhibitory activity against retrotransposons and HIV-1.", description: "唯一拷贝的Z2型人胞苷脱氨酶APOBEC3H对逆转录转座子和HIV-1具有抑制活性。"},
  {name: "Somatic expression of LINE-1 elements in human tissues.", description: "人类组织中LINE-1元件的体细胞表达。"},
  {name: "Somatic LINE-1 retrotransposition in cortical neurons and non-brain tissues of Rett patients and healthy individuals.", description: "Rett综合征患者和健康个体皮层神经元及非脑组织中的体细胞LINE-1逆转录转座。"},
  {name: "Somatic mosaicism in neuronal precursor cells mediated by L1 retrotransposition.", description: "L1逆转录转座介导的神经元前体细胞体细胞嵌合。"},
  {name: "Somatic retrotransposition alters the genetic landscape of the human brain.", description: "体细胞逆转录转座改变人类大脑的遗传景观。"},
  {name: "Somatic retrotransposition in the developing rhesus macaque brain.", description: "《发育中的恒河猴大脑中的体细胞逆转录转座》"},
  {name: "Somatically Acquired LINE-1 Insertions in Normal Esophagus Undergo Clonal Expansion in Esophageal Squamous Cell Carcinoma.", description: "本论文报道了在食管鳞状细胞癌中，体细胞获得的LINE-1插入在正常食管中发生并在肿瘤中克隆性扩增。"},
  {name: "SOX-11 regulates LINE-1 retrotransposon activity during neuronal differentiation.", description: "SOX-11在神经元分化过程中调控LINE-1逆转录转座子活性。"},
  {name: "Spatial assembly and RNA binding stoichiometry of a LINE-1 protein essential for retrotransposition.", description: "一篇关于LINE-1转座子ORF1蛋白空间组装和RNA结合化学计量学的论文。"},
  {name: "Spliced integrated retrotransposed element (SpIRE) formation in the human genome.", description: "该论文报道了人类基因组中剪接整合逆转录元件的形成。"},
  {name: "sRNA/L1 retrotransposition: using siRNAs and miRNAs to expand the applications of the cell culture-based LINE-1 retrotransposition assay", description: "本文描述了一种将传统的基于细胞培养的LINE-1逆转录转座报告基因检测与siRNA和miRNA模拟物或抑制剂相结合的高重现性、定量、稳健且灵活的协议。"},
  {name: "Stable integration of transgenes delivered by a retrotransposon-adenovirus hybrid vector.", description: "通过逆转录转座子-腺病毒杂合载体递送的转基因的稳定整合。"},
  {name: "STING通过分选ORF1p至溶酶体降解来抑制LINE-1逆转录转座", description: "STING通过分选ORF1p至溶酶体降解来抑制LINE-1逆转录转座。"},
  {name: "Stress out the LINEs.", description: "应激抑制LINEs。"},
  {name: "Striking a balance: regulation of transposable elements by Zfp281 and Mll2 in mouse embryonic stem cells.", description: "该论文报道了在小鼠胚胎干细胞中，Zfp281通过直接结合并抑制包括年轻活跃LINE-1元件在内的逆转录转座子，并揭示其通过与Tet1、Sin3A和Mll2等因子相互作用，调控这些元件的表观遗传状态和表达平衡。"},
  {name: "Structural features of somatic and germline retrotransposition events in humans.", description: "人类体细胞和生殖系逆转录转座事件的结构特征。"},
  {name: "Structural insight into dGTP-dependent activation of tetrameric SAMHD1 deoxynucleoside triphosphate triphosphohydrolase.", description: "关于dGTP依赖性激活四聚体SAMHD1脱氧核苷三磷酸三磷酸水解酶的结构研究。"},
  {name: "Structures, functions and adaptations of the human LINE-1 ORF2 protein", description: "本文报道了人类LINE-1 ORF2蛋白的结构、功能和适应性。"},
  {name: "Subfamily-selective PCR primers for the human LINE1 L1PA lineage.", description: "用于人类LINE1 L1PA谱系的亚家族选择性PCR引物。"},
  {name: "Subfamily-specific differential contribution of individual monomers and the tether sequence to mouse L1 promoter activity.", description: "本研究比较了年轻小鼠L1亚家族的启动子活性，并剖析了单个单体和tether序列对启动子活性的差异贡献。"},
  {name: "Subfamily-specific quantification of endogenous mouse L1 retrotransposons by droplet digital PCR", description: "通过微滴数字PCR对小鼠内源性L1逆转录转座子进行亚家族特异性定量。"},
  {name: "SVA elements are nonautonomous retrotransposons that cause disease in humans.", description: "SVA元件是人类基因组中导致疾病的非自主逆转录转座子。"},
  {name: "Targeting of human retrotransposon integration is directed by the specificity of the L1 endonuclease for regions of unusual DNA structure.", description: "人类逆转录转座子整合的靶向是由L1内切酶对异常DNA结构区域的特异性所决定的。"},
  {name: "Template and target-site recognition by human LINE-1 in retrotransposition.", description: "人类LINE-1在逆转录转座中对模板和靶位点的识别。"},
  {name: "Testing the retroelement invasion hypothesis for the emergence of the ancestral eukaryotic cell.", description: "测试逆转座子入侵假说以解释祖先真核细胞的出现。"},
  {name: "TET-dependent regulation of retrotransposable elements in mouse embryonic stem cells.", description: "TET酶在小鼠胚胎干细胞中对逆转录转座子的调控作用。"},
  {name: "The carboxy-terminal segment of the human LINE-1 ORF2 protein is involved in RNA binding.", description: "该论文报道了人类LINE-1 ORF2蛋白的羧基末端片段在RNA结合中的作用。"},
  {name: "The controversy of SARS-CoV-2 integration into the human genome", description: "关于SARS-CoV-2整合入人类基因组的争议"},
  {name: "The DEAD box RNA helicase DDX42 is an intrinsic inhibitor of positive-strand RNA viruses.", description: "DEAD盒RNA解旋酶DDX42是正链RNA病毒的内在抑制剂。"},
  {name: "The Engineered SVA Trans-mobilization Assay", description: "工程化的SVA反式动员实验。"},
  {name: "The Flow of the Gibbon LAVA Element Is Facilitated by the LINE-1 Retrotransposition Machinery.", description: "长臂猿LAVA元件的流动由LINE-1逆转录转座机制促进。"},
  {name: "The genome-defence gene Tex19.1 suppresses LINE-1 retrotransposons in the placenta and prevents intra-uterine growth retardation in mice.", description: "该论文报道了基因组防御基因Tex19.1在胎盘中抑制LINE-1逆转录转座子并防止小鼠宫内生长迟缓。"},
  {name: "The human LINE-1 retrotransposon creates DNA double-strand breaks.", description: "人类LINE-1逆转录转座子造成DNA双链断裂。"},
  {name: "The identification of retro-DNAs in primate genomes as DNA transposons mobilizing via retrotransposition.", description: "在灵长类基因组中鉴定出通过逆转录转座移动的DNA转座子--retro-DNAs。"},
  {name: "The innate antiretroviral factor APOBEC3G does not affect human LINE-1 retrotransposition in a cell culture assay.", description: "这篇论文报道了先天抗病毒因子APOBEC3G在细胞培养实验中不影响人类LINE-1逆转录转座的研究。"},
  {name: "The interferon stimulated gene-encoded protein HELZ2 inhibits human LINE-1 retrotransposition and LINE-1 RNA-mediated type I interferon induction.", description: "干扰素刺激基因编码的蛋白HELZ2抑制人类LINE-1逆转录转座和LINE-1 RNA介导的I型干扰素诱导。"},
  {name: "The L1 retrotranspositional stimulation by particulate and soluble cadmium exposure is independent of the generation of DNA breaks.", description: "该论文报道了颗粒态和可溶性镉暴露对L1逆转录转座的刺激作用，且此作用与DNA断裂的生成无关。"},
  {name: "The L1-dependant and Pol III transcribed Alu retrotransposon, from its discovery to innate immunity.", description: "这篇综述总结了从发现到先天免疫的、依赖于L1并由Pol III转录的Alu逆转录转座子的主要发现。"},
  {name: "The L1-ORF1p coiled coil enables formation of a tightly compacted nucleic acid-bound complex that is associated with retrotransposition.", description: "L1-ORF1p的卷曲螺旋结构域能够使其形成与逆转录转座相关的紧密压缩的核酸结合复合体。"},
  {name: "The Landscape of L1 Retrotransposons in the Human Genome Is Shaped by Pre-insertion Sequence Biases and Post-insertion Selection.", description: "人类基因组中L1逆转录转座子的分布格局由插入前序列偏好性和插入后选择所塑造。"},
  {name: "The Microprocessor controls the activity of mammalian retrotransposons.", description: "该论文报道了Microprocessor复合物作为哺乳动物逆转录转座子的转录后抑制因子，在维持人类基因组完整性中的新作用。"},
  {name: "The minimal active human SVA retrotransposon requires only the 5'-hexamer and Alu-like domains.", description: "最小活性的人类SVA逆转录转座子仅需要5'-六聚体和Alu样结构域。"},
  {name: "The NF1 gene contains hotspots for L1 endonuclease-dependent de novo insertion.", description: "NF1基因包含L1内切酶依赖性从头插入的热点区域。"},
  {name: "The RNA editing enzyme ADAR2 restricts L1 mobility.", description: "RNA编辑酶ADAR2限制L1转座子的移动性。"},
  {name: "The role of amino-terminal sequences in cellular localization and antiviral activity of APOBEC3B.", description: "氨基末端序列在APOBEC3B的细胞定位和抗病毒活性中的作用。"},
  {name: "The Role of Somatic L1 Retrotransposition in Human Cancers.", description: "体细胞L1逆转录转座在人类癌症中的作用。"},
  {name: "The Simons Genome Diversity Project: A Global Analysis of Mobile Element Diversity.", description: "Simons基因组多样性计划：移动元件多样性的全球分析。"},
  {name: "The Zinc-Finger Antiviral Protein ZAP Inhibits LINE and Alu Retrotransposition.", description: "锌指抗病毒蛋白ZAP抑制LINE和Alu逆转录转座。"},
  {name: "Thrombopoietin protects hematopoietic stem cells from retrotransposon-mediated damage by promoting an antiviral response.", description: "血小板生成素通过促进抗病毒反应保护造血干细胞免受逆转录转座子介导的损伤。"},
  {name: "Tissue-Specific Methylation of Long Interspersed Nucleotide Element-1 of Homo Sapiens (L1Hs) During Human Embryogenesis and Roles in Neural Tube Defects.", description: "人类胚胎发生过程中长散布核元件-1（L1Hs）的组织特异性甲基化及其在神经管缺陷中的作用。"},
  {name: "Transcriptional landscape of repetitive elements in normal and cancer human cells.", description: "正常与癌细胞中重复元件的转录图谱。"},
  {name: "Transcriptional regulation of human-specific SVAF₁ retrotransposons by cis-regulatory MAST2 sequences.", description: "顺式调控MAST2序列对人类特异性SVAF₁逆转录转座子的转录调控。"},
  {name: "Transduction of 3'-flanking sequences is common in L1 retrotransposition.", description: "该论文报道了LINE-1逆转录转座过程中，3'侧翼序列转导是常见现象，并评估了其对人类基因组大小的影响。"},
  {name: "Transduction-specific ATLAS reveals a cohort of highly active L1 retrotransposons in human populations.", description: "《转导特异性ATLAS揭示人类群体中一组高活性L1逆转录转座子》"},
  {name: "Transposable Elements and DNA Methylation Create in Embryonic Stem Cells Human-Specific Regulatory Sequences Associated with Distal Enhancers and Noncoding RNAs.", description: "转座子元件和DNA甲基化在胚胎干细胞中创建与远端增强子和非编码RNA相关的人类特异性调控序列。"},
  {name: "Transposable Elements and Their Epigenetic Regulation in Mental Disorders: Current Evidence in the Field.", description: "《转座元件及其在精神疾病中的表观遗传调控：该领域的当前证据》"},
  {name: "TRIM28 B盒结构域在L1逆转录转座和ORF2p介导的cDNA合成中的新作用", description: "本论文的中文标题，报道了TRIM28蛋白通过其B盒结构域影响LINE-1活性的新机制。"},
  {name: "TRIM5α中的一个常见SNP显著增强针对LINE-1元件的先天免疫反应", description: "TRIM5α中的一个常见SNP显著增强针对LINE-1元件的先天免疫反应。"},
  {name: "Trimeric structure and flexibility of the L1ORF1 protein in human L1 retrotransposition.", description: "人类L1逆转录转座中L1ORF1蛋白的三聚体结构和灵活性研究。"},
  {name: "Twin priming: a proposed mechanism for the creation of inversions in L1 retrotransposition.", description: "双引物机制：一种用于解释L1逆转录转座中倒位形成的机制。"},
  {name: "U6 snRNA Pseudogenes: Markers of Retrotransposition Dynamics in Mammals.", description: "U6 snRNA假基因：哺乳动物逆转录转座动力学的标记物。"},
  {name: "Unbiased proteomic mapping of the LINE-1 promoter using CRISPR Cas9", description: "使用CRISPR Cas9对LINE-1启动子进行无偏蛋白质组学定位。"},
  {name: "Upregulated LINE-1 Activity in the Fanconi Anemia Cancer Susceptibility Syndrome Leads to Spontaneous Pro-inflammatory Cytokine Production.", description: "范可尼贫血癌症易感综合征中上调的LINE-1活性导致自发性促炎细胞因子产生。"},
  {name: "Uridylation by TUT4/7 Restricts Retrotransposition of Human LINE-1s.", description: "TUT4/7介导的尿苷化限制人类LINE-1的逆转录转座。"},
  {name: "Use of long sequence alignments to study the evolution and regulation of mammalian globin gene clusters.", description: "利用长序列比对研究哺乳动物珠蛋白基因簇的进化与调控。"},
  {name: "Variable patterns of retrotransposition in different HeLa strains provide mechanistic insights into SINE RNA mobilization processes.", description: "不同HeLa细胞系中逆转录转座模式的差异为SINE RNA动员过程提供了机制性见解。"},
  {name: "Viral protein R of HIV type-1 induces retrotransposition and upregulates glutamate synthesis by the signal transducer and activator of transcription 1 signaling pathway.", description: "HIV-1的病毒蛋白R通过信号转导和转录激活因子1信号通路诱导逆转录转座并上调谷氨酸合成。"},
  {name: "Viral protein R of human immunodeficiency virus type-1 induces retrotransposition of long interspersed element-1.", description: "人类免疫缺陷病毒1型的病毒蛋白R诱导长散布核元件-1的逆转录转座。"},
  {name: "Vitamin C activates young LINE-1 elements in mouse embryonic stem cells via H3K9me3 demethylation.", description: "维生素C通过H3K9me3去甲基化激活小鼠胚胎干细胞中年轻的LINE-1元件。"},
  {name: "Where to Draw the LINE-Are Retrotransposable Elements Here to Stay?", description: "本文讨论了Nam及其同事关于LINE-1在结肠上皮和结直肠肿瘤中体细胞逆转录转座频率的发现。"},
  {name: "Whole-genome sequencing reveals principles of brain retrotransposition in neurodevelopmental disorders.", description: "全基因组测序揭示神经发育障碍中脑逆转录转座原理。"},
  {name: "W型人类内源性逆转录病毒（HERV-W）整合及其被L1机制动员：对人类转录组的贡献及对宿主病理生理学的影响", description: "本综述总结了关于HERV-W群在人类基因组中的存在、在生理组织和主要病理背景下的表达，以及其被LINE-1机制动员的当前知识。"},
  {name: "Young LINE-1 transposon 5' UTRs marked by elongation factor ELL3 function as enhancers to regulate naïve pluripotency in embryonic stem cells.", description: "论文报道了由延伸因子ELL3标记的年轻LINE-1转座子5' UTR作为增强子，在小鼠胚胎干细胞中调控naïve多能性。"},
  {name: "ZCCHC3 is a stress granule zinc knuckle protein that strongly suppresses LINE-1 retrotransposition.", description: "ZCCHC3是一种应激颗粒锌指蛋白，能强烈抑制LINE-1逆转录转座。"},
  {name: "ZNF689缺陷促进三阴性乳腺癌的肿瘤内异质性和免疫治疗抵抗", description: "本论文报道了ZNF689缺陷通过重新激活LINE-1逆转录转座，加剧基因组不稳定性，从而促进三阴性乳腺癌的肿瘤内异质性和免疫治疗抵抗。"},
  {name: "一个活跃的L1逆转录转座子逃避体细胞抑制并引发人类结直肠癌", description: "本文报道了一个新的体细胞L1插入如何通过经典的两击通路启动结直肠癌。"},
  {name: "丙型肝炎病毒感染限制人肝癌细胞中LINE-1的逆转录转座", description: "该论文报道了丙型肝炎病毒感染对LINE-1逆转录转座活性的影响及其机制。"},
  {name: "串联UAA重复序列位于转录本3'端对于果蝇I因子逆转录的精确起始至关重要", description: "串联UAA重复序列位于转录本3'端对于果蝇I因子逆转录的精确起始至关重要。"},
  {name: "乙型肝炎病毒聚合酶限制LINE-1的移动性", description: "本论文报道了乙型肝炎病毒聚合酶通过多种步骤限制LINE-1逆转录转座活性的研究。"},
  {name: "人类Alu和L1逆转录转座子的插入活性与癌症中的DNA修复途径和基因组不稳定性相关", description: "本研究结合深度测序和计算分析，探究了人类活跃L1和Alu元件在癌症样本中的转录活性、体细胞插入事件及其与DNA修复、基因组不稳定性和患者预后的关系。"},
  {name: "人类L1 ORF1蛋白的聚合与核酸结合特性", description: "本文报道了人类L1 ORF1蛋白的聚合特性及其对核酸结合与分子伴侣活性的影响。"},
  {name: "人类LINE-1的DNA靶向机制", description: "本文报道了人类LINE-1逆转座子ORF2p蛋白靶向和切割DNA的结构与生化机制。"},
  {name: "人类LINE-1逆转录转座子与肝炎病毒相关肝细胞癌之间的联系", description: "本文探讨了LINE-1转座子活性在肝炎病毒相关肝细胞癌中的潜在作用及其机制。"},
  {name: "人类LINE-1逆转录转座子靶向内切酶的晶体结构", description: "报道了人类LINE-1逆转录转座子编码的内切酶的晶体结构，这是首个逆转录转座子编码蛋白的结构。"},
  {name: "人类因子IX基因中近期逆转录转座事件的频率", description: "本文报道了在血友病B患者的人类因子IX基因中发现的近期生殖系逆转录转座突变及其频率估计。"},
  {name: "人类基因组中L1逆转录转座活性的比较分析表明，尽管存在向低活性进化的趋势，但L1数量仍在持续增加。", description: "该论文通过比较方法研究了人类基因组中LINE-1逆转录转座活性的进化参数和动态。"},
  {name: "人类基因组中复发性倒位多态性与遗传不稳定性和基因组疾病相关", description: "本文报道了人类基因组中复发性倒位多态性的发现，并探讨了其形成机制及其与基因组疾病易感性的关联。"},
  {name: "人类癌症中体细胞逆转录转座的景观", description: "本文献报道了在五种癌症类型的全基因组测序数据中分析转座子插入的研究。"},
  {name: "人类长散布核元件1逆转录转座子的开放阅读框1蛋白结合多个当量的铅", description: "该论文报道了LINE-1的ORF1p能够结合铅离子，并探讨了重金属暴露可能通过影响ORF1p结构来调控LINE-1转座活性的机制。"},
  {name: "从包含一个活跃逆转录转座元件的人类L1亚家族中分离出的另外两个潜在逆转录转座子", description: "本文报道了从JH-27母亲基因组中分离出与活跃L1元件L1.2B密切相关的另外两个全长L1元件L1.3和L1.4，并推测它们也具有活性，表明某些L1亚家族可能包含多个活跃元件。"},
  {name: "低甲基化药物增加L1逆转录元件表达但未在髓系恶性肿瘤中诱导新的插入", description: "本研究探讨了低甲基化药物对髓系恶性肿瘤中LINE-1逆转录转座子表达和活性的影响。"},
  {name: "体外筛选增强人类L1移动性的化合物", description: "本研究使用报告基因检测和高通量实时逆转录转座检测，筛选了多种化合物对LINE-1转录和逆转录转座的影响。"},
  {name: "免疫特征与胃肠道癌症中L1逆转录转座相关", description: "本研究通过整合分析癌症全基因组和匹配的RNA测序数据，揭示了胃肠道癌症中L1活性的多个相关因素及其对基因功能的影响，并发现癌症免疫可能通过抑制L1逆转录转座来维持基因组稳定性。"},
  {name: "全基因组泛癌分析识别出由LINE-1逆转录转座促进的驱动性重排", description: "对全基因组进行泛癌分析，识别出由LINE-1逆转录转座促进的驱动性重排。"},
  {name: "利用内源性逆转录元件进行人脑细胞谱系分析", description: "当前处理的文献，标题为'Cell lineage analysis in human brain using endogenous retroelements.'的中文翻译。"},
  {name: "功能性I逆转录转座子转座的影响取决于亲本暴露的条件和剂量", description: "本研究探讨了亲本辐射条件和剂量对携带活性I逆转录转座子的果蝇后代的影响，评估了其生殖力、DNA损伤和寿命。"},
  {name: "吗啡和枸橼酸芬太尼诱导长散布元件-1的逆转录转座", description: "本研究报道了吗啡和枸橼酸芬太尼在神经元细胞中触发LINE-1逆转录转座，该过程不依赖于DNA损伤或L1 mRNA表达上调，但需要Toll样受体4的参与。"},
  {name: "哺乳动物L1逆转录转座子的生物学", description: "本文综述了哺乳动物LINE-1逆转录转座子的生物学特性及其对基因组的影响。"},
  {name: "哺乳动物LINE-1逆转录转座子特异性逆转录酶抑制剂的合成与表征", description: "本文报道了特异性针对哺乳动物LINE-1逆转录转座子的逆转录酶抑制剂的合成与表征。"},
  {name: "哺乳动物LINE-1逆转录转座子的非常规翻译", description: "报道了LINE-1转座子ORF2蛋白通过一种不依赖于标准AUG起始密码子的终止/再起始机制进行翻译的研究。"},
  {name: "基于基因组组装比较的犬类逆转录转座速率系统发育估计", description: "A phylogenetic estimate of canine retrotransposition rates based on genome assembly comparisons."},
  {name: "基于长读长测序的1019个不同人类个体的结构变异分析", description: "Structural variation in 1,019 diverse humans based on long-read sequencing."},
  {name: "外泌体包裹的APOBEC3G和APOBEC3F对LINE-1和Alu逆转录转座的抑制作用", description: "该论文报道了外泌体包裹的APOBEC3G和APOBEC3F蛋白能够抑制LINE-1和Alu的逆转录转座活性。"},
  {name: "小鼠L1逆转录转座子ORF1蛋白的定点自旋标记电子顺磁共振研究", description: "本研究报道了对全长ORF1蛋白RNA结合区域内27个残基的定点自旋标记电子顺磁共振（SDSL-EPR）研究结果。"},
  {name: "小鼠LINE-1第一个ORF蛋白的体外特性支持其在逆转录转座过程中核糖核蛋白颗粒形成中的作用", description: "本文报道了小鼠LINE-1 ORF1蛋白的体外核酸结合特性及其在核糖核蛋白颗粒形成中的作用。"},
  {name: "小鼠原始生殖细胞和早期胚胎中的可遗传L1逆转录转座", description: "本研究报道了在小鼠原始生殖细胞和早期胚胎中L1的可遗传逆转录转座事件及其频率。"},
  {name: "小鼠和人类L1元件的结构反映了它们的插入机制", description: "该论文探讨了小鼠和人类LINE-1元件的结构特征与其插入机制之间的关系。"},
  {name: "广谱抗病毒蛋白ZAP限制人类逆转录转座", description: "本论文报道了广谱抗病毒蛋白ZAP能够通过破坏L1 RNA及其核糖核蛋白颗粒的完整性来强烈抑制人类LINE-1转座子在细胞培养中的逆转录转座活性。"},
  {name: "截短的ORF1蛋白能以反式作用抑制LINE-1逆转录转座", description: "该论文报道了人类基因组中许多含有提前终止密码子的非功能性LINE-1位点能够表达截短的ORF1蛋白，其中一些截短蛋白能以反式作用抑制功能性LINE-1的逆转录转座。"},
  {name: "抑制LINE-1逆转录转座会阻碍小鼠2细胞胚胎发育过程中的端粒重编程", description: "本研究探讨了抑制LINE-1逆转录转座对小鼠2细胞胚胎端粒重编程的影响。"},
  {name: "拯救Alu：新插入的恢复显示LINE-1通过A-tail扩展维持Alu活性", description: "Rescuing Alu: recovery of new inserts shows LINE-1 preserves Alu activity through A-tail expansion."},
  {name: "揭示LINE-1在肺腺癌进化中的作用", description: "本研究通过整合多组学数据，分析了1024例肺腺癌的进化轨迹，并发现了LINE-1活性在特定亚型中的作用。"},
  {name: "核糖核蛋白颗粒形成对LINE-1逆转录转座是必要但不充分的", description: "该论文通过表位标记技术，研究了LINE-1编码蛋白ORF1p在核糖核蛋白颗粒形成和逆转录转座中的作用。"},
  {name: "核苷类似物逆转录酶抑制剂差异性地抑制人类LINE-1逆转录转座", description: "该论文报道了使用体外LINE-1逆转录转座报告基因检测法，评估几种抗逆转录病毒化合物抑制LINE-1逆转录转座的能力。"},
  {name: "核苷酸切除修复途径限制L1逆转录转座", description: "该论文报道了核苷酸切除修复（NER）途径在限制LINE-1逆转录转座和防止插入位点大片段重复中的作用。"},
  {name: "正常结直肠上皮中广泛的体细胞L1逆转录转座", description: "本研究探索了来自28个个体的三种不同细胞类型的899个单细胞克隆的全基因组序列，揭示了正常细胞中L1逆转录转座诱导的体细胞嵌合现象。"},
  {name: "海马神经元中普遍存在的L1嵌合现象", description: "这篇论文报道了通过单细胞逆转录转座子捕获测序技术，在人海马神经元中发现了广泛的体细胞LINE-1插入事件。"},
  {name: "灵长类和鼠类LINE-1元件的功能模块性在进化上具有保守性", description: "本文探讨了人类和鼠类LINE-1序列的功能保守性，通过构建和测试嵌合体评估其逆转录转座能力。"},
  {name: "犬类DUXC：对DUX4逆转录转座和FSHD临床前模型的启示", description: "本研究探讨了犬类DUXC基因的功能及其与人类DUX4的相似性，为面肩肱型肌营养不良症的临床前模型提供了见解。"},
  {name: "环境因素诱导长散布元件-1逆转录转座的模式", description: "这篇论文总结了当前对体细胞中LINE-1逆转录转座机制的理解，特别关注了依赖bHLH/PAS转录因子的转座模式。"},
  {name: "癌症中的移动DNA。癌症基因组中由L1逆转录转座介导的非重复DNA的广泛转导。", description: "本研究报道了在癌症基因组中，L1逆转录转座介导的体细胞3'转导现象及其影响。"},
  {name: "肠道病毒感染限制长散布元件1的逆转录转座", description: "本论文报道了肠道病毒感染对LINE-1逆转录转座活动的影响及其抑制机制。"},
  {name: "自主转座子调整其序列以确保体细胞抑制", description: "本文报道了SAFB蛋白通过结合L1转座子的保守序列，在防止其逆转录转座的同时，也抑制其外显子化，从而在体细胞中维持基因组完整性和剪接完整性。"},
  {name: "自闭症大脑中LINE-1逆转录转座子的过表达", description: "本研究报道了在自闭症患者小脑中LINE-1表达显著升高，并探讨了其与表观遗传抑制解除和氧化应激的关联。"},
  {name: "致癌性microRNA miR-222促进人类LINE-1逆转录转座", description: "本论文报道了miR-222在肝细胞癌中促进LINE-1逆转录转座活性的机制。"},
  {name: "芳烃受体激动剂苯并芘通过经典TGF-β1信号通路在HepG2细胞中重新激活LINE-1：对肝细胞癌发生的影响", description: "本论文的标题，报道了AhR配体通过TGF-β1信号通路重新激活LINE-1及其在肝细胞癌中的潜在作用。"},
  {name: "苯并(a)芘，一种普遍存在的环境致癌物，激活人类长散布核元件1的逆转录转座", description: "本论文报道了环境致癌物苯并(a)芘通过诱导DNA损伤，激活LINE-1逆转录转座的过程。"},
  {name: "裸鼹鼠基因组中一个活性LINE-1的特征分析", description: "本论文报道了从裸鼹鼠基因组中克隆并鉴定了一个活性LINE-1转座子NMR-L1。"},
  {name: "褪黑素及其受体对L1表达和逆转录转座的调控：对夜间光照相关癌症风险的启示", description: "本文报道了褪黑素及其受体通过下调L1 mRNA和ORF1蛋白来抑制L1的逆转录转座活性，并探讨了夜间光照可能通过抑制褪黑素增加L1活性从而增加癌症风险的机制。"},
  {name: "评估HepG2细胞暴露于重金属后LINE-1的移动程度", description: "评估铝、铅和铜暴露与人类肝细胞癌细胞系中L1逆转录转座关联的研究。"},
  {name: "评估不同DNA结合域以调控人类细胞中L1 ORF2p驱动的位点特异性逆转录转座事件", description: "评估不同DNA结合域（DBD）和策略（AAV Rep蛋白、Cre、TAL效应子、锌指蛋白和Cas9/gRNA系统）靶向L1 ORF2蛋白以驱动Alu元件在人类基因组特定序列中逆转录转座的能力。"},
  {name: "评估暴露于极低频脉冲磁场下神经母细胞瘤细胞中的LINE-1逆转录转座活性", description: "评估暴露于极低频脉冲磁场下神经母细胞瘤细胞中的LINE-1逆转录转座活性"},
  {name: "转座元件和远端增强子对人类胚胎干细胞间期染色质结构人类特异性特征进化的贡献", description: "论文原标题的中文翻译：Contribution of transposable elements and distal enhancers to evolution of human-specific features of interphase chromatin architecture in embryonic stem cells."},
  {name: "转座子、炎症与神经系统疾病", description: "本文探讨了转座子（特别是逆转录转座子）在炎症和神经系统疾病中的作用。"},
  {name: "转座子、胎盘发育和卵母细胞激活：细胞应激和AMPK将跳跃基因与人类生命的创造联系起来", description: "本文探讨了细胞应激和AMPK如何将转座子（如LINE-1）的激活和转座与胎盘发育和卵母细胞激活联系起来，从而促进人类基因组进化和生命的创造。"},
  {name: "转座子及其基因组影响的研究", description: "Study of Transposable Elements and Their Genomic Impact. 的中文翻译。"},
  {name: "追踪一个胚胎期的L1逆转录转座事件", description: "追踪一个胚胎期的L1逆转录转座事件。"},
  {name: "逆转录元件与APOBEC3家族成员：无法从“七壮士”中逃脱", description: "这篇综述总结了当前对人类基因组中活跃的逆转录元件与抗逆转录元件APOBEC3蛋白之间相互作用的最新理解。"},
  {name: "逆转录病毒对整合酶链转移抑制剂的不同敏感性", description: "本文评估了多种逆转录病毒和转座子对整合酶抑制剂拉替拉韦和埃替拉韦的敏感性。"},
  {name: "逆转录转座子-腺病毒杂交载体：通过两阶段机制实现转基因的高效递送和稳定整合", description: "本文报道了一种基于LINE-1的逆转录转座子-腺病毒杂交载体系统。"},
  {name: "逆转录转座子L1的5'截短：一种基因组完整性的过程", description: "该综述论文讨论了LINE-1转座子5'端截短的特征、分布、发生环境、机制及其对基因组的影响。"},
  {name: "逆转录转座子与糖尿病", description: "这篇综述总结了关于Alu和LINE-1逆转录转座子甲基化状态的主要表观遗传改变及其作为全基因组DNA甲基化表观遗传标志物在糖尿病发病机制中的潜在作用。"},
  {name: "逆转录转座子捕获测序（RC-Seq）：一种靶向、高通量的方法来解析人类体细胞L1逆转录转座", description: "本文描述了一种名为RC-Seq的序列捕获方法，用于检测和表征移动遗传元件的插入。"},
  {name: "逆转录转座子转录后调控的最新进展", description: "本文总结了转录后因子在逆转录转座子（特别是LINE-1）生物学中的作用，包括RNA代谢、细胞质隔离和先天免疫等方面的最新知识。"},
  {name: "通过交换两个LINE的核酸内切酶结构域来移植靶位点特异性", description: "通过交换两个LINE的核酸内切酶结构域来移植靶位点特异性。"},
  {name: "通过靶向富集方法在韩国个体中新颖发现LINE-1", description: "本研究应用系统方法，通过高通量测序数据的生物信息学分析，识别人类特异性L1（L1Hs），并在韩国个体基因组（KPGP9）中鉴定出525个可能携带非参考L1Hs的候选位点。"},
  {name: "野生型和突变型人L1内切酶的结构动力学及其序列特异性核酸结合机制的分子动力学研究", description: "通过分子动力学模拟，揭示了L1内切酶的结构特征、其与DNA（特别是TA连接处）特异性识别的机制，以及Mg2+在催化中的作用。"},
  {name: "长散布元件-1 (LINE-1) 逆转录酶与端粒酶之间的相似性", description: "本论文报道了LINE-1逆转录转座与端粒酶机制之间的相似性，特别是ENi途径在端粒处的活动。"},
  {name: "长散布核元件-1的逆转录转座参与7,12-二甲基苯并[a]蒽和12-O-十四烷酰佛波醇-13-乙酸酯诱导的皮肤肿瘤发生", description: "本研究首次报道了LINE-1逆转录转座在化学致癌中的作用，并建立了携带人L1和增强型绿色荧光蛋白的转基因小鼠模型用于研究。"},
  {name: "限制逆转录转座子：一篇综述", description: "这篇综述探讨了细胞与逆转录转座子共存的策略，重点关注人类和小鼠的非长末端重复逆转录转座子。"},
  {name: "非LTR逆转录转座子与微卫星：基因组变异的伙伴", description: "这篇综述探讨了在基因组变异和进化背景下，非LTR逆转录转座子与微卫星之间的相互作用和动态。"},
  {name: "非自主逆转录转座子SVA被人类LINE-1蛋白机器反式动员", description: "该论文报道了SVA元件依赖于LINE-1编码的ORF1p和ORF2p进行逆转录转座，并描述了其插入特征。"},
  {name: "驯化的转座子蛋白L1TD1与其祖先L1 ORF1p结合以促进LINE-1逆转录转座", description: "该论文报道了DNA低甲基化诱导L1TD1表达，L1TD1与L1 ORF1p和L1转录本相互作用，促进LINE-1逆转录转座，并可能在肿瘤发生中起作用。"}
] AS row
MERGE (n:Paper {name: row.name})
ON CREATE SET n.description = row.description, n.source_group = "papers";
