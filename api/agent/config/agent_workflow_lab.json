{
    "version": 2,
    "title": "TE-KG Agent Workflow Lab",
    "description": "Developer-facing workflow specification for the proposed MoE-style academic agent.",
    "nodes": [
        {
            "id": 1,
            "name": "Question Understanding Node",
            "kind": "core",
            "model": "deepseek-reasoner",
            "description": "Parse the user question, detect intent and complexity, and run entity normalization inside the node when needed. There is no separate entity expert.",
            "inputs": [
                "question"
            ],
            "outputs": [
                "analysis",
                "entity_resolution"
            ],
            "position": {
                "x": 80,
                "y": 120
            }
        },
        {
            "id": 2,
            "name": "Planning Node",
            "kind": "core",
            "model": "deepseek-reasoner",
            "description": "Build knowledge gaps, subtasks, and the first-pass expert activation plan.",
            "inputs": [
                "question",
                "analysis",
                "entity_resolution",
                "session_context"
            ],
            "outputs": [
                "planning"
            ],
            "position": {
                "x": 320,
                "y": 120
            }
        },
        {
            "id": 3,
            "name": "Evidence Collection Node",
            "kind": "controller",
            "model": "deepseek-reasoner",
            "description": "MoE-style controller that activates one expert at a time, merges JSON outputs, and explicitly decides whether the current evidence is sufficient or whether more experts must be activated.",
            "inputs": [
                "question",
                "analysis",
                "planning",
                "graph_result",
                "analytics_result",
                "cypher_result",
                "literature_result",
                "literature_synthesis",
                "tree_result",
                "expression_result",
                "genome_result",
                "sequence_result",
                "citation_result",
                "collected_results",
                "evidence_bundle",
                "citation_bundle"
            ],
            "outputs": [
                "collection_state",
                "active_expert",
                "sufficiency_decision",
                "graph_result",
                "analytics_result",
                "cypher_result",
                "literature_result",
                "literature_synthesis",
                "tree_result",
                "expression_result",
                "genome_result",
                "sequence_result",
                "citation_result",
                "collected_results",
                "evidence_bundle",
                "citation_bundle"
            ],
            "position": {
                "x": 600,
                "y": 120
            }
        },
        {
            "id": 4,
            "name": "Local Graph Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Graph Plugin for local TE-centered neighborhoods and entity-pair relations.",
            "inputs": [
                "question",
                "analysis",
                "planning",
                "collected_results"
            ],
            "outputs": [
                "graph_result"
            ],
            "position": {
                "x": 940,
                "y": 40
            }
        },
        {
            "id": 5,
            "name": "Graph Analytics Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Graph Analytics Plugin for topology, ranking, counts, and graph-wide structure questions.",
            "inputs": [
                "question",
                "analysis",
                "planning"
            ],
            "outputs": [
                "analytics_result"
            ],
            "position": {
                "x": 940,
                "y": 120
            }
        },
        {
            "id": 6,
            "name": "Cypher Explorer Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Cypher Explorer Plugin with validated read-only aggregation queries when fixed graph tools are not enough.",
            "inputs": [
                "question",
                "analysis",
                "planning",
                "collected_results"
            ],
            "outputs": [
                "cypher_result"
            ],
            "position": {
                "x": 940,
                "y": 200
            }
        },
        {
            "id": 7,
            "name": "Literature Retrieval Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Literature Plugin to retrieve local graph citations and PubMed metadata.",
            "inputs": [
                "question",
                "analysis",
                "planning",
                "collected_results"
            ],
            "outputs": [
                "literature_result"
            ],
            "position": {
                "x": 940,
                "y": 280
            }
        },
        {
            "id": 8,
            "name": "Literature Reading Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Literature Reading Plugin to cluster claims, conflicts, and missing evidence from the reviewed citation set.",
            "inputs": [
                "question",
                "analysis",
                "planning",
                "literature_result",
                "citation_bundle"
            ],
            "outputs": [
                "literature_synthesis"
            ],
            "position": {
                "x": 940,
                "y": 360
            }
        },
        {
            "id": 9,
            "name": "Tree Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Tree Plugin for family, subfamily, and lineage context.",
            "inputs": [
                "question",
                "analysis",
                "planning"
            ],
            "outputs": [
                "tree_result"
            ],
            "position": {
                "x": 940,
                "y": 440
            }
        },
        {
            "id": 10,
            "name": "Expression Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Expression Plugin for tissue and cell-context evidence.",
            "inputs": [
                "question",
                "analysis",
                "planning"
            ],
            "outputs": [
                "expression_result"
            ],
            "position": {
                "x": 940,
                "y": 520
            }
        },
        {
            "id": 11,
            "name": "Genome Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Genome Plugin for locus-level and browser context.",
            "inputs": [
                "question",
                "analysis",
                "planning"
            ],
            "outputs": [
                "genome_result"
            ],
            "position": {
                "x": 940,
                "y": 600
            }
        },
        {
            "id": 12,
            "name": "Sequence Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Sequence Plugin for Repbase-backed sequence facts, length, and structure hints.",
            "inputs": [
                "question",
                "analysis",
                "planning"
            ],
            "outputs": [
                "sequence_result"
            ],
            "position": {
                "x": 940,
                "y": 680
            }
        },
        {
            "id": 13,
            "name": "Citation Resolver Expert",
            "kind": "expert",
            "model": "deepseek-chat",
            "description": "Runs Citation Resolver to normalize and deduplicate citation records.",
            "inputs": [
                "collected_results",
                "citation_bundle"
            ],
            "outputs": [
                "citation_result"
            ],
            "position": {
                "x": 940,
                "y": 760
            }
        },
        {
            "id": 14,
            "name": "Evidence Synthesis Node",
            "kind": "core",
            "model": "deepseek-reasoner",
            "description": "Organize the collected evidence into supported claims, conflicts, missing-evidence notes, and claim clusters. This node does not decide whether evidence is sufficient; that stays in Evidence Collection Node.",
            "inputs": [
                "question",
                "analysis",
                "planning",
                "graph_result",
                "analytics_result",
                "cypher_result",
                "literature_result",
                "literature_synthesis",
                "tree_result",
                "expression_result",
                "genome_result",
                "sequence_result",
                "citation_result",
                "collected_results",
                "evidence_bundle",
                "citation_bundle"
            ],
            "outputs": [
                "supported_claims",
                "conflicting_claims",
                "missing_evidence",
                "claim_clusters"
            ],
            "position": {
                "x": 1320,
                "y": 180
            }
        },
        {
            "id": 15,
            "name": "Answer Structuring Node",
            "kind": "core",
            "model": "deepseek-reasoner",
            "description": "A larger reasoning node that receives all expert outputs and the synthesis output, then organizes the answer outline as answer_structure.",
            "inputs": [
                "question",
                "analysis",
                "planning",
                "collected_results",
                "graph_result",
                "analytics_result",
                "cypher_result",
                "literature_result",
                "literature_synthesis",
                "tree_result",
                "expression_result",
                "genome_result",
                "sequence_result",
                "citation_result",
                "supported_claims",
                "conflicting_claims",
                "missing_evidence",
                "claim_clusters"
            ],
            "outputs": [
                "answer_structure"
            ],
            "position": {
                "x": 1320,
                "y": 360
            }
        },
        {
            "id": 16,
            "name": "Answer Writer Node",
            "kind": "core",
            "model": "deepseek-reasoner",
            "description": "Generate the final academic answer from answer_structure and the validated evidence/citation bundle.",
            "inputs": [
                "question",
                "analysis",
                "answer_structure",
                "supported_claims",
                "conflicting_claims",
                "missing_evidence",
                "citation_bundle"
            ],
            "outputs": [
                "answer"
            ],
            "position": {
                "x": 1600,
                "y": 280
            }
        },
        {
            "id": 17,
            "name": "Process Narrator Node",
            "kind": "core",
            "model": "deepseek-chat",
            "description": "Generate front-end thinking trace lines from real execution events only.",
            "inputs": [
                "event_stream",
                "analysis",
                "entity_resolution",
                "planning",
                "collection_state",
                "active_expert",
                "sufficiency_decision",
                "graph_result",
                "analytics_result",
                "cypher_result",
                "literature_result",
                "literature_synthesis",
                "tree_result",
                "expression_result",
                "genome_result",
                "sequence_result",
                "citation_result",
                "supported_claims",
                "conflicting_claims",
                "missing_evidence",
                "claim_clusters",
                "answer_structure",
                "answer"
            ],
            "outputs": [
                "trace_event"
            ],
            "position": {
                "x": 1320,
                "y": 560
            }
        }
    ],
